  // ------------------------------------------------------------



  // Parse ?id= from URL.



  // ------------------------------------------------------------



  function getOpeningId() {



    var m = location.search.match(/[?&]id=([^&]+)/);



    return m ? decodeURIComponent(m[1]).toLowerCase().trim() : null;



  }







  var openingId = getOpeningId();



  var opening = openingId ? OPENINGS[openingId] : null;







  // ------------------------------------------------------------



  // Not found? Bail.



  // ------------------------------------------------------------



  if (!opening) {



    document.getElementById('opening-title').textContent = 'Opening not found';



    document.getElementById('opening-eco').textContent = '';



    document.getElementById('opening-side').textContent = '';



    document.getElementById('not-found').hidden = false;



    return;



  }







  // ------------------------------------------------------------



  // Render header.



  // ------------------------------------------------------------



  document.getElementById('opening-title').textContent = opening.name;



  document.getElementById('opening-eco').textContent = 'ECO ' + opening.eco;



  document.getElementById('opening-side').textContent =



    opening.side === 'white' ? 'You play White' : 'You play Black';







  var guide = STUDY_GUIDES[openingId];



  var drillHref = '/chess-school/opening-builder/drill?id=' + encodeURIComponent(openingId);







  // ------------------------------------------------------------



  // Render variations sidebar (if data exists for this opening).



  // ------------------------------------------------------------



  var variationsBox = document.getElementById('variations-sidebar');



  var variationsIntro = document.getElementById('variations-intro');



  var variationsList = document.getElementById('variations-list');



  var variationsData = VARIATIONS[openingId];







  if (variationsBox && variationsData) {



    variationsIntro.innerHTML = variationsData.note;



    variationsList.innerHTML = '';
      var fg=document.getElementById('full-guide-cta'); if(fg && openingId){ fg.setAttribute('href', '/chess-school/opening-builder/'+openingId); }



    variationsData.items.forEach(function(item) {



      var li = document.createElement('li');



      li.className = 'variation-item';



      var btn = document.createElement('button');



      btn.type = 'button';



      btn.className = 'variation-toggle';



      btn.setAttribute('aria-expanded', 'false');



      btn.innerHTML = '<span class="variation-name">' + item.name + '</span><span class="variation-chevron">&rsaquo;</span>';



      var moveBox = document.createElement('div');



      moveBox.className = 'variation-move';



      moveBox.hidden = true;



      moveBox.textContent = item.move;



      btn.addEventListener('click', function() {



        var expanded = btn.getAttribute('aria-expanded') === 'true';



        btn.setAttribute('aria-expanded', expanded ? 'false' : 'true');



        moveBox.hidden = expanded;



      });



      li.appendChild(btn);



      li.appendChild(moveBox);



      variationsList.appendChild(li);



    });



    variationsBox.hidden = false;



  }







  // ------------------------------------------------------------



  // No full guide yet? Show placeholder.



  // ------------------------------------------------------------



  if (!guide) {



    document.getElementById('placeholder').hidden = false;



    var phLink = document.getElementById('drill-link-placeholder');



    if (phLink) phLink.href = drillHref;



    return;



  }







  // ------------------------------------------------------------



  // Render full study guide.



  // ------------------------------------------------------------



  document.getElementById('study-content').hidden = false;







  // Overview (HTML).



  document.getElementById('overview-text').innerHTML = guide.overview;







  // Annotated moves.



  var movesList = document.getElementById('annotated-moves');



  for (var i = 0; i < guide.annotated.length; i++) {



    var entry = guide.annotated[i];



    var li = document.createElement('li');



    var moveEl = document.createElement('strong');



    moveEl.className = 'move';



    moveEl.textContent = entry.move;



    var noteEl = document.createElement('span');



    noteEl.className = 'note';



    noteEl.textContent = entry.note;



    li.appendChild(moveEl);



    li.appendChild(document.createTextNode(' '));



    li.appendChild(noteEl);



    movesList.appendChild(li);



  }







  // Studied by.



  var studiedList = document.getElementById('studied-by');



  for (var j = 0; j < guide.studiedBy.length; j++) {



    var s = guide.studiedBy[j];



    var sli = document.createElement('li');



    var nameEl = document.createElement('strong');



    nameEl.className = 'master';



    nameEl.textContent = s.master;



    var snoteEl = document.createElement('span');



    snoteEl.className = 'note';



    snoteEl.textContent = s.note;



    sli.appendChild(nameEl);



    sli.appendChild(document.createTextNode(' '));



    sli.appendChild(snoteEl);



    studiedList.appendChild(sli);



  }







  // Drill CTA link.



  var drillLink = document.getElementById('drill-link');



  if (drillLink) drillLink.href = drillHref;



})();



</script>







<style>



/* ---------- page chrome (mirrors drill.astro / opening-builder.astro) ---------- */



