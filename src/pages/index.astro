      color: #a0a0a0;
      margin-bottom: 2rem;
    }
    .chess-cta-btn {
      display: inline-block;
      padding: 1.1rem 3rem;
      background: #c9a84c;
      color: #0f111c;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: 0.03em;
      animation: ctaPulse 2s ease-in-out infinite;
      transition: transform 0.2s;
      box-shadow: 0 0 20px rgba(201, 168, 76, 0.3);
    }
    .chess-cta-btn:hover {
