.placeholder-msg { color: rgba(232,224,208,0.78); font-family: 'EB Garamond', Georgia, serif; font-size: 1.02rem; line-height: 1.6; margin: 0 0 1rem; max-width: 620px; margin-left: auto; margin-right: auto; }







.page-footer { margin-top: 2.5rem; padding: 1.5rem 1rem; text-align: center; border-top: 1px solid rgba(201,168,76,0.1); }



