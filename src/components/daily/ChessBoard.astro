---
// ChessBoard.astro — a self-contained, server-rendered chess board.
// Renders a position from a FEN string as inline SVG. No external library,
// no API call, no client-side JavaScript. Pieces are drawn as serif Unicode
// chess glyphs to match the broadsheet typography of The Daily Gambit.
interface Props {
  fen?: string;
  caption?: string;
}
const { fen = '8/8/8/8/8/8/8/8 w', caption } = Astro.props;

// --- Parse the FEN placement field into an 8x8 grid (rank 8 -> rank 1). ---
const placement = (fen || '').trim().split(/\s+/)[0] || '8/8/8/8/8/8/8/8';
const rows = placement.split('/');
const board: (string | null)[][] = [];
for (let r = 0; r < 8; r++) {
  const line = rows[r] || '8';
  const cells: (string | null)[] = [];
  for (const ch of line) {
    if (/[1-8]/.test(ch)) {
      const n = parseInt(ch, 10);
      for (let i = 0; i < n; i++) cells.push(null);
    } else {
      cells.push(ch);
    }
  }
  while (cells.length < 8) cells.push(null);
  board.push(cells.slice(0, 8));
}

// --- Map FEN piece letters to Unicode chess glyphs. ---
// Uppercase = White, lowercase = Black.
const GLYPH: Record<string, string> = {
  K: '\u2654', Q: '\u2655', R: '\u2656', B: '\u2657', N: '\u2658', P: '\u2659',
  k: '\u265A', q: '\u265B', r: '\u265C', b: '\u265D', n: '\u265E', p: '\u265F',
};

// --- Geometry (SVG user units; CSS controls the rendered pixel width). ---
const M = 22;        // margin reserved for coordinate labels
const S = 60;        // square size
const BOARD = S * 8; // 480
const SIZE = BOARD + M * 2;

const LIGHT = '#f5ead6';
const DARK = '#c9a87a';

const files = ['a', 'b', 'c', 'd', 'e', 'f', 'g', 'h'];
const ranks = ['8', '7', '6', '5', '4', '3', '2', '1'];

// Flatten squares for easy iteration in the template.
const squares = [];
for (let r = 0; r < 8; r++) {
  for (let c = 0; c < 8; c++) {
    const piece = board[r][c];
    squares.push({
      x: M + c * S,
      y: M + r * S,
      light: (r + c) % 2 === 0,
      glyph: piece ? GLYPH[piece] : null,
      white: piece ? piece === piece.toUpperCase() : false,
    });
  }
}
---

<figure class="tdg-chessboard">
  <svg viewBox={`0 0 ${SIZE} ${SIZE}`} xmlns="http://www.w3.org/2000/svg" role="img" aria-label={caption || 'Chess position'} class="tdg-cb-svg">
    {squares.map((sq) => (
      <rect x={sq.x} y={sq.y} width={S} height={S} fill={sq.light ? LIGHT : DARK} />
    ))}
    {squares.map((sq) => (sq.glyph ? (
      <text x={sq.x + S / 2} y={sq.y + S / 2} class={sq.white ? 'tdg-cb-pc tdg-cb-white' : 'tdg-cb-pc tdg-cb-black'} text-anchor="middle" dominant-baseline="central">{sq.glyph}</text>
    ) : null))}
    <rect x={M} y={M} width={BOARD} height={BOARD} fill="none" stroke="#111" stroke-width="2" />
    {files.map((f, c) => (
      <text x={M + c * S + S / 2} y={M + BOARD + M / 2 + 2} class="tdg-cb-coord" text-anchor="middle" dominant-baseline="middle">{f}</text>
    ))}
    {ranks.map((rk, r) => (
      <text x={M / 2} y={M + r * S + S / 2} class="tdg-cb-coord" text-anchor="middle" dominant-baseline="central">{rk}</text>
    ))}
  </svg>
  {caption && <figcaption class="tdg-cb-cap">{caption}</figcaption>}
</figure>

<style>
.tdg-chessboard { width: 100%; max-width: 320px; margin: 0 auto 0.6rem; }
.tdg-cb-svg { display: block; width: 100%; height: auto; }
.tdg-cb-pc { font-size: 40px; font-family: Georgia, 'Times New Roman', Times, serif; }
.tdg-cb-white { fill: #fffdf7; stroke: #111; stroke-width: 1.1px; paint-order: stroke fill; }
.tdg-cb-black { fill: #1a1a1a; stroke: #000; stroke-width: 0.4px; paint-order: stroke fill; }
.tdg-cb-coord { font-size: 13px; font-family: Georgia, 'Times New Roman', Times, serif; fill: #5a4a1d; }
.tdg-cb-cap { font-size: 0.7rem; font-style: italic; color: #777; text-align: center; margin: 0.3rem 0 0; }
@media (min-width: 700px) { .tdg-chessboard { max-width: 380px; } }
</style>
