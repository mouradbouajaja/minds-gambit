.empty, .loading { text-align: center; padding: 3rem 1rem; color: var(--text-3); font-style: italic; }
.loading::after { content: ""; display: inline-block; width: 16px; height: 16px; margin-left: 0.6rem; border: 2px solid var(--gold-dim); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }

.placeholder-card { background: var(--bg-2); border: 1px dashed var(--border); border-radius: 12px; padding: 3rem 2rem; text-align: center; color: var(--text-2); max-width: 720px; margin: 2rem auto; }
.placeholder-card h3 { font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-size: 1.4rem; margin: 0 0 0.7rem; }
.placeholder-card p { line-height: 1.6; margin: 0 0 0.5rem; }
