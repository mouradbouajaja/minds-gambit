.game-card-cta { display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; margin-top: 0.4rem; padding: 0.5rem 0.9rem; background: transparent; border: 1px solid var(--gold-dim); color: var(--gold); text-decoration: none; border-radius: 8px; font-size: 0.85rem; font-family: inherit; letter-spacing: 0.03em; pointer-events: none; }
