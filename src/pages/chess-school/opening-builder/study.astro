.variations-footer { margin: 0.9rem 0 0; padding-top: 0.7rem; border-top: 1px solid rgba(201,168,76,0.15); color: rgba(232,224,208,0.5); font-family: 'EB Garamond', Georgia, serif; font-size: 0.78rem; font-style: italic; line-height: 1.5; }







