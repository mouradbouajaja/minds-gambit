        { move: '4.g3',   note: "White's main response. Prepares to challenge Black's fianchettoed bishop with Bg2." },



        { move: "4...Ba6", note: "The Kasparov / Petrosian move. Hits White's c4 pawn  sharp, modern." },



        { move: '5.b3',   note: 'Defends c4, prepares Bb2.' },



        { move: '5...Bb4+', note: 'Forces an early decision  the bishop trade or block.' },



