      box-shadow: 0 0 35px rgba(201, 168, 76, 0.5);
    }
    @keyframes ctaPulse {
      0%, 100% { box-shadow: 0 0 20px rgba(201, 168, 76, 0.3); }
      50% { box-shadow: 0 0 40px rgba(201, 168, 76, 0.6), 0 0 60px rgba(201, 168, 76, 0.2); }
