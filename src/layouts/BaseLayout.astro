---
interface Props {
  title?: string;
  description?: string;
}
const { title = "Mourad Bouajaja — The Mind's Gambit", description = "Chess, Madness, and the Battle for the Mind — a book in ten chapters" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="description" content={description}>
  <meta name="author" content="Mourad Bouajaja">
  <meta name="google-site-verification" content="rSAnHjPa8O5rHn6IUEK2yWJhZHay3Fo5LqZaZw43FvI" />
  <title>{title}</title>
  <!-- PWA -->
  <link rel="manifest" href="/manifest.json">
  <meta name="theme-color" content="#0f1117">
  <link rel="apple-touch-icon" href="/images/apple-touch-icon.png">

  <!-- Open Graph Meta Tags -->
  <meta property="og:title" content={title}>
  <meta property="og:description" content={description}>
  <meta property="og:image" content="https://mindsgambit.com/images/og-share.jpg">
  <meta property="og:url" content="https://mindsgambit.com">
  <meta property="og:type" content="website">
  <meta property="og:site_name" content="The Mind's Gambit">

  <!-- Twitter Card Meta Tags -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content={title}>
  <meta name="twitter:description" content={description}>
  <meta name="twitter:image" content="https://mindsgambit.com/images/og-share.jpg">

  <!-- Canonical URL -->
  <link rel="canonical" href="https://mindsgambit.com">

  <!-- Structured Data (JSON-LD) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Book",
    "name": "The Mind's Gambit",
    "alternateName": "Chess, Madness, and the Battle for the Mind",
    "author": {
      "@type": "Person",
      "name": "Mourad Bouajaja"
    },
    "description": "Chess, Madness, and the Battle for the Mind",
    "url": "https://mindsgambit.com",
    "image": "https://mindsgambit.com/images/og-share.jpg",
    "genre": ["Psychology", "Chess", "Philosophy"],
    "inLanguage": "en",
    "publisher": {
      "@type": "Organization",
      "name": "The Mind's Gambit",
      "url": "https://mindsgambit.com"
    }
  }
  </script>

  <!-- Preconnect for performance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <link rel="stylesheet" href="/styles/global.css">
  <script async crossorigin="anonymous" data-clerk-publishable-key="pk_live_Y2xlcmsubWluZHNnYW1iaXQuY29tJA" src="https://clerk.mindsgambit.com/npm/@clerk/clerk-js@latest/dist/clerk.browser.js" type="text/javascript"></script>
</head>
<body>
  <slot />
  <!-- Service worker registration removed 2026-05-29: legacy SW caused stale routing + reload loop. New visitors get no SW. -->

    <!-- Newsletter Signup (site-wide) -->
    <section class="newsletter-band" id="newsletter" aria-labelledby="newsletter-heading">
      <div class="newsletter-inner">
        <div class="newsletter-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m2 6 10 7 10-7"></path>
          </svg>
        </div>
        <h2 id="newsletter-heading">Stay in the Loop</h2>
        <p class="newsletter-sub">Get occasional updates on new chapters, the documentary, and fresh content on the site. Weekly at most — only if you want them.</p>
        <form class="newsletter-form" action="https://formsubmit.co/Mourad@mindsgambit.com" method="POST">
          <input type="hidden" name="_subject" value="New newsletter signup" />
          <input type="hidden" name="_captcha" value="false" />
          <input type="hidden" name="_template" value="table" />
          <input type="email" name="email" placeholder="you@example.com" required aria-label="Email address" />
          <button type="submit">Subscribe</button>
        </form>
        <p class="newsletter-privacy">Your email is shared voluntarily and used only to send you site updates. We never sell or share your information, and you can unsubscribe anytime.</p>
      </div>
    </section>

    <style>
      .newsletter-band { background: var(--bg-card, #16161c); border-top: 1px solid var(--border, #2a2a33); padding: 3.5rem 1.5rem; }
      .newsletter-inner { max-width: 560px; margin: 0 auto; text-align: center; }
      .newsletter-icon { color: var(--gold, #c8a84e); display: flex; justify-content: center; margin-bottom: 1rem; }
      .newsletter-band h2 { font-family: var(--font-display, Georgia, serif); font-size: 1.6rem; color: var(--text-primary, #f5f5f0); margin: 0 0 0.6rem; }
      .newsletter-sub { color: var(--text-secondary, #b8b8b8); font-size: 0.98rem; line-height: 1.6; margin: 0 0 1.4rem; }
      .newsletter-form { display: flex; gap: 0.5rem; max-width: 420px; margin: 0 auto 1rem; }
      .newsletter-form input[type=email] { flex: 1; padding: 0.7rem 0.9rem; border-radius: 8px; border: 1px solid var(--border, #2a2a33); background: var(--bg-primary, #0f0f17); color: var(--text-primary, #f5f5f0); font-size: 0.95rem; }
      .newsletter-form input[type=email]:focus { outline: none; border-color: var(--gold, #c8a84e); }
      .newsletter-form button { padding: 0.7rem 1.3rem; border-radius: 8px; border: none; background: var(--gold, #c8a84e); color: var(--bg-primary, #0f0f17); font-weight: 600; cursor: pointer; white-space: nowrap; transition: opacity 0.2s; }
      .newsletter-form button:hover { opacity: 0.88; }
      .newsletter-privacy { color: var(--text-muted, #8a8a8a); font-size: 0.8rem; line-height: 1.5; margin: 0; }
      @media (max-width: 480px) { .newsletter-form { flex-direction: column; } }
    </style>

  <!-- Google Translate Widget -->
  <div id="gt-wrapper" style="position:fixed;top:27px;right:10px;z-index:10000;">
    <div id="google_translate_element"></div>
  </div>
  <style>
    #gt-wrapper { transition: opacity 0.3s; }
    #gt-wrapper .goog-te-gadget { font-size: 0 !important; }
    #gt-wrapper .goog-te-gadget .goog-te-combo {
      background: rgba(30,30,30,0.85);
      color: #c8a84e;
      border: 1px solid #c8a84e;
      border-radius: 6px;
      padding: 6px 10px;
      font-size: 13px;
      font-family: inherit;
      cursor: pointer;
      outline: none;
    }
    .goog-te-banner-frame, .skiptranslate { display: none !important; }
    body { top: 0 !important; }
    @media (max-width: 768px) {
      #gt-wrapper { top: 27px; right: 10px; }
    }
  </style>
  <script is:inline type="text/javascript">
    function googleTranslateElementInit() {
      new google.translate.TranslateElement({
        pageLanguage: "en",
        includedLanguages: "en,fr,ar",
        layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
        autoDisplay: false
      }, "google_translate_element");
    }
  </script>
  <script is:inline src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>



<style is:global>
.nav-burger{display:none;background:none;border:0;font-size:1.7rem;line-height:1;cursor:pointer;color:inherit;padding:0 0.4rem;}
@media (max-width:768px){
 nav{position:relative;}
 .mg-navwrap{display:flex !important;align-items:center;}
 .nav-burger{display:block;margin-left:auto;}
 nav .nav-links{display:none !important;position:absolute;top:100%;left:0;right:0;flex-direction:column;align-items:flex-start;background:#0f1117;padding:1.1rem 1.4rem;gap:0.5rem;z-index:1000;box-shadow:0 12px 28px rgba(0,0,0,0.45);border-bottom:1px solid rgba(255,255,255,0.12);}
 nav .nav-links.open{display:flex !important;}
 nav .nav-links li{width:100%;}
 nav .nav-links li a{display:block;width:100%;padding:0.35rem 0;}
 nav .nav-links .dropdown-menu{position:static !important;display:block;background:transparent;box-shadow:none;padding-left:0.8rem;}
}
</style>
<script is:inline>
(function(){
 function init(){
  var nav=document.querySelector("nav");
  var links=nav&&nav.querySelector(".nav-links");
  if(nav&&links&&!nav.querySelector(".nav-burger")){
   var wrap=links.parentElement; wrap.classList.add("mg-navwrap");
   var b=document.createElement("button"); b.type="button"; b.className="nav-burger"; b.setAttribute("aria-label","Toggle menu"); b.innerHTML=String.fromCharCode(9776);
   b.addEventListener("click",function(){ links.classList.toggle("open"); });
   wrap.appendChild(b);
   links.addEventListener("click",function(e){ if(e.target&&e.target.closest&&e.target.closest("a")) links.classList.remove("open"); });
  }
  var d=document.querySelectorAll("nav a[href='/daily']"); for(var i=0;i<d.length;i++) d[i].setAttribute("href","/daily-wired");
  var c=document.querySelectorAll("nav a[href*='buymeacoffee']"); for(var k=0;k<c.length;k++){ c[k].textContent="Donate"; c[k].setAttribute("href","/#donate"); }
 }
 if(document.readyState!=="loading") init(); else document.addEventListener("DOMContentLoaded",init);
})();
</script>
</body>
</html>
