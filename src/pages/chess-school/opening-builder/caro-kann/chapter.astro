<script is:inline>

(function() {

  'use strict';



  // ------------------------------------------------------------

  // CHAPTER DATA — eight Caro-Kann Defense chapters, verbatim.

  // ------------------------------------------------------------

  var CHAPTERS = {
  'exchange': {
    num: 1, title: 'The Exchange', eco: 'B13', firstMove: '3.exd5',
    intro: '<p>The most common reply at club level: White trades in the center at once and develops simply. The position is symmetrical but not equal in understanding — White usually follows the famous Bd3, Bf4, c3 setup, and Black equalizes with natural moves: …Nc6, …Nf6, …Bg4 and the freeing breaks.</p><p><strong>Strategic priority:</strong> Do not drift. Symmetry rewards the player with the clearer plan — know where every piece belongs and the middlegame plays itself.</p>',
    subVariations: [
    { id: 'exchange-rubinstein', name: '4.Bd3 (Fischer setup)', mainline: 'e4 c6 d4 d5 exd5 cxd5 Bd3 Nc6 c3 Nf6 Bf4 Bg4 Qb3 Qd7', label: 'The classic battle: White builds Bd3-Bf4-c3, Black answers with the Rubinstein recipe …Bg4 and …Qd7. Fully balanced with best play.' },
    { id: 'exchange-nf3', name: '4.Nf3 with Bb5+', mainline: 'e4 c6 d4 d5 exd5 cxd5 Nf3 Nf6 Bb5+ Bd7 Bxd7+ Nbxd7', label: 'White trades the good bishop to disturb development — after the recapture Black already stands slightly more comfortably.' }
    ],
    studiedBy: [
      { master: 'Bobby Fischer', note: 'As White, made the Exchange famous with the Bd3—Bf4 plan — his 1970 win over Petrosian is the model game for this whole structure.' },
      { master: 'Mikhail Botvinnik', note: 'On the Black side, showed that symmetry is not equality until every piece stands right — patient, exact handling.' }
    ]
  },
  'advance': {
    num: 2, title: 'The Advance', eco: 'B12', firstMove: '3.e5',
    intro: '<p>3.e5 grabs space and closes the center — but unlike the French, your light-squared bishop is already OUT before …e6. That single detail is why many strong players consider the Advance simply pleasant for Black.</p><p><strong>Strategic priority:</strong> Bishop first, pawns second. Get …Bf5 settled, then strike at the base with …c5 — and meet the wing rushes with a cool head and …h5.</p>',
    subVariations: [
    { id: 'advance-short', name: 'Short System (4.Nf3, 5.Be2)', mainline: 'e4 c6 d4 d5 e5 Bf5 Nf3 e6 Be2 c5 Be3 cxd4 Nxd4 Ne7', label: 'The modern positional main line, named for Nigel Short. Black hits d4 with …c5 and develops smoothly behind the wall.' },
    { id: 'advance-bayonet', name: 'Bayonet 4.Nc3 e6 5.g4', mainline: 'e4 c6 d4 d5 e5 Bf5 Nc3 e6 g4 Bg6 Nge2 c5 h4 h5', label: 'White lunges on the kingside. The cold-blooded …c5 and …h5 counters leave the engine unimpressed by the attack.' },
    { id: 'advance-tal', name: 'Tal Variation 4.h4', mainline: 'e4 c6 d4 d5 e5 Bf5 h4 h5 c4 e6 Nc3 Ne7', label: 'The immediate wing rush. Meet h4 with …h5, then return to the center — Black is fine in every line.' },
    { id: 'advance-botvinnik', name: '3…c5 (Botvinnik-Carls)', mainline: 'e4 c6 d4 d5 e5 c5 dxc5 Nc6 Nf3 Bg4', label: 'The counter-strike alternative: hit d4 before developing. A sound extra weapon once you know the main system.' }
    ],
    studiedBy: [
      { master: 'Mikhail Tal', note: 'Loved White’s space-grabbing tries with g4 and h4 — study his attacks to know exactly what Black must survive.' },
      { master: 'Nigel Short', note: 'Gave his name to White’s calm Nf3—Be2 system — the modern treatment Black most often faces.' }
    ]
  },
  'panov': {
    num: 3, title: 'The Panov-Botvinnik Attack', eco: 'B13—B14', firstMove: '4.c4',
    intro: '<p>White’s most ambitious try: 4.c4 turns the game into an isolated-queen-pawn battle. White gets activity and attacking chances; Black gets the d5 blockade square and the better endgame — a classic trade of present versus future.</p><p><strong>Strategic priority:</strong> Blockade, then exchange. Every piece trade increases the value of your structure — the isolani only grows weaker as the board empties.</p>',
    subVariations: [
    { id: 'panov-main', name: 'Main Line 5…e6 6.Nf3 Bb4', mainline: 'e4 c6 d4 d5 exd5 cxd5 c4 Nf6 Nc3 e6 Nf3 Bb4 cxd5 Nxd5 Bd2 Nc6 Bd3 O-O O-O Be7', label: 'The classical recipe: pin, exchange on d5, blockade. Both sides develop fully — Black’s position is rock solid.' },
    { id: 'panov-carlsbad', name: '5…Nc6 6.Bg5 (Carlsbad)', mainline: 'e4 c6 d4 d5 exd5 cxd5 c4 Nf6 Nc3 Nc6 Bg5 e6 Nf3 Be7 c5 O-O', label: 'White clamps with c5; Black calmly castles and prepares …b6 and …Ne4 to chip the chain. Equal chances, rich play.' }
    ],
    studiedBy: [
      { master: 'Mikhail Botvinnik', note: 'Hammered the Panov as White for decades — the isolated-pawn attack carries his name for a reason.' },
      { master: 'Anatoly Karpov', note: 'The model for Black: blockade the isolani on d5, trade the right pieces, win the ending.' }
    ]
  },
  'classical': {
    num: 4, title: 'The Classical', eco: 'B18—B19', firstMove: '3.Nd2 dxe4 4.Nxe4 Bf5',
    intro: '<p>The heart of the Caro-Kann and the core of this study guide: 3.Nd2 (or 3.Nc3) dxe4 4.Nxe4 Bf5. Black develops the problem bishop to its dream square, builds the famous pawn wall on e6 and h6, and reaches a position that is healthy, solid and quietly venomous.</p><p><strong>Strategic priority:</strong> Follow the known path with understanding, not memory: …Bg6, …Nd7, …e6, …Ngf6, castle — and only then choose your plan with …c5.</p>',
    subVariations: [
    { id: 'classical-main', name: 'Main Line (6.h4 h6 7.Nf3)', mainline: 'e4 c6 d4 d5 Nd2 dxe4 Nxe4 Bf5 Ng3 Bg6 h4 h6 Nf3 Nd7 h5 Bh7 Bd3 Bxd3 Qxd3 e6 Bd2 Ngf6 O-O-O Be7', label: 'The full classical tabiya, played in world championships for a century. Trade the bishops, finish development, equal game.' },
    { id: 'classical-flohr', name: 'Flohr 6.Nh3', mainline: 'e4 c6 d4 d5 Nd2 dxe4 Nxe4 Bf5 Ng3 Bg6 Nh3 Nd7 Nf4 e5', label: 'White reroutes the knight to f4 — meet it with the central strike …e5 and the position opens at the moment of YOUR choosing.' }
    ],
    studiedBy: [
      { master: 'José Raúl Capablanca', note: 'His clean handling of the …Bf5 systems made the Caro-Kann a world-championship weapon.' },
      { master: 'Anatoly Karpov', note: 'Built a career on exactly these quiet, healthy structures — develop, neutralize, outplay.' }
    ]
  },
  'karpov': {
    num: 5, title: 'The Karpov (4…Nd7)', eco: 'B17', firstMove: '4…Nd7',
    intro: '<p>The flexible alternative: 4…Nd7 keeps every option open. Black prepares …Ngf6 without allowing doubled pawns, and the light-squared bishop chooses its diagonal later. Less forcing than 4…Bf5 — and harder to attack.</p><p><strong>Strategic priority:</strong> Precision over speed in the first ten moves. White’s early Ng5 and Bc4 tries look scary and are harmless against exact play — which this chapter gives you.</p>',
    subVariations: [
    { id: 'karpov-modern', name: 'Modern Main Line 5.Ng5', mainline: 'e4 c6 d4 d5 Nd2 dxe4 Nxe4 Nd7 Ng5 Ngf6 Bd3 e6 N1f3 Bd6 Qe2 h6 Ne4 Nxe4 Qxe4', label: 'The critical test. Know the exact sequence — …h6 hits the knight at the right moment and Black emerges fully equal.' },
    { id: 'karpov-smyslov', name: 'Smyslov 5.Bc4', mainline: 'e4 c6 d4 d5 Nd2 dxe4 Nxe4 Nd7 Bc4 Ngf6 Ng5 e6 Qe2 Nb6 Bb3 h6 N5f3 c5', label: 'The Smyslov treatment: …Nb6 calmly questions the bishop, then …c5 strikes the center. Engine-approved equality.' }
    ],
    studiedBy: [
      { master: 'Anatoly Karpov', note: 'The variation bears his name — flexible development first, the bishop finds its diagonal later.' },
      { master: 'Vasily Smyslov', note: 'The harmonious …Ngf6 and …e6 treatment is the soul of this line.' }
    ]
  },
  'two-knights': {
    num: 6, title: 'The Two Knights', eco: 'B10—B11', firstMove: '2.Nc3 d5 3.Nf3',
    intro: '<p>2.Nc3 and 3.Nf3 — fast development, no early d4. Black’s cleanest answer is the Mindeno pin 3…Bg4: offer the bishop pair, take total structural comfort in return.</p><p><strong>Strategic priority:</strong> After 4.h3, capture on f3 without regret — the resulting wall of pawns and knights is exactly the kind of position the Caro-Kann was born for.</p>',
    subVariations: [
    { id: 'twoknights-exchange', name: 'Mindeno: 4.h3 Bxf3', mainline: 'e4 c6 Nc3 d5 Nf3 Bg4 h3 Bxf3 Qxf3 e6 d3 Nf6 Bd2 Nbd7', label: 'Give the bishop, build the wall: …e6, …Nf6, …Nbd7 — and White’s queen stares at granite.' },
    { id: 'twoknights-retreat', name: 'Mindeno: 4.h3 Bh5', mainline: 'e4 c6 Nc3 d5 Nf3 Bg4 h3 Bh5 exd5 cxd5 Bb5+ Nc6 g4 Bg6 Ne5 Rc8', label: 'The fighting retreat. White wins the bishop pair by force — and Black gets the center, the open c-file and full compensation.' }
    ],
    studiedBy: [
      { master: 'Bobby Fischer', note: 'Favored the Two Knights as White in his early years — fast development aiming to punish slow play.' },
      { master: 'Tigran Petrosian', note: 'Showed Black’s answer: trade calmly on f3 and build an unbreakable wall.' }
    ]
  },
  'fantasy': {
    num: 7, title: 'The Fantasy (3.f3)', eco: 'B12', firstMove: '3.f3',
    intro: '<p>3.f3 — White protects e4 with a pawn and dreams of a huge center. It looks eccentric and is genuinely dangerous against careless play; this is the one anti-Caro sideline worth real preparation.</p><p><strong>Strategic priority:</strong> Counter in the center, never on the wing. Either the French-style …e6 with …c5, or the principled strike 3…dxe4 4.fxe4 e5 — both engine-sound, both teaching the same lesson: a big center must be challenged, not admired.</p>',
    subVariations: [
    { id: 'fantasy-e6', name: '3…e6 (solid)', mainline: 'e4 c6 d4 d5 f3 e6 Nc3 Nf6 e5 Nfd7 f4 c5 Nf3 Nc6', label: 'Treat it like a French where f3 has cost White a tempo — hit the chain with …c5 and develop with easy equality.' },
    { id: 'fantasy-e5', name: '3…dxe4 4.fxe4 e5 (principled)', mainline: 'e4 c6 d4 d5 f3 dxe4 fxe4 e5 Nf3 Bg4 Bc4 Nd7', label: 'The central counter-strike. Pin with …Bg4, support e5 with …Nd7 — the engine calls it dead level.' }
    ],
    studiedBy: [
      { master: 'Géza Maróczy', note: 'The 3.f3 idea carries his name — White offers a big center and asks Black to prove it is too big. This chapter is the proof.' }
    ]
  },
  'sidelines': {
    num: 8, title: 'Sidelines: 2.c4 and 2.d3', eco: 'B10', firstMove: '2.c4 / 2.d3',
    intro: '<p>Two quieter tries you will still meet: the Accelerated Panov (2.c4) and the slow 2.d3 setups. Neither asks a hard question if you know the recipe — and both reward Black’s most natural moves.</p><p><strong>Strategic priority:</strong> Against 2.c4, capture and develop — the game flows into friendly Panov waters. Against 2.d3, take the center yourself with …e5 and play the reversed setup with confidence.</p>',
    subVariations: [
    { id: 'sidelines-accpanov', name: 'Accelerated Panov 2.c4', mainline: 'e4 c6 c4 d5 exd5 cxd5 cxd5 Nf6 Nc3 Nxd5 Nf3 Nc6 d4 Bg4', label: 'Recapture, then play against d4 with tempo: …Nc6 and …Bg4 give Black the most comfortable IQP setup in the book.' },
    { id: 'sidelines-breyer', name: '2.d3 (Breyer / KIA style)', mainline: 'e4 c6 d3 d5 Nd2 e5 Ngf3 Bd6 g3 Nf6 Bg2 O-O O-O Re8', label: 'White plays a King’s Indian Attack — Black simply takes the full center with …e5 and stands at least equal from move six.' }
    ],
    studiedBy: [
      { master: 'Mikhail Botvinnik', note: 'The c4 structures transpose into his favorite isolani battles — the same plans apply, one move earlier.' }
    ]
  }
};



  // ------------------------------------------------------------

  // Chapter order for prev/next navigation.

  // ------------------------------------------------------------

  var ORDER = ['exchange', 'advance', 'mccutcheon', 'classical', 'tarrasch', 'two-knights', 'schlechter', 'kia'];



  // ------------------------------------------------------------

  // Parse ?id= from URL.

  // ------------------------------------------------------------

  function getChapterId() {

    var m = location.search.match(/[?&]id=([^&]+)/);

    return m ? decodeURIComponent(m[1]).toLowerCase().trim() : null;

  }



  var chapterId = getChapterId();

  var chapter = chapterId ? CHAPTERS[chapterId] : null;



  if (!chapter) {

    document.getElementById('chapter-title').textContent = 'Chapter not found';

    document.getElementById('chapter-eco').textContent = '';

    document.getElementById('chapter-setup').textContent = '';

    document.getElementById('not-found').hidden = false;

    return;

  }



  // ------------------------------------------------------------

  // Render header.

  // ------------------------------------------------------------

  document.getElementById('chapter-title').textContent = chapter.title;

  document.getElementById('chapter-eyebrow').innerHTML =

    'Caro-Kann Repertoire &middot; Chapter ' + chapter.num + ' of 8';

  document.getElementById('chapter-eco').textContent = 'ECO ' + chapter.eco;

  document.getElementById('chapter-setup').textContent =

    'Black against 1.e4 e6 2.d4 d5 3.' + chapter.firstMove.replace(/^3\./, '');

  document.title = chapter.title + ' — Caro-Kann Repertoire — Mind\'s Gambit';



  document.getElementById('chapter-content').hidden = false;



  // Intro

  document.getElementById('chapter-intro').innerHTML = chapter.intro;



  // ------------------------------------------------------------

  // Render sub-variations.

  // ------------------------------------------------------------

  var subList = document.getElementById('subvariation-list');

  for (var i = 0; i < chapter.subVariations.length; i++) {

    var sv = chapter.subVariations[i];

    var li = document.createElement('li');

    li.className = 'subvariation-card';



    var header = document.createElement('div');

    header.className = 'subvar-header';

    var nameEl = document.createElement('h3');

    nameEl.className = 'subvar-name';

    nameEl.textContent = sv.name;

    header.appendChild(nameEl);

    li.appendChild(header);



    var moves = document.createElement('div');

    moves.className = 'subvar-mainline';

    moves.textContent = sv.mainline;

    li.appendChild(moves);



    var label = document.createElement('p');

    label.className = 'subvar-label';

    label.textContent = sv.label;

    li.appendChild(label);



    var drillRow = document.createElement('div');

    drillRow.className = 'subvar-cta-row';

    var drillLink = document.createElement('a');

    drillLink.className = 'cta-primary';

    drillLink.href = '/chess-school/opening-builder/drill?mainline=' + encodeURIComponent(sv.mainline) + '&name=' + encodeURIComponent(chapter.title + ' · ' + sv.name) + '&side=black&parent=' + encodeURIComponent(chapterId);

    drillLink.textContent = 'Drill this line →';

    drillRow.appendChild(drillLink);

    li.appendChild(drillRow);



    subList.appendChild(li);

  }



  // ------------------------------------------------------------

  // Render studied-by.

  // ------------------------------------------------------------

  var studiedList = document.getElementById('studied-by');

  for (var j = 0; j < chapter.studiedBy.length; j++) {

    var s = chapter.studiedBy[j];

    var sli = document.createElement('li');

    var nameEl2 = document.createElement('strong');

    nameEl2.className = 'master';

    nameEl2.textContent = s.master;

    var snoteEl = document.createElement('span');

    snoteEl.className = 'note';

    snoteEl.textContent = s.note;

    sli.appendChild(nameEl2);

    sli.appendChild(document.createTextNode(' '));

    sli.appendChild(snoteEl);

    studiedList.appendChild(sli);

  }



  // ------------------------------------------------------------

  // Prev / Next chapter navigation.

  // ------------------------------------------------------------

  var idx = ORDER.indexOf(chapterId);

  var prev = document.getElementById('prev-chapter');

  var next = document.getElementById('next-chapter');

  if (idx > 0) {

    prev.href = '/chess-school/opening-builder/caro-kann/chapter?id=' + ORDER[idx - 1];

    prev.textContent = '← ' + CHAPTERS[ORDER[idx - 1]].title;

  } else {

    prev.classList.add('disabled');

    prev.removeAttribute('href');

    prev.textContent = '← First chapter';

  }

  if (idx < ORDER.length - 1) {

    next.href = '/chess-school/opening-builder/caro-kann/chapter?id=' + ORDER[idx + 1];

    next.textContent = CHAPTERS[ORDER[idx + 1]].title + ' →';

  } else {

    next.classList.add('disabled');

    next.removeAttribute('href');

    next.textContent = 'Last chapter →';

  }



  // ------------------------------------------------------------

  // Progress widget (localStorage mg_carokann_progress).

  // ------------------------------------------------------------

  function loadProgress() {

    try {

      var raw = localStorage.getItem('mg_carokann_progress');

      return raw ? JSON.parse(raw) : {};

    } catch (e) { return {}; }

  }

  function saveProgress(p) {

    try { localStorage.setItem('mg_carokann_progress', JSON.stringify(p)); } catch (e) {}

  }

  var progress = loadProgress();

  if (!progress[chapterId]) progress[chapterId] = { started: true, completed: false, percent: 15 };

  else progress[chapterId].started = true;

  saveProgress(progress);



  var widget = document.getElementById('progress-widget');

  widget.hidden = false;

  var fill = document.getElementById('sidebar-progress-fill');

  var label2 = document.getElementById('sidebar-progress-label');

  function renderProgress() {

    var p = progress[chapterId] || {};

    var pct = typeof p.percent === 'number' ? Math.max(0, Math.min(100, p.percent)) : (p.completed ? 100 : 15);

    fill.style.width = pct + '%';

    label2.textContent = p.completed ? 'Chapter complete.' : 'Reading in progress (' + pct + '%)';

  }

  renderProgress();



  var btn = document.getElementById('mark-complete');

  btn.addEventListener('click', function() {

    progress[chapterId].completed = !progress[chapterId].completed;

    progress[chapterId].percent = progress[chapterId].completed ? 100 : 25;

    saveProgress(progress);

    renderProgress();

    btn.textContent = progress[chapterId].completed ? 'Mark as not complete' : 'Mark chapter as complete';

  });



  // ------------------------------------------------------------

  // MASTER GAMES — load PGN, parse, render list + embedded board.

  // ------------------------------------------------------------

  (function initMasterGames() {

    var section = document.getElementById('master-games-section');

    var listEl = document.getElementById('master-games-list');

    var viewerEl = document.getElementById('master-games-viewer');

    if (!section || !listEl) return;



    var games = [];          // parsed games {headers, moves}

    var currentGame = null;  // chess.js instance for current game

    var history = [];        // SAN history of current game

    var verbose = [];        // verbose history (for FEN replay)

    var ply = 0;             // current half-move index (0..history.length)

    var board = null;        // chessboardjs instance

    var replay = null;       // chess.js replay instance



    // --- Parse PGN string into games array ----------------------

    function parsePgn(text) {

      if (!text || typeof text !== 'string') return [];

      // Normalise line endings

      var norm = text.replace(/\r\n/g, '\n').replace(/\r/g, '\n').trim();

      // Split on blank-line + [Event boundary, but keep [Event with each chunk

      var chunks = norm.split(/\n\n(?=\[Event )/);

      var out = [];

      for (var i = 0; i < chunks.length; i++) {

        var chunk = chunks[i].trim();

        if (!chunk) continue;

        var headers = {};

        var headerRegex = /\[(\w+)\s+"([^"]*)"\]/g;

        var m;

        while ((m = headerRegex.exec(chunk)) !== null) {

          headers[m[1]] = m[2];

        }

        // Moves section: everything after the last "]\n" header

        var movesText = chunk.replace(/\[(\w+)\s+"([^"]*)"\]\s*/g, '').trim();

        if (!movesText) continue;

        out.push({ headers: headers, moves: movesText, raw: chunk });

      }

      return out;

    }



    function safeFetchPgn(url) {

      return fetch(url, { cache: 'no-cache' }).then(function(r) {

        if (!r.ok) throw new Error('not found');

        return r.text();

      });

    }



    function fmtPlayer(name, elo) {

      if (!name) return '?';

      return elo ? name + ' (' + elo + ')' : name;

    }

    function fmtYear(headers) {

      if (headers.Year) return headers.Year;

      if (headers.Date) {

        var y = (headers.Date.split('.')[0] || '').replace(/\?/g, '');

        if (y) return y;

      }

      return '';

    }

    function resultClass(r) {

      if (r === '1-0') return 'mg-result-white';

      if (r === '0-1') return 'mg-result-black';

      return 'mg-result-draw';

    }

    function fmtResult(r) {

      if (r === '1/2-1/2') return '½-½';

      return r || '*';

    }



    // --- Render the games list ---------------------------------

    function renderList() {

      listEl.innerHTML = '';

      var limit = Math.min(games.length, 10);

      for (var i = 0; i < limit; i++) {

        (function(idx) {

          var g = games[idx];

          var h = g.headers;

          var row = document.createElement('li');

          row.className = 'mg-row';

          row.tabIndex = 0;



          var line1 = document.createElement('div');

          line1.className = 'mg-row-players';

          line1.innerHTML =

            '<span class="mg-white">' + fmtPlayer(h.White, h.WhiteElo) + '</span>' +

            ' <span class="mg-vs">vs</span> ' +

            '<span class="mg-black">' + fmtPlayer(h.Black, h.BlackElo) + '</span>' +

            ' <span class="mg-result ' + resultClass(h.Result) + '">' + fmtResult(h.Result) + '</span>';

          row.appendChild(line1);



          var line2 = document.createElement('div');

          line2.className = 'mg-row-meta';

          var yr = fmtYear(h);

          var bits = [];

          if (yr) bits.push(yr);

          if (h.Event) bits.push(h.Event);

          if (h.ECO) bits.push('ECO ' + h.ECO);

          line2.textContent = bits.join(' · ');

          row.appendChild(line2);



          row.addEventListener('click', function() { selectGame(idx, row); });

          row.addEventListener('keydown', function(e) {

            if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectGame(idx, row); }

          });

          listEl.appendChild(row);

        })(i);

      }

    }



    // --- Select a game, build a chess.js replay (loadPgn) -------

    function selectGame(idx, rowEl) {

      var g = games[idx];

      if (!g) return;

      var rows = listEl.querySelectorAll('.mg-row');

      for (var k = 0; k < rows.length; k++) rows[k].classList.remove('mg-row-active');

      if (rowEl) rowEl.classList.add('mg-row-active');



      try {

        currentGame = new Chess();

        var ok = currentGame.load_pgn(g.moves, { sloppy: true });

        if (!ok) {

          // Try loading the raw chunk (some PGNs need headers)

          currentGame = new Chess();

          ok = currentGame.load_pgn(g.raw, { sloppy: true });

        }

        if (!ok) throw new Error('parse failed');

        history = currentGame.history();

        verbose = currentGame.history({ verbose: true });

        ply = history.length;

      } catch (err) {

        return;

      }



      viewerEl.hidden = false;

      var hdr = document.getElementById('mg-game-header');

      if (hdr) {

        hdr.innerHTML =

          '<strong>' + fmtPlayer(g.headers.White, g.headers.WhiteElo) + '</strong> vs ' +

          '<strong>' + fmtPlayer(g.headers.Black, g.headers.BlackElo) + '</strong> &middot; ' +

          fmtResult(g.headers.Result) + (fmtYear(g.headers) ? ' &middot; ' + fmtYear(g.headers) : '');

      }



      if (!board && typeof ChessBoard !== 'undefined' && window.jQuery) {

        board = ChessBoard('master-board', {

          position: 'start',

          pieceTheme: 'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/{piece}.png',

          showNotation: true

        });

      }

      renderMoves();

      goToPly(ply);

      // Scroll the viewer into view on mobile

      viewerEl.scrollIntoView({ behavior: 'smooth', block: 'nearest' });

    }



    function renderMoves() {

      var movesEl = document.getElementById('mg-moves');

      if (!movesEl) return;

      movesEl.innerHTML = '';

      for (var i = 0; i < history.length; i++) {

        if (i % 2 === 0) {

          var num = document.createElement('span');

          num.className = 'mg-move-num';

          num.textContent = (i / 2 + 1) + '.';

          movesEl.appendChild(num);

        }

        (function(idx) {

          var mv = document.createElement('span');

          mv.className = 'mg-move';

          mv.textContent = history[idx];

          mv.addEventListener('click', function() { goToPly(idx + 1); });

          movesEl.appendChild(mv);

        })(i);

      }

    }



    function goToPly(target) {

      if (!history.length) return;

      target = Math.max(0, Math.min(history.length, target));

      ply = target;

      // Replay from start

      replay = new Chess();

      for (var i = 0; i < ply; i++) {

        replay.move(history[i], { sloppy: true });

      }

      if (board) board.position(replay.fen(), false);

      // Highlight current move

      var marks = document.querySelectorAll('#mg-moves .mg-move');

      for (var k = 0; k < marks.length; k++) marks[k].classList.remove('mg-move-active');

      if (ply > 0 && marks[ply - 1]) {

        marks[ply - 1].classList.add('mg-move-active');

        marks[ply - 1].scrollIntoView({ block: 'nearest', behavior: 'smooth' });

      }

    }



    function bindControls() {

      var s = document.getElementById('mg-start');

      var p = document.getElementById('mg-prev');

      var n = document.getElementById('mg-next');

      var e = document.getElementById('mg-end');

      if (s) s.addEventListener('click', function() { goToPly(0); });

      if (p) p.addEventListener('click', function() { goToPly(ply - 1); });

      if (n) n.addEventListener('click', function() { goToPly(ply + 1); });

      if (e) e.addEventListener('click', function() { goToPly(history.length); });



      document.addEventListener('keydown', function(ev) {

        if (viewerEl.hidden) return;

        var tag = (ev.target && ev.target.tagName) || '';

        if (tag === 'INPUT' || tag === 'TEXTAREA') return;

        if (ev.key === 'ArrowLeft') { ev.preventDefault(); goToPly(ply - 1); }

        else if (ev.key === 'ArrowRight') { ev.preventDefault(); goToPly(ply + 1); }

        else if (ev.key === 'Home') { ev.preventDefault(); goToPly(0); }

        else if (ev.key === 'End') { ev.preventDefault(); goToPly(history.length); }

      });

    }



    // Kick it off

    var pgnUrl = '/pgn/caro-kann-' + chapterId + '.pgn';

    safeFetchPgn(pgnUrl).then(function(text) {

      games = parsePgn(text);

      if (!games.length) return; // hide section silently

      section.hidden = false;

      renderList();

      bindControls();

    }).catch(function() {

      // Silent fail — section remains hidden

    });

  })();

})();

</script>



