---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

// ============================================================
//  OPENING REPERTOIRE BUILDER  Catalog page
//  Phase 1: Catalog (live).
//  Phase 2: Interactive drill mode (LIVE  /chess-school/opening-builder/drill?id=<id>).
//  Phase 3: Custom repertoire builder (coming  paste your own PGN lines).
//
//  Each opening carries a `mainLine` (12-16 plies of canonical SAN,
//  no move numbers) consumed by the drill page.
// ============================================================

const WHITE_OPENINGS = [
  {
    id: 'ruy-lopez',
    name: 'Ruy Lopez (Spanish Opening)',
    eco: 'C60C99',
    moves: '1. e4 e5 2. Nf3 Nc6 3. Bb5',
    style: 'Classical, strategic',
    description: "The oldest fully-analyzed opening still in elite play. Pin the knight, fight for the center, build a long-game advantage. Magnus Carlsen's lifelong workhorse.",
    mainLine: 'e4 e5 Nf3 Nc6 Bb5 a6 Ba4 Nf6 O-O Be7 Re1 b5 Bb3 d6 c3'
  },
  {
    id: 'italian',
    name: 'Italian Game',
    eco: 'C50C59',
    moves: '1. e4 e5 2. Nf3 Nc6 3. Bc4',
    style: 'Aggressive, attacking',
    description: "Direct attack on f7. Modern Italian (Giuoco Pianissimo) is razor-sharp at top level  slow build-up that explodes when the moment is right.",
    mainLine: 'e4 e5 Nf3 Nc6 Bc4 Bc5 c3 Nf6 d3 d6 O-O O-O Re1 a6 h3',
    recommended: true
  },
  {
    id: 'queens-gambit',
    name: "Queen's Gambit",
    eco: 'D06D69',
    moves: '1. d4 d5 2. c4',
    style: 'Classical, positional',
    description: "Offer the c-pawn to seize central control. Most respected opening in chess history. Backbone of Karpov, Kramnik, Carlsen's repertoires.",
    mainLine: 'd4 d5 c4 e6 Nc3 Nf6 cxd5 exd5 Bg5 Be7 e3 c6 Bd3 O-O Nf3',
    recommended: true
  },
  {
    id: 'english',
    name: 'English Opening',
    eco: 'A10A39',
    moves: '1. c4',
    style: 'Flexible, positional',
    description: "Flank opening that transposes into countless structures. Reversed Sicilian as a feature, not a bug. Favored by Botvinnik, Kasparov, and modern grinders.",
    mainLine: 'c4 e5 Nc3 Nf6 Nf3 Nc6 g3 d5 cxd5 Nxd5 Bg2 Nb6 O-O Be7 d3'
  },
  {
    id: 'london',
    name: 'London System',
    eco: 'D02 / A45',
    moves: '1. d4 2. Bf4',
    style: 'Solid, low-theory',
    description: "Same setup against almost anything Black plays. Low-maintenance for the busy player; pet line of Magnus Carlsen at world-championship level.",
    mainLine: 'd4 d5 Bf4 Nf6 e3 e6 Nf3 Bd6 Bg3 O-O Bd3 c5 c3 Nc6 Nbd2',
    recommended: true
  },
  {
    id: 'colle-zukertort',
    name: 'Colle-Zukertort',
    eco: 'D04D05',
    moves: '1. d4 d5 2. Nf3 Nf6 3. e3',
    style: 'Solid, low-theory',
    description: "The London's cousin: same one-system-vs-anything philosophy, but with the queen's bishop fianchettoed on b2 instead of f4. Pressures the long diagonal — especially after a future e4 break. Edgar Colle's 1920s creation, refined by Zukertort. Perfect for the busy player who wants to think in plans, not memorize moves.",
    mainLine: 'd4 d5 Nf3 Nf6 e3 e6 Bd3 c5 b3 Nc6 Bb2 Bd6 O-O O-O Nbd2 b6',
    recommended: true
  },
  {
    id: 'kia',
    name: "King's Indian Attack",
    eco: 'A07A08',
    moves: '1. Nf3 2. g3 3. Bg2',
    style: 'Flexible, attacking',
    description: "A setup, not a forced line  reach this against any Black system. Bobby Fischer played it for years. Quiet kingside fianchetto before launching a thematic attack.",
    mainLine: 'Nf3 d5 g3 Nf6 Bg2 c5 O-O Nc6 d3 e6 Nbd2 Be7 e4 O-O Re1'
  }
];

const BLACK_VS_E4 = [
  {
    id: 'sicilian',
    name: 'Sicilian Defense',
    eco: 'B20B99',
    moves: '1. e4 c5',
    style: 'Sharp, fighting',
    description: "The most popular and most scoring reply to 1.e4 at every level. Asymmetric from move one. Najdorf, Dragon, Sveshnikov  pick your sub-line and dig in.",
    mainLine: 'e4 c5 Nf3 d6 d4 cxd4 Nxd4 Nf6 Nc3 a6 Be2 e5 Nb3 Be7 O-O'
  },
  {
    id: 'french',
    name: 'French Defense',
    eco: 'C00C19',
    moves: '1. e4 e6',
    style: 'Solid, strategic',
    description: "Concede space, build a fortress, counterpunch. Beloved by Botvinnik, Korchnoi, and modern grinders. The pawn structure decides everything.",
    mainLine: 'e4 e6 d4 d5 Nd2 c5 exd5 exd5 Ngf3 Nc6 Bb5 Bd6 dxc5 Bxc5 O-O',
    recommended: true
  },
  {
    id: 'caro-kann',
    name: 'Caro-Kann Defense',
    eco: 'B10B19',
    moves: '1. e4 c6',
    style: 'Solid, classical',
    description: "Karpov's defense of choice. Build a solid structure with ...c6 and ...d5, no weaknesses, wait for the opponent to overextend.",
    mainLine: 'e4 c6 d4 d5 Nc3 dxe4 Nxe4 Bf5 Ng3 Bg6 h4 h6 Nf3 Nd7 h5 Bh7',
    recommended: true
  },
  {
    id: 'berlin',
    name: 'Berlin Defense',
    eco: 'C65C67',
    moves: '1. e4 e5 2. Nf3 Nc6 3. Bb5 Nf6',
    style: 'Solid, endgame-focused',
    description: "Kramnik's weapon to defang Kasparov in 2000. Trade queens early, head straight to a slightly worse but tenacious endgame. Drawing weapon par excellence.",
    mainLine: 'e4 e5 Nf3 Nc6 Bb5 Nf6 O-O Nxe4 d4 Nd6 Bxc6 dxc6 dxe5 Nf5'
  },
  {
    id: 'scandinavian',
    name: 'Scandinavian Defense',
    eco: 'B01',
    moves: '1. e4 d5',
    style: 'Solid, low-theory',
    description: "Black plays ...d5 on move 1  immediate central challenge with no theory race. Pick a recapture (Qd5 or ...Nf6 gambit style) and play sound positional chess. Anand has used it at world-class level.",
    mainLine: 'e4 d5 exd5 Qxd5 Nc3 Qa5 d4 Nf6 Nf3 c6 Bc4 Bf5 Bd2 e6 Nd5'
  }
];

const BLACK_VS_D4 = [
  {
    id: 'kid',
    name: "King's Indian Defense",
    eco: 'E60E99',
    moves: '1. d4 Nf6 2. c4 g6',
    style: 'Aggressive, kingside attack',
    description: "Let White have the center, then storm the kingside with ...f5, ...g5, ...h5. Fischer and Kasparov's favorite. Win or lose  this is fighting chess.",
    mainLine: 'd4 Nf6 c4 g6 Nc3 Bg7 e4 d6 Nf3 O-O Be2 e5 O-O Nc6 d5 Ne7'
  },
  {
    id: 'qgd',
    name: "Queen's Gambit Declined",
    eco: 'D30D69',
    moves: '1. d4 d5 2. c4 e6',
    style: 'Classical, solid',
    description: "The most respected reply to 1.d4. Maintain the d5 pawn, develop classically, equalize patiently. Anand, Karpov, and a thousand world-class players' backbone.",
    mainLine: 'd4 d5 c4 e6 Nc3 Nf6 Bg5 Be7 e3 O-O Nf3 Nbd7 Rc1 c6 Bd3 dxc4'
  },
  {
    id: 'slav',
    name: 'Slav Defense',
    eco: 'D10D19',
    moves: '1. d4 d5 2. c4 c6',
    style: 'Solid, flexible',
    description: "Protect d5 with the c-pawn instead of e-pawn  keeps the c8-bishop's diagonal open. Modern preference at top level. Sound and rich in possibilities.",
    mainLine: 'd4 d5 c4 c6 Nf3 Nf6 Nc3 dxc4 a4 Bf5 e3 e6 Bxc4 Bb4 O-O'
  },
  {
    id: 'nimzo',
    name: 'Nimzo-Indian Defense',
    eco: 'E20E59',
    moves: '1. d4 Nf6 2. c4 e6 3. Nc3 Bb4',
    style: 'Strategic, positional',
    description: "Aron Nimzowitsch's lasting gift to chess. Pin the knight, double White's pawns, fight for the dark squares. Often considered the most respectable defense to 1.d4.",
    mainLine: 'd4 Nf6 c4 e6 Nc3 Bb4 e3 O-O Bd3 d5 Nf3 c5 O-O Nc6 a3 Bxc3',
    recommended: true
  },
  {
    id: 'queens-indian',
    name: "Queen's Indian Defense",
    eco: 'E12E19',
    moves: '1. d4 Nf6 2. c4 e6 3. Nf3 b6',
    style: 'Hypermodern, flexible',
    description: "Fianchetto the queen's bishop to b7 and contest the long diagonal. Pairs naturally with the Nimzo (Black plays QID when White avoids 3.Nc3). Karpov's lifelong weapon  a complete repertoire when combined with the Nimzo.",
    mainLine: 'd4 Nf6 c4 e6 Nf3 b6 g3 Ba6 b3 Bb4+ Bd2 Be7 Bg2 c6 O-O d5',
    recommended: true
  },
  {
    id: 'bogo-indian',
    name: 'Bogo-Indian Defense',
    eco: 'E11',
    moves: '1. d4 Nf6 2. c4 e6 3. Nf3 Bb4+',
    style: 'Solid, principled',
    description: "Bishop check on b4  same Nimzo idea, but against 3.Nf3 instead of 3.Nc3. Quieter, less theory-heavy, easier to learn. A good Indian system when you want fewer surprises than the Nimzo proper.",
    mainLine: 'd4 Nf6 c4 e6 Nf3 Bb4+ Bd2 a5 Nc3 O-O e3 d5 a3 Bxc3 Bxc3 dxc4'
  }
];
---

<BaseLayout title="Opening Repertoire Builder  Mind's Gambit Chess School" description="Build a chess opening repertoire. Pick your White and Black weapons, learn the main lines, drill until they're automatic. Free.">

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#book">The Book</a></li>
      <li><a href="/watch">Documentary</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/chess-school">Chess School</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>
    </ul>
  </div>
</nav>

<section class="page">
  <a href="/chess-school" class="back-link">&larr; Back to Chess School</a>
  <span class="eyebrow">Mind&rsquo;s Gambit Chess School</span>
  <h1>Opening Repertoire Builder</h1>
  <p class="lead">Pick your weapons. Build a repertoire you can actually rely on &mdash; both as White and against the openings you&rsquo;ll see as Black. Below: a curated catalog of <strong>18 sound, strategic openings</strong>, with 8 flagged as a complete intermediate repertoire. Click <em>&ldquo;Drill mode&rdquo;</em> on any opening to practice the mainline against the engine; your accuracy saves locally so you can track progress.</p>

  <!-- Status banner -->
  <div class="status-banner">
    <span class="status-icon">&#9881;</span>
    <div>
      <strong>Phase 2 &mdash; Drill Mode is Live</strong>
      <span>Click &lsquo;Drill mode&rsquo; on any opening below to practice the mainline against the engine. Your scores save automatically &mdash; come back to see your progress. Phase 3 (custom PGN repertoire) is next.</span>
    </div>
  </div>

  <!-- MG Recommendations editorial block -->
  <section class="mg-recs">
    <span class="mg-recs-chip">Mind&rsquo;s Gambit Recommendations</span>
    <h2 class="mg-recs-title">A complete repertoire for intermediate players</h2>
    <p class="mg-recs-body">We curate sound, strategic openings &mdash; not trap-based gambits or fringe lines that fall apart once your opponent knows the refutation. Every opening here survives accurate play and teaches real principles. The eight openings marked <strong class="mg-rec-inline">&#10038; MG Recommended</strong> below form a complete intermediate repertoire: Pick one White system (or play the London/Colle if you want minimal theory), one Black answer to 1.e4 (French or Caro-Kann), and a Nimzo/Queen&rsquo;s Indian pair against 1.d4.</p>
  </section>

  <!-- WHITE REPERTOIRE -->
  <section class="repertoire-section">
    <header class="repertoire-header">
      <span class="rep-color-chip white-chip">&#9817; White Repertoire</span>
      <h2>Openings to play as White</h2>
      <p class="rep-intro">Choose one main weapon against 1.e4 e5, one against the Sicilian (or play 1.d4 to avoid it), and a system that suits your style. Most strong players have one solid mainline and one offbeat surprise.</p>
    </header>
    <div class="opening-grid">
      {WHITE_OPENINGS.map((o) => (
        <article class="opening-card" data-id={o.id}>
          {o.recommended && <span class="mg-rec-badge">&#10038; MG Recommended</span>}
          <header class="opening-card-header">
            <h3 class="opening-name">{o.name}</h3>
            <span class="opening-eco">{o.eco}</span>
          </header>
          <div class="opening-moves">{o.moves}</div>
          <span class="opening-style">{o.style}</span>
          <p class="opening-description">{o.description}</p>
          <div class="opening-cta-row">
            <a class="opening-cta-primary" href={`/chess-school/opening-builder/study?id=${o.id}`}>Study Guide</a>
            <a class="opening-cta-secondary" href={`/chess-school/opening-builder/drill?id=${o.id}`}>Drill &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- BLACK vs e4 -->
  <section class="repertoire-section">
    <header class="repertoire-header">
      <span class="rep-color-chip black-chip">&#9823; Black vs 1.e4</span>
      <h2>Defenses against 1. e4</h2>
      <p class="rep-intro">When White opens 1.e4, you need a reply you understand deeply. Pick one mainline you can play in every game without thinking.</p>
    </header>
    <div class="opening-grid">
      {BLACK_VS_E4.map((o) => (
        <article class="opening-card" data-id={o.id}>
          {o.recommended && <span class="mg-rec-badge">&#10038; MG Recommended</span>}
          <header class="opening-card-header">
            <h3 class="opening-name">{o.name}</h3>
            <span class="opening-eco">{o.eco}</span>
          </header>
          <div class="opening-moves">{o.moves}</div>
          <span class="opening-style">{o.style}</span>
          <p class="opening-description">{o.description}</p>
          <div class="opening-cta-row">
            <a class="opening-cta-primary" href={`/chess-school/opening-builder/study?id=${o.id}`}>Study Guide</a>
            <a class="opening-cta-secondary" href={`/chess-school/opening-builder/drill?id=${o.id}`}>Drill &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- BLACK vs d4 -->
  <section class="repertoire-section">
    <header class="repertoire-header">
      <span class="rep-color-chip black-chip">&#9823; Black vs 1.d4</span>
      <h2>Defenses against 1. d4</h2>
      <p class="rep-intro">Queen-pawn openings demand a different toolkit. Choose between solid (QGD, Slav) and dynamic (King&rsquo;s Indian, Nimzo) depending on your fighting temperament.</p>
    </header>
    <div class="opening-grid">
      {BLACK_VS_D4.map((o) => (
        <article class="opening-card" data-id={o.id}>
          {o.recommended && <span class="mg-rec-badge">&#10038; MG Recommended</span>}
          <header class="opening-card-header">
            <h3 class="opening-name">{o.name}</h3>
            <span class="opening-eco">{o.eco}</span>
          </header>
          <div class="opening-moves">{o.moves}</div>
          <span class="opening-style">{o.style}</span>
          <p class="opening-description">{o.description}</p>
          <div class="opening-cta-row">
            <a class="opening-cta-primary" href={`/chess-school/opening-builder/study?id=${o.id}`}>Study Guide</a>
            <a class="opening-cta-secondary" href={`/chess-school/opening-builder/drill?id=${o.id}`}>Drill &rarr;</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <!-- Roadmap -->
  <section class="roadmap">
    <h2>What&rsquo;s coming</h2>
    <ul class="roadmap-list">
      <li><strong>Phase 2 &middot; Drill mode</strong> &mdash; <span style="color:#8fbf8f">&#10003; Now live.</span> Click &lsquo;Drill mode&rsquo; on any opening above. Your accuracy saves locally.</li>
      <li><strong>Phase 3 &middot; Custom repertoire</strong> &mdash; Paste your own PGN lines (export from any chess platform) to build a repertoire from <em>your</em> games. Drill the lines you actually play.</li>
      <li><strong>Phase 4 &middot; Coach integration</strong> &mdash; Share your repertoire with your Mind&rsquo;s Gambit coach for review. Your titled-coach can suggest improvements directly inside the page.</li>
    </ul>
    <p class="roadmap-note">Have a request or a favorite opening you want featured? Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a>.</p>
  </section>

  <footer class="page-footer">
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind&rsquo;s Gambit Chess School is a production of &copy; MYB Studio LLC.</p>
  </footer>
</section>

<style>
.eyebrow { display: block; font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.18em; margin-top: 1.5rem; }
.page { max-width: 1150px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
.back-link { display: inline-block; color: rgba(232,224,208,0.65); text-decoration: none; font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; margin: 1rem 0 0; transition: color 0.18s; }
.back-link:hover { color: #c9a84c; }
.page h1 { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 2.6rem; margin: 0.6rem 0 0.7rem; letter-spacing: 0.01em; }
.lead { color: rgba(232,224,208,0.82); font-family: 'EB Garamond', Georgia, serif; font-size: 1.12rem; line-height: 1.65; margin: 0 0 1.8rem; max-width: 780px; }

.status-banner { display: flex; gap: 1rem; align-items: center; background: linear-gradient(135deg, rgba(91,133,195,0.12), rgba(201,168,76,0.08)); border: 1px solid rgba(91,133,195,0.35); border-radius: 12px; padding: 1rem 1.2rem; margin: 0 0 2.5rem; }
.status-icon { font-size: 1.6rem; color: #93b8e8; flex-shrink: 0; }
.status-banner strong { display: block; color: #93b8e8; font-family: 'Playfair Display', Georgia, serif; font-size: 1.02rem; margin-bottom: 0.15rem; }
.status-banner span { color: rgba(232,224,208,0.78); font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; line-height: 1.5; display: block; }

.mg-recs { background: linear-gradient(135deg, rgba(201,168,76,0.10), rgba(91,133,195,0.05)); border: 1px solid rgba(201,168,76,0.35); border-radius: 14px; padding: 1.4rem 1.6rem 1.5rem; margin: 0 0 2.5rem; }
.mg-recs-chip { display: inline-block; font-family: 'Playfair Display', Georgia, serif; font-size: 0.75rem; padding: 4px 11px; border-radius: 99px; letter-spacing: 0.12em; text-transform: uppercase; margin-bottom: 0.7rem; background: rgba(201,168,76,0.18); color: #c9a84c; border: 1px solid rgba(201,168,76,0.4); }
.mg-recs-title { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.45rem; margin: 0 0 0.6rem; }
.mg-recs-body { color: rgba(232,224,208,0.82); font-family: 'EB Garamond', Georgia, serif; font-size: 1rem; line-height: 1.6; margin: 0; max-width: 880px; }
.mg-rec-inline { color: #c9a84c; font-weight: 600; white-space: nowrap; }

.mg-rec-badge { display: inline-block; font-family: 'Playfair Display', Georgia, serif; font-size: 0.66rem; padding: 3px 8px; border-radius: 99px; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 0.55rem; background: rgba(201,168,76,0.22); color: #c9a84c; border: 1px solid rgba(201,168,76,0.45); align-self: flex-start; font-weight: 600; }

.repertoire-section { margin: 0 0 3rem; }
.repertoire-header { margin-bottom: 1.5rem; }
.rep-color-chip { display: inline-block; font-family: 'Playfair Display', Georgia, serif; font-size: 0.78rem; padding: 4px 11px; border-radius: 99px; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.6rem; }
.white-chip { background: rgba(232,224,208,0.12); color: #e8e0d0; border: 1px solid rgba(232,224,208,0.32); }
.black-chip { background: rgba(15,17,28,0.6); color: rgba(201,168,76,0.85); border: 1px solid rgba(201,168,76,0.32); }
.repertoire-header h2 { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.7rem; margin: 0 0 0.45rem; }
.rep-intro { color: rgba(232,224,208,0.72); font-family: 'EB Garamond', Georgia, serif; font-size: 1rem; line-height: 1.55; margin: 0; max-width: 780px; font-style: italic; }

.opening-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 1.1rem; }
.opening-card { background: linear-gradient(135deg, rgba(201,168,76,0.07), rgba(30,34,52,0.6)); border: 1px solid rgba(201,168,76,0.25); border-radius: 12px; padding: 1.2rem 1.2rem 1rem; display: flex; flex-direction: column; transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s; }
.opening-card:hover { transform: translateY(-2px); border-color: rgba(201,168,76,0.5); box-shadow: 0 12px 26px rgba(0,0,0,0.4); }
.opening-card-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 0.6rem; margin-bottom: 0.5rem; }
.opening-name { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.18rem; margin: 0; line-height: 1.25; flex: 1; }
.opening-eco { background: rgba(201,168,76,0.15); color: rgba(201,168,76,0.85); font-family: 'Courier New', monospace; font-size: 0.72rem; padding: 3px 7px; border-radius: 4px; white-space: nowrap; flex-shrink: 0; }
.opening-moves { font-family: 'Courier New', monospace; color: #e8e0d0; background: rgba(15,17,28,0.55); padding: 7px 11px; border-radius: 6px; font-size: 0.92rem; margin: 0.3rem 0 0.7rem; border: 1px solid rgba(201,168,76,0.15); }
.opening-style { display: inline-block; color: rgba(232,224,208,0.55); font-family: 'EB Garamond', Georgia, serif; font-size: 0.82rem; font-style: italic; margin-bottom: 0.55rem; }
.opening-description { color: rgba(232,224,208,0.82); font-family: 'EB Garamond', Georgia, serif; font-size: 0.94rem; line-height: 1.55; flex: 1; margin: 0 0 0.95rem; }

/* Legacy disabled-CTA pill (kept for any future reuse). */
.opening-cta-disabled { display: inline-block; background: rgba(91,133,195,0.12); color: rgba(147,184,232,0.85); border: 1px solid rgba(91,133,195,0.3); padding: 7px 12px; border-radius: 8px; font-family: 'EB Garamond', Georgia, serif; font-size: 0.84rem; font-style: italic; text-align: center; align-self: flex-start; }

/* Phase 2 "Drill mode" pill  gold, prominent, slight lift on hover. (legacy, kept for any future reuse) */
