<script>document.querySelectorAll('.nav-links a').forEach(function(a){a.addEventListener('click',function(){var t=a.getAttribute('href');if(t&&t.indexOf('#')===0){var el=document.querySelector(t);if(el)setTimeout(function(){el.scrollIntoView({behavior:'instant',block:'start'});},300);}});});</script><style>section[data-reveal]{transition:transform 0.3s ease;overflow:hidden;}section[data-reveal]:hover{transform:scale(1.02);}#about,#book,#blog,#chess-school-home{padding-top:10px !important;scroll-margin-top:80px;}
  @keyframes comingSoonBlink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }
  .coming-soon-blink {
    animation: comingSoonBlink 1.8s ease-in-out infinite;
    color: #e74c3c;
    font-style: italic;
    margin-top: 12px;
    font-size: 0.9rem;
  }

    /* Chess Player CTA Button */
    .chess-cta-section {
      text-align: center;
      padding: 4rem 2rem 5rem;
      max-width: 800px;
      margin: 0 auto;
    }
    .chess-cta-inner {
      background: rgba(30, 33, 48, 0.8);
      border: 1px solid rgba(201, 168, 76, 0.2);
      border-radius: 20px;
      padding: 3rem 2rem;
    }
    .chess-cta-question {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.2rem;
      color: #c9a84c;
      margin-bottom: 0.5rem;
    }
    .chess-cta-subtitle {
      font-size: 1rem;
      color: #a0a0a0;
      margin-bottom: 2rem;
    }
    .chess-cta-btn {
      display: inline-block;
      padding: 1.1rem 3rem;
      background: #c9a84c;
      color: #0f111c;
      text-decoration: none;
      border-radius: 12px;
      font-weight: 800;
      font-size: 1.2rem;
      letter-spacing: 0.03em;
      animation: ctaPulse 2s ease-in-out infinite;
      transition: transform 0.2s;
      box-shadow: 0 0 20px rgba(201, 168, 76, 0.3);
    }
    .chess-cta-btn:hover {
      transform: scale(1.08);
      box-shadow: 0 0 35px rgba(201, 168, 76, 0.5);
    }
    @keyframes ctaPulse {
      0%, 100% { box-shadow: 0 0 20px rgba(201, 168, 76, 0.3); }
      50% { box-shadow: 0 0 40px rgba(201, 168, 76, 0.6), 0 0 60px rgba(201, 168, 76, 0.2); }
    }

    /* Chess School dropdown */
    .nav-links .has-dropdown { position: relative; }
    .nav-links .has-dropdown > .dropdown-toggle { display: inline-flex; align-items: center; gap: 0.35rem; }
    .nav-links .has-dropdown > .dropdown-toggle .caret { font-size: 0.7em; transition: transform 0.2s; }
    .nav-links .has-dropdown:hover > .dropdown-toggle .caret,
    .nav-links .has-dropdown:focus-within > .dropdown-toggle .caret { transform: rotate(180deg); color: #c9a84c; }
    .nav-links .dropdown-menu {
      display: none;
      position: absolute;
      top: calc(100% + 0.5rem);
      left: 50%;
      transform: translateX(-50%);
      background: rgba(15, 17, 28, 0.98);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(201, 168, 76, 0.3);
      border-radius: 8px;
      padding: 0.5rem 0;
      min-width: 260px;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.55);
      list-style: none;
      margin: 0;
      gap: 0;
      flex-direction: column;
      z-index: 200;
    }
    .nav-links .has-dropdown:hover > .dropdown-menu,
    .nav-links .has-dropdown:focus-within > .dropdown-menu { display: flex; }
    .nav-links .dropdown-menu li { padding: 0; }
    .nav-links .dropdown-menu a {
      display: block;
      padding: 0.7rem 1.1rem;
      text-transform: none;
      letter-spacing: 0.02em;
      font-size: 0.85rem;
      font-family: 'Playfair Display', Georgia, serif;
      color: #e8e0d0;
      white-space: nowrap;
      transition: background 0.2s, color 0.2s;
    }
    .nav-links .dropdown-menu a:hover,
    .nav-links .dropdown-menu a:focus { background: rgba(201, 168, 76, 0.12); color: #c9a84c; }

    @media (max-width: 880px) {
      .nav-links .dropdown-menu {
        position: static;
        transform: none;
        display: none;
        box-shadow: none;
        border: none;
        background: transparent;
        padding: 0;
        margin-top: 0.5rem;
      }
      .nav-links .has-dropdown.open > .dropdown-menu { display: flex; }
    }

  </style>

<!-- HERO -->
<section class="hero" id="home" data-reveal>
  <div class="hero-inner">
    <div class="hero-banner-tile">
      <video src="https://mindsgambit-cdn.b-cdn.net/videos/Landing_MG.Chess%20School.mp4?v=1" autoplay loop muted playsinline style="width:100%;height:100%;object-fit:cover;"></video>
    </div>
  </div>
</section>

<style is:global>
.hero { padding: 1.5rem 1.5rem 0 !important; }
.hero-inner { max-width: 1500px !important; width: 100% !important; }
.hero-banner-tile { width: 100% !important; max-width: 100% !important; padding: 0 !important; aspect-ratio: 16 / 9 !important; height: auto !important; border-radius: 20px !important; overflow: hidden !important; }
.hero-banner-tile video { width: 100% !important; height: 100% !important; max-width: 100% !important; max-height: 100% !important; min-height: 100% !important; object-fit: cover !important; display: block !important; }
</style>


<!-- FOUNDING COACH WELCOME — WGM Maryana Huda -->
<section id="founding-coach" class="founding-coach-section" data-reveal>
  <div class="fc-inner">
    <div class="fc-card">
      <span class="fc-pill">Featured Announcement</span>
      <div class="fc-grid">
        <a class="fc-photo-wrap" href="/chess-school/grandmasters/maryana-huda">
          <img class="fc-photo" src="https://image.lichess1.org/display?fmt=webp&h=350&op=thumbnail&path=morshynska1:coach:morshynska1:47WCJA8z.jpg&w=350&sig=7153456a989676933f39b96c09cc68502ebf226c" alt="WGM Maryana Huda" loading="eager" referrerpolicy="no-referrer" />
          <div class="fc-photo-ring"></div>
        </a>
        <div class="fc-content">
          <p class="fc-eyebrow">Mind&rsquo;s Gambit Welcomes Our Founding Coach</p>
          <h2 class="fc-name">WGM Maryana Huda</h2>
          <p class="fc-credentials">Woman Grandmaster &middot; FIDE Trainer &middot; Sport Scientist &middot; Lviv, Ukraine</p>
          <p class="fc-bio">Maryana joins Mind&rsquo;s Gambit Chess School as our Founding Coach. A FIDE Trainer and Woman Grandmaster based in Lviv, she is also a scholar at the Lviv State University of Physical Culture, where she researches the psychophysiology of chess &mdash; how the format of the game (classical, rapid, blitz) shapes the player&rsquo;s mind, heart, and decisions under pressure. Her work, <em>Time Control as a Stress Factor</em>, was presented at the 2025 IX International Scientific-Practical Conference &ldquo;Physical Activity and Quality of Human Life.&rdquo; She brings to our students deep technical instruction and a rare understanding of how the game tests the whole person.</p>
          <blockquote class="fc-quote">
            <p>&ldquo;The shorter the format of the game, the higher the level of emotional and physiological tension. Six of eight chess players we studied in blitz showed heart rates above 160 beats per minute &mdash; the load of an athlete in intense exertion, all while seated at the board.&rdquo;</p>
            <footer class="fc-quote-attr">A Word From Our Coach &mdash; WGM Maryana Huda, <em>Time Control as a Stress Factor</em> (2025)</footer>
          </blockquote>
          <a class="fc-cta cta-btn" href="/chess-school/grandmasters/maryana-huda">
            <span class="fc-cta-text">Meet Your Coach</span>
            <span class="fc-cta-arrow">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style is:global>
.founding-coach-section { padding: 3rem 1.5rem 1.5rem; }
.fc-inner { max-width: 1280px; margin: 0 auto; }
.fc-card { position: relative; background: linear-gradient(135deg, rgba(201,168,76,0.13) 0%, rgba(30,34,52,0.78) 60%, rgba(15,17,28,0.92) 100%); border: 1px solid rgba(201,168,76,0.55); border-radius: 18px; padding: 2.2rem 2.4rem 2rem; box-shadow: 0 18px 50px rgba(201,168,76,0.20), 0 10px 28px rgba(0,0,0,0.45); overflow: hidden; }
.fc-card::before { content: ""; position: absolute; inset: 0; background: radial-gradient(circle at 90% 0%, rgba(201,168,76,0.18) 0%, transparent 55%); pointer-events: none; }
.fc-pill { display: inline-block; background: #c9a84c; color: #0f111c; padding: 0.32rem 0.95rem; border-radius: 999px; font-size: 0.7rem; font-weight: 800; letter-spacing: 0.14em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; margin-bottom: 1.3rem; position: relative; z-index: 1; }
.fc-grid { display: grid; grid-template-columns: 280px 1fr; gap: 2.4rem; align-items: start; position: relative; z-index: 1; }
.fc-photo-wrap { position: relative; display: block; width: 280px; height: 280px; border-radius: 50%; overflow: hidden; flex-shrink: 0; box-shadow: 0 14px 36px rgba(0,0,0,0.5), 0 0 0 4px rgba(201,168,76,0.18); transition: transform 0.3s ease, box-shadow 0.3s ease; text-decoration: none; }
.fc-photo-wrap:hover { transform: translateY(-3px); box-shadow: 0 22px 50px rgba(0,0,0,0.6), 0 0 0 4px rgba(201,168,76,0.35); }
.fc-photo { width: 100%; height: 100%; object-fit: cover; display: block; }
.fc-photo-ring { position: absolute; inset: -6px; border-radius: 50%; border: 1px solid rgba(201,168,76,0.4); pointer-events: none; }
.fc-content { color: #e8e0d0; }
.fc-eyebrow { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 0.95rem; letter-spacing: 0.18em; text-transform: uppercase; margin: 0 0 0.45rem; font-weight: 700; }
.fc-name { font-family: 'Playfair Display', Georgia, serif; font-size: clamp(2rem, 3.6vw, 2.85rem); line-height: 1.1; color: #f5ecd1; margin: 0 0 0.55rem; font-weight: 800; }
.fc-credentials { color: rgba(232,224,208,0.78); font-size: 0.95rem; font-style: italic; margin: 0 0 1.3rem; font-family: 'EB Garamond', Georgia, serif; }
.fc-bio { color: rgba(232,224,208,0.93); font-size: 1.04rem; line-height: 1.65; font-family: 'EB Garamond', Georgia, serif; margin: 0 0 1.5rem; }
.fc-bio em { color: #c9a84c; font-style: italic; }
.fc-quote { margin: 0 0 1.6rem; padding: 1rem 1.3rem; background: rgba(15,17,28,0.55); border-left: 4px solid #c9a84c; border-radius: 4px; }
.fc-quote p { margin: 0 0 0.7rem; color: #f5ecd1; font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 1.08rem; line-height: 1.55; }
.fc-quote-attr { font-family: 'Playfair Display', Georgia, serif; font-size: 0.78rem; letter-spacing: 0.05em; color: rgba(201,168,76,0.85); font-style: normal; }
.fc-quote-attr em { font-style: italic; color: rgba(232,224,208,0.7); }
.fc-cta { display: inline-flex; align-items: center; gap: 0.55rem; background: #c9a84c; color: #0f111c !important; padding: 0.85rem 1.6rem; border-radius: 8px; text-decoration: none; font-weight: 800; font-family: 'Playfair Display', Georgia, serif; letter-spacing: 0.05em; font-size: 0.95rem; transition: background 0.2s, transform 0.2s, box-shadow 0.2s; box-shadow: 0 8px 22px rgba(201,168,76,0.35); }
.fc-cta:hover { background: #d4b556; transform: translateY(-2px); box-shadow: 0 14px 30px rgba(201,168,76,0.55); }
.fc-cta-arrow { font-size: 1.1rem; }
@media (max-width: 820px) {
  .founding-coach-section { padding: 2rem 1rem 0.5rem; }
  .fc-card { padding: 1.6rem 1.3rem 1.6rem; border-radius: 14px; }
  .fc-grid { grid-template-columns: 1fr; gap: 1.5rem; text-align: center; }
  .fc-photo-wrap { width: 200px; height: 200px; margin: 0 auto; }
  .fc-name { font-size: 1.85rem; }
  .fc-credentials { font-size: 0.88rem; }
  .fc-bio { font-size: 1rem; text-align: left; }
  .fc-quote { text-align: left; }
  .fc-cta { width: 100%; justify-content: center; }
}
</style>


