---
// Success page after Stripe checkout
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
      <title>Welcome — The Examined Republic TV</title>
        <style>
            @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

                * { margin: 0; padding: 0; box-sizing: border-box; }

                    body {
                          font-family: 'Inter', sans-serif;
                                background: #08080E;
                                      color: #fff;
                                            min-height: 100vh;
                                                  display: flex;
                                                        align-items: center;
                                                              justify-content: center;
                                                                  }

                                                                      .hero-bg {
                                                                            position: fixed;
                                                                                  top: 0; left: 0; right: 0; bottom: 0;
                                                                                        background: radial-gradient(ellipse at 50% 40%, rgba(200, 164, 94, 0.12) 0%, transparent 60%);
                                                                                              z-index: 0;
                                                                                                  }

                                                                                                      .container {
                                                                                                            position: relative;
                                                                                                                  z-index: 1;
                                                                                                                        text-align: center;
                                                                                                                              max-width: 600px;
                                                                                                                                    padding: 40px 24px;
                                                                                                                                        }
                                                                                                                                        
                                                                                                                                            .checkmark {
                                                                                                                                                  width: 80px;
                                                                                                                                                        height: 80px;
                                                                                                                                                              border-radius: 50%;
                                                                                                                                                                    background: rgba(200, 164, 94, 0.15);
                                                                                                                                                                          border: 2px solid #C8A45E;
                                                                                                                                                                                display: flex;
                                                                                                                                                                                      align-items: center;
                                                                                                                                                                                            justify-content: center;
                                                                                                                                                                                                  margin: 0 auto 30px;
                                                                                                                                                                                                        font-size: 2.5rem;
                                                                                                                                                                                                              color: #C8A45E;
                                                                                                                                                                                                                  }
                                                                                                                                                                                                                  
                                                                                                                                                                                                                      .brand {
                                                                                                                                                                                                                            font-size: 2rem;
                                                                                                                                                                                                                                  font-weight: 700;
                                                                                                                                                                                                                                        letter-spacing: 0.15em;
                                                                                                                                                                                                                                              margin-bottom: 30px;
                                                                                                                                                                                                                                                  }
                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                      .brand span:first-child { color: #fff; }
                                                                                                                                                                                                                                                          .brand span:last-child { color: #C8A45E; }
                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                              h1 {
                                                                                                                                                                                                                                                                    font-size: 1.8rem;
                                                                                                                                                                                                                                                                          font-weight: 600;
                                                                                                                                                                                                                                                                                margin-bottom: 16px;
                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                        p {
                                                                                                                                                                                                                                                                                              color: #999;
                                                                                                                                                                                                                                                                                                    font-size: 1.05rem;
                                                                                                                                                                                                                                                                                                          line-height: 1.7;
                                                                                                                                                                                                                                                                                                                margin-bottom: 20px;
                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                        .roku-info {
                                                                                                                                                                                                                                                                                                                              background: rgba(200, 164, 94, 0.08);
                                                                                                                                                                                                                                                                                                                                    border: 1px solid rgba(200, 164, 94, 0.2);
                                                                                                                                                                                                                                                                                                                                          border-radius: 16px;
                                                                                                                                                                                                                                                                                                                                                padding: 25px;
                                                                                                                                                                                                                                                                                                                                                      margin: 30px 0;
                                                                                                                                                                                                                                                                                                                                                            text-align: left;
                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                    .roku-info h3 {
                                                                                                                                                                                                                                                                                                                                                                          color: #C8A45E;
                                                                                                                                                                                                                                                                                                                                                                                font-size: 1rem;
                                                                                                                                                                                                                                                                                                                                                                                      margin-bottom: 12px;
                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                              .roku-info ol {
                                                                                                                                                                                                                                                                                                                                                                                                    color: #bbb;
                                                                                                                                                                                                                                                                                                                                                                                                          font-size: 0.9rem;
                                                                                                                                                                                                                                                                                                                                                                                                                line-height: 1.8;
                                                                                                                                                                                                                                                                                                                                                                                                                      padding-left: 20px;
                                                                                                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                              .btn {
                                                                                                                                                                                                                                                                                                                                                                                                                                    display: inline-block;
                                                                                                                                                                                                                                                                                                                                                                                                                                          padding: 16px 40px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                background: #C8A45E;
                                                                                                                                                                                                                                                                                                                                                                                                                                                      color: #08080E;
                                                                                                                                                                                                                                                                                                                                                                                                                                                            border: none;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                  border-radius: 12px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                        font-size: 1.1rem;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                              font-weight: 600;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    font-family: inherit;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          cursor: pointer;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                text-decoration: none;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      transition: all 0.2s;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            margin: 10px;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    .btn:hover {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          background: #D4B46A;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                transform: translateY(-1px);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        .btn-outline {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              background: transparent;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    border: 1px solid rgba(200, 164, 94, 0.4);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          color: #C8A45E;
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  .btn-outline:hover {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        background: rgba(200, 164, 94, 0.1);
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </style>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              </head>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <body>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <div class="hero-bg"></div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <div class="container">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div class="checkmark">&#10003;</div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <div class="brand"><span>EX</span><span>R</span></div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              <h1>Welcome to The Examined Republic</h1>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        Your subscription is active. You now have unlimited access to all
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                              premieres, soundtracks, and podcasts.
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  </p>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      <div class="roku-info">
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            <h3>Watching on Roku?</h3>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <ol>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <li>Open "The Examined Republic TV" on your Roku</li>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <li>Select any content to play</li>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                          <li>Enter the email you just subscribed with</li>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                  <li>Enjoy unlimited streaming on your TV</li>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        </ol>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                <a href="/watch" class="btn">Start Watching</a>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    <a href="/" class="btn btn-outline">Home</a>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </div>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </body>
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                      </html>
