.games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.4rem; margin-bottom: 2rem; }
.game-card { background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(30,34,52,0.65)); border: 1px solid rgba(201,168,76,0.28); border-radius: 14px; padding: 1.6rem 1.4rem; display: flex; flex-direction: column; transition: transform 0.18s, border-color 0.18s, box-shadow 0.18s; }
.game-card:hover { transform: translateY(-3px); border-color: rgba(201,168,76,0.55); box-shadow: 0 14px 32px rgba(0,0,0,0.45); }
.game-card-header { margin-bottom: 0.9rem; }
.game-era { display: inline-block; background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.35); color: #c9a84c; font-size: 0.72rem; padding: 3px 9px; border-radius: 99px; letter-spacing: 0.08em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; margin-bottom: 0.55rem; }
.game-title { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.5rem; margin: 0 0 0.45rem; line-height: 1.2; }
.game-players { color: #e8e0d0; font-family: 'EB Garamond', Georgia, serif; font-size: 1.05rem; margin: 0 0 0.2rem; line-height: 1.4; }
.game-players strong { color: #e8e0d0; font-weight: 600; }
.game-meta { color: rgba(232,224,208,0.6); font-family: 'EB Garamond', Georgia, serif; font-size: 0.88rem; font-style: italic; margin: 0; }
.game-significance { color: rgba(232,224,208,0.78); font-family: 'EB Garamond', Georgia, serif; font-size: 0.96rem; line-height: 1.6; flex: 1; margin: 0 0 1.2rem; }
.game-open-btn { background: linear-gradient(135deg, #c9a84c, #d4b556); color: #0f111c; border: 0; padding: 0.75rem 1.1rem; border-radius: 10px; font-family: 'EB Garamond', Georgia, serif; font-weight: 700; font-size: 0.98rem; cursor: pointer; transition: all 0.18s; box-shadow: 0 6px 16px rgba(201,168,76,0.28); align-self: flex-start; }
.game-open-btn:hover { transform: translateY(-1px); box-shadow: 0 9px 22px rgba(201,168,76,0.45); }
.games-more { color: rgba(232,224,208,0.6); font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; font-style: italic; text-align: center; margin: 1.6rem 0 2.5rem; padding: 1.1rem 1rem; background: rgba(15,17,28,0.45); border: 1px dashed rgba(201,168,76,0.22); border-radius: 10px; }
.games-more a { color: #c9a84c; }

/* VIEWER */
.game-viewer { background: linear-gradient(180deg, rgba(15,17,28,0.92), rgba(20,22,32,0.82)); border: 1px solid rgba(201,168,76,0.38); border-radius: 16px; padding: 1.8rem 1.6rem; margin: 1.5rem 0 2rem; position: relative; box-shadow: 0 22px 60px rgba(0,0,0,0.5); }
.viewer-close { position: absolute; top: 14px; right: 16px; background: rgba(30,34,52,0.6); color: rgba(232,224,208,0.7); border: 1px solid rgba(201,168,76,0.22); padding: 6px 12px; border-radius: 8px; font-family: 'EB Garamond', Georgia, serif; font-size: 0.92rem; cursor: pointer; }
.viewer-close:hover { background: rgba(201,168,76,0.12); color: #c9a84c; }
.viewer-header { margin-bottom: 1.4rem; padding-right: 100px; }
.viewer-era { display: inline-block; background: rgba(201,168,76,0.15); border: 1px solid rgba(201,168,76,0.35); color: #c9a84c; font-size: 0.72rem; padding: 3px 9px; border-radius: 99px; letter-spacing: 0.08em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; margin-bottom: 0.55rem; }
.viewer-title { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.8rem; margin: 0 0 0.4rem; }
