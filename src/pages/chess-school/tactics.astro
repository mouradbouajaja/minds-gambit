---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Tactics Trainer — Mind's Gambit Chess School" description="Pick a theme — pins, forks, mate-in-2, endgames — and grind rated puzzles. 5.94 million puzzles indexed by theme.">

<link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#book">The Book</a></li>
      <li><a href="/watch">Documentary</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/chess-school">Chess School</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>
    </ul>
  </div>
</nav>

<section class="page">
  <a href="/chess-school" class="back-link">&larr; Back to Chess School</a>
  <span class="eyebrow">Mind's Gambit Chess School</span>
  <h1>Tactics Trainer</h1>
  <p class="lead">Pick a theme. Grind puzzles in that pattern until it's second nature. <strong>5.94 million puzzles</strong>, sorted into 73 tactical themes.</p>

  <!-- Theme picker (default state) -->
  <div id="theme-picker" class="theme-picker">
    <p class="picker-prompt">Choose a theme to start training:</p>
    <div class="theme-grid" id="theme-grid">
      <div class="theme-loading">Loading themes…</div>
    </div>
  </div>

  <!-- Training state (hidden until theme picked) -->
  <div id="trainer" class="trainer hidden">
    <div class="trainer-header">
      <div>
        <span class="trainer-eyebrow">Training theme</span>
        <h2 class="trainer-theme" id="trainer-theme">—</h2>
      </div>
      <button class="ctrl-btn ctrl-btn-secondary" id="btn-change-theme" type="button">&larr; Change theme</button>
    </div>

    <div class="stats-bar">
      <div class="stat"><div class="stat-label">Solved</div><div class="stat-value" id="solved-count">0</div></div>
      <div class="stat"><div class="stat-label">Attempted</div><div class="stat-value" id="attempted-count">0</div></div>
      <div class="stat"><div class="stat-label">Accuracy</div><div class="stat-value" id="accuracy-pct">—</div></div>
      <div class="stat"><div class="stat-label">Puzzle Rating</div><div class="stat-value" id="puzzle-rating">—</div></div>
    </div>

    <div class="puzzle-area">
      <div class="board-wrap">
        <div id="puzzle-board"></div>
        <div class="board-status" id="board-status">Loading puzzle…</div>
      </div>

      <aside class="puzzle-info">
        <div class="turn-indicator" id="turn-indicator">—</div>
        <div class="info-block"><div class="info-label">Themes</div><div class="info-content theme-tags" id="puzzle-themes">—</div></div>
        <div class="info-block"><div class="info-label">Instructions</div><div class="info-content">Find the best move. The opponent will respond. Continue until the puzzle is solved — then the next one in this theme loads automatically.</div></div>
        <div class="puzzle-controls">
          <button class="ctrl-btn" id="btn-hint" type="button">Hint</button>
          <button class="ctrl-btn" id="btn-solution" type="button">Show Solution</button>
          <button class="ctrl-btn" id="btn-skip" type="button">Next Puzzle &rarr;</button>
        </div>
      </aside>
    </div>
  </div>

  <p class="attribution">Puzzles streamed from the <a href="https://database.lichess.org/#puzzles" target="_blank" rel="noopener">Lichess Open Puzzle Database</a> (CC0) — 5.94 million tactics hosted on Mind's Gambit CDN. Board rendering powered by chessboard.js and chess.js, both open-source.</p>

  <footer class="page-footer">
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind's Gambit Chess School is a production of &copy; MYB Studio LLC.</p>
  </footer>
</section>

<script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/chess.js@0.10.3/chess.min.js"></script>
<script is:inline src="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>

<script is:inline>
(function() {
  'use strict';
  var CDN = 'https://mindsgambit-cdn.b-cdn.net/puzzles';

  var game, board, solution = [], solutionIdx = 0, userColor = 'w', solved = false, isAnimating = false;
  var currentTheme = null;
  var themeIds = [];
  var shardCache = {};
  var solvedCount = 0, attemptedCount = 0, currentAttemptCounted = false;

  // Themes we feature first — chess fundamentals
  var FEATURED = ['mateIn1', 'mateIn2', 'mateIn3', 'fork', 'pin', 'skewer', 'discoveredAttack', 'sacrifice', 'endgame', 'middlegame', 'opening', 'mate', 'crushing', 'hangingPiece', 'backRankMate', 'pawnEndgame', 'rookEndgame', 'queenEndgame', 'attackingF2F7', 'kingsideAttack', 'queensideAttack', 'promotion', 'enPassant', 'castling', 'zugzwang', 'trappedPiece', 'deflection', 'attraction', 'clearance', 'interference', 'doubleCheck', 'smotheredMate', 'discoveredCheck', 'quietMove', 'defensiveMove', 'intermezzo', 'oneMove', 'short', 'long', 'veryLong'];

  // DOM refs
  var pickerEl = document.getElementById('theme-picker');
  var trainerEl = document.getElementById('trainer');
  var themeGridEl = document.getElementById('theme-grid');
  var themeLabelEl = document.getElementById('trainer-theme');
  var changeThemeBtn = document.getElementById('btn-change-theme');

  var statusEl = document.getElementById('board-status');
  var turnEl = document.getElementById('turn-indicator');
  var themesEl = document.getElementById('puzzle-themes');
  var ratingEl = document.getElementById('puzzle-rating');
  var solvedCountEl = document.getElementById('solved-count');
  var attemptedCountEl = document.getElementById('attempted-count');
  var accuracyEl = document.getElementById('accuracy-pct');
  var hintBtn = document.getElementById('btn-hint');
  var solBtn = document.getElementById('btn-solution');
  var skipBtn = document.getElementById('btn-skip');

  function updateStats() {
    solvedCountEl.textContent = solvedCount;
    attemptedCountEl.textContent = attemptedCount;
    accuracyEl.textContent = attemptedCount > 0 ? Math.round((solvedCount / attemptedCount) * 100) + '%' : '—';
  }

  function humanizeTheme(t) {
    return t.replace(/([A-Z])/g, ' $1').replace(/^./, function(c) { return c.toUpperCase(); }).trim();
  }
  function formatCount(n) { return n.toLocaleString(); }

  function setStatus(msg, kind) {
    statusEl.textContent = msg;
    statusEl.className = 'board-status' + (kind ? ' status-' + kind : '');
  }
  function setTurn() {
    if (!game || solved) return;
    var t = game.turn() === 'w' ? 'White' : 'Black';
    var who = (game.turn() === userColor) ? 'Your move' : 'Opponent thinking…';
    turnEl.innerHTML = '<span class="turn-color">' + t + ' to move</span><br/><span class="turn-who">' + who + '</span>';
  }
  function uciToMove(uci) {
    return { from: uci.substring(0, 2), to: uci.substring(2, 4), promotion: uci.length >= 5 ? uci.substring(4, 5) : undefined };
  }
  function moveToUci(move) { return move.from + move.to + (move.promotion || ''); }

  function loadThemes() {
    fetch(CDN + '/metadata.json').then(function(r) {
      if (!r.ok) throw new Error('Metadata ' + r.status);
      return r.json();
    }).then(function(meta) {
      var themes = meta.themes || {};
      var entries = Object.keys(themes).map(function(k) { return { key: k, count: themes[k] }; });
      // Sort by featured order first, then by count desc
      entries.sort(function(a, b) {
        var ai = FEATURED.indexOf(a.key), bi = FEATURED.indexOf(b.key);
        if (ai !== -1 && bi !== -1) return ai - bi;
        if (ai !== -1) return -1;
        if (bi !== -1) return 1;
        return b.count - a.count;
      });
      renderThemeGrid(entries);
    }).catch(function(err) {
      themeGridEl.innerHTML = '<div class="theme-loading">Could not load themes: ' + err.message + '</div>';
    });
  }

  function renderThemeGrid(entries) {
    themeGridEl.innerHTML = entries.map(function(e) {
      return '<button class="theme-card" data-theme="' + e.key + '">' +
        '<div class="theme-card-name">' + humanizeTheme(e.key) + '</div>' +
        '<div class="theme-card-count">' + formatCount(e.count) + ' puzzles</div>' +
        '</button>';
    }).join('');
    Array.from(themeGridEl.querySelectorAll('.theme-card')).forEach(function(btn) {
      btn.addEventListener('click', function() { startTheme(btn.getAttribute('data-theme')); });
    });
  }

  function startTheme(themeKey) {
    currentTheme = themeKey;
    themeLabelEl.textContent = humanizeTheme(themeKey);
    pickerEl.classList.add('hidden');
    trainerEl.classList.remove('hidden');
    solvedCount = 0; attemptedCount = 0;
    updateStats();
    setStatus('Loading theme puzzles…', '');

    fetch(CDN + '/themes/' + themeKey + '.json').then(function(r) {
      if (!r.ok) throw new Error('Theme ' + r.status);
      return r.json();
    }).then(function(data) {
      themeIds = data.ids || [];
      if (!themeIds.length) throw new Error('No puzzles in theme');
      loadNextThemePuzzle();
    }).catch(function(err) {
      setStatus('Could not load theme. Try another. (' + err.message + ')', 'bad');
    });
  }

  function getShard(key) {
    if (shardCache[key]) return Promise.resolve(shardCache[key]);
    return fetch(CDN + '/shards/' + key + '.json').then(function(r) {
      if (!r.ok) throw new Error('Shard ' + key + ' ' + r.status);
      return r.json();
    }).then(function(puzzles) {
      // Index by id for O(1) lookup
      var idx = {};
      for (var i = 0; i < puzzles.length; i++) idx[puzzles[i].id] = puzzles[i];
      shardCache[key] = idx;
      return idx;
    });
  }

  function loadNextThemePuzzle() {
    solved = false; solutionIdx = 0; currentAttemptCounted = false; isAnimating = false;
    setStatus('Loading puzzle…', '');
    themesEl.innerHTML = '—';
    ratingEl.textContent = '—';
    turnEl.innerHTML = '—';

    var id = themeIds[Math.floor(Math.random() * themeIds.length)];
    var shardKey = (id[0] || '_').toLowerCase();
    getShard(shardKey).then(function(idx) {
      var puzzle = idx[id];
      if (!puzzle) {
        // Should never happen, but just in case — try another
        loadNextThemePuzzle();
        return;
      }
      showPuzzle(puzzle);
    }).catch(function(err) {
      setStatus('Could not load puzzle. Click Next Puzzle to retry. (' + err.message + ')', 'bad');
    });
  }

  function onDragStart(source, piece) {
    if (solved || isAnimating) return false;
    if (!game || game.game_over()) return false;
    if (game.turn() !== userColor) return false;
    if ((userColor === 'w' && piece.charAt(0) !== 'w') || (userColor === 'b' && piece.charAt(0) !== 'b')) return false;
    return true;
  }

  function onDrop(source, target) {
    var attempt = game.move({ from: source, to: target, promotion: 'q' });
    if (attempt === null) return 'snapback';
    var played = moveToUci(attempt);
    var expected = solution[solutionIdx];
    if (played === expected) {
      solutionIdx += 1;
      if (solutionIdx >= solution.length) { finishSolved(); return; }
      setStatus('Correct. Watch the response…', 'good');
      setTurn();
      isAnimating = true;
      setTimeout(playOpponent, 500);
    } else {
      if (!currentAttemptCounted) {
        attemptedCount += 1;
        currentAttemptCounted = true;
        updateStats();
      }
      setStatus('Not the best move. Try again.', 'bad');
      setTimeout(function() { game.undo(); board.position(game.fen()); setTurn(); }, 700);
    }
  }

  function onSnapEnd() { board.position(game.fen()); }

  function playOpponent() {
    if (solutionIdx >= solution.length) { finishSolved(); isAnimating = false; return; }
    game.move(uciToMove(solution[solutionIdx]));
    board.position(game.fen());
    solutionIdx += 1;
    isAnimating = false;
    if (solutionIdx >= solution.length) finishSolved();
    else { setStatus('Your move. Find the best continuation.', ''); setTurn(); }
  }

  function finishSolved() {
    solved = true;
    if (!currentAttemptCounted) {
      attemptedCount += 1;
      currentAttemptCounted = true;
    }
    solvedCount += 1;
    updateStats();
    setStatus('Solved. Loading next puzzle…', 'good');
    turnEl.innerHTML = '<span class="turn-color">Puzzle complete</span>';
    setTimeout(loadNextThemePuzzle, 1300);
  }

  hintBtn.addEventListener('click', function() {
    if (solved || isAnimating) return;
    if (solutionIdx >= solution.length) return;
    var from = solution[solutionIdx].substring(0, 2);
    var sq = document.querySelector('.square-' + from);
    if (sq) { sq.classList.add('hint-square'); setTimeout(function() { sq.classList.remove('hint-square'); }, 1400); }
    setStatus('Hint: the piece on ' + from + ' moves.', '');
  });

  solBtn.addEventListener('click', function() {
    if (solved) return;
    if (!currentAttemptCounted) {
      attemptedCount += 1;
      currentAttemptCounted = true;
      updateStats();
    }
    setStatus('Playing through the full solution…', '');
    isAnimating = true;
    function step() {
      if (solutionIdx >= solution.length) {
        solved = true;
        setStatus('Loading next puzzle…', '');
        setTimeout(loadNextThemePuzzle, 1200);
        isAnimating = false;
        return;
      }
      game.move(uciToMove(solution[solutionIdx]));
      board.position(game.fen());
      solutionIdx += 1;
      setTimeout(step, 700);
    }
    step();
  });

  skipBtn.addEventListener('click', function() {
    if (isAnimating) return;
    if (!solved && !currentAttemptCounted) {
      attemptedCount += 1;
      updateStats();
    }
    loadNextThemePuzzle();
  });

  changeThemeBtn.addEventListener('click', function() {
    trainerEl.classList.add('hidden');
    pickerEl.classList.remove('hidden');
    currentTheme = null;
    themeIds = [];
  });

  function showPuzzle(puzzle) {
    solution = (puzzle.moves || '').split(' ').filter(Boolean);
    ratingEl.textContent = puzzle.rating || '—';
    var themes = (puzzle.themes || []).slice(0, 5);
    themesEl.innerHTML = themes.map(function(t) {
      return '<span class="theme-tag">' + humanizeTheme(t).toLowerCase() + '</span>';
    }).join('');

    game = new Chess();
    game.load(puzzle.fen);
    userColor = game.turn() === 'w' ? 'b' : 'w';

    if (board) { try { board.destroy && board.destroy(); } catch (e) {} }
    board = Chessboard('puzzle-board', {
      position: game.fen(),
      orientation: userColor === 'w' ? 'white' : 'black',
      draggable: true,
      onDragStart: onDragStart,
      onDrop: onDrop,
      onSnapEnd: onSnapEnd,
      pieceTheme: 'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/{piece}.png',
      moveSpeed: 'slow',
      snapbackSpeed: 250
    });

    setStatus('Opponent moves first…', '');
    setTimeout(function() {
      if (solution.length > 0) {
        game.move(uciToMove(solution[0]));
        board.position(game.fen());
        solutionIdx = 1;
        setStatus('Your move. Find the best continuation.', '');
        setTurn();
      }
    }, 900);

    window.addEventListener('resize', function() { if (board) board.resize(); });
  }

  function whenReady(cb) {
    if (window.Chess && window.Chessboard && window.jQuery) cb();
    else setTimeout(function() { whenReady(cb); }, 50);
  }
  whenReady(loadThemes);
})();
</script>

</BaseLayout>

<style is:global>
nav { background: rgba(15,17,28,0.95); border-bottom: 1px solid rgba(201,168,76,0.2); position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0.75rem 2rem; display: flex; align-items: center; justify-content: space-between; }
.nav-links { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; align-items: center; }
.nav-links a { color: #e8e0d0; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; transition: color 0.3s; }
.nav-links a:hover { color: #c9a84c; }
.nav-btn { background: #c9a84c !important; color: #0f111c !important; padding: 0.5rem 1.25rem; border-radius: 4px; font-weight: 600; }

.page { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }
.back-link { color: #c9a84c; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.05em; display: inline-block; margin-bottom: 2rem; transition: opacity 0.25s; }
.back-link:hover { opacity: 0.7; transform: translateX(-3px); }
.eyebrow { color: #c9a84c; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.25em; display: block; margin-bottom: 1rem; }
.page h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 3rem; color: #e8e0d0; line-height: 1.1; margin: 0 0 1rem; }
.lead { color: rgba(232,224,208,0.8); font-size: 1.2rem; font-family: 'EB Garamond', Georgia, serif; line-height: 1.55; max-width: 720px; margin: 0 0 2rem; }
.lead strong { color: #c9a84c; }

.hidden { display: none !important; }

/* Theme picker */
.theme-picker { margin: 1.5rem 0 3rem; }
.picker-prompt { color: rgba(232,224,208,0.7); font-size: 1rem; font-family: 'EB Garamond', Georgia, serif; font-style: italic; margin: 0 0 1.25rem; }
.theme-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(190px, 1fr)); gap: 0.75rem; }
.theme-loading { grid-column: 1 / -1; color: rgba(232,224,208,0.6); padding: 2rem; text-align: center; font-style: italic; }
.theme-card { background: linear-gradient(135deg, rgba(30,34,52,0.6), rgba(20,22,32,0.85)); border: 1px solid rgba(201,168,76,0.22); border-radius: 10px; padding: 1rem 1.1rem; cursor: pointer; transition: all 0.2s ease; text-align: left; color: inherit; font: inherit; }
.theme-card:hover { background: linear-gradient(135deg, rgba(201,168,76,0.16), rgba(30,34,52,0.8)); border-color: rgba(201,168,76,0.55); transform: translateY(-2px); box-shadow: 0 10px 24px rgba(0,0,0,0.4); }
.theme-card-name { color: #e8e0d0; font-family: 'Playfair Display', Georgia, serif; font-size: 1.02rem; font-weight: 600; margin-bottom: 0.25rem; }
.theme-card-count { color: rgba(201,168,76,0.85); font-size: 0.78rem; letter-spacing: 0.04em; font-family: 'EB Garamond', Georgia, serif; }

/* Trainer state */
.trainer { margin: 1rem 0 2rem; }
.trainer-header { display: flex; justify-content: space-between; align-items: center; gap: 1.5rem; margin-bottom: 1.5rem; padding-bottom: 1rem; border-bottom: 1px solid rgba(201,168,76,0.15); }
.trainer-eyebrow { color: rgba(201,168,76,0.7); font-family: 'Playfair Display', Georgia, serif; font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase; display: block; margin-bottom: 0.35rem; }
.trainer-theme { font-family: 'Playfair Display', Georgia, serif; font-size: 1.8rem; color: #e8e0d0; margin: 0; }

.stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem; }
.stat { background: rgba(30,34,52,0.55); border: 1px solid rgba(201,168,76,0.2); border-radius: 12px; padding: 1.1rem 1rem; text-align: center; transition: border-color 0.25s, transform 0.25s; }
.stat:hover { border-color: rgba(201,168,76,0.45); transform: translateY(-2px); }
.stat-label { color: rgba(232,224,208,0.55); font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.18em; margin-bottom: 0.45rem; font-family: 'Playfair Display', Georgia, serif; }
.stat-value { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; font-weight: 700; line-height: 1; }

.puzzle-area { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 2rem; margin-bottom: 3rem; align-items: start; }
.board-wrap { position: relative; }
#puzzle-board { width: 100%; max-width: 640px; margin: 0 auto; box-shadow: 0 18px 50px rgba(0,0,0,0.5); border-radius: 8px; overflow: hidden; }
.board-status { margin-top: 1.25rem; padding: 0.85rem 1.2rem; background: rgba(30,34,52,0.65); border: 1px solid rgba(201,168,76,0.25); border-radius: 10px; color: #e0e0e0; font-family: 'EB Garamond', Georgia, serif; font-size: 1.05rem; text-align: center; transition: background 0.25s, border-color 0.25s, color 0.25s; }
.status-good { background: rgba(74,222,128,0.12); border-color: rgba(74,222,128,0.5); color: #a7f3d0; }
.status-bad { background: rgba(248,113,113,0.12); border-color: rgba(248,113,113,0.5); color: #fecaca; }

@keyframes hintPulse { 0%, 100% { box-shadow: inset 0 0 0 0 rgba(201,168,76,0); } 50% { box-shadow: inset 0 0 0 6px rgba(201,168,76,0.85); } }
.hint-square { animation: hintPulse 1.4s ease-out; }

.puzzle-info { background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(30,34,52,0.6)); border: 1px solid rgba(201,168,76,0.25); border-radius: 14px; padding: 1.5rem; font-family: 'EB Garamond', Georgia, serif; }
.turn-indicator { background: rgba(15,17,28,0.65); border: 1px solid rgba(201,168,76,0.2); border-radius: 10px; padding: 0.95rem 1.1rem; margin-bottom: 1.25rem; text-align: center; }
.turn-color { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 1.15rem; font-weight: 700; letter-spacing: 0.04em; }
.turn-who { color: rgba(232,224,208,0.6); font-size: 0.85rem; font-style: italic; }
.info-block { margin-bottom: 1.25rem; }
.info-label { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.16em; margin-bottom: 0.5rem; }
.info-content { color: rgba(232,224,208,0.85); font-size: 0.98rem; line-height: 1.55; }
.theme-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.theme-tag { background: rgba(201,168,76,0.14); color: #c9a84c; padding: 0.25rem 0.7rem; border-radius: 999px; font-size: 0.78rem; letter-spacing: 0.03em; text-transform: capitalize; border: 1px solid rgba(201,168,76,0.22); }

.puzzle-controls { display: flex; flex-direction: column; gap: 0.55rem; margin-top: 1.5rem; }
.ctrl-btn { background: transparent; border: 1px solid rgba(201,168,76,0.45); color: #c9a84c; padding: 0.7rem 1.1rem; border-radius: 8px; cursor: pointer; font-family: 'Playfair Display', Georgia, serif; font-size: 0.92rem; letter-spacing: 0.04em; transition: background 0.2s, border-color 0.2s, transform 0.15s; }
