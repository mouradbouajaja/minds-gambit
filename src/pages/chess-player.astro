---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Are You a Chess Player? Ã¢ÂÂ The Mind's Gambit">
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">M.B</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/podcasts" class="nav-btn">Podcasts</a></li>
      </ul>
    </div>
  </nav>

  <div class="chess-player-page">
    <div class="page-hero">
      <div class="chess-icon">&#9816;</div>
      <h1>Are You a Chess Player?</h1>
      <p class="hero-subtitle">Just please take the survey that applies to you &mdash; this will help me with my book.</p>
    </div>

    <div class="surveys-container">
      <div class="survey-card">
        <h2>Survey on Women Experiences in the Chess World</h2>
        <p>Help us understand the chess community better. Your responses shape the content we create.</p>
        <a href="https://forms.cloud.microsoft/Pages/ResponsePage.aspx?id=DQSIkWdsW0yxEjajBLZtrQAAAAAAAAAAAAO__UaLycpUODNEOFFTVUpWQ0FDQ0tXNzI4RlpMRlJPQS4u" target="_blank" rel="noopener noreferrer" class="survey-btn">
          Take the Survey <span class="arrow">&rarr;</span>
        </a>
      </div>

      <div class="survey-card">
        <h2>The Mind's Gambit: Chess Experience Survey</h2>
        <p>A few more questions to help us tailor the experience for players of all levels.</p>
        <a href="https://forms.cloud.microsoft/Pages/ResponsePage.aspx?id=DQSIkWdsW0yxEjajBLZtrQAAAAAAAAAAAAO__UaLycpUMk04VTMxRTdaV0g4NVM3UlBGV1M2VjZERi4u" target="_blank" rel="noopener noreferrer" class="survey-btn">
          Take the Survey <span class="arrow">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="back-home">
      <a href="/">&larr; Back to Home</a>
    </div>
  </div>

  <style>
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(15, 17, 28, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: #c9a84c;
      text-decoration: none;
    }
    .nav-links {
      list-style: none;
      display: flex;
      gap: 2rem;
      align-items: center;
      margin: 0;
      padding: 0;
    }
    .nav-links a {
      color: #f0ece4;
      text-decoration: none;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: color 0.3s;
    }
    .nav-links a:hover { color: #c9a84c; }
    .nav-btn {
      border: 1px solid #c9a84c;
      padding: 0.5rem 1.25rem;
      border-radius: 4px;
    }

    .chess-player-page {
      min-height: 100vh;
      padding-top: 100px;
      padding-bottom: 4rem;
    }

    .page-hero {
      text-align: center;
      padding: 3rem 2rem 2rem;
      max-width: 700px;
      margin: 0 auto;
    }
    .chess-icon {
      font-size: 4rem;
      color: #c9a84c;
      margin-bottom: 1rem;
      filter: drop-shadow(0 0 20px rgba(201, 168, 76, 0.3));
    }
    .page-hero h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.8rem;
      color: #c9a84c;
      margin-bottom: 1rem;
    }
    .hero-subtitle {
      font-size: 1.1rem;
      color: #a0a0a0;
      line-height: 1.7;
      max-width: 550px;
      margin: 0 auto;
    }

    .surveys-container {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 2rem;
      max-width: 800px;
      margin: 3rem auto;
      padding: 0 2rem;
    }

    .survey-card {
      background: rgba(30, 33, 48, 0.9);
      border: 1px solid rgba(201, 168, 76, 0.15);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      text-align: center;
      transition: border-color 0.3s, transform 0.3s;
      position: relative;
    }
    .survey-card:hover {
      border-color: rgba(201, 168, 76, 0.5);
      transform: translateY(-4px);
    }
    .survey-card h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      color: #f0ece4;
      margin-bottom: 1rem;
    }
    .survey-card p {
      font-size: 0.9rem;
      color: #a0a0a0;
      line-height: 1.6;
      margin-bottom: 2rem;
    }

    .survey-btn {
      display: inline-block;
      padding: 0.85rem 2.5rem;
      background: #c9a84c;
      color: #0f111c;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 700;
      font-size: 0.95rem;
      transition: background 0.3s, transform 0.2s;
      letter-spacing: 0.02em;
    }
    .survey-btn:hover {
      background: #d4b65c;
      transform: scale(1.05);
    }
    .survey-btn .arrow {
      margin-left: 6px;
      transition: margin-left 0.2s;
    }
    .survey-btn:hover .arrow {
      margin-left: 12px;
    }

    .back-home {
      text-align: center;
      margin-top: 2rem;
    }
    .back-home a {
      color: #c9a84c;
      text-decoration: none;
      font-size: 0.9rem;
      transition: opacity 0.3s;
    }
    .back-home a:hover { opacity: 0.7; }

    @media (max-width: 640px) {
      .surveys-container {
        grid-template-columns: 1fr;
      }
      .page-hero h1 {
        font-size: 2rem;
      }
    }
  </style>
</BaseLayout>
