<BaseLayout title="Our Games Library | Mind's Gambit" description="Play through 14.8 million chess games on the board, right here. Modern tournaments, historical masters, and every great player from Morphy to Carlsen. Free, on the Mind's Gambit network, no downloads required.">

<style>
:root {
  --bg: #0f111c;
  --bg-2: #181b2a;
  --bg-3: #1f2335;
  --gold: #c9a84c;
  --gold-dim: #9a7d3e;
  --text: #e8e0d0;
  --text-2: rgba(232, 224, 208, 0.7);
  --text-3: rgba(232, 224, 208, 0.45);
  --border: rgba(201, 168, 76, 0.2);
  --light-sq: #f5ead6;
  --dark-sq: #c9a87a;
  --board-border: #2a2a35;
}

.games-page { background: var(--bg); color: var(--text); min-height: 100vh; padding: 4rem 1.5rem 6rem; font-family: 'Inter', system-ui, sans-serif; }
.games-inner { max-width: 1200px; margin: 0 auto; }
.games-hero { text-align: center; margin-bottom: 3rem; }
.games-eyebrow { display: inline-block; color: var(--gold); font-family: 'Playfair Display', Georgia, serif; font-size: 0.8rem; letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 0.6rem; }
.games-title { font-family: 'Playfair Display', Georgia, serif; font-size: 3rem; margin: 0 0 0.7rem; color: var(--text); }
.games-sub { color: var(--text-2); font-size: 1.05rem; max-width: 720px; margin: 0 auto; line-height: 1.6; }
.games-stats { display: flex; justify-content: center; gap: 2.5rem; flex-wrap: wrap; margin: 2rem 0 0; padding-top: 1.5rem; border-top: 1px solid var(--border); }
.games-stat { text-align: center; }
.games-stat-num { font-family: 'Playfair Display', Georgia, serif; font-size: 1.8rem; color: var(--gold); display: block; }
.games-stat-label { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin-top: 0.2rem; display: block; }

.tab-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
.tab-btn { background: var(--bg-2); border: 1px solid var(--border); color: var(--text-2); padding: 0.7rem 1.4rem; border-radius: 999px; font-size: 0.9rem; font-family: inherit; cursor: pointer; transition: all 0.2s; letter-spacing: 0.04em; }
.tab-btn:hover { border-color: var(--gold-dim); color: var(--text); }
.tab-btn.active { background: var(--gold); border-color: var(--gold); color: var(--bg); font-weight: 600; }

.tab-panel { display: none; }
.tab-panel.active { display: block; }
.panel-intro { background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem 1.8rem; margin-bottom: 1.5rem; font-size: 0.95rem; color: var(--text-2); line-height: 1.6; }
.panel-intro strong { color: var(--text); }

.search-row { display: flex; gap: 0.8rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.search-input { flex: 1; min-width: 220px; background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 0.8rem 1rem; color: var(--text); font-family: inherit; font-size: 0.95rem; }
.search-input:focus { outline: none; border-color: var(--gold); }
.search-info { align-self: center; font-size: 0.85rem; color: var(--text-3); }

.games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.9rem; }
.game-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.1rem; transition: all 0.2s; display: flex; flex-direction: column; gap: 0.6rem; cursor: pointer; }
.game-card:hover { border-color: var(--gold); background: var(--bg-3); transform: translateY(-2px); }
.game-card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem; }
