@media (max-width: 900px) { .study-layout { grid-template-columns: 1fr; } }







/* ---------- variations sidebar ---------- */



.variations-sidebar { background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(30,34,52,0.55)); border: 1px solid rgba(201,168,76,0.25); border-radius: 12px; padding: 1.1rem 1rem 1rem; align-self: start; position: sticky; top: 1rem; }



.variations-header { margin-bottom: 0.8rem; }



.variations-header h2 { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 1.05rem; margin: 0 0 0.4rem; letter-spacing: 0.04em; }



