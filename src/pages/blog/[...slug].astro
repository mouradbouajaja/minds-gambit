---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export const prerender = true;

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const formattedDate = new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title} — The Mind's Gambit`}>
<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/#documentary" class="nav-btn">Documentary</a></li>
    </ul>
  </div>
</nav>

<article>
  <header class="article-header">
    <a href="/blog" class="back-link">&larr; Back to Blog</a>
    <span class="date">{formattedDate}</span>
    <h1>{entry.data.title}</h1>
    <p class="subtitle">{entry.data.description}</p>
    <div class="article-meta">
      <span class="author">By {entry.data.author}</span>
      <div class="tags">
        {entry.data.tags && entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
      </div>
    </div>
  </header>

  <div class="article-content">
    <Content />
  </div>

  <footer class="article-footer">
    <div class="footer-divider"></div>
    <p class="footer-cta">If this chapter resonated, share it with someone who needs to read it. Every reader sharpens the next draft.</p>
    <div class="footer-actions">
      <a href="/blog" class="back-link">&larr; All Articles</a>
      <a href="/#documentary" class="back-link">Watch the Documentary &rarr;</a>
    </div>
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. The Mind's Gambit is a production of &copy; MYB Studio LLC.</p>
  </footer>
</article>

</BaseLayout>

<style is:global>
/* Navigation */
nav { background: rgba(15,17,28,0.95); border-bottom: 1px solid rgba(201,168,76,0.2); position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0.75rem 2rem; display: flex; align-items: center; justify-content: space-between; }
.nav-links { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; align-items: center; }
.nav-links a { color: #e8e0d0; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; transition: color 0.3s; }
.nav-links a:hover { color: #c9a84c; }
.nav-btn { background: #c9a84c !important; color: #0f111c !important; padding: 0.5rem 1.25rem; border-radius: 4px; font-weight: 600; }

/* Article Layout */
article { max-width: 800px; margin: 0 auto; padding: 3rem 1.5rem; }
.article-header { margin-bottom: 3rem; padding-bottom: 2rem; border-bottom: 1px solid rgba(201,168,76,0.2); }
.back-link { color: #c9a84c; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.05em; display: inline-block; margin-bottom: 1rem; transition: opacity 0.3s; }
.back-link:hover { opacity: 0.7; }
.date { color: rgba(232,224,208,0.5); font-size: 0.85rem; display: block; margin-bottom: 0.75rem; }
.article-header h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 2.75rem; color: #e8e0d0; line-height: 1.2; margin: 0 0 1rem; }
.subtitle { color: rgba(232,224,208,0.75); font-size: 1.15rem; line-height: 1.5; margin: 0 0 1.5rem; font-style: italic; }
.article-meta { display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; }
.author { color: rgba(232,224,208,0.6); font-size: 0.9rem; }
.tags { display: flex; gap: 0.5rem; flex-wrap: wrap; }
.tag { background: rgba(201,168,76,0.15); color: #c9a84c; padding: 0.25rem 0.75rem; border-radius: 4px; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; }

/* Article Content */
.article-content { line-height: 1.8; color: #e0e0e0; font-size: 1.1rem; font-family: 'EB Garamond', Georgia, serif; }
.article-content p { margin: 0 0 1.5rem; }
.article-content h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.9rem; color: #c9a84c; margin: 3rem 0 1rem; }
.article-content h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.45rem; color: #e8e0d0; margin: 2rem 0 0.75rem; }
.article-content img { width: 100%; border-radius: 8px; margin: 2rem 0; }
.article-content blockquote { border-left: 3px solid #c9a84c; padding-left: 1.5rem; margin: 2rem 0; color: rgba(232,224,208,0.85); font-style: italic; font-size: 1.15rem; }
.article-content a { color: #c9a84c; text-decoration: underline; text-underline-offset: 3px; }
.article-content ul, .article-content ol { padding-left: 1.5rem; margin: 0 0 1.5rem; }
.article-content li { margin-bottom: 0.5rem; }
.article-content hr { border: none; border-top: 1px solid rgba(201,168,76,0.2); margin: 3rem auto; max-width: 200px; }

/* Footer */
.article-footer { margin-top: 4rem; padding-top: 2rem; text-align: center; }
.footer-divider { width: 60px; height: 1px; background: rgba(201,168,76,0.4); margin: 0 auto 2rem; }
.footer-cta { color: rgba(232,224,208,0.75); font-size: 1.05rem; line-height: 1.6; max-width: 540px; margin: 0 auto 2rem; font-style: italic; }
.footer-actions { display: flex; gap: 2rem; justify-content: center; flex-wrap: wrap; margin-bottom: 3rem; }
.footer-credit { color: rgba(232,224,208,0.4); font-size: 0.8rem; padding-top: 2rem; border-top: 1px solid rgba(201,168,76,0.1); }

@media (max-width: 640px) {
  .article-header h1 { font-size: 2rem; }
  .subtitle { font-size: 1rem; }
  .article-content { font-size: 1rem; }
}
</style>
