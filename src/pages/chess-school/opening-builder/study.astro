  // ------------------------------------------------------------



  // Full study guides — eight MG Recommended openings.



  // Each guide: overview (HTML string), annotated moves array,



  // studiedBy array of master notes.



  // ------------------------------------------------------------



  var STUDY_GUIDES = {



    'italian': {



      overview: "<p>The Italian Game is the most popular White opening at every level below master. The bishop on c4 trains on f7 — Black's weakest square — and a piece-based attack often follows. Modern theory has shifted from the sharp Evans Gambit toward the Giuoco Pianissimo: slow, positional, building pressure piece by piece.</p><p>Magnus Carlsen revived the Italian at the elite level in the 2010s; it now appears in nearly every world-class tournament. Perfect for the player who wants classical principles and clear plans rather than a 30-move memorized line.</p>",



      annotated: [



        { move: '1.e4',   note: "Stakes the central claim and opens lines for the king's bishop and queen." },



        { move: '1...e5', note: 'Classical reply. Black mirrors the central claim.' },



        { move: '2.Nf3',  note: "Develops with tempo, attacks Black's e5 pawn." },



        { move: '2...Nc6', note: 'Defends e5 and develops a piece.' },



        { move: '3.Bc4',  note: "The Italian. Bishop trains on f7, the weakest square in Black's camp." },



        { move: '3...Bc5', note: 'Symmetric development. Black mirrors.' },



        { move: '4.c3',   note: 'Quiet. Supports a later d4 push and clears space for the queen.' },



        { move: '4...Nf6', note: 'Develops and attacks e4.' },



        { move: '5.d3',   note: 'The Pianissimo (very slow) approach. Keeps the bishop on c4 instead of d3.' },



        { move: '5...d6', note: 'Symmetric. Black plays a complete mirror system.' },



        { move: '6.O-O',  note: 'Tucks the king to safety, prepares Re1 and h3.' },



        { move: '6...O-O', note: 'Black follows suit.' },



        { move: '7.Re1',  note: 'Steps onto the e-file. Supports an eventual e4-e5 break or the Nbd2-Nf1-Ng3 maneuver.' },



        { move: '7...a6', note: 'Quiet move. Prepares ...Ba7 to dodge any Na4 trade, and a future ...b5.' },



        { move: '8.h3',   note: 'The thematic "Italian luft." Prevents ...Bg4 pinning the knight and prepares the Nf1 maneuver.' }



      ],



      studiedBy: [



        { master: 'Magnus Carlsen',   note: 'Revived the Italian at world-championship level after a century of being considered "drawish." Watch his 2018 match games vs Caruana for the modern treatment.' },



        { master: 'Fabiano Caruana',  note: 'Co-author of modern Italian theory; the elite reference for serious students of this opening.' },



        { master: 'Hikaru Nakamura',  note: 'Modern aggressive treatments at the GM streamer level; accessible study material on his YouTube channel.' }



      ]



    },







    'queens-gambit': {



      overview: "<p>The Queen's Gambit is the most respected positional opening in chess history. White offers the c-pawn to lure Black's d-pawn from the center; whether Black accepts or declines, White builds a structural advantage that's been the foundation of world champions from Karpov to Carlsen.</p><p>The Exchange Variation shown here simplifies — White trades on d5, locks the Carlsbad pawn structure, and grinds with the minority attack on the queenside. Strategically rich, technically demanding, the calling card of patient positional players.</p>",



      annotated: [



        { move: '1.d4',   note: "Claims the dark central square and opens the c1-bishop's diagonal." },



        { move: '1...d5', note: 'Symmetric. Fights for the center.' },



        { move: '2.c4',   note: 'The Gambit. Offers the pawn but Black usually declines.' },



        { move: '2...e6', note: 'Declines with the Queen\'s Gambit Declined (QGD). Solid, supports d5.' },



        { move: '3.Nc3',  note: 'Adds a defender of e4 and prepares future cxd5.' },



        { move: '3...Nf6', note: 'Develops, defends e4 from any future Ne4 idea.' },



        { move: '4.cxd5', note: 'The Exchange. Locks the structure into the Carlsbad pattern.' },



        { move: '4...exd5', note: 'Forced — the alternative ...Nxd5 leaves a passive position.' },



        { move: '5.Bg5',  note: 'Pins the knight on f6 to add pressure on d5.' },



        { move: '5...Be7', note: 'Develops, prepares to break the pin if needed.' },



        { move: '6.e3',   note: "Solid. Doesn't block the c1-bishop's diagonal." },



        { move: '6...c6', note: 'Solidifies the pawn chain.' },



        { move: '7.Bd3',  note: 'Standard development square.' },



        { move: '7...O-O', note: 'Tucks the king.' },



        { move: '8.Nf3',  note: "Completes development. White's plan: Rb1, b4-b5  the famous minority attack to weaken Black's queenside." }



      ],



      studiedBy: [



        { master: 'Vladimir Kramnik', note: 'Defended his world title with the Queen\'s Gambit; his 2000 match games vs Kasparov are textbook QGD.' },



        { master: 'Anatoly Karpov',   note: 'Made the Carlsbad structure his trademark; the minority attack technique is named for his approach.' },



        { master: 'Magnus Carlsen',   note: 'Plays the Queen\'s Gambit (both sides) at elite tournaments; uses the Exchange for safe technical wins.' }



      ]



    },







    'london': {



      overview: "<p>The London System is the lowest-theory weapon in modern chess. White plays the same setup  d4, Bf4, e3, Nf3, c3, Nbd2, Bd3, O-O  against almost any Black system. You learn one structure, you play it for decades.</p><p>Magnus Carlsen plays it at world-championship level; it's not just a beginner system but a respectable line that's nearly impossible to refute. Perfect for the busy player who wants results without 100 hours of theory.</p>",



      annotated: [



        { move: '1.d4',   note: 'Claims the center.' },



        { move: '1...d5', note: 'Symmetric defense.' },



        { move: '2.Bf4',  note: 'The London move. Bishop steps out before being blocked by the e-pawn.' },



        { move: '2...Nf6', note: 'Standard development.' },



        { move: '3.e3',   note: 'Solid. Supports d4 and prepares the system.' },



        { move: '3...e6', note: 'Symmetric, prepares ...Bd6.' },



        { move: '4.Nf3',  note: 'Develops.' },



        { move: '4...Bd6', note: "Black's most direct challenge to the London bishop on f4." },



        { move: '5.Bg3',  note: 'Steps the bishop aside to avoid a trade.' },



        { move: '5...O-O', note: 'Tucks the king.' },



        { move: '6.Bd3',  note: 'Standard bishop placement, eyes h7.' },



        { move: "6...c5", note: "Black's only real challenge: hits White's d4." },



        { move: '7.c3',   note: 'Supports d4. Maintains the structure.' },



        { move: '7...Nc6', note: 'Develops, increases pressure on d4.' },



        { move: '8.Nbd2', note: "Completes development. White's plan: Ne5, f4, and a kingside attack with Bxh7+ tactics if Black is careless." }



      ],



      studiedBy: [



        { master: 'Magnus Carlsen', note: 'Plays the London at world-championship level (including the 2021 Carlsen-Nepomniachtchi match). The single biggest reason it\'s no longer "anti-chess."' },



        { master: 'Gata Kamsky',    note: 'One of the first elite players to make the London a primary weapon in tournament chess.' },



        { master: 'Eric Hansen',    note: 'Popularized the modern London at the GM streamer level; his Chessbrah videos are accessible study material.' }



      ]



    },







    'colle-zukertort': {



      overview: "<p>The Colle-Zukertort is the London's cousin  same one-system-vs-anything philosophy, but with the queen's bishop fianchettoed on b2 instead of f4. The b2-bishop pressures the long diagonal, especially after a future e4 break in the center.</p><p>Edgar Colle popularized it in the 1920s; Zukertort added the fianchetto refinement. A perfect 'one-system-fits-all' weapon for club players who want to think in plans rather than memorize moves.</p>",



      annotated: [



        { move: '1.d4',   note: 'Claim the center.' },



        { move: '1...d5', note: 'Symmetric.' },



        { move: '2.Nf3',  note: 'Develops. Avoids early commitments.' },



        { move: '2...Nf6', note: 'Symmetric.' },



        { move: '3.e3',   note: 'Solid. Prepares the Colle setup.' },



        { move: '3...e6', note: 'Standard reply.' },



        { move: '4.Bd3',  note: 'Develops on the active diagonal; eyes h7.' },



        { move: '4...c5', note: "Black's challenge to d4. Same idea as in the London." },



        { move: '5.b3',   note: 'The Zukertort refinement. Prepares the Bb2 fianchetto.' },



        { move: '5...Nc6', note: 'Develops, presses d4.' },



        { move: '6.Bb2',  note: 'The bishop battery. Eyes g7 once Black castles, and controls the long diagonal e5-h8.' },



        { move: '6...Bd6', note: 'Develops actively.' },



        { move: '7.O-O',  note: 'King safety first.' },



        { move: '7...O-O', note: 'Symmetric.' },



        { move: '8.Nbd2', note: "Completes development. White's plan: Ne5, f4, Bxh7+ sacrifice ideas, or the slower e3-e4 break." },



        { move: '8...b6', note: 'Black prepares a queenside fianchetto with ...Bb7, fighting for the long diagonal as well.' }



      ],



      studiedBy: [



        { master: 'Susan Polgar',          note: 'Wrote extensively on the Colle system; her training material includes Colle-Zukertort lines for amateurs.' },



        { master: 'Daniel King',           note: 'Modern explainer of the Colle on his Power Play DVD series; clear video lessons.' },



        { master: 'Edgar Colle (historical)', note: "The opening's namesake. His 1925-1932 games are the foundational text; many available in old tournament books." }



      ]



    },







    'french': {



      overview: "<p>The French Defense is Black's most strategically rich answer to 1.e4. Black gives up space (the e5 chain after 3.e5 leaves Black cramped) in exchange for a solid structure and clear counterplay against d4.</p><p>The Tarrasch (3.Nd2) shown here is White's main system at club level: flexible, safe, avoids the sharp theory of the Winawer (3.Nc3 Bb4). For Black, the open-game Tarrasch leads to balanced middlegames where deep understanding beats memorization. Mourad's lifelong defense.</p>",



      annotated: [



        { move: '1.e4',   note: 'White claims center.' },



        { move: '1...e6', note: 'The French. Modest, prepares ...d5 with full support.' },



        { move: '2.d4',   note: 'Standard.' },



        { move: '2...d5', note: "The French structure. Direct challenge to White's center." },



        { move: '3.Nd2',  note: 'The Tarrasch. Avoids the pin from ...Bb4 (Winawer line).' },



        { move: '3...c5', note: 'The open Tarrasch. Hits d4 immediately.' },



        { move: '4.exd5', note: 'Concedes the center but keeps the structure clean.' },



        { move: '4...exd5', note: 'Black now has an isolated queen pawn (IQP) on d5 in return for open lines and active piece play.' },



        { move: '5.Ngf3', note: 'Develops.' },



        { move: '5...Nc6', note: 'Develops, defends d5.' },



        { move: '6.Bb5',  note: 'Pins the knight, prepares Bxc6 followed by exploitation of doubled c-pawns.' },



        { move: '6...Bd6', note: 'Active development, eyes h2.' },



        { move: '7.dxc5', note: 'Locks the structure. Removes pressure on d4.' },



        { move: '7...Bxc5', note: 'Black recaptures actively.' },



        { move: '8.O-O',  note: 'White is fully developed. Plans Nb3-Nbd4 maneuvers and exploitation of the IQP later.' }



      ],



      studiedBy: [



        { master: 'Artur Yusupov',  note: 'His training manuals (especially the "Build Up Your Chess" series) are the gold standard for understanding French structures. Recommended by Mourad personally.' },



        { master: 'Jacob Aagaard',  note: 'Modern French theory in his "Attacking Chess" and "Grandmaster Repertoire" series. Rigorous, deep coverage.' },



        { master: 'Alexei Shirov',  note: 'Sharpest French practitioner of the modern era; his games show the dynamic possibilities Black has in supposedly "passive" structures.' }



      ]



    },







    'caro-kann': {



      overview: "<p>The Caro-Kann is the Karpov defense  solid, classical, no holes in the position. Black plays ...c6 to prepare ...d5 without blocking the queen's diagonal (the way ...e6 does in the French).</p><p>The Classical line (3.Nc3 dxe4) trades minor pieces and heads to a slightly passive but rock-solid endgame. Black accepts a small space disadvantage in exchange for zero pawn weaknesses. Hard to lose with.</p>",



      annotated: [



        { move: '1.e4',   note: 'Standard.' },



        { move: '1...c6', note: 'The Caro-Kann move. Prepares ...d5 with full pawn support.' },



        { move: '2.d4',   note: 'Standard.' },



        { move: '2...d5', note: 'Black challenges the center, fully supported.' },



        { move: '3.Nc3',  note: 'Defends e4 and prepares the Classical line.' },



        { move: '3...dxe4', note: 'Black takes. The simplifying line.' },



        { move: '4.Nxe4', note: 'Recaptures.' },



        { move: '4...Bf5', note: 'The Classical. Develops the bishop outside the pawn chain  the whole point of the Caro structure (solving the "bad bishop" problem the French has).' },



        { move: '5.Ng3',  note: 'Attacks the bishop.' },



        { move: '5...Bg6', note: 'Retreats. Bishop is safe and well-placed.' },



        { move: '6.h4',   note: 'Kingside attack. Threatens h5 trapping the bishop.' },



        { move: '6...h6', note: 'Prophylaxis. Prevents Nh5 with discovered-attack ideas.' },



        { move: '7.Nf3',  note: 'Develops.' },



        { move: '7...Nd7', note: 'Prepares ...Ngf6 without blocking the bishop.' },



        { move: '8.h5',   note: 'Restricts the bishop to h7.' },



        { move: '8...Bh7', note: 'The "passive" but solid Caro setup. Plans: ...Ngf6, ...e6, ...Bd6, castle, slow grind.' }



      ],



      studiedBy: [



        { master: 'Anatoly Karpov',     note: 'THE Caro-Kann expert of all time. His treatises (e.g. "Karpov on the Caro-Kann") are the foundational text.' },



        { master: 'Vasyl Ivanchuk',     note: 'Modern elite practitioner; his games show dynamic possibilities in supposedly "drawing" structures.' },



        { master: 'Daniel Naroditsky',  note: 'Modern Caro-Kann advocate at the streamer level; his speed-run lessons explain the strategic ideas in plain language.' }



      ]



    },







    'nimzo': {



      overview: "<p>The Nimzo-Indian is the most respected Black defense against 1.d4. Aron Nimzowitsch's lasting gift to chess theory: pin White's knight on c3, double White's pawns when White breaks the pin, and fight for the dark squares forever after.</p><p>Often paired with the Queen's Indian (when White avoids 3.Nc3 with 3.Nf3) to form a complete Black repertoire vs 1.d4. WGM Maryana Huda guided Mourad to this defense; the strategic depth rewards study.</p>",



      annotated: [



        { move: '1.d4',   note: 'White claim.' },



        { move: '1...Nf6', note: "Indian setup. Doesn't commit the d-pawn, keeps options open." },



        { move: '2.c4',   note: 'Standard.' },



        { move: '2...e6', note: 'Prepares ...d5 or ...Bb4 (Nimzo).' },



        { move: '3.Nc3',  note: 'The natural developing move. Triggers the Nimzo.' },



        { move: '3...Bb4', note: 'The Nimzo. Pins the knight, eyes c3 for the doubled-pawn idea.' },



