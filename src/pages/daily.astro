---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  getDailyArchive,
  getDailyBookExcerpt,
  getDailyOpening,
  getDailyPlayer,
  getDailyWhatIs,
  getDailyQuote,
  getDailyThisWeek,
  getDailyGamesOfWeek,
} from '../utils/daily-rotation';

const today = new Date();
// Anchor "today" to America/New_York — avoids UTC-build vs ET-edition date drift (task #207).
// Without this, a build at 00:30 UTC shows tomorrow's date even though ET is still yesterday.
const etISO = today.toLocaleDateString('en-CA', { timeZone: 'America/New_York' }); // "2026-06-01"
const [etY, etM, etD] = etISO.split('-').map(Number);
const todayMidnight = new Date(etY, etM - 1, etD);
const dateLine = todayMidnight.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
// Edition counter — auto-increments daily from the launch date (May 30, 2026 = Vol. 1, No. 1).
// VOL. bumps and NO. resets to 1 on each launch anniversary (May 30).
const LAUNCH = new Date(2026, 4, 30); // May is month index 4
const MS_PER_DAY = 86400000;
// Most recent launch anniversary (May 30) on or before today (ET).
let anniversary = new Date(todayMidnight.getFullYear(), 4, 30);
if (anniversary > todayMidnight) anniversary = new Date(todayMidnight.getFullYear() - 1, 4, 30);
// Before launch, pin to Vol. 1, No. 1.
const volumeNumber = todayMidnight < LAUNCH ? 1 : (anniversary.getFullYear() - LAUNCH.getFullYear()) + 1;
const editionNumber = todayMidnight < LAUNCH ? 1 : Math.floor((todayMidnight - anniversary) / MS_PER_DAY) + 1;
import ChessBoard from '../components/daily/ChessBoard.astro';

// Daily rotation pools — picked by dayOfYear (ET) from JSON files in src/data/daily/.
const todaysQuote = getDailyQuote(today);
const todaysPlayer = getDailyPlayer(today);
const todaysArchive = getDailyArchive(today);
const todaysWhatIs = getDailyWhatIs(today);
const todaysOpening = getDailyOpening(today);
const todaysBookExcerpt = getDailyBookExcerpt(today);
const todaysThisWeek = getDailyThisWeek(today);
const todaysGames = getDailyGamesOfWeek(today);

// Pull all published Daily Gambit stories, newest first.
const all = (await getCollection('daily', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Isolate the latest published edition (by date) for the front page.
// All stories in a single edition share the same frontmatter date:,
// so filtering by ===latestDate cleanly groups one edition's stories.
// The archive (further down) still reads from all to preserve history.
const latestDate = all.length ? all[0].data.date.valueOf() : null;
const edition = latestDate !== null
  ? all.filter((s) => s.data.date.valueOf() === latestDate)
  : [];

const SECTION_LABELS = {
  world: 'World Chess',
  tournaments: 'Tournaments',
  players: 'Players',
  openings: 'Openings',
  local: 'Local',
  opinion: 'Opinion',
  puzzle: 'Puzzle',
};

// Lead story: an explicit lead flag wins, otherwise the newest non-local story.
const lead = edition.find((s) => s.data.lead) || edition.find((s) => s.data.section !== 'local') || edition[0] || null;
// Secondary column: non-local stories that are not the lead (max 4).
const secondary = edition.filter((s) => s.data.section !== 'local' && s.id !== (lead && lead.id)).slice(0, 8);
// Local section: Pittsburgh & Pennsylvania stories (max 4).
// Local section: latest Pittsburgh & Pennsylvania stories from the full archive (max 4),
  // pinned across editions so local visitors always see upcoming PA events.
  const local = all.filter((s) => s.data.section === 'local').slice(0, 4);
const hasStories = edition.length > 0;
---

<BaseLayout title="The Daily Gambit — Chess News, Results & Analysis" description="The Daily Gambit: your morning briefing from the chess world. Tournament results, player news, opening theory, puzzles, local Pittsburgh & Pennsylvania chess, and analysis — gathered fresh every day.">
  <div class="tdg-paper">
    <div class="tdg-sheet">

      <div class="tdg-strip">
        <span>Vol. {volumeNumber} — No. {editionNumber}</span>
        <span>The Mind's Gambit</span>
        <span>Price: Free</span>
      </div>

      <header class="tdg-masthead">
        <div class="tdg-mast-side tdg-mast-left">
          <span>{dateLine}</span>
          <span class="tdg-mast-edition">Morning Edition</span>
        </div>
        <div class="tdg-mast-center">
          <h1 class="tdg-nameplate">The Daily Gambit</h1>
          <p class="tdg-motto">"All the chess that's fit to print"</p>
        </div>
        <div class="tdg-mast-side tdg-mast-right">
          <span>Chess · Mind · Culture</span>
          <span class="tdg-mast-edition">A Mind's Gambit Publication</span>
        </div>
      </header>

      <nav class="tdg-sectionbar">
        <a href="#">Tournaments</a>
        <a href="#">Players</a>
        <a href="#">Openings</a>
        <a href="#tdg-local">Local</a>
        <a href="#">Puzzles</a>
        <a href="#">Opinion</a>
        <a href="#">World Chess</a>
        <a href="/daily/archive" class="tdg-sectionbar-archive">Archive</a>
      </nav>

      {!hasStories && (
        <div class="tdg-banner">
          <span class="tdg-dot"></span>
          Preview edition — a sample of what The Daily Gambit will look like. Live coverage launching soon.
        </div>
      )}

      <main class="tdg-frontpage">

        <aside class="tdg-rail">
          <div class="tdg-box">
            <h4 class="tdg-boxtitle">Puzzle of the Day</h4>
            <link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />
            <div id="tdg-daily-board" class="tdg-daily-board"></div>
            <p class="tdg-boxtext"><strong id="tdg-daily-caption">Loading today&rsquo;s puzzle&hellip;</strong></p>
            <p class="tdg-boxtext tdg-daily-flavor">A fresh tactic to sharpen your eye before your coffee gets cold.</p>
            <p class="tdg-daily-status" id="tdg-daily-status"></p>
            <p class="tdg-cta"><a href="/daily/puzzles">Browse past daily puzzles &rarr;</a></p>
          </div>
          <div class="tdg-box">
            <h4 class="tdg-boxtitle">Results at a Glance</h4>
            <p class="tdg-results-event">Open · Round 5</p>
            <ul class="tdg-results">
              <li><span>Carlsen – So</span><span>0–1</span></li>
              <li><span>Praggnanandhaa – Gukesh</span><span>0–1</span></li>
              <li><span>Firouzja – Keymer</span><span>1½–1</span></li>
            </ul>
            <p class="tdg-results-event">Women · Round 5</p>
            <ul class="tdg-results">
              <li><span>Zhu Jiner – Deshmukh</span><span>0–1</span></li>
              <li><span>Muzychuk – Assaubayeva</span><span>1½–1</span></li>
              <li><span>Ju Wenjun – Koneru</span><span>1–1½</span></li>
            </ul>
            <p class="tdg-boxnote">Norway Chess 2026. Drawn classical games are decided by an Armageddon tiebreak, so a player can score 1½–1 without winning the main game — see the explainer below.</p>
          </div>
          <div class="tdg-box tdg-profile">
            <h4 class="tdg-boxtitle">Player Profile</h4>
            <p class="tdg-profile-name">{todaysPlayer.name}</p>
            <p class="tdg-profile-meta">{todaysPlayer.meta}</p>
            <p class="tdg-boxtext">{todaysPlayer.bio}</p>
            <p class="tdg-cta"><a href="/daily/archive">More from the players desk &rarr;</a></p>
          </div>
          <div class="tdg-box tdg-archives">
            <h4 class="tdg-boxtitle">From the Archives</h4>
            {todaysArchive.imageUrl && (
              <figure class="tdg-archfig">
                <img class="tdg-archimg" src={todaysArchive.imageUrl} alt={todaysArchive.imageAlt || todaysArchive.name} loading="lazy" />
                <figcaption class="tdg-archcap">{todaysArchive.imageCaption || todaysArchive.name}</figcaption>
              </figure>
            )}
            <p class="tdg-profile-name">{todaysArchive.name}</p>
            <p class="tdg-profile-meta">{todaysArchive.meta}</p>
            <p class="tdg-boxtext">{todaysArchive.bio}</p>
            <p class="tdg-cta"><a href="/daily/archive">More chess history &rarr;</a></p>
          </div>
          <div class="tdg-box tdg-explainer">
            <h4 class="tdg-boxtitle">{todaysWhatIs.title}</h4>
            <p class="tdg-boxtext">{todaysWhatIs.paragraph}</p>
            <p class="tdg-cta"><a href={todaysWhatIs.ctaUrl}>{todaysWhatIs.ctaText}</a></p>
          </div>
          <div class="tdg-box tdg-quotebox">
            <p class="tdg-quote">"{todaysQuote.text}"</p>
            <p class="tdg-quoteattr">— {todaysQuote.author}</p>
          </div>
          <div class="tdg-box tdg-thisweek">
            <h4 class="tdg-boxtitle">This Week in Chess History</h4>
            <ul class="tdg-timeline">
              {todaysThisWeek.events.map((e) => (
                <li><span class="tdg-tldate">{e.year}</span><span class="tdg-tltext">{e.text}</span></li>
              ))}
            </ul>
          </div>
        </aside>
        <article class="tdg-lead">
          {lead ? (
            <>
              <p class="tdg-kicker">{lead.data.kicker || SECTION_LABELS[lead.data.section]}</p>
              <h2 class="tdg-leadhead">{lead.data.headline}</h2>
              {lead.data.subhead && <p class="tdg-subhead">{lead.data.subhead}</p>}
              <p class="tdg-byline">By The Daily Gambit Desk{lead.data.sourceName ? ' · ' : ''}{lead.data.sourceName && <span class="tdg-dateline">{lead.data.sourceName}</span>}</p>
              <p class="tdg-body tdg-dropcap">{lead.data.summary}</p>
              {lead.data.results && lead.data.results.length > 0 && (
                <div class="tdg-standings">
                  <p class="tdg-standings-title">{lead.data.resultsTitle || 'Results'}</p>
                  <table class="tdg-standings-table">
                    <tbody>
                      {lead.data.results.map((g) => (
                        <tr>
                          <td class="tdg-standings-player">{g.white} – {g.black}</td>
                          <td class="tdg-standings-score">{g.score}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              {lead.data.standings && lead.data.standings.length > 0 && (
                <div class="tdg-standings">
                  <p class="tdg-standings-title">{lead.data.standingsTitle || 'Standings'}</p>
                  <table class="tdg-standings-table">
                    <tbody>
                      {lead.data.standings.map((row, i) => (
                        <tr>
                          <td class="tdg-standings-rank">{i + 1}</td>
                          <td class="tdg-standings-player">{row.player}</td>
                          <td class="tdg-standings-score">{row.score}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              )}
              {lead.data.pgn && (
                <div class="tdg-moves">
                  <p class="tdg-moves-title">{lead.data.pgnLabel || 'Moves'}</p>
                  <pre class="tdg-moves-pre">{lead.data.pgn}</pre>
                </div>
              )}
              {lead.data.sourceUrl && (
                <p class="tdg-readmore"><a href={lead.data.sourceUrl} target="_blank" rel="noopener">Read the full story →</a></p>
              )}
            </>
          ) : (
            <>
              <p class="tdg-kicker">World Championship</p>
              <h2 class="tdg-leadhead">A New Era Begins on the 64 Squares</h2>
              <p class="tdg-subhead">After a fortnight of grueling classical play, the title match heads to its decisive final games — and the chess world holds its breath.</p>
              <p class="tdg-byline">By The Daily Gambit Desk · <span class="tdg-dateline">CITY</span></p>
              <p class="tdg-body tdg-dropcap">This is placeholder text for the lead story. When The Daily Gambit goes live, the day's biggest chess headline will appear here, summarized in clean prose with a link to the original coverage.</p>
            </>
          )}
        </article>

        <section class="tdg-secondary">
          {secondary.length > 0 ? secondary.map((s, i) => (
            <>
              {i > 0 && <div class="tdg-rule"></div>}
              <article class="tdg-story">
                <p class="tdg-kicker">{s.data.kicker || SECTION_LABELS[s.data.section]}</p>
                <h3 class="tdg-storyhead">{s.data.headline}</h3>
                <p class="tdg-body">{s.data.summary}</p>
                {s.data.results && s.data.results.length > 0 && (
                  <div class="tdg-standings">
                    <p class="tdg-standings-title">{s.data.resultsTitle || 'Results'}</p>
                    <table class="tdg-standings-table">
                      <tbody>
                        {s.data.results.map((g) => (
                          <tr>
                            <td class="tdg-standings-player">{g.white} – {g.black}</td>
                            <td class="tdg-standings-score">{g.score}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
                {s.data.standings && s.data.standings.length > 0 && (
                  <div class="tdg-standings">
                    <p class="tdg-standings-title">{s.data.standingsTitle || 'Standings'}</p>
                    <table class="tdg-standings-table">
                      <tbody>
                        {s.data.standings.map((row, i) => (
                          <tr>
                            <td class="tdg-standings-rank">{i + 1}</td>
                            <td class="tdg-standings-player">{row.player}</td>
                            <td class="tdg-standings-score">{row.score}</td>
                          </tr>
                        ))}
                      </tbody>
                    </table>
                  </div>
                )}
                {s.data.pgn && (
                  <div class="tdg-moves">
                    <p class="tdg-moves-title">{s.data.pgnLabel || 'Moves'}</p>
                    <pre class="tdg-moves-pre">{s.data.pgn}</pre>
                  </div>
                )}
                {s.data.sourceUrl && (
                  <p class="tdg-readmore"><a href={s.data.sourceUrl} target="_blank" rel="noopener">Read more →</a></p>
                )}
              </article>
            </>
          )) : (
            <>
              <article class="tdg-story">
                <p class="tdg-kicker">Tournaments</p>
                <h3 class="tdg-storyhead">More Stories Coming Soon</h3>
                <p class="tdg-body">As editions are published, the day's tournament results, player news, and opening theory will fill this column.</p>
              </article>
            </>
          )}
          <div class="tdg-rule"></div>
          <article class="tdg-story">
            <p class="tdg-kicker">Opening Spotlight</p>
            <h3 class="tdg-storyhead">The {todaysOpening.opening}</h3>
            {todaysOpening.paragraphs && todaysOpening.paragraphs.map((p) => (
              <p class="tdg-body">{p}</p>
            ))}
          </article>
          <div class="tdg-rule"></div>
          <aside class="tdg-bookexcerpt">
            <p class="tdg-book-kicker">From the Book · The Mind's Gambit</p>
            <h3 class="tdg-book-title">{todaysBookExcerpt.title}</h3>
            <blockquote class="tdg-book-quote">
              {todaysBookExcerpt.paragraphs && todaysBookExcerpt.paragraphs.map((p) => <p>{p}</p>)}
            </blockquote>
            <p class="tdg-book-attr">— Mourad Bouajaja, <em>The Mind's Gambit</em> ({todaysBookExcerpt.chapter})</p>
          </aside>
        </section>


      </main>

      <section class="tdg-games" id="tdg-games"><div class="tdg-gameshead"><span class="tdg-pin">♞</span><h2 class="tdg-localtitle">Games of the Week</h2><span class="tdg-localtag">Annotated</span></div><p class="tdg-localintro">Two games worth replaying — one from the men's game, one from the women's — chosen for their beauty and their place in chess history. Set up a board and follow along.</p><div class="tdg-gamesgrid"><article class="tdg-game"><p class="tdg-kicker">{todaysGames.men.kicker}</p><h3 class="tdg-storyhead">{todaysGames.men.players}</h3><p class="tdg-game-meta">{todaysGames.men.meta}</p><p class="tdg-body">{todaysGames.men.body}</p>{todaysGames.men.pgn && (<div class="tdg-moves"><p class="tdg-moves-title">Full Game</p><pre class="tdg-moves-pre">{todaysGames.men.pgn}</pre></div>)}</article><article class="tdg-game"><p class="tdg-kicker">{todaysGames.women.kicker}</p><h3 class="tdg-storyhead">{todaysGames.women.players}</h3><p class="tdg-game-meta">{todaysGames.women.meta}</p><p class="tdg-body">{todaysGames.women.body}</p>{todaysGames.women.pgn && (<div class="tdg-moves"><p class="tdg-moves-title">Full Game</p><pre class="tdg-moves-pre">{todaysGames.women.pgn}</pre></div>)}</article></div></section><section class="tdg-origins" id="tdg-origins"><div class="tdg-gameshead"><span class="tdg-pin">♞</span><h2 class="tdg-localtitle">The Long Road to the 64 Squares</h2><span class="tdg-localtag">History</span></div><p class="tdg-localintro">Long before Morphy and Fischer, before Spain and Italy ever saw a board, the game was born in India and carried west by Persian courts and Arab geographers. A history told from its source, not from Europe.</p><div class="tdg-originsgrid"><div class="tdg-originscol"><p class="tdg-kicker">India · Chaturanga</p><h3 class="tdg-storyhead">A Game Named for an Army</h3><p class="tdg-body">The oldest known ancestor of chess is chaturanga, played in northern India by the sixth and seventh centuries during the Gupta era. Its name is Sanskrit for "having four limbs" — the four divisions of a classical Indian army: infantry, cavalry, elephantry, and chariotry. Those four arms survive on today's board as the pawn, the knight, the bishop, and the rook. The word itself is older than the game, appearing in the Mahabharata as a term for an army drawn up for battle, and a clear reference to the game by name turns up in Bana's Harshacharita around 625 AD. Most historians regard chaturanga as the common root not only of chess but of xiangqi in China, shogi in Japan, and makruk in Thailand.</p></div><div class="tdg-originscol"><p class="tdg-kicker">Persia &amp; Arabia · Shatranj</p><h3 class="tdg-storyhead">The Geographer Who Wrote It Down</h3><p class="tdg-body">From India the game travelled to Sassanid Persia, where it became chatrang and entered the education of the nobility; after the Arab conquest, lacking the Persian sounds, the name softened into shatranj. Among those who recorded its story was al-Mas'udi (c. 896–956), the Baghdad-born historian and traveller later called "the Herodotus of the Arabs." In his sweeping chronicle The Meadows of Gold he placed the game's invention squarely in India and gathered the lore around it. It was through this Arabic and Persian world — not a European one — that the game finally crossed into Spain and Sicily, and only then began its long transformation into the chess Morphy would one day master.</p></div></div></section><section class="tdg-local" id="tdg-local">
        <div class="tdg-localhead">
          <span class="tdg-pin">♟</span>
          <h2 class="tdg-localtitle">Pittsburgh &amp; Pennsylvania</h2>
          <span class="tdg-localtag">Local Chess</span>
        </div>
        <p class="tdg-localintro">Coverage close to home — club nights, scholastic results, and tournaments across the Steel City and the Commonwealth. From the Pittsburgh Chess Club to the Pennsylvania State Championship, this is where local players make headlines.</p>
        <div class="tdg-localgrid">
          {local.length > 0 ? local.map((s) => (
            <article class="tdg-localstory">
              <p class="tdg-kicker">{s.data.kicker || 'Local'}</p>
              <h3 class="tdg-storyhead">{s.data.headline}</h3>
              <p class="tdg-body">{s.data.summary}</p>
              {s.data.sourceUrl && (
                <p class="tdg-readmore"><a href={s.data.sourceUrl} target="_blank" rel="noopener">Read more →</a></p>
              )}
            </article>
          )) : (
            <>
              <article class="tdg-localstory">
                <p class="tdg-kicker">Pittsburgh Chess League</p>
                <h3 class="tdg-storyhead">Local Coverage Coming Soon</h3>
                <p class="tdg-body">Standings, scholastic results, and club news from Pittsburgh and across Pennsylvania will appear here.</p>
              </article>
              <article class="tdg-localstory">
                <p class="tdg-kicker">Scholastic</p>
                <h3 class="tdg-storyhead">Pennsylvania Scholastic Scene</h3>
                <p class="tdg-body">K–12 results, rising young talent, and coverage of school and college chess across the state.</p>
              </article>
              <article class="tdg-localstory">
                <p class="tdg-kicker">State Championship</p>
                <h3 class="tdg-storyhead">PA State Championship</h3>
                <p class="tdg-body">Round-by-round coverage of the PA State Championship and major opens across the Commonwealth.</p>
              </article>
              <article class="tdg-localstory">
                <p class="tdg-kicker">Community</p>
                <h3 class="tdg-storyhead">Clubs &amp; Colleges</h3>
                <p class="tdg-body">Local clubs, college teams, casual meetups, and the people growing chess in Western Pennsylvania.</p>
              </article>
            </>
          )}
        </div>
      </section>

      {hasStories && (
        <section class="tdg-archive" id="tdg-archive">
          <h4 class="tdg-archive-title">Edition Archive</h4>
          <p class="tdg-archive-intro">Every story published in The Daily Gambit, newest first.</p>
          <ul class="tdg-archive-list">
                        {all.slice(0, 9).map((s) => (
              <li class="tdg-archive-item">
                <span class="tdg-archive-date">{s.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</span>
                <span class="tdg-archive-sec">{SECTION_LABELS[s.data.section]}</span>
                {s.data.sourceUrl ? (
                  <a class="tdg-archive-link" href={s.data.sourceUrl} target="_blank" rel="noopener">{s.data.headline}</a>
                ) : (
                  <span class="tdg-archive-link">{s.data.headline}</span>
                )}
              </li>
            ))}
          </ul>
          {all.length > 9 && (
            <p class="tdg-archive-more"><a href="/daily/archive">View the full archive ({all.length} editions) &rarr;</a></p>
          )}
        </section>
      )}

      <footer class="tdg-foot">
        <div class="tdg-rulebold"></div>
        <p>The Daily Gambit is published by The Mind's Gambit. Coverage summarizes and links to original reporting from across the chess world. <a href="/">Return to The Mind's Gambit →</a></p>
      </footer>

    </div>
  </div>

  <style>
    .tdg-sheet *::before, .tdg-sheet *::after { background-image: none; }

    .tdg-paper { background: #14141a; padding: 2.5rem 1rem 4rem; display: flex; justify-content: center; }
    .tdg-sheet { position: relative; background: #f5f1e6; color: #1a1a1a; width: 100%; max-width: 1080px; padding: 2.2rem 2.6rem 2.8rem; box-shadow: 0 24px 60px rgba(0,0,0,0.5); font-family: Georgia, 'Times New Roman', Times, serif; }
    .tdg-strip { display: flex; justify-content: space-between; font-size: 0.72rem; letter-spacing: 0.04em; text-transform: uppercase; color: #4a4a4a; border-bottom: 1px solid #1a1a1a; padding-bottom: 0.4rem; }
    .tdg-masthead { display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 1rem; padding: 1.1rem 0 0.6rem; }
    .tdg-mast-side { display: flex; flex-direction: column; gap: 0.25rem; font-size: 0.74rem; letter-spacing: 0.04em; text-transform: uppercase; color: #3a3a3a; }
    .tdg-mast-right { text-align: right; }
    .tdg-mast-edition { font-style: italic; text-transform: none; color: #6a6a6a; }
    .tdg-mast-center { text-align: center; }
    .tdg-nameplate { font-family: 'Times New Roman', Times, Georgia, serif; font-weight: 800; font-size: clamp(2.4rem, 6vw, 4.6rem); line-height: 0.95; margin: 0; letter-spacing: -0.01em; color: #111; }
    .tdg-motto { font-style: italic; font-size: 0.92rem; color: #555; margin: 0.4rem 0 0; }
