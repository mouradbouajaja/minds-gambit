.nav-links a { color: #e8e0d0; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; transition: color 0.3s; }
.nav-links a:hover { color: #c9a84c; }
.nav-btn { background: #c9a84c !important; color: #0f111c !important; padding: 0.5rem 1.25rem; border-radius: 4px; font-weight: 600; }

.page { max-width: 1200px; margin: 0 auto; padding: 3rem 1.5rem; }
.back-link { color: #c9a84c; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.05em; display: inline-block; margin-bottom: 2rem; transition: opacity 0.25s; }
.back-link:hover { opacity: 0.7; transform: translateX(-3px); }
.eyebrow { color: #c9a84c; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.25em; display: block; margin-bottom: 1rem; }
.page h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 3rem; color: #e8e0d0; line-height: 1.1; margin: 0 0 1rem; }
.lead { color: rgba(232,224,208,0.8); font-size: 1.2rem; font-family: 'EB Garamond', Georgia, serif; line-height: 1.55; max-width: 720px; margin: 0 0 2.5rem; }

.stats-bar { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
.stat { background: rgba(30,34,52,0.55); border: 1px solid rgba(201,168,76,0.2); border-radius: 12px; padding: 1.25rem 1rem; text-align: center; transition: border-color 0.25s, transform 0.25s; }
.stat:hover { border-color: rgba(201,168,76,0.45); transform: translateY(-2px); }
.stat-label { color: rgba(232,224,208,0.55); font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.18em; margin-bottom: 0.5rem; font-family: 'Playfair Display', Georgia, serif; }
.stat-value { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 1.7rem; font-weight: 700; line-height: 1; }
.stat-streak .stat-value { color: #f4d989; }
.streak-fire { font-size: 1.2rem; margin-left: 0.3rem; }

.puzzle-area { display: grid; grid-template-columns: minmax(0, 1fr) 360px; gap: 2rem; margin-bottom: 3rem; align-items: start; }
.board-wrap { position: relative; }
#puzzle-board { width: 100%; max-width: 640px; margin: 0 auto; box-shadow: 0 18px 50px rgba(0,0,0,0.5); border-radius: 8px; overflow: hidden; }
.board-status { margin-top: 1.25rem; padding: 0.85rem 1.2rem; background: rgba(30,34,52,0.65); border: 1px solid rgba(201,168,76,0.25); border-radius: 10px; color: #e0e0e0; font-family: 'EB Garamond', Georgia, serif; font-size: 1.05rem; text-align: center; transition: background 0.25s, border-color 0.25s, color 0.25s; }
.status-good { background: rgba(74,222,128,0.12); border-color: rgba(74,222,128,0.5); color: #a7f3d0; }
.status-bad { background: rgba(248,113,113,0.12); border-color: rgba(248,113,113,0.5); color: #fecaca; }

@keyframes hintPulse { 0%, 100% { box-shadow: inset 0 0 0 0 rgba(201,168,76,0); } 50% { box-shadow: inset 0 0 0 6px rgba(201,168,76,0.85); } }
.hint-square { animation: hintPulse 1.4s ease-out; }

.puzzle-info { background: linear-gradient(135deg, rgba(201,168,76,0.08), rgba(30,34,52,0.6)); border: 1px solid rgba(201,168,76,0.25); border-radius: 14px; padding: 1.5rem; font-family: 'EB Garamond', Georgia, serif; }
.turn-indicator { background: rgba(15,17,28,0.65); border: 1px solid rgba(201,168,76,0.2); border-radius: 10px; padding: 0.95rem 1.1rem; margin-bottom: 1.25rem; text-align: center; }
.turn-color { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 1.15rem; font-weight: 700; letter-spacing: 0.04em; }
.turn-who { color: rgba(232,224,208,0.6); font-size: 0.85rem; font-style: italic; }
.info-block { margin-bottom: 1.25rem; }
.info-label { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.16em; margin-bottom: 0.5rem; }
.info-content { color: rgba(232,224,208,0.85); font-size: 0.98rem; line-height: 1.55; }
.theme-tags { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.theme-tag { background: rgba(201,168,76,0.14); color: #c9a84c; padding: 0.25rem 0.7rem; border-radius: 999px; font-size: 0.78rem; letter-spacing: 0.03em; text-transform: capitalize; border: 1px solid rgba(201,168,76,0.22); }

.puzzle-controls { display: flex; flex-direction: column; gap: 0.55rem; margin-top: 1.5rem; }
.ctrl-btn { background: transparent; border: 1px solid rgba(201,168,76,0.45); color: #c9a84c; padding: 0.7rem 1.1rem; border-radius: 8px; cursor: pointer; font-family: 'Playfair Display', Georgia, serif; font-size: 0.92rem; letter-spacing: 0.04em; transition: background 0.2s, border-color 0.2s, transform 0.15s; }
.ctrl-btn:hover { background: rgba(201,168,76,0.12); border-color: #c9a84c; transform: translateY(-1px); }
.ctrl-btn:active { transform: translateY(0); }
.controls-done .ctrl-btn { opacity: 0.4; pointer-events: none; }

.solved-block { display: none; margin-top: 1.5rem; padding: 1.25rem; background: linear-gradient(135deg, rgba(74,222,128,0.1), rgba(30,34,52,0.65)); border: 1px solid rgba(74,222,128,0.4); border-radius: 12px; text-align: center; }
.solved-block.shown { display: block; animation: slideIn 0.4s ease-out; }
@keyframes slideIn { from { opacity: 0; transform: translateY(8px); } to { opacity: 1; transform: translateY(0); } }
.solved-title { font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; color: #a7f3d0; margin-bottom: 0.4rem; }
.solved-text { color: rgba(232,224,208,0.8); font-size: 0.95rem; margin: 0 0 1rem; line-height: 1.5; }
.solved-cta { display: inline-block; background: #c9a84c; color: #0f111c; padding: 0.65rem 1.3rem; border-radius: 8px; text-decoration: none; font-family: 'Playfair Display', Georgia, serif; font-weight: 700; font-size: 0.92rem; transition: transform 0.2s, box-shadow 0.2s; }
.solved-cta:hover { transform: translateY(-2px); box-shadow: 0 8px 22px rgba(201,168,76,0.4); }

.habit-card, .next-card { background: rgba(30,34,52,0.5); border: 1px solid rgba(201,168,76,0.18); border-radius: 12px; padding: 2rem; margin-bottom: 1.5rem; font-family: 'EB Garamond', Georgia, serif; }
.habit-card h2, .next-card h2 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; color: #c9a84c; margin: 0 0 1rem; }
.habit-card p, .next-card p { color: #e0e0e0; font-size: 1.05rem; line-height: 1.65; margin: 0 0 1rem; }
.next-list { list-style: none; padding: 0; margin: 1rem 0 1.5rem; }
.next-list li { padding: 0.6rem 0 0.6rem 1.5rem; border-bottom: 1px solid rgba(201,168,76,0.1); color: #e0e0e0; font-size: 1rem; line-height: 1.55; position: relative; }
.next-list li::before { content: '♞'; color: #c9a84c; position: absolute; left: 0; top: 0.6rem; }
.next-list strong { color: #c9a84c; font-family: 'Playfair Display', Georgia, serif; }
.next-note { color: rgba(232,224,208,0.55) !important; font-size: 0.92rem !important; font-style: italic; margin: 0 !important; }

.attribution { color: rgba(232,224,208,0.5); font-size: 0.82rem; font-family: 'EB Garamond', Georgia, serif; line-height: 1.55; margin: 2rem 0 1rem; font-style: italic; }
.attribution a { color: #c9a84c; text-decoration: underline; }
.page-footer { margin-top: 3rem; padding-top: 2rem; text-align: center; border-top: 1px solid rgba(201,168,76,0.1); }
.footer-credit { color: rgba(232,224,208,0.4); font-size: 0.8rem; font-family: 'EB Garamond', Georgia, serif; }

@media (max-width: 960px) { .puzzle-area { grid-template-columns: 1fr; } .puzzle-info { order: 2; } .stats-bar { grid-template-columns: repeat(2, 1fr); } .page h1 { font-size: 2.25rem; } }
@media (max-width: 560px) { .stats-bar { grid-template-columns: 1fr 1fr; } .puzzle-controls { gap: 0.4rem; } .habit-card, .next-card { padding: 1.5rem; } }
.board-b72b1 { box-sizing: border-box; }
