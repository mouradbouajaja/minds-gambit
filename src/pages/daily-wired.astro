<script is:inline src="https://cdn.jsdelivr.net/npm/chess.js@0.12.0/chess.js"></script>
<script is:inline>
(function () {
  var board = document.querySelector('[data-puzzle-board]');
  if (!board || typeof Chess === 'undefined') return;
  var fen = board.getAttribute('data-fen');
  var moves = (board.getAttribute('data-moves') || '').trim().split(/\s+/).filter(Boolean);
  if (!fen || moves.length === 0) return;
  var card = document.querySelector('[data-puzzle-card]');
  var feedback = card.querySelector('[data-puzzle-feedback]');
  var titleEl = card.querySelector('[data-puzzle-title]');
  var game = new Chess(fen);
  var step = 1;
  var solved = false;
  var selected = null;
  var PIECE_BASE = 'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/';
  function codeFor(p){ return (p.color === 'w' ? 'w' : 'b') + p.type.toUpperCase(); }
  function altFor(p){ var names={p:'pawn',n:'knight',b:'bishop',r:'rook',q:'queen',k:'king'}; return (p.color==='w'?'white ':'black ')+names[p.type]; }
  function cellFor(sq){ return board.querySelector('[data-sq="' + sq + '"]'); }
  function clearSel(){ if(selected){ var c=cellFor(selected); if(c) c.style.outline=''; selected=null; } }
  function repaint(){
    var cells = board.querySelectorAll('[data-sq]');
    cells.forEach(function(cell){
      var sq = cell.getAttribute('data-sq');
      var p = game.get(sq);
      cell.innerHTML = '';
      if (p) { var img=document.createElement('img'); img.src=PIECE_BASE+codeFor(p)+'.png'; img.alt=altFor(p); cell.appendChild(img); }
    });
  }
  function setFeedback(msg){ if(feedback) feedback.textContent = msg; }
  function freezeSolved(lastTo){
    solved = true; clearSel();
    var c = cellFor(lastTo); if(c) c.style.boxShadow = 'inset 0 0 0 4px #d6b85a';
    if (titleEl) { titleEl.innerHTML = ''; var a=document.createElement('a'); a.href='/chess-school/tactics'; a.textContent='Solved! \u2713 Train more \u2192'; a.style.color='#8a6d1d'; a.style.textDecoration='none'; titleEl.appendChild(a); }
    setFeedback('');
  }
  function autoPlay(uci){
    var mv = game.move({ from: uci.slice(0,2), to: uci.slice(2,4), promotion: uci.slice(4,5) || undefined });
    if (mv) { repaint(); }
  }
  function tryUserMove(from, to){
    if (solved) return;
    var expected = moves[step];
    var promo = expected.length > 4 ? expected.slice(4,5) : undefined;
    var uci = from + to + (promo || '');
    if (uci !== expected) { setFeedback('Not quite \u2014 try again.'); return false; }
    game.move({ from: from, to: to, promotion: promo });
    repaint(); step++;
    if (step >= moves.length) { freezeSolved(to); return true; }
    setFeedback('');
    var opp = moves[step];
    setTimeout(function(){ autoPlay(opp); step++; }, 400);
    return true;
  }
  board.addEventListener('click', function(ev){
    if (solved) return;
    var cell = ev.target.closest('[data-sq]'); if(!cell) return;
    var sq = cell.getAttribute('data-sq');
    var p = game.get(sq);
    var sideChar = game.turn();
    if (selected === null) {
      if (p && p.color === sideChar) { selected = sq; cell.style.outline = '3px solid #d6b85a'; cell.style.outlineOffset = '-3px'; }
      return;
    }
    if (sq === selected) { clearSel(); return; }
    if (p && p.color === sideChar) { clearSel(); selected = sq; cell.style.outline = '3px solid #d6b85a'; cell.style.outlineOffset = '-3px'; return; }
    var from = selected; clearSel();
    tryUserMove(from, sq);
  });
})();
</script>
</body>
