---
import { getCollection } from 'astro:content';
import {
  getDailyArchive, getDailyBookExcerpt, getDailyOpening, getDailyPlayer,
  getDailyWhatIs, getDailyQuote, getDailyThisWeek, getDailyGamesOfWeek,
} from '../utils/daily-rotation';

const today = new Date();
const dateLine = today.toLocaleDateString('en-US', { timeZone: 'America/New_York', weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }).toUpperCase();
const editionLabel = (parseInt(today.toLocaleString('en-US', { timeZone: 'America/New_York', hour: '2-digit', hour12: false }), 10) < 12) ? 'Morning Edition' : 'Evening Edition';

const todaysQuote = getDailyQuote(today);
const todaysPlayer = getDailyPlayer(today);
const todaysArchive = getDailyArchive(today);
const SIL_NEUTRAL = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 180'%3E%3Crect width='160' height='180' fill='%232a2a2a'/%3E%3Cg fill='%23565049'%3E%3Ccircle cx='80' cy='68' r='30'/%3E%3Cpath d='M22 180c0-43 26-62 58-62s58 19 58 62z'/%3E%3C/g%3E%3C/svg%3E";
const SIL_FEMALE = "data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 160 180'%3E%3Crect width='160' height='180' fill='%232a2a2a'/%3E%3Cg fill='%23565049'%3E%3Cpath d='M48 74c0-28 14-46 32-46s32 18 32 46c0 16-6 22-12 26H60c-6-4-12-10-12-26z'/%3E%3Ccircle cx='80' cy='70' r='25'/%3E%3Cpath d='M26 180c0-42 25-60 54-60s54 18 54 60z'/%3E%3C/g%3E%3C/svg%3E";
const archiveSilhouette = (todaysArchive && todaysArchive.gender === 'female') ? SIL_FEMALE : SIL_NEUTRAL;
const todaysWhatIs = getDailyWhatIs(today);
const todaysOpening = getDailyOpening(today);
const todaysBookExcerpt = getDailyBookExcerpt(today);
const todaysThisWeek = getDailyThisWeek(today);
const todaysGames = getDailyGamesOfWeek(today);

const all = (await getCollection('daily', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const latestDate = all.length ? all[0].data.date.valueOf() : null;
const edition = latestDate !== null ? all.filter((s) => s.data.date.valueOf() === latestDate) : [];

function formatStoryDate(d) { return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }); }

const lead = edition.find((s) => s.data.lead) || edition.find((s) => s.data.section !== 'local') || edition[0] || null;
const secondary = edition.filter((s) => s.data.section !== 'local' && s.id !== (lead && lead.id)).slice(0, 4);
const local = all.filter((s) => s.data.section === 'local').slice(0, 4);

const story2 = secondary[0] || null;
const story3 = secondary[1] || null;
const story4 = secondary[2] || null;
const story5 = secondary[3] || null;

const standingsOpen = (lead && lead.data.standings) || [];
const standingsWomen = (lead && lead.data.standingsWomen) || [];
const standingsRound = (lead && lead.data.standingsRound) || 'Round 5';
const resultsOpen = (lead && lead.data.resultsOpen) || '';
const resultsWomen = (lead && lead.data.resultsWomen) || '';

// ---- Puzzle of the Day (build-time fetch from Bunny CDN pool) ----
function getDayOfYearET(d = new Date()) {
  const et = new Date(d.toLocaleString('en-US', { timeZone: 'America/New_York' }));
  const start = new Date(et.getFullYear(), 0, 0);
  return Math.floor((et.getTime() - start.getTime()) / 86400000);
}
const FALLBACK_PUZZLE = { fen: '8/8/8/8/8/8/8/8 w - - 0 1', moves: '', mateIn: 2 };
let puzzle = FALLBACK_PUZZLE;
try {
  const res = await fetch('https://mindsgambit-cdn.b-cdn.net/puzzles/puzzle-pool.json');
  if (res.ok) {
    const pool = await res.json();
    const list = pool.puzzles || [];
    if (list.length) puzzle = list[getDayOfYearET(today) % list.length];
  }
} catch (e) { /* keep fallback so build never breaks */ }

// Parse FEN placement field into 64 cells (rank 8..1, file a..h).
const PIECE_BASE = 'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/';
const PIECE_CODE = { p:'bP', n:'bN', b:'bB', r:'bR', q:'bQ', k:'bK', P:'wP', N:'wN', B:'wB', R:'wR', Q:'wQ', K:'wK' };
const PIECE_ALT = { p:'black pawn', n:'black knight', b:'black bishop', r:'black rook', q:'black queen', k:'black king', P:'white pawn', N:'white knight', B:'white bishop', R:'white rook', Q:'white queen', K:'white king' };
function applyUci(fen, uci) {
  if (!fen || !uci || uci.length < 4) return fen;
  const parts = fen.split(' ');
  const rows = parts[0].split('/');
  const bd = rows.map((r) => { const a = []; for (const ch of r) { if (/\d/.test(ch)) { for (let i = 0; i < +ch; i++) a.push(''); } else a.push(ch); } return a; });
  const fileIdx = (c) => c.charCodeAt(0) - 97;
  const rankIdx = (c) => 8 - (+c);
  const from = uci.slice(0, 2), to = uci.slice(2, 4), promo = uci[4];
  const fr = rankIdx(from[1]), ff = fileIdx(from[0]), tr = rankIdx(to[1]), tf = fileIdx(to[0]);
  let piece = bd[fr][ff]; const active = parts[1]; const isPawn = piece.toLowerCase() === 'p';
  if (isPawn && ff !== tf && bd[tr][tf] === '') bd[fr][tf] = '';
  if (piece.toLowerCase() === 'k' && Math.abs(tf - ff) === 2) { if (tf > ff) { bd[fr][7] = ''; bd[fr][5] = active === 'w' ? 'R' : 'r'; } else { bd[fr][0] = ''; bd[fr][3] = active === 'w' ? 'R' : 'r'; } }
  bd[fr][ff] = ''; if (promo) piece = active === 'w' ? promo.toUpperCase() : promo.toLowerCase(); bd[tr][tf] = piece;
  const np = bd.map((rk) => { let s = '', e = 0; for (const c of rk) { if (c === '') { e++; } else { if (e) { s += e; e = 0; } s += c; } } if (e) s += e; return s; }).join('/');
  const na = active === 'w' ? 'b' : 'w'; let cr = parts[2] || '-';
  if (piece.toLowerCase() === 'k') cr = active === 'w' ? cr.replace(/[KQ]/g, '') : cr.replace(/[kq]/g, ''); if (cr === '') cr = '-';
  let ep = '-'; if (isPawn && Math.abs(tr - fr) === 2) { const er = active === 'w' ? '3' : '6'; ep = from[0] + er; }
  let full = +(parts[5] || 1); if (active === 'b') full += 1;
  return [np, na, cr, ep, 0, full].join(' ');
}
const rawFen = puzzle.fen || '8/8/8/8/8/8/8/8 w - - 0 1';
const movesList = (puzzle.moves || '').trim().split(/\s+/).filter(Boolean);
// Lichess convention: moves[0] is the opponent's forced setup ply, auto-applied here so the
// static board shows the real puzzle position and side-to-move = the solver's color.
const postSetupFEN = movesList.length ? applyUci(rawFen, movesList[0]) : rawFen;
const fenParts = (postSetupFEN || '').split(' ');
const placement = fenParts[0] || '8/8/8/8/8/8/8/8';
const activeColor = fenParts[1] || 'w';
const files = ['a','b','c','d','e','f','g','h'];
const puzzleCells = [];
const rows = placement.split('/');
for (let r = 0; r < 8; r++) {
  const rankNum = 8 - r;
  let fileIdx = 0;
  const row = rows[r] || '8';
  for (const ch of row) {
    if (/[1-8]/.test(ch)) {
      const n = parseInt(ch, 10);
      for (let k = 0; k < n; k++) {
        const sq = files[fileIdx] + rankNum;
        const shade = ((fileIdx + r) % 2 === 0) ? 'cb-light' : 'cb-dark';
        puzzleCells.push({ square: sq, shade, piece: null, alt: '' });
        fileIdx++;
      }
    } else {
      const sq = files[fileIdx] + rankNum;
      const shade = ((fileIdx + r) % 2 === 0) ? 'cb-light' : 'cb-dark';
      puzzleCells.push({ square: sq, shade, piece: PIECE_BASE + PIECE_CODE[ch] + '.png', alt: PIECE_ALT[ch] || '' });
      fileIdx++;
    }
  }
}
const sideToMove = activeColor === 'b' ? 'Black to move' : 'White to move';
const puzzleTitle = (activeColor === 'b' ? 'Black' : 'White') + ' to move, mate in ' + puzzle.mateIn + '.';
