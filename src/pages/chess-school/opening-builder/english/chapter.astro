---

import BaseLayout from '../../../../layouts/BaseLayout.astro';



export const prerender = true;



// ============================================================

//  ENGLISH OPENING — Chapter detail page

//  Route: /chess-school/opening-builder/english/chapter?id=<chapterId>

//

//  Reads ?id= from URL and renders the corresponding chapter

//  from the embedded CHAPTERS object. Each chapter exposes

//  its sub-variations, a strategic intro, and a "studied by"

//  master list.

// ============================================================

---



<BaseLayout

  title="English Opening Chapter — Mind's Gambit"

  description="A chapter of the Mind's Gambit English Opening complete repertoire. Mainline moves, strategic ideas, recommended masters."

>



<nav>

  <div class="nav-inner">

    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>

    <ul class="nav-links">

      <li><a href="/">Home</a></li>

      <li><a href="/#book">The Book</a></li>

      <li><a href="/watch">Documentary</a></li>

      <li><a href="/blog">Blog</a></li>

      <li><a href="/chess-school">Chess School</a></li>

      <li><a href="/#about">About</a></li>

      <li><a href="/#contact">Contact</a></li>

      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>

    </ul>

  </div>

</nav>



<section class="page">

  <a href="/chess-school/opening-builder/english" class="back-link">&larr; Back to English Repertoire</a>

  <span class="eyebrow" id="chapter-eyebrow">English Repertoire</span>

  <h1 id="chapter-title">Loading chapter&hellip;</h1>

  <p class="subtitle"><span id="chapter-eco">&mdash;</span> &middot; <span id="chapter-setup">&mdash;</span></p>



  <div class="chapter-layout">

    <div class="chapter-main">

      <!-- Not-found fallback -->

      <div id="not-found" class="not-found" hidden>

        <h2>Chapter not found</h2>

        <p>Pick a chapter from the English course landing page and try again.</p>

        <a href="/chess-school/opening-builder/english" class="cta-primary">&larr; Back to the English course</a>

      </div>



      <!-- Full chapter content -->

      <div id="chapter-content" hidden>

        <!-- Strategic intro -->

        <section class="study-section">

          <h2>Strategic overview</h2>

          <div id="chapter-intro"></div>

        </section>



        <!-- Sub-variations -->

        <section class="study-section">

          <h2>Sub-variations</h2>

          <p class="section-intro">Each sub-variation below is a complete mainline you can drill independently. Drill them in order; once you know all three (or four), you&rsquo;re ready for any club opponent in this chapter.</p>

          <ul class="subvariation-list" id="subvariation-list"></ul>

        </section>



        <!-- Master Games (PGN-driven) -->

        <section class="study-section master-games" id="master-games-section" hidden>

          <span class="eyebrow master-games-eyebrow">From the 8-million game archive</span>

          <h2>Master Games</h2>

          <p class="section-intro">Curated games where strong players battled this exact line.</p>

          <ul class="master-games-list" id="master-games-list"></ul>

          <div class="master-games-viewer" id="master-games-viewer" hidden>

            <div class="mg-board-wrap">

              <div id="master-board" class="master-board"></div>

              <div class="mg-controls">

                <button class="mg-btn" id="mg-start" type="button" title="Start">|&#9664;</button>

                <button class="mg-btn" id="mg-prev" type="button" title="Previous">&#9664;</button>

                <button class="mg-btn" id="mg-next" type="button" title="Next">&#9654;</button>

                <button class="mg-btn" id="mg-end" type="button" title="End">&#9654;|</button>

              </div>

              <p class="mg-game-header" id="mg-game-header"></p>

            </div>

            <div class="mg-moves" id="mg-moves"></div>

          </div>

        </section>



        <!-- Studied by -->

        <section class="study-section">

          <h2>Studied by</h2>

          <p class="section-intro">Recommended teachers for this variation:</p>

          <ul class="studied-by" id="studied-by"></ul>

        </section>



        <!-- Chapter navigation footer -->

        <nav class="chapter-nav">

          <a id="prev-chapter" class="chapter-nav-btn chapter-nav-prev" href="#">&larr; Previous chapter</a>

          <a class="chapter-nav-back" href="/chess-school/opening-builder/english">Back to course</a>

          <a id="next-chapter" class="chapter-nav-btn chapter-nav-next" href="#">Next chapter &rarr;</a>

        </nav>

      </div>

    </div>



    <aside class="chapter-sidebar">

      <div class="widget-card" id="progress-widget" hidden>

        <h3 class="widget-title">Chapter progress</h3>

        <div class="chapter-progress-bar"><div class="chapter-progress-fill" id="sidebar-progress-fill" style="width:0%"></div></div>

        <p class="widget-body" id="sidebar-progress-label">Not started</p>

        <button id="mark-complete" class="cta-secondary" type="button">Mark chapter as complete</button>

      </div>



      <div class="widget-card widget-help">

        <h3 class="widget-title">If you get stuck</h3>

        <p class="widget-body">Email <a href="mailto:Mourad@mindsgambit.com">Mourad@mindsgambit.com</a> with the line you&rsquo;re struggling with. He&rsquo;ll usually reply within a day with the strategic idea behind the move.</p>

      </div>

    </aside>

  </div>



  <footer class="page-footer">

    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind&rsquo;s Gambit Chess School is a production of &copy; MYB Studio LLC.</p>

  </footer>

</section>



