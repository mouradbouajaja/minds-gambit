---
/*
 watch.astro — The Mind's Gambit
 Static feed of documentary episodes hosted on Bunny CDN.
 (Previously fetched from /api/feed; now hardcoded for reliability.)
*/

const BUNNY_VIDEOS = 'https://mindsgambitvideos.b-cdn.net';

const feed = {
  title: "Mind's Gambit",
  description: "Stream the Mind's Gambit documentary series and chess content",
  categories: [
    {
      id: 'documentary',
      title: "The Mind's Gambit Documentary",
      items: [
        {
          title: 'Episode 1 — The Constant',
          description: 'The first episode in The Mind\'s Gambit documentary series. The opening reflection on chess, attention, and what makes a player return to the board.',
          streamUrl: `${BUNNY_VIDEOS}/mg-ep1-the-constant.mp4`,
          streamFormat: 'mp4',
          thumbnail: '',
          contentType: 'Documentary',
          duration: 0,
        },
        {
          title: 'Episode 2 — The Number',
          description: 'On rating, identity, and the strange relationship between a chess player and the number that follows them their whole career.',
          streamUrl: `${BUNNY_VIDEOS}/mg-ep2-the-number.mp4`,
          streamFormat: 'mp4',
          thumbnail: '',
          contentType: 'Documentary',
          duration: 0,
        },
        {
          title: 'Episode 3 — Brilliance That Bleeds',
          description: 'When chess brilliance and personal cost intersect. Portraits of players whose greatness extracted a price the public never sees.',
          streamUrl: `${BUNNY_VIDEOS}/mg-ep3-brilliance-that-bleeds.mp4`,
          streamFormat: 'mp4',
          thumbnail: '',
          contentType: 'Documentary',
          duration: 0,
        },
        {
          title: "Episode 4 — The Queen's Burden",
          description: "The fourth episode examines women in chess — the talent, the institutional walls, and what a queen's move means inside and outside the 64 squares.",
          streamUrl: `${BUNNY_VIDEOS}/mg-ep4-the-queens-burden.mp4`,
          streamFormat: 'mp4',
          thumbnail: '',
          contentType: 'Documentary',
          duration: 0,
        },
      ],
    },
  ],
};
---
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Watch | Mind's Gambit</title>
  <meta name="description" content="Stream The Mind's Gambit documentary series — four episodes on chess, mind, and culture. Free, ad-free, hosted on the Mind's Gambit network." />
  <!-- Open Graph -->
  <meta property="og:title" content="Watch | Mind's Gambit" />
  <meta property="og:description" content="Stream The Mind's Gambit documentary series — four episodes on chess, mind, and culture." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://mindsgambit.com/watch" />
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
  <!-- HLS.js for m3u8 stream support (kept for future live-stream content) -->
  <script src="https://cdn.jsdelivr.net/npm/hls.js@latest"></script>
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }
    :root {
      --bg-primary: #0a0a0f;
      --bg-secondary: #111118;
      --bg-card: #16161f;
      --bg-card-hover: #1e1e2a;
      --gold: #C8A45E;
      --gold-light: #d4b876;
      --gold-dim: #9a7d3e;
      --text-primary: #f0ece4;
      --text-secondary: #a0a0a8;
      --text-muted: #6a6a74;
      --border: #2a2a35;
      --font-display: 'Cinzel', serif;
      --font-body: 'Inter', sans-serif;
    }
    body { background-color: var(--bg-primary); color: var(--text-primary); font-family: var(--font-body); line-height: 1.6; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    .site-header { position: sticky; top: 0; z-index: 100; background: rgba(10, 10, 15, 0.92); backdrop-filter: blur(12px); border-bottom: 1px solid var(--border); padding: 0 2rem; }
    .header-inner { max-width: 1400px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 72px; }
    .site-logo { font-family: var(--font-display); font-size: 1.4rem; font-weight: 700; color: var(--gold); letter-spacing: 0.08em; }
    .site-logo span { color: var(--text-primary); font-weight: 400; }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a { font-size: 0.9rem; font-weight: 500; color: var(--text-secondary); transition: color 0.2s; letter-spacing: 0.03em; }
    .nav-links a:hover, .nav-links a.active { color: var(--gold); }
    .hero { text-align: center; padding: 4rem 2rem 2rem; max-width: 800px; margin: 0 auto; }
    .hero h1 { font-family: var(--font-display); font-size: 2.8rem; font-weight: 700; color: var(--text-primary); margin-bottom: 0.8rem; }
    .hero h1 em { font-style: normal; color: var(--gold); }
    .hero p { font-size: 1.1rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto 2rem; }
    .roku-badge { display: inline-flex; align-items: center; gap: 0.5rem; background: var(--bg-card); border: 1px solid var(--border); border-radius: 999px; padding: 0.5rem 1.2rem; font-size: 0.85rem; color: var(--text-secondary); }
    .roku-badge .dot { width: 8px; height: 8px; border-radius: 50%; background: var(--gold); }
    .filter-bar { max-width: 1400px; margin: 0 auto; padding: 1rem 2rem 0; display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .filter-btn { background: var(--bg-card); border: 1px solid var(--border); color: var(--text-secondary); padding: 0.5rem 1.2rem; border-radius: 999px; font-size: 0.85rem; font-family: var(--font-body); cursor: pointer; transition: all 0.2s; }
    .filter-btn:hover { border-color: var(--gold-dim); color: var(--text-primary); }
    .filter-btn.active { background: var(--gold); border-color: var(--gold); color: var(--bg-primary); font-weight: 600; }
    .categories-container { max-width: 1400px; margin: 0 auto; padding: 2rem; }
    .category-section { margin-bottom: 3rem; }
    .category-header { display: flex; align-items: center; gap: 1rem; margin-bottom: 1.2rem; padding-bottom: 0.8rem; border-bottom: 1px solid var(--border); }
    .category-header h2 { font-family: var(--font-display); font-size: 1.5rem; font-weight: 600; color: var(--text-primary); }
    .category-count { font-size: 0.8rem; color: var(--text-muted); background: var(--bg-card); padding: 0.2rem 0.7rem; border-radius: 999px; }
    .video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.5rem; }
    .video-card { background: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; transition: all 0.3s ease; cursor: pointer; }
    .video-card:hover { background: var(--bg-card-hover); border-color: var(--gold-dim); transform: translateY(-4px); box-shadow: 0 12px 40px rgba(0, 0, 0, 0.4); }
    .card-thumbnail { position: relative; width: 100%; aspect-ratio: 16 / 9; background: linear-gradient(135deg, #1a1a25 0%, #0a0a0f 100%); overflow: hidden; display: flex; align-items: center; justify-content: center; }
    .card-thumbnail .placeholder-text { font-family: var(--font-display); font-size: 1.4rem; color: var(--gold-dim); letter-spacing: 0.1em; text-align: center; padding: 1rem; opacity: 0.7; }
    .card-thumbnail img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s; }
    .video-card:hover .card-thumbnail img { transform: scale(1.05); }
    .card-thumbnail .play-overlay { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; background: rgba(10, 10, 15, 0.5); opacity: 0; transition: opacity 0.3s; }
    .video-card:hover .play-overlay { opacity: 1; }
    .play-icon { width: 64px; height: 64px; border-radius: 50%; background: var(--gold); display: flex; align-items: center; justify-content: center; box-shadow: 0 8px 24px rgba(200, 164, 94, 0.4); }
    .play-icon svg { width: 28px; height: 28px; fill: var(--bg-primary); margin-left: 4px; }
    .duration-badge { position: absolute; bottom: 8px; right: 8px; background: rgba(0, 0, 0, 0.8); color: var(--text-primary); font-size: 0.75rem; font-weight: 500; padding: 0.15rem 0.5rem; border-radius: 4px; }
    .content-type-badge { position: absolute; top: 8px; left: 8px; background: var(--gold); color: var(--bg-primary); font-size: 0.7rem; font-weight: 600; padding: 0.2rem 0.7rem; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .card-info { padding: 1.2rem 1.4rem 1.4rem; }
    .card-info h3 { font-family: var(--font-display); font-size: 1.1rem; font-weight: 600; color: var(--text-primary); margin-bottom: 0.5rem; line-height: 1.3; }
    .card-info p { font-size: 0.9rem; color: var(--text-secondary); line-height: 1.55; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
    .modal-overlay { display: none; position: fixed; inset: 0; z-index: 1000; background: rgba(0, 0, 0, 0.95); align-items: center; justify-content: center; padding: 2rem; }
    .modal-overlay.active { display: flex; }
    .modal-content { width: 100%; max-width: 1024px; background: var(--bg-secondary); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .modal-video { width: 100%; aspect-ratio: 16 / 9; background: #000; }
    .modal-video video { width: 100%; height: 100%; }
    .modal-info { padding: 1.5rem 2rem; }
    .modal-info h2 { font-family: var(--font-display); font-size: 1.4rem; margin-bottom: 0.6rem; color: var(--text-primary); }
    .modal-info p { font-size: 0.95rem; color: var(--text-secondary); line-height: 1.6; }
    .modal-close { position: absolute; top: 1.5rem; right: 1.5rem; width: 44px; height: 44px; border-radius: 50%; background: rgba(255, 255, 255, 0.1); border: none; color: white; font-size: 1.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; z-index: 10; }
    .modal-close:hover { background: rgba(255, 255, 255, 0.2); }
    .site-footer { text-align: center; padding: 3rem 2rem; border-top: 1px solid var(--border); color: var(--text-muted); font-size: 0.85rem; }
    .site-footer .gold { color: var(--gold); }
    @media (max-width: 768px) {
      .hero h1 { font-size: 2rem; }
      .video-grid { grid-template-columns: 1fr; }
      .nav-links { gap: 1rem; }
      .header-inner { flex-direction: column; height: auto; padding: 1rem 0; gap: 0.8rem; }
    }
  </style>
</head>
<body>
  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">MIND'S <span>GAMBIT</span></a>
      <nav>
        <ul class="nav-links">
          <li><a href="/">Home</a></li>
          <li><a href="/daily">Daily</a></li>
          <li><a href="/watch" class="active">Watch</a></li>
        </ul>
      </nav>
    </div>
  </header>

  <section class="hero">
    <h1>The <em>Mind's</em> Gambit Documentary</h1>
    <p>Four episodes on chess, mind, and the human cost of greatness. Free to stream, ad-free, hosted on the Mind's Gambit network.</p>
    <div class="roku-badge">
      <span class="dot"></span>
      4 Episodes Available
    </div>
  </section>

  <div class="filter-bar">
    <button class="filter-btn active" data-filter="all">All</button>
    {feed.categories.map((cat: any) => (
      <button class="filter-btn" data-filter={cat.id}>{cat.title}</button>
    ))}
  </div>

  <main class="categories-container">
    {feed.categories.map((category: any) => (
      <section class="category-section" data-category={category.id}>
        <div class="category-header">
          <h2>{category.title}</h2>
          <span class="category-count">{category.items.length} episodes</span>
        </div>
        <div class="video-grid">
          {category.items.map((item: any) => (
            <article
              class="video-card"
              data-stream={item.streamUrl}
              data-format={item.streamFormat}
              data-title={item.title}
              data-desc={item.description}
            >
              <div class="card-thumbnail">
                {item.thumbnail ? (
                  <img src={item.thumbnail} alt={item.title} loading="lazy" onerror="this.style.display='none'; this.nextElementSibling.style.display='block';" />
                ) : null}
                <div class="placeholder-text">MIND'S GAMBIT</div>
                <div class="play-overlay">
                  <div class="play-icon">
                    <svg viewBox="0 0 24 24"><polygon points="5,3 19,12 5,21" /></svg>
                  </div>
                </div>
                <span class="content-type-badge">{item.contentType}</span>
                {item.duration > 0 && (
                  <span class="duration-badge">
                    {Math.floor(item.duration / 60)}:{String(item.duration % 60).padStart(2, '0')}
                  </span>
                )}
              </div>
              <div class="card-info">
                <h3>{item.title}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
      </section>
    ))}
  </main>

  <div class="modal-overlay" id="playerModal">
    <button class="modal-close" id="modalClose">&times;</button>
    <div class="modal-content">
      <div class="modal-video">
        <video id="modalVideo" controls preload="metadata" playsinline></video>
      </div>
      <div class="modal-info">
        <h2 id="modalTitle"></h2>
        <p id="modalDesc"></p>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    <p>&copy; 2026 <span class="gold">Mind's Gambit</span>. All rights reserved.</p>
  </footer>

  <script>
    const filterBtns = document.querySelectorAll('.filter-btn');
    const categorySections = document.querySelectorAll('.category-section');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const filter = (btn as HTMLElement).dataset.filter;
        categorySections.forEach(section => {
          if (filter === 'all' || (section as HTMLElement).dataset.category === filter) {
            (section as HTMLElement).style.display = 'block';
          } else {
            (section as HTMLElement).style.display = 'none';
          }
        });
      });
    });

    const modal = document.getElementById('playerModal')!;
    const modalVideo = document.getElementById('modalVideo') as HTMLVideoElement;
    const modalTitle = document.getElementById('modalTitle')!;
    const modalDesc = document.getElementById('modalDesc')!;
    const modalClose = document.getElementById('modalClose')!;
    let hlsInstance: any = null;

    function playStream(streamUrl: string, format: string) {
      if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
      if (format === 'm3u8' && (window as any).Hls && (window as any).Hls.isSupported()) {
        hlsInstance = new (window as any).Hls();
        hlsInstance.loadSource(streamUrl);
        hlsInstance.attachMedia(modalVideo);
        hlsInstance.on((window as any).Hls.Events.MANIFEST_PARSED, () => { modalVideo.play(); });
      } else {
        modalVideo.src = streamUrl;
        modalVideo.play();
      }
    }

    document.querySelectorAll('.video-card').forEach(card => {
      card.addEventListener('click', () => {
        const el = card as HTMLElement;
        const streamUrl = el.dataset.stream!;
        const format = el.dataset.format || 'mp4';
        const title = el.dataset.title!;
        const desc = el.dataset.desc!;
        modalTitle.textContent = title;
        modalDesc.textContent = desc;
        modal.classList.add('active');
        playStream(streamUrl, format);
      });
    });

    function closeModal() {
      modal.classList.remove('active');
      modalVideo.pause();
      modalVideo.src = '';
      if (hlsInstance) { hlsInstance.destroy(); hlsInstance = null; }
    }

    modalClose.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
  </script>

<style is:global>
.nav-burger{display:none;background:none;border:0;font-size:1.7rem;line-height:1;cursor:pointer;color:inherit;padding:0 0.4rem;}
@media (max-width:860px){
 .mg-navwrap{display:flex !important;align-items:center;flex-wrap:wrap !important;}
 .nav-burger{display:block;margin-left:auto;order:2;}
 nav .nav-logo{order:1;}
 nav .nav-links{display:none !important;order:3;flex-basis:100%;width:100%;flex-direction:column;align-items:flex-start;gap:0.15rem;padding:0.5rem 0;}
 nav .nav-links.open{display:flex !important;}
 nav .nav-links li{width:100%;}
 nav .nav-links li a{display:block;padding:0.55rem 0.2rem;width:100%;}
 nav .nav-links .dropdown-menu{display:none !important;}
}
</style>
<script is:inline>
(function(){
 function init(){
  var nav=document.querySelector("nav");
  var links=nav&&nav.querySelector(".nav-links");
  if(nav&&links&&!nav.querySelector(".nav-burger")){
   var wrap=links.parentElement; wrap.classList.add("mg-navwrap");
   var b=document.createElement("button"); b.type="button"; b.className="nav-burger"; b.setAttribute("aria-label","Toggle menu"); b.innerHTML=String.fromCharCode(9776);
   b.addEventListener("click",function(){ links.classList.toggle("open"); });
   wrap.appendChild(b);
   links.addEventListener("click",function(e){ if(e.target&&e.target.closest&&e.target.closest("a")) links.classList.remove("open"); });
  }
  var d=document.querySelectorAll("nav a[href='/daily']"); for(var i=0;i<d.length;i++) d[i].setAttribute("href","/daily-wired");
  var c=document.querySelectorAll("nav a[href*='buymeacoffee']"); for(var k=0;k<c.length;k++){ c[k].textContent="Donate"; c[k].setAttribute("href","/#donate"); }
 }
 if(document.readyState!=="loading") init(); else document.addEventListener("DOMContentLoaded",init);
})();
</script>
</body>
</html>
