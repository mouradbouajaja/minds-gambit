---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Daily Puzzle — Mind's Gambit Chess School" description="A fresh chess puzzle every day. Train tactics, build your streak, sharpen your eye. Free and ad-free — by Mind's Gambit.">

<link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#book">The Book</a></li>
      <li><a href="/watch">Documentary</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/chess-school">Chess School</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>
    </ul>
  </div>
</nav>

<section class="page">
  <a href="/chess-school/grandmasters" class="back-link">&larr; Back to Chess School</a>
  <span class="eyebrow">Mind's Gambit Chess School</span>
  <h1>Daily Puzzle</h1>
  <p class="lead">One fresh tactical puzzle every day. Build the habit. Sharpen the eye. Watch your streak climb.</p>

  <div class="stats-bar">
    <div class="stat"><div class="stat-label">Today</div><div class="stat-value" id="today-date">—</div></div>
    <div class="stat stat-streak"><div class="stat-label">Streak</div><div class="stat-value"><span id="streak-counter">0</span><span class="streak-fire">🔥</span></div></div>
    <div class="stat"><div class="stat-label">Puzzle Rating</div><div class="stat-value" id="puzzle-rating">—</div></div>
    <div class="stat"><div class="stat-label">Times Played</div><div class="stat-value" id="puzzle-plays">—</div></div>
  </div>

  <div class="puzzle-area">
    <div class="board-wrap">
      <div id="puzzle-board"></div>
      <div class="board-status" id="board-status">Loading today's puzzle…</div>
    </div>

    <aside class="puzzle-info">
      <div class="turn-indicator" id="turn-indicator">—</div>
      <div class="info-block"><div class="info-label">Themes</div><div class="info-content theme-tags" id="puzzle-themes">—</div></div>
      <div class="info-block"><div class="info-label">Instructions</div><div class="info-content">Find the best move. The opponent will respond. Continue until the puzzle is solved.</div></div>
      <div class="puzzle-controls" id="puzzle-controls">
        <button class="ctrl-btn" id="btn-hint" type="button">Hint</button>
        <button class="ctrl-btn" id="btn-solution" type="button">Show Solution</button>
        <button class="ctrl-btn" id="btn-reset" type="button">Reset Position</button>
      </div>
      <div class="solved-block" id="solved-block">
        <div class="solved-title">Solved.</div>
        <p class="solved-text">Come back tomorrow for a fresh puzzle. Your streak is logged.</p>
        <a href="/chess-school/grandmasters" class="solved-cta">Work with a Grandmaster &rarr;</a>
      </div>
    </aside>
  </div>

  <div class="habit-card">
    <h2>Why the daily habit works</h2>
    <p>Five minutes of tactics every day &mdash; not an hour every Sunday &mdash; is the single highest-return habit in chess improvement. The patterns sink in faster, your calculation gets sharper, and the game itself stops feeling like a fight against the board and starts feeling like a conversation.</p>
    <p>The streak counter exists because consistency beats intensity. Miss a day and the streak resets &mdash; not as punishment, but as a small honest signal. Show up tomorrow. Try again.</p>
  </div>

  <div class="next-card">
    <h2>Coming soon to Mind's Gambit Chess School</h2>
    <ul class="next-list">
      <li><strong>Tactics Trainer</strong> &mdash; pick a theme (pins, forks, mating nets, endgames), get rated puzzles, track your accuracy.</li>
      <li><strong>Play vs the Computer</strong> &mdash; face Stockfish at any strength, fully in your browser.</li>
      <li><strong>Game Analysis</strong> &mdash; paste a PGN, get a computer evaluation, find your blunders.</li>
      <li><strong>Lessons with Grandmasters</strong> &mdash; structured curricula authored by WGM Maryana Huda and the Mind's Gambit roster.</li>
    </ul>
    <p class="next-note">Built little by little. Free, ad-free, open-source-powered, branded to stay in your lane &mdash; ours.</p>
  </div>

  <p class="attribution">Daily puzzles drawn from the <a href="https://database.lichess.org/#puzzles" target="_blank" rel="noopener">Lichess Open Puzzle Database</a> (CC0 / public domain) — 5.9 million tactics hosted on the Mind’s Gambit CDN. Board rendering powered by chessboard.js and chess.js, both open-source. No tracking. No accounts required.</p>

  <footer class="page-footer">
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind's Gambit Chess School is a production of &copy; MYB Studio LLC.</p>
  </footer>
</section>

<!-- Libraries from jsDelivr / unpkg (cached globally). is:inline keeps Astro from bundling them. -->
<script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/chess.js@0.10.3/chess.min.js"></script>
<script is:inline src="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>

<script is:inline>
(function() {
  'use strict';
  var game, board, solution=[], solutionIdx=0, userColor='w', startFen=null, solved=false, isAnimating=false;
  var statusEl=document.getElementById('board-status');
  var turnEl=document.getElementById('turn-indicator');
  var themesEl=document.getElementById('puzzle-themes');
  var ratingEl=document.getElementById('puzzle-rating');
  var playsEl=document.getElementById('puzzle-plays');
  var streakEl=document.getElementById('streak-counter');
  var dateEl=document.getElementById('today-date');
  var hintBtn=document.getElementById('btn-hint');
  var solBtn=document.getElementById('btn-solution');
  var resetBtn=document.getElementById('btn-reset');
  var solvedBlock=document.getElementById('solved-block');
  var controlsEl=document.getElementById('puzzle-controls');

  dateEl.textContent=new Date().toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});

  function loadStreak(){ var n=parseInt(localStorage.getItem('mg_puzzle_streak')||'0',10); streakEl.textContent=n; return n; }
  function bumpStreakOnSolve(){
    var today=new Date().toISOString().slice(0,10);
    var last=localStorage.getItem('mg_puzzle_lastSolved');
    var streak=parseInt(localStorage.getItem('mg_puzzle_streak')||'0',10);
    if(last===today)return streak;
    var yesterday=new Date(Date.now()-86400000).toISOString().slice(0,10);
    if(last===yesterday)streak+=1; else streak=1;
    localStorage.setItem('mg_puzzle_streak',String(streak));
    localStorage.setItem('mg_puzzle_lastSolved',today);
    streakEl.textContent=streak; return streak;
  }
  loadStreak();

  function setStatus(msg,kind){ statusEl.textContent=msg; statusEl.className='board-status'+(kind?' status-'+kind:''); }
  function setTurn(){
    if(!game||solved)return;
    var t=game.turn()==='w'?'White':'Black';
    var who=(game.turn()===userColor)?'Your move':'Opponent thinking…';
    turnEl.innerHTML='<span class="turn-color turn-'+game.turn()+'">'+t+' to move</span><br/><span class="turn-who">'+who+'</span>';
  }
  function uciToMove(uci){ return {from:uci.substring(0,2),to:uci.substring(2,4),promotion:uci.length>=5?uci.substring(4,5):undefined}; }
  function moveToUci(move){ return move.from+move.to+(move.promotion||''); }

  function onDragStart(source,piece){
    if(solved||isAnimating)return false;
    if(!game||game.game_over())return false;
    if(game.turn()!==userColor)return false;
    if((userColor==='w'&&piece.charAt(0)!=='w')||(userColor==='b'&&piece.charAt(0)!=='b'))return false;
    return true;
  }

  function onDrop(source,target){
    var attempt=game.move({from:source,to:target,promotion:'q'});
    if(attempt===null)return 'snapback';
    var played=moveToUci(attempt);
    var expected=solution[solutionIdx];
    if(played===expected){
      solutionIdx+=1;
      if(solutionIdx>=solution.length){ finishSolved(); return; }
      setStatus('Correct. Watch the response…','good'); setTurn();
      isAnimating=true; setTimeout(playOpponent,550);
    } else {
      setStatus('Not the best move. Try again.','bad');
      setTimeout(function(){ game.undo(); board.position(game.fen()); setTurn(); },700);
    }
  }

  function onSnapEnd(){ board.position(game.fen()); }

  function playOpponent(){
    if(solutionIdx>=solution.length){ finishSolved(); isAnimating=false; return; }
    game.move(uciToMove(solution[solutionIdx]));
    board.position(game.fen());
    solutionIdx+=1; isAnimating=false;
    if(solutionIdx>=solution.length) finishSolved();
    else { setStatus('Your move. Find the best continuation.',''); setTurn(); }
  }

  function finishSolved(){
    solved=true; setStatus('Solved.','good');
    turnEl.innerHTML='<span class="turn-color">Puzzle complete</span>';
    controlsEl.classList.add('controls-done');
    solvedBlock.classList.add('shown');
    bumpStreakOnSolve();
  }

  hintBtn.addEventListener('click',function(){
    if(solved||isAnimating)return;
    if(solutionIdx>=solution.length)return;
    var from=solution[solutionIdx].substring(0,2);
    var squareEl=document.querySelector('.square-'+from);
    if(squareEl){ squareEl.classList.add('hint-square'); setTimeout(function(){ squareEl.classList.remove('hint-square'); },1400); }
    setStatus('Hint: the piece on '+from+' moves.','');
  });

  solBtn.addEventListener('click',function(){
    if(solved)return;
    setStatus('Playing through the full solution…','');
    isAnimating=true;
    function step(){
      if(solutionIdx>=solution.length){ finishSolved(); isAnimating=false; return; }
      game.move(uciToMove(solution[solutionIdx]));
      board.position(game.fen());
      solutionIdx+=1; setTimeout(step,700);
    }
    step();
  });

  resetBtn.addEventListener('click',function(){
    if(!startFen)return;
    game.load(startFen); solutionIdx=0; solved=false;
    solvedBlock.classList.remove('shown'); controlsEl.classList.remove('controls-done');
    board.position(game.fen());
    setStatus('Position reset. Opponent moves first…','');
    setTimeout(function(){
      if(solutionIdx===0&&solution.length>0){
        game.move(uciToMove(solution[0]));
        board.position(game.fen());
        solutionIdx=1;
        setStatus('Your move. Find the best continuation.','');
        setTurn();
      }
    },800);
  });

  var CDN='https://mindsgambit-cdn.b-cdn.net/puzzles';

  function dailySeed(){
    // YYYYMMDD as integer — deterministic per calendar day, same for everyone
    var d=new Date(); var y=d.getUTCFullYear(), m=d.getUTCMonth()+1, day=d.getUTCDate();
    return y*10000 + m*100 + day;
  }

  function loadPuzzle(){
    setStatus('Loading today’s puzzle from Mind’s Gambit CDN…','');
    var seed=dailySeed();
    fetch(CDN+'/metadata.json')
      .then(function(r){ if(!r.ok)throw new Error('Metadata '+r.status); return r.json(); })
      .then(function(meta){
        var shardKeys=meta.shardKeys||[];
        if(!shardKeys.length)throw new Error('No shards in metadata');
        var shardKey=shardKeys[seed % shardKeys.length];
        return fetch(CDN+'/shards/'+shardKey+'.json')
          .then(function(r){ if(!r.ok)throw new Error('Shard '+shardKey+' '+r.status); return r.json(); })
          .then(function(puzzles){
            if(!puzzles.length)throw new Error('Empty shard');
            return puzzles[seed % puzzles.length];
          });
      })
      .then(function(puzzle){
        solution=(puzzle.moves||'').split(' ').filter(Boolean);
        ratingEl.textContent=puzzle.rating||'—';
        playsEl.textContent=(puzzle.nbPlays||0).toLocaleString();
        var themes=(puzzle.themes||[]).slice(0,6);
        themesEl.innerHTML=themes.map(function(t){ return '<span class="theme-tag">'+t.replace(/([A-Z])/g,' $1').toLowerCase().trim()+'</span>'; }).join('');

        game=new Chess();
        game.load(puzzle.fen);
        startFen=game.fen();
        userColor=game.turn()==='w'?'b':'w';

        board=Chessboard('puzzle-board',{
          position:game.fen(),
          orientation:userColor==='w'?'white':'black',
          draggable:true,
          onDragStart:onDragStart,
          onDrop:onDrop,
          onSnapEnd:onSnapEnd,
          pieceTheme:'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/{piece}.png',
          moveSpeed:'slow',
          snapbackSpeed:250
        });

        setStatus('Opponent’s move first…','');
        setTimeout(function(){
          if(solution.length>0){
            game.move(uciToMove(solution[0]));
            board.position(game.fen());
            solutionIdx=1;
            setStatus('Your move. Find the best continuation.','');
            setTurn();
          }
        },1000);

        window.addEventListener('resize',function(){ if(board)board.resize(); });
      })
      .catch(function(err){ setStatus('Could not load today’s puzzle. Refresh to try again. ('+err.message+')','bad'); });
  }

  function whenReady(cb){
    if(window.Chess&&window.Chessboard&&window.jQuery) cb();
    else setTimeout(function(){ whenReady(cb); },50);
  }
  whenReady(loadPuzzle);
})();
</script>
<!-- ============================================================
     MIND'S GAMBIT FAQ BOT — Static keyword-search bot.
     Free. No API calls. Edit the FAQ_DATA array below to add Q&As.
============================================================ -->
<button id="mg-faq-bubble" type="button" aria-label="Need help? Open Mind's Gambit Help" title="Click me for help &mdash; technical questions, engine issues, account, anything.">
