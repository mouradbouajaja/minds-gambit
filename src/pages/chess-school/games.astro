        <div class="games-stat"><span class="games-stat-num">540 yrs</span><span class="games-stat-label">Of history</span></div>
        <div class="games-stat"><span class="games-stat-num">500+</span><span class="games-stat-label">Openings</span></div>
        <div class="games-stat"><span class="games-stat-num">36</span><span class="games-stat-label">Great players</span></div>
