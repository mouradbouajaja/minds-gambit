.footnote { margin: 3rem auto 0; max-width: 900px; font-size: 0.85rem; color: var(--text-3); text-align: center; line-height: 1.6; }

/* ===== Opening Tree (ChessBase-style hierarchy) ===== */
.tree-section { margin: 0 0 2.5rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.tree-section > summary { padding: 1.1rem 1.5rem; cursor: pointer; font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-size: 1.15rem; list-style: none; display: flex; align-items: center; justify-content: space-between; user-select: none; }
.tree-section > summary::-webkit-details-marker { display: none; }
.tree-section > summary::after { content: "\25BE"; color: var(--gold-dim); transition: transform 0.2s; font-size: 0.9rem; }
.tree-section[open] > summary::after { transform: rotate(180deg); }
.tree-section > summary:hover { background: var(--bg-3); }
.tree-body { padding: 0 1.5rem 1.5rem; }
.tree-intro { font-size: 0.92rem; color: var(--text-2); margin: 0 0 1.2rem; line-height: 1.6; padding: 0.9rem 1.1rem; background: var(--bg); border-left: 3px solid var(--gold-dim); border-radius: 6px; }
.tree-intro strong { color: var(--text); }

.tree-node { border-left: 2px solid rgba(201, 168, 76, 0.15); margin-left: 0.5rem; padding-left: 0.9rem; margin-bottom: 0.45rem; }
.tree-node > summary { padding: 0.55rem 0.7rem; cursor: pointer; font-size: 0.96rem; color: var(--text); list-style: none; user-select: none; border-radius: 6px; transition: background 0.15s; display: flex; align-items: center; gap: 0.5rem; }
.tree-node > summary::-webkit-details-marker { display: none; }
.tree-node > summary::before { content: "\25B8"; color: var(--gold-dim); font-size: 0.75rem; transition: transform 0.2s; flex-shrink: 0; }
.tree-node[open] > summary::before { transform: rotate(90deg); }
.tree-node > summary:hover { background: var(--bg-3); }
.tree-help { font-size: 0.82rem; color: var(--text-3); font-style: italic; padding: 0.2rem 0.7rem 0.8rem 1.9rem; line-height: 1.5; }

.tree-subnode { border-left: 2px solid rgba(201, 168, 76, 0.1); margin-left: 0.7rem; padding-left: 0.8rem; margin: 0.3rem 0; }
.tree-subnode > summary { padding: 0.45rem 0.7rem; cursor: pointer; font-size: 0.88rem; color: var(--text-2); list-style: none; user-select: none; border-radius: 6px; transition: background 0.15s; display: flex; align-items: center; gap: 0.5rem; }
.tree-subnode > summary::-webkit-details-marker { display: none; }
.tree-subnode > summary::before { content: "\25B8"; color: rgba(201, 168, 76, 0.45); font-size: 0.7rem; transition: transform 0.2s; flex-shrink: 0; }
.tree-subnode[open] > summary::before { transform: rotate(90deg); }
.tree-subnode > summary:hover { background: var(--bg-3); color: var(--text); }

.tree-leaves { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.3rem; padding: 0.4rem 0 0.7rem 0.5rem; }
.tree-leaf { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.7rem; cursor: pointer; display: flex; align-items: center; gap: 0.6rem; transition: all 0.15s; font-size: 0.82rem; }
.tree-leaf:hover { border-color: var(--gold); background: var(--bg-3); }
.tree-leaf-code { font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-weight: 600; flex-shrink: 0; min-width: 38px; }
.tree-leaf-name { color: var(--text); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.8rem; }
.tree-leaf-count { color: var(--text-3); font-size: 0.72rem; font-variant-numeric: tabular-nums; flex-shrink: 0; }

/* Tournament series + Opening family collapsible blocks */
.tournament-series, .opening-family { margin: 0 0 1.2rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.tournament-series-summary, .opening-family-summary { padding: 1rem 1.4rem; cursor: pointer; font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-size: 1.05rem; list-style: none; display: flex; align-items: center; justify-content: space-between; user-select: none; gap: 0.8rem; }
.tournament-series-summary::-webkit-details-marker, .opening-family-summary::-webkit-details-marker { display: none; }
.tournament-series-summary::after, .opening-family-summary::after { content: "\25BE"; color: var(--gold-dim); transition: transform 0.2s; font-size: 0.85rem; }
.tournament-series[open] .tournament-series-summary::after,
.opening-family[open] .opening-family-summary::after { transform: rotate(180deg); }
.tournament-series-summary:hover, .opening-family-summary:hover { background: var(--bg-3); }
.tournament-series-name, .opening-family-name { flex: 1; }
.tournament-series-count, .opening-family-count { color: var(--text-3); font-family: 'Inter', system-ui, sans-serif; font-size: 0.78rem; letter-spacing: 0.08em; text-transform: uppercase; }
.tournament-series-intro, .opening-family-intro { padding: 0 1.4rem 1rem; margin: 0 0 0.8rem; font-size: 0.92rem; color: var(--text-2); line-height: 1.55; font-style: italic; border-bottom: 1px solid var(--border); }
.tournament-series .games-grid, .opening-family .games-grid { padding: 0 1.4rem 1.2rem; }
.tournament-card { display: flex; flex-direction: column; gap: 0.4rem; }
.opening-card .game-card-name { font-size: 0.92rem; }

/* ===== Viewer Modal ===== */
.viewer-overlay { display: none; position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.92); padding: 1.5rem; overflow-y: auto; }
.viewer-overlay.active { display: flex; align-items: center; justify-content: center; }
.viewer-modal { background: var(--bg-2); border: 1px solid var(--border); border-radius: 14px; width: 100%; max-width: 1280px; max-height: 92vh; display: grid; grid-template-columns: 280px 1fr 320px; grid-template-rows: auto 1fr; gap: 0; overflow: hidden; }
.viewer-header { grid-column: 1 / 4; display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-3); }
.viewer-title { font-family: 'Playfair Display', Georgia, serif; font-size: 1.2rem; color: var(--gold); margin: 0; }
.viewer-sub { font-size: 0.8rem; color: var(--text-3); margin-top: 0.15rem; }
.viewer-close { background: rgba(255,255,255,0.08); border: none; color: white; width: 38px; height: 38px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; transition: background 0.2s; }
.viewer-close:hover { background: rgba(255,255,255,0.18); }

.viewer-gamelist { border-right: 1px solid var(--border); overflow-y: auto; max-height: 75vh; padding: 0.5rem; }
