---

<BaseLayout title="Our Games Library | Mind's Gambit" description="Play through 14.8 million chess games on the board, right here. Modern tournaments, historical masters, and every great player from Morphy to Carlsen. Free, on the Mind's Gambit network, no downloads required.">

<style>
:root {
  --bg: #0f111c;
  --bg-2: #181b2a;
  --bg-3: #1f2335;
  --gold: #c9a84c;
  --gold-dim: #9a7d3e;
  --text: #e8e0d0;
  --text-2: rgba(232, 224, 208, 0.7);
  --text-3: rgba(232, 224, 208, 0.45);
  --border: rgba(201, 168, 76, 0.2);
  --light-sq: #f5ead6;
  --dark-sq: #c9a87a;
  --board-border: #2a2a35;
}

.games-page { background: var(--bg); color: var(--text); min-height: 100vh; padding: 4rem 1.5rem 6rem; font-family: 'Inter', system-ui, sans-serif; }
.games-inner { max-width: 1200px; margin: 0 auto; }
.games-hero { text-align: center; margin-bottom: 3rem; }
.games-eyebrow { display: inline-block; color: var(--gold); font-family: 'Playfair Display', Georgia, serif; font-size: 0.8rem; letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 0.6rem; }
.games-title { font-family: 'Playfair Display', Georgia, serif; font-size: 3rem; margin: 0 0 0.7rem; color: var(--text); }
.games-sub { color: var(--text-2); font-size: 1.05rem; max-width: 720px; margin: 0 auto; line-height: 1.6; }
.games-stats { display: flex; justify-content: center; gap: 2.5rem; flex-wrap: wrap; margin: 2rem 0 0; padding-top: 1.5rem; border-top: 1px solid var(--border); }
.games-stat { text-align: center; }
.games-stat-num { font-family: 'Playfair Display', Georgia, serif; font-size: 1.8rem; color: var(--gold); display: block; }
.games-stat-label { font-size: 0.78rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin-top: 0.2rem; display: block; }

.tab-bar { display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; margin-bottom: 2rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border); }
.tab-btn { background: var(--bg-2); border: 1px solid var(--border); color: var(--text-2); padding: 0.7rem 1.4rem; border-radius: 999px; font-size: 0.9rem; font-family: inherit; cursor: pointer; transition: all 0.2s; letter-spacing: 0.04em; }
.tab-btn:hover { border-color: var(--gold-dim); color: var(--text); }
.tab-btn.active { background: var(--gold); border-color: var(--gold); color: var(--bg); font-weight: 600; }

.tab-panel { display: none; }
.tab-panel.active { display: block; }
.panel-intro { background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; padding: 1.5rem 1.8rem; margin-bottom: 1.5rem; font-size: 0.95rem; color: var(--text-2); line-height: 1.6; }
.panel-intro strong { color: var(--text); }

.search-row { display: flex; gap: 0.8rem; margin-bottom: 1.5rem; flex-wrap: wrap; }
.search-input { flex: 1; min-width: 220px; background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 0.8rem 1rem; color: var(--text); font-family: inherit; font-size: 0.95rem; }
.search-input:focus { outline: none; border-color: var(--gold); }
.search-info { align-self: center; font-size: 0.85rem; color: var(--text-3); }

.games-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 0.9rem; }
.game-card { background: var(--bg-2); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.1rem; transition: all 0.2s; display: flex; flex-direction: column; gap: 0.6rem; cursor: pointer; }
.game-card:hover { border-color: var(--gold); background: var(--bg-3); transform: translateY(-2px); }
.game-card-head { display: flex; align-items: baseline; justify-content: space-between; gap: 0.8rem; }
.game-card-code { font-family: 'Playfair Display', Georgia, serif; font-size: 1.15rem; color: var(--gold); font-weight: 600; }
.game-card-size { font-size: 0.75rem; color: var(--text-3); font-variant-numeric: tabular-nums; }
.game-card-name { font-size: 0.95rem; color: var(--text); line-height: 1.35; }
.game-card-stats { font-size: 0.78rem; color: var(--text-3); font-variant-numeric: tabular-nums; letter-spacing: 0.03em; }
.game-card-cta { display: inline-flex; align-items: center; justify-content: center; gap: 0.4rem; margin-top: 0.4rem; padding: 0.5rem 0.9rem; background: transparent; border: 1px solid var(--gold-dim); color: var(--gold); text-decoration: none; border-radius: 8px; font-size: 0.85rem; font-family: inherit; letter-spacing: 0.03em; pointer-events: none; }
.game-card:hover .game-card-cta { background: var(--gold); color: var(--bg); border-color: var(--gold); }

.empty, .loading { text-align: center; padding: 3rem 1rem; color: var(--text-3); font-style: italic; }
.loading::after { content: ""; display: inline-block; width: 16px; height: 16px; margin-left: 0.6rem; border: 2px solid var(--gold-dim); border-top-color: transparent; border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: middle; }
@keyframes spin { to { transform: rotate(360deg); } }

.placeholder-card { background: var(--bg-2); border: 1px dashed var(--border); border-radius: 12px; padding: 3rem 2rem; text-align: center; color: var(--text-2); max-width: 720px; margin: 2rem auto; }
.placeholder-card h3 { font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-size: 1.4rem; margin: 0 0 0.7rem; }
.placeholder-card p { line-height: 1.6; margin: 0 0 0.5rem; }
.placeholder-card .meta { font-size: 0.85rem; color: var(--text-3); margin-top: 1rem; }

.footnote { margin: 3rem auto 0; max-width: 900px; font-size: 0.85rem; color: var(--text-3); text-align: center; line-height: 1.6; }

/* ===== Opening Tree (ChessBase-style hierarchy) ===== */
.tree-section { margin: 0 0 2.5rem; background: var(--bg-2); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
.tree-section > summary { padding: 1.1rem 1.5rem; cursor: pointer; font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-size: 1.15rem; list-style: none; display: flex; align-items: center; justify-content: space-between; user-select: none; }
.tree-section > summary::-webkit-details-marker { display: none; }
.tree-section > summary::after { content: "\25BE"; color: var(--gold-dim); transition: transform 0.2s; font-size: 0.9rem; }
.tree-section[open] > summary::after { transform: rotate(180deg); }
.tree-section > summary:hover { background: var(--bg-3); }
.tree-body { padding: 0 1.5rem 1.5rem; }
.tree-intro { font-size: 0.92rem; color: var(--text-2); margin: 0 0 1.2rem; line-height: 1.6; padding: 0.9rem 1.1rem; background: var(--bg); border-left: 3px solid var(--gold-dim); border-radius: 6px; }
.tree-intro strong { color: var(--text); }

.tree-node { border-left: 2px solid rgba(201, 168, 76, 0.15); margin-left: 0.5rem; padding-left: 0.9rem; margin-bottom: 0.45rem; }
.tree-node > summary { padding: 0.55rem 0.7rem; cursor: pointer; font-size: 0.96rem; color: var(--text); list-style: none; user-select: none; border-radius: 6px; transition: background 0.15s; display: flex; align-items: center; gap: 0.5rem; }
.tree-node > summary::-webkit-details-marker { display: none; }
.tree-node > summary::before { content: "\25B8"; color: var(--gold-dim); font-size: 0.75rem; transition: transform 0.2s; flex-shrink: 0; }
.tree-node[open] > summary::before { transform: rotate(90deg); }
.tree-node > summary:hover { background: var(--bg-3); }
.tree-help { font-size: 0.82rem; color: var(--text-3); font-style: italic; padding: 0.2rem 0.7rem 0.8rem 1.9rem; line-height: 1.5; }

.tree-subnode { border-left: 2px solid rgba(201, 168, 76, 0.1); margin-left: 0.7rem; padding-left: 0.8rem; margin: 0.3rem 0; }
.tree-subnode > summary { padding: 0.45rem 0.7rem; cursor: pointer; font-size: 0.88rem; color: var(--text-2); list-style: none; user-select: none; border-radius: 6px; transition: background 0.15s; display: flex; align-items: center; gap: 0.5rem; }
.tree-subnode > summary::-webkit-details-marker { display: none; }
.tree-subnode > summary::before { content: "\25B8"; color: rgba(201, 168, 76, 0.45); font-size: 0.7rem; transition: transform 0.2s; flex-shrink: 0; }
.tree-subnode[open] > summary::before { transform: rotate(90deg); }
.tree-subnode > summary:hover { background: var(--bg-3); color: var(--text); }

.tree-leaves { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 0.3rem; padding: 0.4rem 0 0.7rem 0.5rem; }
.tree-leaf { background: var(--bg); border: 1px solid var(--border); border-radius: 6px; padding: 0.45rem 0.7rem; cursor: pointer; display: flex; align-items: center; gap: 0.6rem; transition: all 0.15s; font-size: 0.82rem; }
.tree-leaf:hover { border-color: var(--gold); background: var(--bg-3); }
.tree-leaf-code { font-family: 'Playfair Display', Georgia, serif; color: var(--gold); font-weight: 600; flex-shrink: 0; min-width: 38px; }
.tree-leaf-name { color: var(--text); flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; font-size: 0.8rem; }
.tree-leaf-count { color: var(--text-3); font-size: 0.72rem; font-variant-numeric: tabular-nums; flex-shrink: 0; }

/* ===== Viewer Modal ===== */
.viewer-overlay { display: none; position: fixed; inset: 0; z-index: 1000; background: rgba(0,0,0,0.92); padding: 1.5rem; overflow-y: auto; }
.viewer-overlay.active { display: flex; align-items: center; justify-content: center; }
.viewer-modal { background: var(--bg-2); border: 1px solid var(--border); border-radius: 14px; width: 100%; max-width: 1280px; max-height: 92vh; display: grid; grid-template-columns: 280px 1fr 320px; grid-template-rows: auto 1fr; gap: 0; overflow: hidden; }
.viewer-header { grid-column: 1 / 4; display: flex; align-items: center; justify-content: space-between; padding: 1rem 1.5rem; border-bottom: 1px solid var(--border); background: var(--bg-3); }
.viewer-title { font-family: 'Playfair Display', Georgia, serif; font-size: 1.2rem; color: var(--gold); margin: 0; }
.viewer-sub { font-size: 0.8rem; color: var(--text-3); margin-top: 0.15rem; }
.viewer-close { background: rgba(255,255,255,0.08); border: none; color: white; width: 38px; height: 38px; border-radius: 50%; font-size: 1.3rem; cursor: pointer; transition: background 0.2s; }
.viewer-close:hover { background: rgba(255,255,255,0.18); }

.viewer-gamelist { border-right: 1px solid var(--border); overflow-y: auto; max-height: 75vh; padding: 0.5rem; }
.viewer-gamelist h4 { font-size: 0.75rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin: 0.5rem 0.7rem 0.6rem; }
.viewer-gameitem { padding: 0.7rem 0.8rem; border-radius: 8px; cursor: pointer; border: 1px solid transparent; margin-bottom: 0.3rem; transition: background 0.15s, border-color 0.15s; }
.viewer-gameitem:hover { background: var(--bg-3); }
.viewer-gameitem.active { background: var(--bg-3); border-color: var(--gold-dim); }
.viewer-gameitem-players { font-size: 0.88rem; color: var(--text); line-height: 1.3; }
.viewer-gameitem-meta { font-size: 0.72rem; color: var(--text-3); margin-top: 0.2rem; display: flex; gap: 0.6rem; flex-wrap: wrap; }
.viewer-gameitem-result { color: var(--gold); font-weight: 600; }

.viewer-board { padding: 1.5rem; display: flex; align-items: flex-start; justify-content: center; background: var(--bg); }
.board-wrap { width: 100%; max-width: 500px; }
.board-svg { width: 100%; height: auto; display: block; border: 2px solid var(--board-border); border-radius: 4px; }
.board-controls { display: flex; gap: 0.4rem; justify-content: center; margin-top: 0.9rem; }
.board-btn { background: var(--bg-2); border: 1px solid var(--border); color: var(--text); padding: 0.5rem 0.9rem; border-radius: 8px; font-family: inherit; font-size: 0.9rem; cursor: pointer; transition: all 0.15s; min-width: 56px; }
.board-btn:hover:not(:disabled) { border-color: var(--gold); background: var(--bg-3); }
.board-btn:disabled { opacity: 0.4; cursor: not-allowed; }
.board-position { text-align: center; margin-top: 0.6rem; font-size: 0.85rem; color: var(--text-3); font-variant-numeric: tabular-nums; }

.viewer-side { border-left: 1px solid var(--border); padding: 1.2rem; overflow-y: auto; max-height: 75vh; display: flex; flex-direction: column; gap: 1rem; }
.game-headers { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 1rem 1.1rem; }
.game-headers-title { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin: 0 0 0.5rem; }
.game-headers dl { display: grid; grid-template-columns: auto 1fr; gap: 0.3rem 0.8rem; margin: 0; font-size: 0.84rem; }
.game-headers dt { color: var(--text-3); }
.game-headers dd { color: var(--text); margin: 0; word-break: break-word; }

.movelist-wrap { background: var(--bg); border: 1px solid var(--border); border-radius: 10px; padding: 0.9rem 1rem; min-height: 0; flex: 1; display: flex; flex-direction: column; }
.movelist-wrap h5 { font-size: 0.72rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--text-3); margin: 0 0 0.6rem; }
.movelist { flex: 1; overflow-y: auto; font-family: 'JetBrains Mono', 'Menlo', monospace; font-size: 0.85rem; line-height: 1.55; color: var(--text); }
.move-num { color: var(--text-3); margin-right: 0.35rem; }
.move-san { display: inline-block; padding: 0 0.3rem; border-radius: 3px; cursor: pointer; transition: background 0.1s; }
.move-san:hover { background: var(--bg-3); }
.move-san.current { background: var(--gold); color: var(--bg); font-weight: 600; }

.viewer-empty { text-align: center; color: var(--text-3); font-style: italic; padding: 3rem 1rem; }

@media (max-width: 1024px) {
  .viewer-modal { grid-template-columns: 1fr; max-height: 96vh; }
  .viewer-gamelist { max-height: 30vh; border-right: none; border-bottom: 1px solid var(--border); }
  .viewer-side { max-height: none; border-left: none; border-top: 1px solid var(--border); }
}
@media (max-width: 768px) { .games-title { font-size: 2.1rem; } .games-stats { gap: 1.5rem; } }
