---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;
---

<BaseLayout title="Play The Mind's Gambit — Chess School" description="Face our engine in your browser. Pick any strength from just-learning to merciless. Free, ad-free, no accounts. Powered by Stockfish.">

<link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#book">The Book</a></li>
      <li><a href="/watch">Documentary</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/chess-school">Chess School</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>
    </ul>
  </div>
</nav>

<section class="page">
  <a href="/chess-school" class="back-link">&larr; Back to Chess School</a>
  <span class="eyebrow">Mind's Gambit Chess School</span>
  <h1>Play The Mind&rsquo;s Gambit</h1>
  <p class="lead">Face our engine. Twenty levels of strength &mdash; from "just learning" to "merciless." All in your browser. No accounts, no waiting, no ads.</p>

  <!-- Setup state (shown first) -->
  <div id="setup-panel" class="setup-panel">
    <div class="setup-block player-block">
      <label class="setup-label" for="player-name">Your name <span class="setup-label-thin">(saved on this device)</span></label>
      <div class="player-row">
        <input type="text" id="player-name" maxlength="24" placeholder="Anonymous Player" autocomplete="off" />
        <div class="player-rating-display">
          <span class="player-rating-value" id="player-rating">1200</span>
          <span class="player-rating-label">your rating</span>
        </div>
      </div>
      <div class="player-stats-grid">
        <div class="player-stat"><span class="player-stat-num" id="stat-wins">0</span><span class="player-stat-label">Wins</span></div>
        <div class="player-stat"><span class="player-stat-num" id="stat-losses">0</span><span class="player-stat-label">Losses</span></div>
        <div class="player-stat"><span class="player-stat-num" id="stat-draws">0</span><span class="player-stat-label">Draws</span></div>
        <div class="player-stat"><span class="player-stat-num" id="stat-peak">1200</span><span class="player-stat-label">Peak</span></div>
      </div>
    </div>

    <div class="setup-block">
      <label class="setup-label">Pick your strength</label>
      <div class="strength-row">
        <input type="range" min="0" max="20" value="5" id="skill-slider" />
        <div class="strength-display">
          <span class="strength-value" id="skill-value">5</span>
          <span class="strength-desc" id="skill-desc">Casual club</span>
        </div>
      </div>
    </div>

    <div class="setup-block">
      <label class="setup-label">Play as</label>
      <div class="color-row">
        <button class="color-btn color-btn-active" data-color="w" type="button"><span class="color-king">&#9812;</span> White</button>
        <button class="color-btn" data-color="b" type="button"><span class="color-king color-king-dark">&#9818;</span> Black</button>
        <button class="color-btn" data-color="random" type="button">&#127922; Random</button>
      </div>
    </div>

    <div class="setup-block">
      <button class="start-btn" id="start-btn" type="button" disabled>Loading engine&hellip;</button>
      <p class="setup-note" id="setup-note">Loading Stockfish&hellip;</p>
    </div>
  </div>

  <!-- Playing state (hidden until game starts) -->
  <div id="play-panel" class="play-panel hidden">
    <div class="play-area">
      <div class="board-wrap">
        <div id="play-board"></div>
        <div class="board-status" id="board-status">Game on.</div>
      </div>

      <aside class="game-info">
        <div class="player-banner">
          <div class="player-banner-row">
            <span class="player-banner-name" id="play-player-name">Anonymous Player</span>
            <span class="player-banner-rating" id="play-player-rating">1200</span>
          </div>
          <span class="player-banner-vs">vs. Mind&rsquo;s Gambit Engine</span>
        </div>
        <div class="info-row">
          <div class="info-stat">
            <span class="info-stat-label">You play</span>
            <span class="info-stat-value" id="player-color">&mdash;</span>
          </div>
          <div class="info-stat">
            <span class="info-stat-label">Engine Skill</span>
            <span class="info-stat-value" id="engine-skill">&mdash;</span>
          </div>
          <div class="info-stat">
            <span class="info-stat-label">Turn</span>
            <span class="info-stat-value" id="turn-display">&mdash;</span>
          </div>
        </div>

        <div class="move-history">
          <div class="info-label">Move History</div>
          <div class="move-list" id="move-list"></div>
        </div>

        <div class="play-controls">
          <button class="ctrl-btn" id="btn-flip" type="button">&#8645; Flip Board</button>
          <button class="ctrl-btn" id="btn-takeback" type="button">&#8630; Take Back</button>
          <button class="ctrl-btn" id="btn-resign" type="button">&#9873; Resign</button>
          <button class="ctrl-btn ctrl-btn-primary" id="btn-newgame" type="button">&#8634; New Game</button>
        </div>

        <div class="game-over" id="game-over">
          <div class="game-over-title" id="game-over-title">&mdash;</div>
          <div class="game-over-sub" id="game-over-sub">&mdash;</div>
          <div class="rating-delta" id="rating-delta"></div>
          <button class="ctrl-btn ctrl-btn-primary" id="btn-rematch" type="button">Play Again</button>
        </div>
      </aside>
    </div>
  </div>

  <p class="attribution">
    Engine: <a href="https://stockfishchess.org/" target="_blank" rel="noopener">Stockfish</a> &mdash; the world&rsquo;s leading open-source chess engine, distributed under the <a href="https://www.gnu.org/licenses/gpl-3.0.en.html" target="_blank" rel="noopener">GNU General Public License v3</a>. Board rendering powered by chessboard.js and chess.js. No tracking. No accounts.
  </p>

  <footer class="page-footer">
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind&rsquo;s Gambit Chess School is a production of &copy; MYB Studio LLC.</p>
  </footer>
</section>

<script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/chess.js@0.10.3/chess.min.js"></script>
<script is:inline src="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>

<script is:inline>
(function() {
  'use strict';

  // ----- Strength descriptions -----
  var SKILL_DESCS = [
    'Just learning', 'Beginner', 'Beginner+', 'Improving', 'Improving+',
    'Casual club', 'Club player', 'Club+', 'Strong club', 'Strong+',
    'Tournament', 'Tournament+', 'Expert', 'Expert+', 'Master',
    'Master+', 'Strong master', 'IM-level', 'GM-level', 'Super-GM', 'Merciless'
  ];

  // ----- State -----
  var stockfish = null;          // The Worker
  var stockfishReady = false;
  var game = null;               // chess.js instance
  var board = null;              // chessboard.js instance
  var userColor = 'w';
  var engineColor = 'b';
  var skillLevel = 5;
  var gameOver = false;
  var enginePending = false;
  var resultRecorded = false;    // Prevent double-counting (e.g. resign then checkmate)

  // ----- Player profile (localStorage, no account needed) -----
  var DEFAULT_RATING = 1200;
  var player = loadPlayer();

  function loadPlayer() {
    try {
      var name = localStorage.getItem('mg_player_name') || '';
      var rating = parseInt(localStorage.getItem('mg_player_rating') || String(DEFAULT_RATING), 10);
      var stats = JSON.parse(localStorage.getItem('mg_player_stats') || 'null') || { wins: 0, losses: 0, draws: 0, peak: DEFAULT_RATING, games: 0 };
      return { name: name, rating: rating, stats: stats };
    } catch (e) {
      return { name: '', rating: DEFAULT_RATING, stats: { wins: 0, losses: 0, draws: 0, peak: DEFAULT_RATING, games: 0 } };
    }
  }

  function savePlayer() {
    try {
      localStorage.setItem('mg_player_name', player.name || '');
      localStorage.setItem('mg_player_rating', String(player.rating));
      localStorage.setItem('mg_player_stats', JSON.stringify(player.stats));
    } catch (e) {}
  }

  function engineRating(skill) {
    // Map Stockfish skill 0..20 to approximate engine playing strength
    // skill 0 → ~800, skill 10 → ~1800, skill 20 → ~2800
    return 800 + skill * 100;
  }

  function expectedScore(playerR, engineR) {
    return 1 / (1 + Math.pow(10, (engineR - playerR) / 400));
  }

  function kFactor() {
    // Higher K for fewer games (learns rating faster), lower K once stable
    if (player.stats.games < 30) return 32;
    if (player.rating < 2400) return 24;
    return 16;
  }

  function updateRatingFromResult(result) {
    // result: 1 = win, 0.5 = draw, 0 = loss
    var oldRating = player.rating;
    var E = expectedScore(player.rating, engineRating(skillLevel));
    var k = kFactor();
    var delta = Math.round(k * (result - E));
    var newRating = Math.max(100, player.rating + delta);
    player.rating = newRating;
    if (newRating > player.stats.peak) player.stats.peak = newRating;
    if (result === 1) player.stats.wins += 1;
    else if (result === 0) player.stats.losses += 1;
    else player.stats.draws += 1;
    player.stats.games += 1;
    savePlayer();
    refreshPlayerUI();
    return { oldRating: oldRating, newRating: newRating, delta: delta };
  }

  function refreshPlayerUI() {
    var nameDisplay = player.name && player.name.trim() ? player.name : 'Anonymous Player';
    var ratingEl = document.getElementById('player-rating');
    var peakEl = document.getElementById('stat-peak');
    var winsEl = document.getElementById('stat-wins');
    var lossesEl = document.getElementById('stat-losses');
    var drawsEl = document.getElementById('stat-draws');
    var playNameEl = document.getElementById('play-player-name');
    var playRatingEl = document.getElementById('play-player-rating');
    if (ratingEl) ratingEl.textContent = player.rating;
    if (peakEl) peakEl.textContent = player.stats.peak;
    if (winsEl) winsEl.textContent = player.stats.wins;
    if (lossesEl) lossesEl.textContent = player.stats.losses;
    if (drawsEl) drawsEl.textContent = player.stats.draws;
    if (playNameEl) playNameEl.textContent = nameDisplay;
    if (playRatingEl) playRatingEl.textContent = player.rating;
  }

  // ----- DOM refs -----
  var skillSlider = document.getElementById('skill-slider');
  var skillValue = document.getElementById('skill-value');
  var skillDesc = document.getElementById('skill-desc');
  var colorBtns = Array.from(document.querySelectorAll('.color-btn'));
  var startBtn = document.getElementById('start-btn');
  var setupNote = document.getElementById('setup-note');
  var setupPanel = document.getElementById('setup-panel');
  var playPanel = document.getElementById('play-panel');
  var statusEl = document.getElementById('board-status');
  var turnEl = document.getElementById('turn-display');
  var playerColorEl = document.getElementById('player-color');
  var engineSkillEl = document.getElementById('engine-skill');
  var moveListEl = document.getElementById('move-list');
  var gameOverEl = document.getElementById('game-over');
  var gameOverTitle = document.getElementById('game-over-title');
  var gameOverSub = document.getElementById('game-over-sub');

  // ----- Initialize Stockfish via blob worker (avoids cross-origin worker issues) -----
  function initStockfish() {
    setupNote.textContent = 'Loading engine (Stockfish)…';
    var STOCKFISH_URL = 'https://cdn.jsdelivr.net/gh/lichess-org/stockfish.js@master/stockfish.js';
    fetch(STOCKFISH_URL)
      .then(function(r) { if (!r.ok) throw new Error('Engine fetch ' + r.status); return r.text(); })
      .then(function(code) {
        var blob = new Blob([code], { type: 'application/javascript' });
        var workerUrl = URL.createObjectURL(blob);
        stockfish = new Worker(workerUrl);
        stockfish.onmessage = handleEngineMessage;
        stockfish.postMessage('uci');
      })
      .catch(function(err) {
        setupNote.textContent = 'Could not load engine: ' + err.message + '. Refresh to retry.';
      });
  }

  function handleEngineMessage(e) {
    var msg = String(e.data || '');
    if (msg === 'uciok' || msg.indexOf('uciok') !== -1) {
      stockfish.postMessage('isready');
      return;
    }
    if (msg === 'readyok' || msg.indexOf('readyok') !== -1) {
      if (!stockfishReady) {
        stockfishReady = true;
        startBtn.disabled = false;
        startBtn.textContent = 'Start Game';
        setupNote.textContent = 'Engine ready. Pick your level and color, then start.';
      }
      return;
    }
    if (msg.indexOf('bestmove') === 0 || msg.indexOf('bestmove') !== -1) {
      var parts = msg.split(/\s+/);
      var bi = parts.indexOf('bestmove');
      var bm = parts[bi + 1];
      if (bm && bm !== '(none)') {
        applyEngineMove(bm);
      } else {
        // No move (mate/stalemate)
        enginePending = false;
        evaluateGameOver();
      }
    }
  }

  function applyEngineMove(uci) {
    if (!game || gameOver) { enginePending = false; return; }
    var move = {
      from: uci.substring(0, 2),
      to: uci.substring(2, 4),
      promotion: uci.length >= 5 ? uci.substring(4, 5) : undefined
    };
    var result = game.move(move);
    if (!result) {
      // Engine produced an illegal move — shouldn't happen
      enginePending = false;
      return;
    }
    board.position(game.fen());
    pushMove(result);
    enginePending = false;
    if (evaluateGameOver()) return;
    setStatus('Your move.', '');
    updateTurn();
  }

  // ----- Slider UI -----
  skillSlider.addEventListener('input', function() {
    var v = parseInt(skillSlider.value, 10);
    skillLevel = v;
    skillValue.textContent = v;
    skillDesc.textContent = SKILL_DESCS[v] || ('Level ' + v);
  });
  // Initial display
  skillValue.textContent = skillSlider.value;
  skillDesc.textContent = SKILL_DESCS[parseInt(skillSlider.value, 10)] || '—';

  // ----- Color picker -----
  colorBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      colorBtns.forEach(function(b) { b.classList.remove('color-btn-active'); });
      btn.classList.add('color-btn-active');
    });
  });

  function getPickedColor() {
    var active = document.querySelector('.color-btn-active');
    var c = active ? active.getAttribute('data-color') : 'w';
    if (c === 'random') return Math.random() < 0.5 ? 'w' : 'b';
    return c;
  }

  // ----- Start game -----
  startBtn.addEventListener('click', function() {
    if (!stockfishReady) return;
    userColor = getPickedColor();
    engineColor = userColor === 'w' ? 'b' : 'w';
    setupPanel.classList.add('hidden');
    playPanel.classList.remove('hidden');
    gameOverEl.classList.remove('shown');
    startGame();
  });

  function startGame() {
    gameOver = false;
    enginePending = false;
    resultRecorded = false;
    refreshPlayerUI();
    game = new Chess();
    playerColorEl.textContent = userColor === 'w' ? 'White' : 'Black';
    engineSkillEl.textContent = skillLevel + ' / 20';
    moveListEl.innerHTML = '';

    if (board) { try { board.destroy && board.destroy(); } catch (e) {} }
    board = Chessboard('play-board', {
      position: 'start',
      orientation: userColor === 'w' ? 'white' : 'black',
      draggable: true,
      onDragStart: onDragStart,
      onDrop: onDrop,
      onSnapEnd: function() { board.position(game.fen()); },
      pieceTheme: 'https://cdn.jsdelivr.net/gh/oakmac/chessboardjs@v1.0.0/website/img/chesspieces/wikipedia/{piece}.png',
      moveSpeed: 150,
      snapbackSpeed: 200,
      snapSpeed: 60
    });

    // Configure engine
    stockfish.postMessage('ucinewgame');
    stockfish.postMessage('setoption name Skill Level value ' + skillLevel);
    stockfish.postMessage('isready');

    setStatus(userColor === 'w' ? 'Your move. Make your opening.' : 'Engine moves first…', '');
    updateTurn();

    if (engineColor === 'w') {
      setTimeout(requestEngineMove, 600);
    }

    window.addEventListener('resize', function() { if (board) board.resize(); });
  }

  // ----- Drag/Drop validation -----
  function onDragStart(source, piece) {
    if (gameOver || enginePending) return false;
    if (!game || game.game_over()) return false;
    if (game.turn() !== userColor) return false;
    if ((userColor === 'w' && piece.charAt(0) !== 'w') ||
        (userColor === 'b' && piece.charAt(0) !== 'b')) return false;
    return true;
  }

  function onDrop(source, target) {
    if (gameOver) return 'snapback';
    var move = game.move({ from: source, to: target, promotion: 'q' });
    if (move === null) return 'snapback';
    // Do NOT call board.position() here — chessboardjs animates the user's drop
    // automatically and onSnapEnd will sync the FEN after. Calling position() here
    // causes a visible double-animation.
    pushMove(move);
    if (evaluateGameOver()) return;
    setStatus('Engine thinking…', '');
    updateTurn();
    setTimeout(requestEngineMove, 100);
  }

  function requestEngineMove() {
    if (gameOver) return;
    enginePending = true;
    var fen = game.fen();
    // Time per move scales with skill — easier engine = quick move; harder = think longer
    // Aggressive snappy curve: 80ms (skill 0) to 600ms (skill 20).
    // Stockfish 7 finds reasonable moves almost instantly in most positions; the engine's STRENGTH
    // limiting at low skill levels is controlled by "Skill Level" UCI option, not by thinking time.
    var movetime = 80 + skillLevel * 26;
    stockfish.postMessage('position fen ' + fen);
    stockfish.postMessage('go movetime ' + movetime);
  }

  function pushMove(move) {
    var n = Math.ceil(game.history().length / 2);
    var entry;
    if (game.history().length % 2 === 1) {
      // White move just played — start a new line
      entry = document.createElement('div');
      entry.className = 'move-line';
      entry.innerHTML = '<span class="move-num">' + n + '.</span> <span class="move-white">' + move.san + '</span>';
      moveListEl.appendChild(entry);
    } else {
      // Black move — append to last line
      var last = moveListEl.lastElementChild;
      if (last) last.innerHTML += ' <span class="move-black">' + move.san + '</span>';
    }
    moveListEl.scrollTop = moveListEl.scrollHeight;
  }

  function rebuildMoveList() {
    moveListEl.innerHTML = '';
    var hist = game.history({ verbose: true });
    for (var i = 0; i < hist.length; i++) pushMove(hist[i]);
  }

  function evaluateGameOver() {
    if (!game.game_over()) return false;
    gameOver = true;
    var title, sub;
    var result = null; // 1 = user win, 0 = user loss, 0.5 = draw
    if (game.in_checkmate()) {
      var loser = game.turn(); // turn = the side that's checkmated
      if (loser === userColor) { title = 'Checkmate.'; sub = 'The engine wins. Tomorrow you take it back.'; result = 0; }
      else { title = 'Checkmate!'; sub = 'You beat Stockfish at skill ' + skillLevel + '. Bump it up.'; result = 1; }
    } else if (game.in_stalemate()) {
      title = 'Stalemate.'; sub = 'A draw by stalemate.'; result = 0.5;
    } else if (game.in_threefold_repetition()) {
      title = 'Draw.'; sub = 'Threefold repetition.'; result = 0.5;
    } else if (game.insufficient_material()) {
      title = 'Draw.'; sub = 'Insufficient material to mate.'; result = 0.5;
    } else if (game.in_draw()) {
      title = 'Draw.'; sub = 'Drawn position.'; result = 0.5;
    } else {
      title = 'Game over.'; sub = '';
    }
    showGameOver(title, sub, result);
    setStatus(title, gameOver && game.in_checkmate() && game.turn() !== userColor ? 'good' : '');
    return true;
  }

  function showGameOver(title, sub, result) {
    gameOverTitle.textContent = title;
    gameOverSub.textContent = sub;
    var deltaEl = document.getElementById('rating-delta');
    if (deltaEl) deltaEl.innerHTML = '';
    // Only record once per game, only if we have a defined result
    if (!resultRecorded && (result === 0 || result === 1 || result === 0.5)) {
      resultRecorded = true;
      var change = updateRatingFromResult(result);
      if (deltaEl) {
        var sign = change.delta > 0 ? '+' : '';
        var cls = change.delta > 0 ? 'delta-up' : (change.delta < 0 ? 'delta-down' : 'delta-flat');
        deltaEl.innerHTML = '<span class="rating-delta-label">Your rating:</span> ' +
          '<span class="rating-delta-old">' + change.oldRating + '</span>' +
          ' <span class="rating-delta-arrow ' + cls + '">' + sign + change.delta + '</span> ' +
          '<span class="rating-delta-new">' + change.newRating + '</span>';
      }
    }
    gameOverEl.classList.add('shown');
  }

  function setStatus(msg, kind) {
    statusEl.textContent = msg;
    statusEl.className = 'board-status' + (kind ? ' status-' + kind : '');
  }
  function updateTurn() {
    if (!game) return;
    var t = game.turn();
    turnEl.textContent = t === userColor ? 'You' : 'Engine';
  }

  // ----- Controls -----
  document.getElementById('btn-flip').addEventListener('click', function() {
    if (board) board.flip();
  });
  document.getElementById('btn-takeback').addEventListener('click', function() {
    if (gameOver || enginePending) return;
    // Take back the last pair (engine move + your move) so it's your turn again
    if (game.history().length === 0) return;
    game.undo();
    if (game.history().length > 0) game.undo();
    board.position(game.fen());
    rebuildMoveList();
    setStatus('Take-back. Try again.', '');
    updateTurn();
  });
  document.getElementById('btn-resign').addEventListener('click', function() {
    if (gameOver) return;
    gameOver = true;
    showGameOver('You resigned.', 'The engine wins. New game when you\'re ready.', 0);
    setStatus('Resigned.', '');
  });
  document.getElementById('btn-newgame').addEventListener('click', function() {
    setupPanel.classList.remove('hidden');
    playPanel.classList.add('hidden');
  });
  document.getElementById('btn-rematch').addEventListener('click', function() {
    gameOverEl.classList.remove('shown');
    startGame();
  });

  // ----- Player name input -----
  var nameInput = document.getElementById('player-name');
  if (nameInput) {
    nameInput.value = player.name || '';
    nameInput.addEventListener('input', function() {
      player.name = nameInput.value;
      savePlayer();
      refreshPlayerUI();
    });
  }
  refreshPlayerUI();

  // ----- Boot -----
  function whenLibsReady(cb) {
    if (window.Chess && window.Chessboard && window.jQuery) cb();
    else setTimeout(function() { whenLibsReady(cb); }, 50);
  }
  whenLibsReady(initStockfish);
})();
</script>
<!-- ============================================================
     MIND'S GAMBIT FAQ BOT — Static keyword-search bot.
     Free. No API calls. Edit the FAQ_DATA array below to add Q&As.
============================================================ -->
<button id="mg-faq-bubble" type="button" aria-label="Need help? Open Mind's Gambit Help" title="Click me for help &mdash; technical questions, engine issues, account, anything.">
  <span class="mg-faq-bubble-icon">&#9819;</span>
  <span class="mg-faq-bubble-label">Need help?</span>
  <span class="mg-faq-bubble-dot"></span>
</button>

<div id="mg-faq-panel" hidden>
  <header class="mg-faq-header">
    <div>
      <div class="mg-faq-title">Mind&rsquo;s Gambit Help</div>
      <div class="mg-faq-subtitle">Ask anything &middot; instant answers</div>
    </div>
    <button id="mg-faq-close" type="button" aria-label="Close">&times;</button>
  </header>
  <div class="mg-faq-messages" id="mg-faq-messages"></div>
  <form class="mg-faq-form" id="mg-faq-form" autocomplete="off">
    <input type="text" id="mg-faq-input" placeholder="Type your question&hellip;" maxlength="200" autocomplete="off" />
    <button type="submit" aria-label="Send">&#10142;</button>
  </form>
  <div class="mg-faq-suggested" id="mg-faq-suggested"></div>
</div>

<script is:inline>
(function() {
  'use strict';

  // ----- FAQ DATABASE -----
  // Edit this array to add/remove Q&As. Each entry has:
  //   keywords: array of words/phrases that trigger this answer (lowercase)
  //   q: short display question (shown in suggested list)
  //   a: the answer (HTML allowed)
  var FAQ_DATA = [
    { keywords: ['daily puzzle', 'puzzle of the day', 'today puzzle', 'how puzzle work'],
      q: 'How does the Daily Puzzle work?',
      a: 'Every visitor sees the <strong>same puzzle each calendar day</strong>, drawn from 5.94 million puzzles in the Lichess Open Puzzle Database (CC0, public domain). The puzzle is picked deterministically by date, so you and a friend will see the same puzzle on the same day. Tomorrow it rotates automatically.' },
    { keywords: ['account', 'login', 'sign up', 'signup', 'register'],
      q: 'Do I need an account?',
      a: '<strong>No.</strong> Mind&rsquo;s Gambit Chess School works without any signup. Your puzzle streak, ELO rating, display name, and game stats are saved in your browser&rsquo;s local storage. They persist between visits on the same device.' },
    { keywords: ['elo', 'rating', 'how rating work'],
      q: 'How does the ELO rating work?',
      a: 'Your rating starts at <strong>1200</strong>. Each game vs the engine adjusts it using the standard ELO formula. Engine strength is mapped to ratings (skill 0 ≈ 800, skill 10 ≈ 1800, skill 20 ≈ 2800). Win a tougher engine = bigger rating jump. Lose to a weaker one = bigger drop. Your <strong>peak rating</strong> is tracked separately so you never lose it.' },
    { keywords: ['stockfish', 'engine', 'what engine'],
      q: 'What is Stockfish?',
      a: '<strong>Stockfish</strong> is the world&rsquo;s leading open-source chess engine, developed by an international team since 2008. Mind&rsquo;s Gambit uses Stockfish under the hood: the older pure-JS version for the in-browser Play page, and the latest <strong>Stockfish 17 NNUE</strong> (via Lichess Cloud Eval) for Game Analysis. Free, open-source, GPL v3.' },
    { keywords: ['progress', 'save', 'data', 'sync', 'devices'],
      q: 'How is my progress saved?',
      a: 'Everything is saved in your browser&rsquo;s <strong>localStorage</strong> on this device. No accounts. No backend. No tracking. Switching devices or clearing your browser data will reset your stats. This is the trade-off for "no signup required" — we&rsquo;re working on optional cross-device sync as a future feature.' },
    { keywords: ['coach', 'lesson', 'book', 'teacher', 'grandmaster'],
      q: 'Can I book a lesson with a coach?',
      a: 'Yes. Click <a href="/chess-school/grandmasters">Grandmasters</a> in the nav (or the tile on the Chess School hub). Each coach has their own profile with hourly rate, languages, and a contact button. Currently featuring <strong>WGM Maryana Huda</strong> with more titled players joining soon.' },
    { keywords: ['become coach', 'apply', 'titled', 'join roster'],
      q: 'How do I become a coach on Mind\'s Gambit?',
      a: 'If you’re a titled player (GM, IM, WGM, WIM, FM, WFM, NM, CM), visit the <a href="/chess-school/grandmasters">Grandmasters page</a> and click <strong>"Apply as a Founding Coach"</strong>. <strong>Free for 6 months</strong> — you keep 100% of your lesson fees, no exclusivity required.' },
    { keywords: ['free', 'cost', 'price', 'how much'],
      q: 'Is Mind\'s Gambit free?',
      a: 'All the puzzle, engine, and analysis features are <strong>completely free</strong>. No ads, no subscriptions, no upsells. Only paid feature: one-on-one lessons with our titled coaches, which goes directly to the coach.' },
    { keywords: ['tactics trainer', 'tactics by theme', 'pin fork', 'training'],
      q: 'How does the Tactics Trainer work?',
      a: 'Pick a tactical theme — pin, fork, mate-in-2, endgame, etc. — and grind puzzles tagged with that pattern. We have <strong>73 themes</strong> indexed across 5.94M puzzles. Your accuracy is tracked per session.' },
    { keywords: ['train now', 'random puzzle', 'just train'],
      q: 'What is Train Now?',
      a: '<strong>Train Now</strong> is the fastest way to start practicing: one click, random puzzle loads, solve it, next puzzle auto-loads. No theme filter, no menus. Tracks your solved / attempted / accuracy stats per session.' },
    { keywords: ['analysis', 'analyze game', 'pgn', 'review game'],
      q: 'How does Game Analysis work?',
      a: 'Paste your game in PGN format on the <a href="/chess-school/analyze">Analyze page</a>. We evaluate every move using <strong>Stockfish 17 NNUE</strong> via the Lichess Cloud Eval API. You’ll see Blunder / Mistake / Inaccuracy / Best Move tags, plus the best move you should have played.' },
    { keywords: ['pgn', 'pgn format', 'where to get pgn'],
      q: 'Where do I get a PGN file?',
      a: 'Every chess platform lets you export games as PGN. On Lichess: open the game, click "Export PGN". On Chess.com: open the game, click the share icon, then "Download PGN". OTB games can be entered move by move in any analysis tool.' },
    { keywords: ['streak', 'daily streak', 'streak count'],
      q: 'How does the daily streak work?',
      a: 'Solve the Daily Puzzle on consecutive calendar days to build a streak. Miss a day and the streak resets to 1 (not zero — not a punishment, just an honest signal). Your streak is saved in your browser.' },
    { keywords: ['play another person', 'pass and play', 'two player', 'with friend'],
      q: 'Can I play vs another person?',
      a: '<strong>Coming soon.</strong> Pass &amp; Play (two players, one device) is on the roadmap. Online matchmaking against other Mind’s Gambit users is a longer-term build. For now, the Play page is vs the engine.' },
    { keywords: ['mobile', 'phone', 'iphone', 'android'],
      q: 'Does it work on mobile?',
      a: 'Yes. All pages are responsive. The board is drag-and-drop on touch. Daily Puzzle, Train Now, Tactics, Play, and Analysis all work on phone. If anything looks broken on your device, please email mourad@mindsgambit.com.' },
    { keywords: ['browser', 'safari', 'chrome', 'firefox'],
      q: 'Which browser should I use?',
      a: 'Any modern browser: Chrome, Edge, Firefox, Safari. JavaScript needs to be enabled. The chess engine runs entirely in your browser (no server-side processing), so older browsers may be slower.' },
    { keywords: ['stockfish 17', 'latest stockfish', 'engine version'],
      q: 'Which version of Stockfish do you use?',
      a: 'The <strong>Play page</strong> uses Stockfish 7 (pure JavaScript, ~3300 Elo — strong enough to beat almost any human). The <strong>Analyze page</strong> uses <strong>Stockfish 17 NNUE</strong> via the Lichess Cloud Eval API (the latest, ~3700 Elo).' },
    { keywords: ['lichess', 'chess.com', 'compare'],
      q: 'How is this different from Lichess or Chess.com?',
      a: 'Three things: (1) <strong>no ads, no upsells, no tracking</strong> — we have nothing to sell you; (2) <strong>integrated with The Mind’s Gambit</strong> book and documentary so chess sits alongside writing about chess; (3) we feature a <strong>curated roster of titled coaches</strong> rather than thousands of unverified profiles. We use both sites’ open data (Lichess puzzle DB, Stockfish engine).' },
    { keywords: ['founder', 'who built', 'mourad', 'mourad bouajaja'],
      q: 'Who built this?',
      a: '<a href="/#about">Mourad Bouajaja</a> — author of <em>The Mind’s Gambit: Chess, Madness, and the Battle for the Mind</em>, documentary maker, chess player. Mind’s Gambit Chess School is a production of MYB Studio LLC.' },
    { keywords: ['book', 'the book', 'where to buy'],
      q: 'Where can I read The Mind\'s Gambit book?',
      a: 'Visit <a href="/#book">The Book section</a> on the homepage for sample chapters and purchase links. The chess school is named after the book; the book is built on the documentary; everything connects.' },
    { keywords: ['documentary', 'watch', 'episodes', 'video'],
      q: 'How do I watch the documentary?',
      a: 'Go to <a href="/watch">/watch</a> (Documentary). The Mind’s Gambit is a 10-episode documentary series chronicling the intellectual journey behind the book. Episodes are also available on YouTube.' },
    { keywords: ['donate', 'support', 'buy coffee'],
      q: 'How can I support Mind\'s Gambit?',
      a: 'If any of this has helped you, you can <a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener">buy us a coffee</a>. There’s also a tip jar in the top nav of every page (the gold button). Beyond money: tell a chess friend about us. Word of mouth is the only marketing we do.' },
    { keywords: ['bug', 'report', 'error', 'broken', 'not working'],
      q: 'Something is broken — how do I report it?',
      a: 'Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a> with: (1) which page, (2) what device/browser, (3) what you expected, (4) what happened. Screenshots help a lot. We fix things fast.' },
    { keywords: ['engine stall', 'engine stuck', 'engine not moving', 'engine freeze', 'stockfish stuck', 'stockfish not moving', 'engine slow', 'no engine move', 'engine took'],
      q: 'The engine is stalling or not making a move',
      a: 'On the Play page the engine runs entirely in your browser, so a stall usually means: (1) <strong>refresh the page</strong> &mdash; the Stockfish worker sometimes loses its thread on slow connections; (2) try a <strong>lower skill level</strong> &mdash; very high levels at long thinking times can take 10-20 seconds; (3) switch to a modern browser (Chrome, Edge, Firefox, Safari). If the problem keeps happening, email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a> with your device + browser and we&rsquo;ll investigate.' },
    { keywords: ['board not loading', 'board blank', 'board missing', 'pieces missing', 'board white', 'board empty'],
      q: 'The chess board is not loading',
      a: 'The board needs JavaScript and an open connection to <code>unpkg.com</code> (where chessboard.js is hosted). Try: (1) hard refresh (Ctrl+Shift+R or Cmd+Shift+R); (2) disable any ad-blocker/script-blocker on this site; (3) check that JavaScript is enabled. If it still doesn&rsquo;t load, email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a> with a screenshot.' },
    { keywords: ['puzzle stuck', 'puzzle not solving', 'puzzle frozen', 'cant solve', 'wrong answer'],
      q: 'The puzzle is stuck or my answer was marked wrong',
      a: 'Each puzzle has <strong>one specific solution sequence</strong> from the Lichess database &mdash; even if your move looks good, only the engine-validated line counts as solved. Hit <strong>Hint</strong> or <strong>Show Solution</strong> to see the intended line. If you believe the puzzle is genuinely broken (e.g. the solution is illegal), email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a> with the puzzle ID and we&rsquo;ll review it.' },
    { keywords: ['lost progress', 'rating reset', 'stats gone', 'lost streak'],
      q: 'I lost my rating / streak / stats',
      a: 'Your progress is stored in your browser&rsquo;s localStorage on this device only. It resets if you: (1) clear your browser data, (2) switch to a different browser or device, (3) open the site in private/incognito mode. We&rsquo;re working on optional cross-device sync as a future feature. For now, stick to the same browser on the same device to keep your progress.' },
    { keywords: ['contact', 'email', 'reach out'],
      q: 'How do I contact Mourad?',
      a: 'Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a>. Or use the <a href="/#contact">Contact section</a> on the homepage.' },
    { keywords: ['privacy', 'tracking', 'cookies', 'data'],
      q: 'Does Mind\'s Gambit track me?',
      a: '<strong>No tracking pixels, no third-party analytics, no ads.</strong> Your puzzle progress and ELO are saved in <em>your</em> browser’s localStorage — we never see it. The only data sent to a third party is the game position FEN sent to Lichess Cloud Eval API when you use Game Analysis (Lichess privacy policy applies).' }
  ];

  // ----- Bot logic -----
  var bubble = document.getElementById('mg-faq-bubble');
  var panel = document.getElementById('mg-faq-panel');
  var closeBtn = document.getElementById('mg-faq-close');
  var form = document.getElementById('mg-faq-form');
  var input = document.getElementById('mg-faq-input');
  var messagesEl = document.getElementById('mg-faq-messages');
  var suggestedEl = document.getElementById('mg-faq-suggested');

  if (!bubble || !panel) return;

  function openPanel() {
    panel.removeAttribute('hidden');
    panel.classList.add('mg-faq-open');
    input.focus();
    if (!messagesEl.children.length) greet();
  }
  function closePanel() {
    panel.setAttribute('hidden', '');
    panel.classList.remove('mg-faq-open');
  }
  bubble.addEventListener('click', function() {
    if (panel.hasAttribute('hidden')) openPanel(); else closePanel();
  });
  closeBtn.addEventListener('click', closePanel);

  function addMessage(text, sender) {
    var div = document.createElement('div');
    div.className = 'mg-faq-msg mg-faq-msg-' + sender;
    div.innerHTML = text;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }

  function score(query, keywords) {
    var q = query.toLowerCase();
    var s = 0;
    for (var i = 0; i < keywords.length; i++) {
      var k = keywords[i].toLowerCase();
      if (q.indexOf(k) !== -1) s += k.length * 2;
      // Also score individual words
      var words = k.split(/\s+/);
      for (var w = 0; w < words.length; w++) {
        if (words[w].length >= 3 && q.indexOf(words[w]) !== -1) s += 1;
      }
    }
    return s;
  }

  function answer(query) {
    var best = null;
    var bestScore = 0;
    for (var i = 0; i < FAQ_DATA.length; i++) {
      var s = score(query, FAQ_DATA[i].keywords);
      if (s > bestScore) { bestScore = s; best = FAQ_DATA[i]; }
    }
    if (best && bestScore >= 3) return best.a;
    return null;
  }

  function greet() {
    addMessage('Hi &mdash; welcome to <strong>Mind&rsquo;s Gambit Help</strong>. I&rsquo;m here for <em>anything</em> you run into on the site:<br><br>&bull; <strong>Technical issues</strong> &mdash; engine stalling, board not loading, puzzle stuck, page broken<br>&bull; <strong>How things work</strong> &mdash; Daily Puzzle, ELO rating, Train Now, Tactics, Analysis<br>&bull; <strong>Account &amp; data</strong> &mdash; progress saving, switching devices, privacy<br>&bull; <strong>Coaches &amp; lessons</strong> &mdash; booking a titled coach, becoming a coach<br>&bull; <strong>Anything else</strong> &mdash; the book, documentary, contact Mourad<br><br>Type your question below, or pick one of these to get started:', 'bot');
    showSuggestions(['Engine is stalling / not moving', 'How does the Daily Puzzle work?', 'How does the ELO rating work?', 'Can I book a lesson with a coach?', 'Is Mind&rsquo;s Gambit free?', 'Something is broken &mdash; how do I report it?']);
  }

  function showSuggestions(questions) {
    suggestedEl.innerHTML = '';
    for (var i = 0; i < questions.length; i++) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'mg-faq-suggest';
      btn.textContent = questions[i];
      (function(q) { btn.addEventListener('click', function() { handleQuery(q); }); })(questions[i]);
      suggestedEl.appendChild(btn);
    }
  }

  function handleQuery(query) {
    suggestedEl.innerHTML = '';
    addMessage(query, 'user');
    var a = answer(query);
    if (a) {
      setTimeout(function() { addMessage(a, 'bot'); }, 200);
    } else {
      setTimeout(function() {
        addMessage('I don’t have a stock answer for that one yet. Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a> and Mourad will reply personally — he usually answers within a day.', 'bot');
        // Show 4 random other suggestions
        var sample = [];
        var pool = FAQ_DATA.slice();
        for (var i = 0; i < 4 && pool.length; i++) {
          var idx = Math.floor(Math.random() * pool.length);
          sample.push(pool[idx].q);
          pool.splice(idx, 1);
        }
        showSuggestions(sample);
      }, 200);
    }
  }

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var q = input.value.trim();
    if (!q) return;
    input.value = '';
    handleQuery(q);
  });
})();
</script>

<style>
