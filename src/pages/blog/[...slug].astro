---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const formattedDate = new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title} &mdash; The Mind's Gambit`}>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo">M.B</a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/podcasts" class="nav-btn">Podcasts</a></li>
      </ul>
    </div>
  </nav>

  <article>
    <header class="article-header">
      <a href="/blog" class="back-link">&larr; Back to Blog</a>
      <span class="date">{formattedDate}</span>
      <h1>{entry.data.title}</h1>
      <p class="subtitle">{entry.data.description}</p>
      <div class="article-meta">
        <span class="author">By {entry.data.author}</span>
        <div class="tags">
          {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    <div class="content-lock-overlay" id="content-lock">
      <div class="lock-icon">&#x1F512;</div>
      <h2 class="lock-title">Register to Unlock This Chapter</h2>
      <p class="lock-subtitle">Create a free account to read the full article</p>
      <div class="lock-buttons">
        <button class="btn-primary" id="signup-btn">Sign Up</button>
        <button class="btn-secondary" id="signin-btn">Sign In</button>
      </div>
    </div>

    <div class="locked-content" id="locked-content">
      <div class="article-content">
        <Content />
      </div>
    </div>

    <footer class="article-footer">
      <a href="/blog" class="back-link">&larr; Back to all articles</a>
    </footer>
  </article>

  <!-- Discussion Section -->
  <section class="discussion-section" id="discussion">
    <div class="discussion-inner">
      <h2 class="discussion-heading">Join the Discussion</h2>
      <p class="discussion-intro">What resonated with you? What did I get wrong? Every chapter is a draft&mdash;your feedback shapes the final book.</p>

      <div class="comment-form-wrapper" id="comment-form-wrapper">
        <div class="login-prompt" id="login-prompt">
          <p>Sign in to join the conversation</p>
          <button class="btn-primary" id="discussion-signin">Sign In</button>
        </div>
        <div class="comment-form" id="comment-form" style="display:none;">
          <div class="comment-form-header">
            <img id="user-avatar" class="comment-avatar" src="" alt="" />
            <span id="user-name" class="comment-username"></span>
          </div>
          <textarea id="comment-input" class="comment-textarea" placeholder="Share your thoughts..." rows="3"></textarea>
          <input type="hidden" id="reply-to" value="" />
          <div class="comment-form-actions">
            <button id="submit-comment" class="btn-primary btn-sm">Post Comment</button>
            <button id="cancel-reply" class="btn-secondary btn-sm" style="display:none;">Cancel Reply</button>
          </div>
        </div>
      </div>

      <div id="comments-list" class="comments-list">
        <div class="comments-loading" id="comments-loading">Loading comments...</div>
      </div>
      <div id="no-comments" class="no-comments" style="display:none;">
        <p>No comments yet. Be the first to share your thoughts!</p>
      </div>
    </div>
  </section>

  <script>
    // ============================================
    // COMMENT SYSTEM - Supabase + Clerk
    // ============================================
    (function() {
      var SUPABASE_URL = '';
      var SUPABASE_ANON_KEY = '';
      var supabaseReady = false;
      var clerkReady = false;
      var db: any = null;
      var currentUser: any = null;
      var articleSlug = window.location.pathname.replace('/blog/', '').replace(/\/$/, '');

      // ---- Clerk Auth Integration ----
      function waitForClerk() {
        var w = window as any;
        if (w.Clerk && w.Clerk.user !== undefined) {
          clerkReady = true;
          currentUser = w.Clerk.user;
          updateAuthUI();
          setupContentLock();
          return;
        }
        document.addEventListener('clerk:loaded', function() {
          var w = window as any;
          clerkReady = true;
          currentUser = w.Clerk.user;
          updateAuthUI();
          setupContentLock();
        });
        var attempts = 0;
        var poll = setInterval(function() {
          var w = window as any;
          attempts++;
          if (w.Clerk && w.Clerk.user !== undefined) {
            clearInterval(poll);
            clerkReady = true;
            currentUser = w.Clerk.user;
            updateAuthUI();
            setupContentLock();
          }
          if (attempts > 50) clearInterval(poll);
        }, 200);
      }

      function setupContentLock() {
        var lock = document.getElementById('content-lock');
        var content = document.getElementById('locked-content');
        if (currentUser) {
          if (lock) lock.style.display = 'none';
          if (content) {
            content.style.filter = 'none';
            content.style.pointerEvents = 'auto';
            content.style.userSelect = 'auto';
          }
        } else {
          if (lock) lock.style.display = '';
          if (content) {
            content.style.filter = 'blur(5px)';
            content.style.pointerEvents = 'none';
            content.style.userSelect = 'none';
          }
        }
      }

      function updateAuthUI() {
        var loginPrompt = document.getElementById('login-prompt');
        var commentForm = document.getElementById('comment-form');
        var avatarEl = document.getElementById('user-avatar') as HTMLImageElement;
        var nameEl = document.getElementById('user-name');

        if (currentUser) {
          if (loginPrompt) loginPrompt.style.display = 'none';
          if (commentForm) commentForm.style.display = 'block';
          if (avatarEl) avatarEl.src = currentUser.imageUrl || '';
          if (nameEl) nameEl.textContent = currentUser.fullName || currentUser.firstName || 'User';
        } else {
          if (loginPrompt) loginPrompt.style.display = '';
          if (commentForm) commentForm.style.display = 'none';
        }
      }

      // ---- Supabase Integration ----
      function initSupabase() {
        if (!SUPABASE_URL || !SUPABASE_ANON_KEY) {
          var el = document.getElementById('comments-loading');
          if (el) el.textContent = 'Comments coming soon!';
          return;
        }
        var script = document.createElement('script');
        script.src = 'https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2/dist/umd/supabase.min.js';
        script.onload = function() {
          var w = window as any;
          db = w.supabase.createClient(SUPABASE_URL, SUPABASE_ANON_KEY);
          supabaseReady = true;
          loadComments();
        };
        document.head.appendChild(script);
      }

      function loadComments() {
        if (!supabaseReady) return;
        db.from('comments')
          .select('*')
          .eq('article_slug', articleSlug)
          .order('created_at', { ascending: true })
          .then(function(result: any) {
            if (result.error) {
              var el = document.getElementById('comments-loading');
              if (el) el.textContent = 'Could not load comments.';
              return;
            }
            renderComments(result.data || []);
          });
      }

      function renderComments(comments: any[]) {
        var container = document.getElementById('comments-list');
        var noComments = document.getElementById('no-comments');
        var loading = document.getElementById('comments-loading');
        if (loading) loading.style.display = 'none';

        if (comments.length === 0) {
          if (container) container.innerHTML = '';
          if (noComments) noComments.style.display = 'block';
          return;
        }
        if (noComments) noComments.style.display = 'none';

        var topLevel: any[] = [];
        var replies: Record<string, any[]> = {};
        comments.forEach(function(c) {
          if (!c.parent_id) {
            topLevel.push(c);
          } else {
            if (!replies[c.parent_id]) replies[c.parent_id] = [];
            replies[c.parent_id].push(c);
          }
        });

        if (container) {
          container.innerHTML = '';
          topLevel.forEach(function(c) {
            container.appendChild(buildCommentEl(c, replies, 0));
          });
        }
      }

      function buildCommentEl(comment: any, replies: Record<string, any[]>, depth: number): HTMLDivElement {
        var div = document.createElement('div');
        div.className = 'comment' + (depth > 0 ? ' comment-reply' : '');
        div.setAttribute('data-id', comment.id);

        var timeAgo = getTimeAgo(new Date(comment.created_at));

        div.innerHTML =
          '<div class="comment-header">' +
            '<img class="comment-avatar" src="' + (comment.user_avatar || '') + '" alt="" />' +
            '<div class="comment-meta">' +
              '<span class="comment-author">' + escapeHtml(comment.user_name) + '</span>' +
              '<span class="comment-time">' + timeAgo + '</span>' +
            '</div>' +
          '</div>' +
          '<div class="comment-body">' + escapeHtml(comment.content) + '</div>' +
          '<div class="comment-actions">' +
            (currentUser ? '<button class="reply-btn" data-id="' + comment.id + '" data-name="' + escapeHtml(comment.user_name) + '">Reply</button>' : '') +
          '</div>';

        if (replies[comment.id]) {
          var repliesDiv = document.createElement('div');
          repliesDiv.className = 'comment-replies';
          replies[comment.id].forEach(function(r) {
            repliesDiv.appendChild(buildCommentEl(r, replies, depth + 1));
          });
          div.appendChild(repliesDiv);
        }

        return div;
      }

      function escapeHtml(str: string): string {
        var d = document.createElement('div');
        d.textContent = str;
        return d.innerHTML;
      }

      function getTimeAgo(date: Date): string {
        var seconds = Math.floor((Date.now() - date.getTime()) / 1000);
        if (seconds < 60) return 'just now';
        var minutes = Math.floor(seconds / 60);
        if (minutes < 60) return minutes + 'm ago';
        var hours = Math.floor(minutes / 60);
        if (hours < 24) return hours + 'h ago';
        var days = Math.floor(hours / 24);
        if (days < 30) return days + 'd ago';
        var months = Math.floor(days / 30);
        if (months < 12) return months + 'mo ago';
        return Math.floor(months / 12) + 'y ago';
      }

      // ---- Event Handlers ----
      function setupEventListeners() {
        var signupBtn = document.getElementById('signup-btn');
        var signinBtn = document.getElementById('signin-btn');
        var discussionSignin = document.getElementById('discussion-signin');

        if (signupBtn) signupBtn.addEventListener('click', function() {
          var w = window as any;
          if (w.Clerk) w.Clerk.openSignUp();
        });
        if (signinBtn) signinBtn.addEventListener('click', function() {
          var w = window as any;
          if (w.Clerk) w.Clerk.openSignIn();
        });
        if (discussionSignin) discussionSignin.addEventListener('click', function() {
          var w = window as any;
          if (w.Clerk) w.Clerk.openSignIn();
        });

        var submitBtn = document.getElementById('submit-comment');
        if (submitBtn) submitBtn.addEventListener('click', submitComment);

        var cancelBtn = document.getElementById('cancel-reply');
        if (cancelBtn) cancelBtn.addEventListener('click', function() {
          var replyTo = document.getElementById('reply-to') as HTMLInputElement;
          if (replyTo) replyTo.value = '';
          if (cancelBtn) cancelBtn.style.display = 'none';
          var input = document.getElementById('comment-input') as HTMLTextAreaElement;
          if (input) input.placeholder = 'Share your thoughts...';
        });

        document.addEventListener('click', function(e) {
          var target = e.target as HTMLElement;
          if (target.classList.contains('reply-btn')) {
            var parentId = target.getAttribute('data-id');
            var parentName = target.getAttribute('data-name');
            var replyTo = document.getElementById('reply-to') as HTMLInputElement;
            if (replyTo) replyTo.value = parentId || '';
            var input = document.getElementById('comment-input') as HTMLTextAreaElement;
            if (input) {
              input.placeholder = 'Replying to ' + parentName + '...';
              input.focus();
            }
            var cancel = document.getElementById('cancel-reply');
            if (cancel) cancel.style.display = 'inline-block';
          }
        });
      }

      function submitComment() {
        if (!supabaseReady || !currentUser) return;
        var input = document.getElementById('comment-input') as HTMLTextAreaElement;
        var content = input.value.trim();
        if (!content) return;

        var replyTo = document.getElementById('reply-to') as HTMLInputElement;
        var parentId = replyTo.value || null;

        var submitBtn = document.getElementById('submit-comment') as HTMLButtonElement;
        submitBtn.disabled = true;
        submitBtn.textContent = 'Posting...';

        db.from('comments').insert({
          article_slug: articleSlug,
          user_id: currentUser.id,
          user_name: currentUser.fullName || currentUser.firstName || 'User',
          user_avatar: currentUser.imageUrl || '',
          parent_id: parentId,
          content: content
        }).then(function(result: any) {
          submitBtn.disabled = false;
          submitBtn.textContent = 'Post Comment';
          if (result.error) {
            alert('Could not post comment. Please try again.');
            return;
          }
          input.value = '';
          replyTo.value = '';
          var cancel = document.getElementById('cancel-reply');
          if (cancel) cancel.style.display = 'none';
          input.placeholder = 'Share your thoughts...';
          loadComments();
        });
      }

      // ---- Initialize ----
      function init() {
        waitForClerk();
        initSupabase();
        setupEventListeners();
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', init);
      } else {
        init();
      }
    })();
  </script>

  <style>
    /* Navigation */
    nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 1000;
      background: rgba(15, 17, 28, 0.95);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid rgba(201, 168, 76, 0.1);
    }
    .nav-inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 1rem 2rem;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    .nav-logo {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      font-weight: 700;
      color: #c9a84c;
      text-decoration: none;
    }
    .nav-links {
      list-style: none;
      display: flex;
      gap: 2rem;
      align-items: center;
      margin: 0;
      padding: 0;
    }
    .nav-links a {
      color: #f0ece4;
      text-decoration: none;
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      transition: color 0.3s;
    }
    .nav-links a:hover {
      color: #c9a84c;
    }
    .nav-btn {
      border: 1px solid #c9a84c;
      padding: 0.5rem 1.25rem;
      border-radius: 4px;
    }

    /* Article */
    article {
      max-width: 800px;
      margin: 0 auto;
      padding: 6rem 2rem 2rem;
    }
    .article-header {
      margin-bottom: 2rem;
      padding-bottom: 2rem;
      border-bottom: 1px solid rgba(201, 168, 76, 0.15);
    }
    .back-link {
      color: #c9a84c;
      text-decoration: none;
      font-size: 0.85rem;
      display: inline-block;
      margin-bottom: 1.5rem;
      transition: opacity 0.3s;
    }
    .back-link:hover {
      opacity: 0.8;
    }
    .date {
      display: block;
      color: #c9a84c;
      font-size: 0.8rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 1rem;
    }
    article h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 2.5rem;
      color: #f0ece4;
      margin-bottom: 1rem;
      line-height: 1.2;
    }
    .subtitle {
      font-size: 1.1rem;
      color: #a0a0a0;
      line-height: 1.6;
      margin-bottom: 1.5rem;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 1.5rem;
      flex-wrap: wrap;
    }
    .author {
      color: #f0ece4;
      font-size: 0.9rem;
    }
    .tags {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
    }
    .tag {
      font-size: 0.75rem;
      color: #c9a84c;
      border: 1px solid rgba(201, 168, 76, 0.3);
      padding: 0.25rem 0.75rem;
      border-radius: 20px;
    }

    /* Content Lock */
    .content-lock-overlay {
      background: rgba(30, 33, 48, 0.95);
      border: 1px solid rgba(201, 168, 76, 0.15);
      border-radius: 12px;
      padding: 3rem;
      text-align: center;
      margin: 2rem 0;
    }
    .lock-icon {
      font-size: 2.5rem;
      margin-bottom: 1rem;
    }
    .lock-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.5rem;
      color: #f0ece4;
      margin-bottom: 0.75rem;
    }
    .lock-subtitle {
      color: #a0a0a0;
      margin-bottom: 1.5rem;
    }
    .lock-buttons {
      display: flex;
      gap: 1rem;
      justify-content: center;
    }
    .btn-primary {
      background: #c9a84c;
      color: #0f111c;
      border: none;
      padding: 0.75rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.9rem;
      transition: background 0.3s;
    }
    .btn-primary:hover {
      background: #d4b85c;
    }
    .btn-secondary {
      background: transparent;
      color: #c9a84c;
      border: 1px solid #c9a84c;
      padding: 0.75rem 2rem;
      border-radius: 6px;
      font-weight: 600;
      cursor: pointer;
      font-size: 0.9rem;
      transition: background 0.3s;
    }
    .btn-secondary:hover {
      background: rgba(201, 168, 76, 0.1);
    }
    .btn-sm {
      padding: 0.5rem 1.25rem;
      font-size: 0.8rem;
    }

    /* Locked Content */
    .locked-content {
      filter: blur(5px);
      pointer-events: none;
      user-select: none;
    }
    .article-content {
      color: #d0ccc4;
      line-height: 1.8;
      font-size: 1.05rem;
    }
    .article-content h2 {
      font-family: 'Playfair Display', Georgia, serif;
      color: #c9a84c;
      font-size: 1.6rem;
      margin-top: 2.5rem;
      margin-bottom: 1rem;
    }
    .article-content h3 {
      font-family: 'Playfair Display', Georgia, serif;
      color: #f0ece4;
      font-size: 1.3rem;
      margin-top: 2rem;
      margin-bottom: 0.75rem;
    }
    .article-content p {
      margin-bottom: 1.25rem;
    }
    .article-content blockquote {
      border-left: 3px solid #c9a84c;
      padding-left: 1.5rem;
      margin: 1.5rem 0;
      color: #a0a0a0;
      font-style: italic;
    }

    /* Article Footer */
    .article-footer {
      padding-top: 2rem;
      margin-top: 3rem;
      border-top: 1px solid rgba(201, 168, 76, 0.15);
    }

    /* ================================ */
    /* DISCUSSION / COMMENTS SECTION    */
    /* ================================ */
    .discussion-section {
      max-width: 800px;
      margin: 0 auto;
      padding: 0 2rem 5rem;
    }
    .discussion-inner {
      padding-top: 2rem;
    }
    .discussion-heading {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.6rem;
      color: #c9a84c;
      margin-bottom: 0.75rem;
    }
    .discussion-intro {
      color: #a0a0a0;
      font-size: 0.95rem;
      line-height: 1.7;
      margin-bottom: 2rem;
    }

    /* Comment Form */
    .comment-form-wrapper {
      background: rgba(30, 33, 48, 0.7);
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 1.5rem;
      margin-bottom: 2rem;
    }
    .login-prompt {
      text-align: center;
      padding: 1rem 0;
    }
    .login-prompt p {
      color: #a0a0a0;
      margin-bottom: 1rem;
    }
    .comment-form-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .comment-avatar {
      width: 36px;
      height: 36px;
      border-radius: 50%;
      object-fit: cover;
      background: rgba(201, 168, 76, 0.2);
    }
    .comment-username {
      color: #f0ece4;
      font-weight: 600;
      font-size: 0.9rem;
    }
    .comment-textarea {
      width: 100%;
      background: rgba(15, 17, 28, 0.6);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 8px;
      color: #f0ece4;
      padding: 0.75rem 1rem;
      font-size: 0.9rem;
      font-family: inherit;
      resize: vertical;
      min-height: 80px;
      transition: border-color 0.3s;
      box-sizing: border-box;
    }
    .comment-textarea:focus {
      outline: none;
      border-color: rgba(201, 168, 76, 0.4);
    }
    .comment-textarea::placeholder {
      color: #666;
    }
    .comment-form-actions {
      display: flex;
      gap: 0.75rem;
      margin-top: 0.75rem;
      justify-content: flex-end;
    }

    /* Comments List */
    .comments-list {
      display: flex;
      flex-direction: column;
      gap: 0;
    }
    .comments-loading, .no-comments {
      color: #666;
      text-align: center;
      padding: 2rem 0;
      font-size: 0.9rem;
    }

    /* Individual Comment */
    .comment {
      padding: 1.25rem 0;
      border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
    .comment:last-child {
      border-bottom: none;
    }
    .comment-reply {
      margin-left: 2.5rem;
      padding-left: 1rem;
      border-left: 2px solid rgba(201, 168, 76, 0.15);
    }
    .comment-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.5rem;
    }
    .comment-meta {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
    }
    .comment-author {
      color: #f0ece4;
      font-weight: 600;
      font-size: 0.85rem;
    }
    .comment-time {
      color: #555;
      font-size: 0.75rem;
    }
    .comment-body {
      color: #c0bbb3;
      font-size: 0.9rem;
      line-height: 1.6;
      padding-left: 2.85rem;
      white-space: pre-wrap;
    }
    .comment-actions {
      padding-left: 2.85rem;
      margin-top: 0.4rem;
    }
    .reply-btn {
      background: none;
      border: none;
      color: #c9a84c;
      font-size: 0.75rem;
      cursor: pointer;
      padding: 0;
      opacity: 0.7;
      transition: opacity 0.3s;
    }
    .reply-btn:hover {
      opacity: 1;
    }
    .comment-replies {
      margin-top: 0;
    }

    /* Responsive */
    @media (max-width: 768px) {
      article {
        padding: 5rem 1rem 2rem;
      }
      article h1 {
        font-size: 1.8rem;
      }
      .discussion-section {
        padding: 0 1rem 3rem;
      }
      .comment-reply {
        margin-left: 1rem;
      }
      .comment-body, .comment-actions {
        padding-left: 2.85rem;
      }
    }
  </style>
</BaseLayout>
