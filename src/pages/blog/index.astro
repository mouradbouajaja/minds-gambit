---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="Blog &mdash; The Mind's Gambit">
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;" /></a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog" class="active">Blog</a></li>
        <li><a href="/podcasts" class="nav-btn">Podcasts</a></li>
      </ul>
    </div>
  </nav>

  <main class="blog-page">
    <section class="blog-hero">
      <h1>The Mind's Gambit</h1>
      <p class="blog-subtitle">Chapters in Progress</p>
      <p class="blog-intro-text">Each article below is a draft chapter from <em>The Mind's Gambit</em>, published here to invite conversation before the book goes to print. Read them, challenge them, and help me sharpen the arguments. For a deeper dive, each chapter has a companion episode on the <a href="/podcasts" style="color:#c9a84c; text-decoration:underline;">Podcast</a>.</p>
    </section>

    <section class="chapters-section">
      <h2 class="section-heading">Dive In &mdash; Read, Challenge, Discuss</h2>
      <div class="featured-grid">
        <a href="/blog/the-constant-board" class="chapter-card featured">
          <div class="chapter-card-img">
            <img src="/images/A_cinematic_realistic_scene_in_a_mgrine_____tunisi_delpmaspu.png" alt="The Constant Board cover" />
          </div>
          <div class="chapter-card-body">
            <span class="chapter-badge">Introduction</span>
            <h3>The Constant Board: From M&eacute;grine to Manhattan</h3>
            <p>A personal journey through the coffee houses of Tunisia and across the Atlantic&mdash;how a vinyl board, a humbling defeat, and a father&rsquo;s quiet faith shaped a lifelong relationship with chess.</p>
            <div class="chapter-meta"><span>February 2026</span><span>12 min read</span><span>Personal Essay</span></div>
          </div>
        </a>
        <a href="/blog/the-number" class="chapter-card featured">
          <div class="chapter-card-img">
            <img src="/images/For%20Website%20The%20Number.png" alt="The Number cover" />
          </div>
          <div class="chapter-card-body">
            <span class="chapter-badge">Chapter 1</span>
            <h3>The Number: Elo Ratings, Identity and the Sociology of Competitive Chess</h3>
            <p>How a statistical tool designed for neutral measurement became one of the most powerful psychological forces in the game, and what that tells us about the systems we build to measure human worth.</p>
            <div class="chapter-meta"><span>February 2026</span><span>18 min read</span><span>Academic Essay</span></div>
          </div>
        </a>
      </div>
    </section>

    <section class="chapters-section">
      <h2 class="section-heading">Upcoming Chapters</h2>
      <div class="upcoming-grid">
        <div class="upcoming-card"><div class="upcoming-number">2</div><div class="upcoming-body"><span class="upcoming-date">Coming March 2026</span><h3>The Myth of the Mad Genius</h3><p>Why the story chess tells about itself&mdash;that the game drives people mad&mdash;is a cultural construction that flatters players while excusing institutions.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">3</div><div class="upcoming-body"><span class="upcoming-date">Coming April 2026</span><h3>Two Endgames: From Fischer to Naroditsky</h3><p>Separated by half a century, undone by the same institutional indifference. Two endgames with no one left to play for them.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">4</div><div class="upcoming-body"><span class="upcoming-date">Coming May 2026</span><h3>The Prodigy Machine</h3><p>Inside the systems that identify, develop, and sometimes destroy young chess talent.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">5</div><div class="upcoming-body"><span class="upcoming-date">Coming June 2026</span><h3>One More Game</h3><p>The architecture of online blitz and bullet chess is nearly perfectly designed to produce addictive behavior.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">6</div><div class="upcoming-body"><span class="upcoming-date">Coming July 2026</span><h3>Chapter 6</h3><p>Coming soon.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">7</div><div class="upcoming-body"><span class="upcoming-date">Coming August 2026</span><h3>Chapter 7</h3><p>Coming soon.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">8</div><div class="upcoming-body"><span class="upcoming-date">Coming September 2026</span><h3>Chapter 8</h3><p>Coming soon.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">9</div><div class="upcoming-body"><span class="upcoming-date">Coming October 2026</span><h3>Chapter 9</h3><p>Coming soon.</p></div></div>
        <div class="upcoming-card"><div class="upcoming-number">10</div><div class="upcoming-body"><span class="upcoming-date">Coming November 2026</span><h3>Chapter 10</h3><p>Coming soon.</p></div></div>
      </div>
    </section>

    <section class  </main>
</BaseLayout>
<style>
  .blog-page, .blog-page * { opacity: 1 !important; }
  .blog-page { min-height: 100vh; padding-top: 80px; }
  .blog-hero { text-align: center; padding: 4rem 2rem 3rem; max-width: 800px; margin: 0 auto; }
  .blog-hero h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 3rem; color: #c9a84c; margin-bottom: 0.5rem; }
  .blog-subtitle { font-size: 1.3rem; color: #f0ece4; opacity: 0.8 !important; margin-bottom: 1.5rem; font-style: italic; }
  .blog-intro-text { font-size: 1rem; color: #a0a0a0; line-height: 1.7; max-width: 650px; margin: 0 auto; }
  .chapters-section, 
  .section-heading { font-family: 'Playfair Display', Georgia, serif; font-size: 1.6rem; color: #c9a84c; margin-bottom: 2rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(201,168,76,0.2); }
  .featured-grid { display: grid; grid-template-columns: 1fr; gap: 2rem; }
  .chapter-card.featured { display: grid; grid-template-columns: 360px 1fr; background: rgba(30,33,48,0.9); border: 1px solid rgba(201,168,76,0.15); border-radius: 12px; overflow: hidden; text-decoration: none; color: inherit; transition: border-color 0.3s, transform 0.2s; }
  .chapter-card.featured:hover { border-color: rgba(201,168,76,0.4); transform: translateY(-2px); }
  .chapter-card-img { overflow: hidden; max-height: 240px; }
  .chapter-card-img img { width: 100%; height: 100%; object-fit: cover; }
  .chapter-card-body { padding: 1.5rem 2rem; display: flex; flex-direction: column; justify-content: center; }
  .chapter-badge { display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: #c9a84c; margin-bottom: 0.75rem; }
  .chapter-card-body h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 1.3rem; color: #f0ece4; margin-bottom: 0.75rem; line-height: 1.3; }
  .chapter-card-body p { font-size: 0.9rem; color: #a0a0a0; line-height: 1.6; margin-bottom: 1rem; }
  .chapter-meta { display: flex; gap: 1.25rem; font-size: 0.75rem; color: #666; text-transform: uppercase; letter-spacing: 0.05em; }
  .upcoming-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
  .upcoming-card { display: flex; gap: 1rem; background: rgba(30,33,48,0.7); border: 1px solid rgba(255,255,255,0.06); border-radius: 10px; padding: 1.5rem; transition: border-color 0.3s; }
  .upcoming-card:hover { border-color: rgba(201,168,76,0.25); }
  .upcoming-number { font-family: 'Playfair Display', Georgia, serif; font-size: 2rem; color: rgba(201,168,76,0.3); font-weight: 700; line-height: 1; min-width: 40px; }
  .upcoming-body { flex: 1; }
  .upcoming-date { font-size: 0.7rem; color: #c9a84c; text-transform: uppercase; letter-spacing: 0.08em; display: block; margin-bottom: 0.5rem; }
  .upcoming-body h3 { font-family: 'Playfair Display', Georgia, serif; font-size: 1rem; color: #f0ece4; margin-bottom: 0.5rem; line-height: 1.3; }
  .upcoming-body p { font-size: 0.8rem; color: #777; line-height: 1.5; }
  .discussion-section { padding-bottom: 5rem; }
  
  
  nav { position: fixed; top: 0; left: 0; right: 0; z-index: 1000; background: rgba(15,17,28,0.95); backdrop-filter: blur(10px); border-bottom: 1px solid rgba(201,168,76,0.1); }
  .nav-inner { max-width: 1200px; margin: 0 auto; padding: 1rem 2rem; display: flex; justify-content: space-between; align-items: center; }
  .nav-logo { font-family: 'Playfair Display', Georgia, serif; font-size: 1.5rem; font-weight: 700; color: #c9a84c; text-decoration: none; }
  .nav-links { list-style: none; display: flex; gap: 2rem; align-items: center; margin: 0; padding: 0; }
  .nav-links a { color: #f0ece4; text-decoration: none; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.1em; transition: color 0.3s; }
  .nav-links a:hover, .nav-links a.active { color: #c9a84c; }
  .nav-btn { border: 1px solid #c9a84c; padding: 0.5rem 1.25rem; border-radius: 4px; }
  @media (max-width: 768px) { .chapter-card.featured { grid-template-columns: 1fr; } .chapter-card-img { max-height: 200px; } .upcoming-grid { grid-template-columns: 1fr; } .blog-hero h1 { font-size: 2rem; } }
  @media (max-width: 1024px) and (min-width: 769px) { .upcoming-grid { grid-template-columns: repeat(2, 1fr); } }
</style>
