---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const blogEntries = await getCollection('blog');
  return blogEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const formattedDate = new Date(entry.data.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title} &mdash; The Mind's Gambit`}>
  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/blog">Blog</a></li>
        <li><a href="/podcasts" class="nav-btn">Podcasts</a></li>
      </ul>
    </div>
  </nav>

  <article>
    <header class="article-header">
      <a href="/blog" class="back-link">&larr; Back to Blog</a>
      <span class="date">{formattedDate}</span>
      <h1>{entry.data.title}</h1>
      <p class="subtitle">{entry.data.description}</p>
      <div class="article-meta">
        <span class="author">By {entry.data.author}</span>
        <div class="tags">
          {entry.data.tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </header>

    <div class="content-lock-overlay" id="content-lock">
      <div class="lock-icon">&#x1F512;</div>
      <h2 class="lock-title">Register to Unlock This Chapter</h2>
      <p class="lock-subtitle">Create a free account to read the full article</p>
      <div class="lock-buttons">
        <button class="btn-primary" id="signup-btn">Sign Up</button>
        <button class="btn-secondary" id="signin-btn">Sign In</button>
      </div>
    </div>

    <div class="locked-content" id="locked-content">
      <div class="article-content">
        <Content />
      </div>
    </div>

    <!-- Reaction Bar -->
  <div id="reactionBarContainer" class="reaction-bar-wrapper">
    <div class="reaction-bar">
      <div id="reactionButtons" class="reaction-buttons"></div>
    </div>
  </div>
  <footer class="article-footer">
      <a href="/blog" class="back-link">&larr; Back to all articles</a>
    </footer>
  </article>

  <!-- Discussion Section -->
<section class="discussion-section" id="discussion">
  <div class="discussion-inner">
    <h2 class="discussion-heading">Join the Discussion</h2>
    <p class="discussion-intro">What resonated with you? What did I get wrong? Every chapter is a draft&mdash;your feedback shapes the final book.</p>
    <div id="authContainer"></div>
    <div id="commentsList" class="comments-list"></div>
    <div id="loadingState" class="loading-state" style="display:none;"><div class="spinner"></div><p>Loading comments...</p></div>
    <div id="errorState" class="error-state" style="display:none;"><p id="errorMessage"></p><button id="retryButton" class="btn-retry">Retry</button></div>
  </div>
</section>
<script>
let supabase, currentUser = null, currentReplyingToId = null, articleSlug = null;
function getArticleSlug() { return window.location.pathname.split('/').filter(Boolean).pop(); }
function getTimeAgo(date) {
  const s = Math.floor((new Date() - new Date(date)) / 1000);
  if (s < 60) return "just now";
  const m = Math.floor(s / 60); if (m < 60) return m + "m ago";
  const h = Math.floor(m / 60); if (h < 24) return h + "h ago";
  const d = Math.floor(h / 24); if (d < 7) return d + "d ago";
  const w = Math.floor(d / 7); if (w < 4) return w + "w ago";
  return Math.floor(d / 30) + "mo ago";
}
function escapeHtml(t) { const d = document.createElement("div"); d.textContent = t; return d.innerHTML; }
function initSupabase() {
  supabase = window.supabase.createClient("https://bhqbawzkqebiscxznexe.supabase.co","eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImJocWJhd3prcWViaXNjeHpuZXhlIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzI0MTczMzYsImV4cCI6MjA4Nzk5MzMzNn0.JkDemmYg40X5tCOcNSxO-vU9eSh8AR8kY6IxTyIuNGM");
}
async function checkAuth() {
  if (!window.Clerk) return null;
  try {
    const u = window.Clerk.user;
    if (u) { currentUser = { id: u.id, name: u.fullName || u.firstName || "User", avatar: u.imageUrl || null }; return currentUser; }
  } catch(e) { console.error(e); }
  return null;
}
function renderAuth() {
  const c = document.getElementById("authContainer");
  if (!currentUser) {
    c.innerHTML = '<div class="sign-in-prompt"><p>Sign in to join the conversation</p><button class="btn-sign-in" id="signInBtn">Sign In</button></div>';
    document.getElementById("signInBtn").addEventListener("click", () => window.Clerk.openSignIn());
  } else {
    c.innerHTML = '<form class="comment-form" id="commentForm"><div id="replyIndicator" class="reply-indicator" style="display:none;"><span class="reply-indicator-text" id="replyingToText"></span><button type="button" class="btn-cancel-reply" id="cancelReplyBtn">x</button></div><div class="form-user-info"><img src="' + (currentUser.avatar || '') + '" alt="" class="user-avatar-form" /><span class="form-user-name">' + escapeHtml(currentUser.name) + '</span></div><textarea id="commentInput" class="form-textarea" placeholder="Share your thoughts..." required></textarea><div class="form-actions"><button type="submit" class="btn-submit" id="submitBtn">Post Comment</button></div></form>';
    document.getElementById("commentForm").addEventListener("submit", handleSubmit);
    document.getElementById("cancelReplyBtn").addEventListener("click", () => { currentReplyingToId = null; updateReplyUI(); });
  }

  // Content gating
  var lock = document.getElementById('content-lock');
  var contentEl = document.getElementById('locked-content');
  if (lock && contentEl) {
    if (currentUser) {
      lock.classList.remove('is-visible');
      contentEl.classList.remove('is-locked');
    } else {
      lock.classList.add('is-visible');
      contentEl.classList.add('is-locked');
    }
  }
  // Hide discussion and reactions for non-authenticated users
  var reactionBar = document.getElementById('reactionBarContainer');
  var discussionSection = document.getElementById('discussion');
  if (currentUser) {
    if (reactionBar) reactionBar.style.display = '';
    if (discussionSection) discussionSection.style.display = '';
  } else {
    if (reactionBar) reactionBar.style.display = 'none';
    if (discussionSection) discussionSection.style.display = 'none';
  }

}
function updateReplyUI() {
  const ind = document.getElementById("replyIndicator");
  if (!ind) return;
  if (currentReplyingToId) {
    ind.style.display = "flex";
    const el = document.querySelector('[data-cid="' + currentReplyingToId + '"]');
    document.getElementById("replyingToText").textContent = "Replying to " + (el ? el.querySelector(".comment-author").textContent : "comment");
  } else { ind.style.display = "none"; }
}
async function handleSubmit(e) {
  e.preventDefault();
  if (!currentUser) { window.Clerk.openSignIn(); return; }
  const content = document.getElementById("commentInput").value.trim();
  if (!content) return;
  const btn = document.getElementById("submitBtn");
  btn.disabled = true; btn.textContent = "Posting...";
  try {
    const { error } = await supabase.from("comments").insert([{ article_slug: articleSlug, user_id: currentUser.id, user_name: currentUser.name, user_avatar: currentUser.avatar, parent_id: currentReplyingToId, content }]);
    if (error) throw error;
    document.getElementById("commentInput").value = "";
    currentReplyingToId = null; updateReplyUI();
    await loadComments();
// Wire lock overlay buttons
document.getElementById('signup-btn')?.addEventListener('click', () => window.Clerk?.openSignUp());
document.getElementById('signin-btn')?.addEventListener('click', () => window.Clerk?.openSignIn());

  } catch(e) { console.error(e); alert("Failed to post. Try again."); }
  finally { btn.disabled = false; btn.textContent = "Post Comment"; }
}
async function loadComments() {
  const list = document.getElementById("commentsList");
  const loading = document.getElementById("loadingState");
  loading.style.display = "flex"; list.innerHTML = "";
  try {
    const { data, error } = await supabase.from("comments").select("*").eq("article_slug", articleSlug).order("created_at", { ascending: true });
    if (error) throw error;
    loading.style.display = "none";
    if (!data || !data.length) { list.innerHTML = '<div class="empty-state"><p>No comments yet. Be the first to share your thoughts!</p></div>'; return; }
    const top = data.filter(c => !c.parent_id);
    const replies = data.filter(c => c.parent_id);
    top.forEach(c => { list.insertAdjacentHTML("beforeend", renderComment(c, replies.filter(r => r.parent_id === c.id))); });
    attachListeners();
    await loadCommentReactions();
  } catch(e) { loading.style.display = "none"; console.error(e); list.innerHTML = '<div class="empty-state"><p>Could not load comments.</p></div>'; }
}
function renderComment(c, replies) {
  const replyHtml = replies && replies.length ? '<div class="replies-container">' + replies.map(r => renderComment(r, [])).join("") + '</div>' : '';
  return '<div class="comment-thread" data-cid="' + c.id + '"><div class="comment-card"><div class="comment-header"><img src="' + (c.user_avatar || '') + '" alt="" class="comment-avatar" /><div class="comment-meta"><div class="comment-author">' + escapeHtml(c.user_name) + '</div><div class="comment-time">' + getTimeAgo(c.created_at) + '</div></div></div><div class="comment-content">' + escapeHtml(c.content) + '</div><div class="comment-actions"><div class="comment-reactions" data-cid="' + c.id + '"></div>' + (currentUser ? '<button class="btn-reply" data-cid="' + c.id + '">Reply</button>' : '') + '</div>' + replyHtml + '</div></div>';
}
function attachListeners() {
  document.querySelectorAll(".btn-reply").forEach(b => b.addEventListener("click", () => { currentReplyingToId = currentReplyingToId === b.dataset.cid ? null : b.dataset.cid; updateReplyUI(); const inp = document.getElementById("commentInput"); if(inp) inp.focus(); }));
  
}
async function loadCommentReactions() {
    const types = [{type:"heart",emoji:"\u2764\uFE0F"},{type:"thumbs_up",emoji:"\uD83D\uDC4D"},{type:"thumbs_down",emoji:"\uD83D\uDC4E"},{type:"fire",emoji:"\uD83D\uDD25"},{type:"mind_blown",emoji:"\uD83E\uDD2F"},{type:"clap",emoji:"\uD83D\uDC4F"}];
    document.querySelectorAll(".comment-reactions").forEach(async (container) => {
      const cid = container.dataset.cid;
      container.innerHTML = "";
      for (const t of types) {
        const { data } = await supabase.from("reactions").select("*").eq("article_slug", articleSlug).eq("comment_id", cid).eq("reaction_type", t.type);
        const count = data ? data.length : 0;
        let active = false;
        if (currentUser && data) active = data.some(r => r.user_id === currentUser.id);
        const btn = document.createElement("button");
        btn.className = "reaction-btn reaction-btn-sm" + (active ? " active" : "");
        btn.dataset.cid = cid;
        btn.dataset.rt = t.type;
        btn.innerHTML = '<span class="reaction-emoji">' + t.emoji + '</span>' + (count ? '<span class="reaction-count">' + count + '</span>' : '');
        btn.addEventListener("click", () => { if (currentUser) toggleCommentReaction(btn); });
        container.appendChild(btn);
      }
    });
  }
  async function toggleCommentReaction(btn) {
    const cid = btn.dataset.cid;
    const rt = btn.dataset.rt;
    try {
      const { data: ex } = await supabase.from("reactions").select("id").eq("comment_id", cid).eq("user_id", currentUser.id).eq("reaction_type", rt).maybeSingle();
      if (ex) {
        await supabase.from("reactions").delete().eq("id", ex.id);
        btn.classList.remove("active");
      } else {
        await supabase.from("reactions").insert([{ article_slug: articleSlug, comment_id: cid, user_id: currentUser.id, reaction_type: rt }]);
        btn.classList.add("active");
      }
      const { data: counts } = await supabase.from("reactions").select("id").eq("comment_id", cid).eq("reaction_type", rt);
      const countEl = btn.querySelector(".reaction-count");
      if (counts && counts.length) {
        if (countEl) countEl.textContent = counts.length;
        else btn.innerHTML = '<span class="reaction-emoji">' + btn.querySelector(".reaction-emoji").textContent + '</span><span class="reaction-count">' + counts.length + '</span>';
      } else {
        if (countEl) countEl.remove();
      }
    } catch(e) { console.error(e); }
  }
  async function loadReactions() {
  const types = [{type:"heart",emoji:"\u2764\uFE0F"},{type:"thumbs_up",emoji:"\uD83D\uDC4D"},{type:"thumbs_down",emoji:"\uD83D\uDC4E"},{type:"fire",emoji:"\uD83D\uDD25"},{type:"mind_blown",emoji:"\uD83E\uDD2F"},{type:"clap",emoji:"\uD83D\uDC4F"}];
  const container = document.getElementById("reactionButtons");
  container.innerHTML = "";
  for (const t of types) {
    const { data } = await supabase.from("reactions").select("*").eq("article_slug", articleSlug).eq("reaction_type", t.type).is("comment_id", null);
    const count = data ? data.length : 0;
    let active = false;
    if (currentUser && data) active = data.some(r => r.user_id === currentUser.id);
    const btn = document.createElement("button");
    btn.className = "reaction-btn" + (active ? " active" : "");
    btn.dataset.rt = t.type;
    btn.innerHTML = '<span class="reaction-emoji">' + t.emoji + '</span><span class="reaction-count">' + (count || "") + '</span>';
    btn.addEventListener("click", () => { if(!currentUser){window.Clerk.openSignIn();return;} toggleArticleReaction(btn, t.type); });
    container.appendChild(btn);
  }
}
async function toggleArticleReaction(btn, type) {
  try {
    const { data: ex } = await supabase.from("reactions").select("id").eq("article_slug", articleSlug).eq("user_id", currentUser.id).eq("reaction_type", type).is("comment_id", null).maybeSingle();
    if (ex) { await supabase.from("reactions").delete().eq("id", ex.id); btn.classList.remove("active"); }
    else { await supabase.from("reactions").insert([{ article_slug: articleSlug, user_id: currentUser.id, reaction_type: type, comment_id: null }]); btn.classList.add("active"); }
    const { data: counts } = await supabase.from("reactions").select("id").eq("article_slug", articleSlug).eq("reaction_type", type).is("comment_id", null);
    btn.querySelector(".reaction-count").textContent = counts ? counts.length : "";
  } catch(e) { console.error(e); }
}
document.addEventListener("DOMContentLoaded", () => {
  articleSlug = getArticleSlug();
  const s = document.createElement("script");
  s.src = "https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2";
  s.onload = async () => {
    initSupabase();
    if (window.Clerk) {
        try { await window.Clerk.load(); } catch(e) { console.error("Clerk load error:", e); }
      } else {
        let att = 0;
        while (!window.Clerk && att < 50) { await new Promise(r => setTimeout(r, 100)); att++; }
        if (window.Clerk) { try { await window.Clerk.load(); } catch(e) { console.error(e); } }
      }
      await checkAuth();
      renderAuth();
      await loadReactions();
      await loadComments();
      if (window.Clerk) {
        window.Clerk.addListener(({ user }) => {
          if (user) { currentUser = { id: user.id, name: user.fullName || user.firstName || "User", avatar: user.imageUrl || null }; }
          else { currentUser = null; }
          renderAuth();
        });
      }
  };
  document.head.appendChild(s);
});
</script>
<style is:global>



/* Navigation */
nav{background:rgba(15,17,28,.95);border-bottom:1px solid rgba(201,168,76,.2);position:sticky;top:0;z-index:100;backdrop-filter:blur(10px)}
.nav-inner{max-width:1200px;margin:0 auto;padding:0.75rem 2rem;display:flex;align-items:center;justify-content:space-between}
.nav-links{display:flex;gap:2rem;list-style:none;margin:0;padding:0;align-items:center}
.nav-links a{color:#e8e0d0;text-decoration:none;font-size:.9rem;letter-spacing:.1em;text-transform:uppercase;font-family:'Playfair Display',Georgia,serif;transition:color .3s}
.nav-links a:hover{color:#c9a84c}
.nav-btn{background:#c9a84c!important;color:#0f111c!important;padding:.5rem 1.25rem;border-radius:4px;font-weight:600}
/* Article Layout */
article{max-width:800px;margin:0 auto;padding:2rem 1.5rem}
.article-header{margin-bottom:2.5rem;padding-bottom:1.5rem;border-bottom:1px solid rgba(201,168,76,.2)}
.back-link{color:#c9a84c;text-decoration:none;font-size:.9rem;letter-spacing:.05em;display:inline-block;margin-bottom:1rem;transition:opacity .3s}
.back-link:hover{opacity:.7}
.date{color:rgba(232,224,208,.5);font-size:.85rem;display:block;margin-bottom:.75rem}
.article-header h1{font-family:'Playfair Display',Georgia,serif;font-size:2.5rem;color:#e8e0d0;line-height:1.2;margin:0 0 .75rem}
.subtitle{color:rgba(232,224,208,.7);font-size:1.1rem;line-height:1.5;margin:0 0 1rem}
.article-meta{display:flex;align-items:center;gap:1rem;flex-wrap:wrap}
.author{color:rgba(232,224,208,.6);font-size:.9rem}
.tags{display:flex;gap:.5rem;flex-wrap:wrap}
.tag{background:rgba(201,168,76,.15);color:#c9a84c;padding:.25rem .75rem;border-radius:4px;font-size:.75rem;text-transform:uppercase;letter-spacing:.05em}
/* Locked state: blur + fade */
.locked-content.is-locked{position:relative;max-height:300px;overflow:hidden;filter:blur(4px);pointer-events:none;user-select:none}
.locked-content.is-locked::after{content:'';position:absolute;bottom:0;left:0;right:0;height:200px;background:linear-gradient(transparent,rgba(15,17,28,.97));pointer-events:none}
.content-lock-overlay{display:none}
.content-lock-overlay.is-visible{display:block}
/* Content Lock */
.content-lock-overlay.is-visible{text-align:center;padding:2.5rem;margin:0 0 2rem;background:rgba(30,34,52,.6);border:1px solid rgba(201,168,76,.2);border-radius:12px}
.lock-icon{font-size:2rem;margin-bottom:1rem}
.lock-title{font-family:'Playfair Display',Georgia,serif;font-size:1.75rem;color:#e8e0d0;margin:0 0 .5rem}
.lock-subtitle{color:rgba(232,224,208,.6);margin:0 0 1.5rem;font-size:1rem}
.lock-buttons{display:flex;gap:1rem;justify-content:center}
.btn-primary{background:#c9a84c;color:#0f111c;border:none;padding:.75rem 2rem;border-radius:6px;font-weight:600;cursor:pointer;font-size:1rem;transition:all .2s}
.btn-primary:hover{background:#d4b356}
.btn-secondary{background:transparent;color:#c9a84c;border:1px solid #c9a84c;padding:.75rem 2rem;border-radius:6px;font-weight:600;cursor:pointer;font-size:1rem;transition:all .2s}
.btn-secondary:hover{background:rgba(201,168,76,.1)}
/* Article Content */
.article-content{line-height:1.8;color:#e0e0e0;font-size:1.05rem}
.article-content p{margin:0 0 1.5rem}
.article-content h2{font-family:'Playfair Display',Georgia,serif;font-size:1.75rem;color:#e8e0d0;margin:2.5rem 0 1rem}
.article-content h3{font-family:'Playfair Display',Georgia,serif;font-size:1.4rem;color:#e8e0d0;margin:2rem 0 .75rem}
.article-content img{width:100%;border-radius:8px;margin:1.5rem 0}
.article-content blockquote{border-left:3px solid #c9a84c;padding-left:1.5rem;margin:1.5rem 0;color:rgba(232,224,208,.8);font-style:italic}
.article-content a{color:#c9a84c;text-decoration:underline;text-underline-offset:3px}
/* Footer */
.article-footer{text-align:center;padding:2rem 0;margin-top:2rem}

.comment-reactions{display:flex;gap:.4rem;flex-wrap:wrap;margin-top:.5rem}
.reaction-btn-sm{padding:.25rem .5rem;font-size:.8rem;border-radius:16px}
.reaction-btn-sm .reaction-emoji{font-size:.9rem}
.reaction-btn-sm .reaction-count{font-size:.75rem}
.comment-actions{display:flex;flex-direction:column;gap:.5rem}
.comment-actions .btn-reply{align-self:flex-start}
.reaction-bar-wrapper{margin:2rem auto;padding:1.5rem 0;border-top:1px solid rgba(201,168,76,.2);border-bottom:1px solid rgba(201,168,76,.2);max-width:800px}
.reaction-buttons{display:flex;gap:.75rem;flex-wrap:wrap}
.reaction-btn{display:flex;align-items:center;gap:.5rem;padding:.5rem 1rem;background:rgba(30,34,52,.5);border:1px solid rgba(201,168,76,.2);border-radius:20px;color:#e0e0e0;font-size:.9rem;cursor:pointer;transition:all .2s;font-family:inherit}
.reaction-btn:hover{background:rgba(201,168,76,.1);border-color:rgba(201,168,76,.4)}
.reaction-btn.active{background:rgba(201,168,76,.2);border-color:#c9a84c;color:#c9a84c}
.reaction-emoji{font-size:1.2rem}.reaction-count{font-size:.85rem;color:#8a8a8a}
.reaction-btn.active .reaction-count{color:#c9a84c}
.discussion-section{max-width:800px;margin:0 auto;padding:3rem 0}
.discussion-heading{font-family:"Playfair Display",serif;font-size:1.75rem;color:#c9a84c;margin-bottom:.5rem}
.discussion-intro{color:#8a8a8a;margin-bottom:2rem;line-height:1.6}
.sign-in-prompt{background:rgba(30,34,52,.8);border:1px solid rgba(201,168,76,.2);border-radius:8px;padding:1.5rem;text-align:center}
.sign-in-prompt p{color:#e0e0e0;margin-bottom:1rem}
.btn-sign-in,.btn-submit{background:#c9a84c;color:#0f111c;border:none;padding:.75rem 1.5rem;border-radius:6px;font-weight:600;cursor:pointer;font-family:inherit;font-size:.95rem;transition:all .2s}
.btn-sign-in:hover,.btn-submit:hover:not(:disabled){background:#d4b356}
.btn-submit:disabled{background:#666;cursor:not-allowed;opacity:.6}
.comment-form{background:rgba(30,34,52,.8);border:1px solid rgba(201,168,76,.2);border-radius:8px;padding:1.5rem;margin-bottom:2rem}
.reply-indicator{display:flex;align-items:center;justify-content:space-between;background:rgba(201,168,76,.1);border-left:3px solid #c9a84c;padding:.75rem 1rem;margin-bottom:1rem;border-radius:4px}
.reply-indicator-text{color:#c9a84c;font-size:.9rem}
.btn-cancel-reply{background:none;border:none;color:#8a8a8a;cursor:pointer;font-size:1.2rem;padding:0}
.form-user-info{display:flex;align-items:center;gap:1rem;margin-bottom:1rem}
.user-avatar-form{width:40px;height:40px;border-radius:50%;object-fit:cover;border:2px solid rgba(201,168,76,.3)}
.form-user-name{color:#e0e0e0;font-weight:600}
.form-textarea{width:100%;min-height:100px;padding:.75rem;background:rgba(15,17,28,.6);border:1px solid rgba(201,168,76,.2);border-radius:6px;color:#e0e0e0;font-family:inherit;font-size:.95rem;resize:vertical;margin-bottom:1rem;box-sizing:border-box}
.form-textarea:focus{outline:none;border-color:#c9a84c}
.form-textarea::placeholder{color:#5a5a5a}
.form-actions{display:flex;justify-content:flex-end}
.comments-list{display:flex;flex-direction:column;gap:1.5rem}
.comment-thread{width:100%}
.comment-card{background:rgba(30,34,52,.6);border:1px solid rgba(201,168,76,.1);border-radius:8px;padding:1.25rem;transition:all .2s}
.comment-card:hover{border-color:rgba(201,168,76,.2);background:rgba(30,34,52,.8)}
.comment-header{display:flex;align-items:center;gap:.75rem;margin-bottom:.75rem}
.comment-avatar{width:36px;height:36px;border-radius:50%;object-fit:cover;border:2px solid rgba(201,168,76,.2)}
.comment-meta{display:flex;flex-direction:column}
.comment-author{color:#e0e0e0;font-weight:600;font-size:.95rem}
.comment-time{color:#8a8a8a;font-size:.85rem}
.comment-content{color:#e0e0e0;line-height:1.6;margin-bottom:1rem;word-wrap:break-word}
.comment-actions{display:flex;gap:1rem;align-items:center}
.btn-heart{background:none;border:none;color:#8a8a8a;cursor:pointer;padding:.25rem .5rem;transition:all .2s;display:flex;align-items:center;gap:.3rem;font-size:.85rem}
.btn-heart:hover{color:#e0e0e0}.btn-heart.active{color:#c9a84c}
.btn-reply{background:none;border:none;color:#8a8a8a;cursor:pointer;font-size:.85rem;padding:.25rem .5rem;transition:color .2s;font-family:inherit}
.btn-reply:hover{color:#c9a84c}
.replies-container{margin-top:1rem;padding-left:2rem;border-left:2px solid rgba(201,168,76,.1);display:flex;flex-direction:column;gap:1rem}
.replies-container .comment-card{background:rgba(30,34,52,.4)}
.empty-state{text-align:center;padding:3rem 1rem;color:#8a8a8a}
.loading-state{display:flex;flex-direction:column;align-items:center;padding:3rem 1rem;gap:1rem}
.spinner{width:40px;height:40px;border:3px solid rgba(201,168,76,.2);border-top-color:#c9a84c;border-radius:50%;animation:spin .8s linear infinite}
@keyframes spin{to{transform:rotate(360deg)}}
.loading-state p{color:#8a8a8a}
.error-state{background:rgba(220,38,38,.1);border:1px solid rgba(220,38,38,.3);border-radius:8px;padding:1.5rem;text-align:center;margin:2rem 0}
.error-state p{color:#fca5a5;margin-bottom:1rem}
.btn-retry{background:#dc2626;color:#fff;border:none;padding:.75rem 1.5rem;border-radius:6px;cursor:pointer;font-family:inherit;font-weight:600}
@media(max-width:640px){.replies-container{padding-left:1rem}.reaction-buttons{gap:.5rem}.reaction-btn{padding:.4rem .8rem;font-size:.85rem}}
</style>

</BaseLayout>