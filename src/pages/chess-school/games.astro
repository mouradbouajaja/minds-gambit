---
import BaseLayout from '../../layouts/BaseLayout.astro';

const BUNNY = 'https://mindsgambitgames.b-cdn.net';

// Fetch the ECO + historical manifests at BUILD TIME (server-side, no CORS).
type EcoEntry = { name?: string; gameCount?: number; games?: number; fileSize?: number; sizeKB?: number };
type EcoManifest = { totalGames?: number; ecos?: Record<string, EcoEntry> };

async function safeFetchJson(url: string): Promise<EcoManifest | null> {
  try {
    const r = await fetch(url);
    if (!r.ok) return null;
    return await r.json() as EcoManifest;
  } catch {
    return null;
  }
}

const ecoManifest = (await safeFetchJson(`${BUNNY}/eco/eco-index.json`)) || { ecos: {} };
const histManifest = (await safeFetchJson(`${BUNNY}/historical/eco-index.json`)) || { ecos: {} };

type NormEntry = { code: string; name: string; games: number; bytes: number };

const ecoEntries: NormEntry[] = Object.entries(ecoManifest.ecos || {})
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([code, e]) => ({
    code, name: e.name || '',
    games: e.gameCount || 0,
    bytes: e.fileSize || 0,
  }));

const histEntries: NormEntry[] = Object.entries(histManifest.ecos || {})
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([code, e]) => ({
    code, name: e.name || '',
    games: e.games || 0,
    bytes: (e.sizeKB || 0) * 1024,
  }));

const totalEcoGames = ecoManifest.totalGames || ecoEntries.reduce((s, e) => s + e.games, 0);
const totalHistGames = histManifest.totalGames || histEntries.reduce((s, e) => s + e.games, 0);

// Map: code -> NormEntry (modern) for quick lookup when rendering the tree.
const ecoByCode = new Map<string, NormEntry>(ecoEntries.map((e) => [e.code, e]));

// Generate a range of ECO codes like ['A00', 'A01', ... 'A09']
function ecoRange(start: string, end: string): string[] {
  const out: string[] = [];
  const letter = start[0];
  const sn = parseInt(start.slice(1));
  const en = parseInt(end.slice(1));
  for (let n = sn; n <= en; n++) out.push(letter + String(n).padStart(2, '0'));
  return out;
}

// Hierarchical tree of opening families, the way most coaches and chess books
// organize them. Each node has either a `codes` array (leaf) OR `children` (branch).
type TreeNode = { label: string; help?: string; codes?: string[]; children?: TreeNode[] };

const ecoTree: TreeNode[] = [
  {
    label: 'Flank Openings &mdash; White does not push a center pawn two squares',
    help: 'Games that begin with a quiet first move like 1.c4 (the English) or 1.b3, 1.Nf3, 1.g3.',
    children: [
      { label: 'Irregular Openings (1.b3, 1.b4, 1.f4, 1.Nc3, etc.)', codes: ecoRange('A00', 'A09') },
      { label: 'The English Opening (1.c4) &mdash; classical lines', codes: ecoRange('A10', 'A19') },
      { label: 'The English Opening &mdash; with 1...e5', codes: ecoRange('A20', 'A29') },
      { label: 'The English Opening &mdash; symmetrical', codes: ecoRange('A30', 'A39') },
    ],
  },
  {
    label: 'Replies to 1.d4 without an early ...d5',
    help: 'Black answers 1.d4 with knights and pieces rather than ...d5. Includes the Indian families and the Dutch.',
    children: [
      { label: 'Old Benoni, Modern Defenses, atypical Black setups', codes: ecoRange('A40', 'A49') },
      { label: 'Old Indian, Benoni, Benko Gambit', codes: ecoRange('A50', 'A79') },
      { label: 'Dutch Defense (1.d4 f5)', codes: ecoRange('A80', 'A99') },
    ],
  },
  {
    label: 'Semi-Open Games &mdash; 1.e4 with Black NOT replying 1...e5',
    help: 'When White plays 1.e4 and Black answers with anything except a pawn to e5 (so: 1...c5, 1...e6, 1...c6, 1...d6, etc.).',
    children: [
      { label: 'Owen, Pirc, Modern, Robatsch (1.e4 various)', codes: ecoRange('B00', 'B09') },
      { label: 'Caro-Kann Defense (1.e4 c6)', codes: ecoRange('B10', 'B19') },
      { label: 'Sicilian Defense (1.e4 c5)', codes: ecoRange('B20', 'B99') },
    ],
  },
  {
    label: 'French Defense (1.e4 e6)',
    help: 'Black answers 1.e4 with 1...e6, planning ...d5 next move.',
    codes: ecoRange('C00', 'C19'),
  },
  {
    label: 'Open Games &mdash; 1.e4 e5',
    help: 'The oldest and most classical battlefield in chess: both sides advance a center pawn two squares with the first move.',
    children: [
      { label: 'King\'s Pawn miscellaneous lines', codes: ecoRange('C20', 'C29') },
      { label: 'King\'s Gambit (1.e4 e5 2.f4)', codes: ecoRange('C30', 'C39') },
      { label: 'Russian Game / Petroff Defense', codes: ecoRange('C40', 'C49') },
      { label: 'Italian Game, Two Knights, Scotch', codes: ecoRange('C50', 'C59') },
      { label: 'Ruy L&oacute;pez (Spanish Opening)', codes: ecoRange('C60', 'C99') },
    ],
  },
  {
    label: 'Closed Games (1.d4 d5)',
    help: 'Both sides push the queen\'s pawn two squares. The Queen\'s Gambit, the Slav, the Tarrasch, and many more.',
    codes: ecoRange('D00', 'D69'),
  },
  {
    label: 'Gr&uuml;nfeld Defense (1.d4 Nf6 with an early ...d5)',
    help: 'Black lets White build a big center, then strikes it down with pieces. A favorite of fighting players.',
    codes: ecoRange('D70', 'D99'),
  },
  {
    label: 'Indian Defenses (1.d4 Nf6 without ...d5)',
    help: 'Black develops knights and bishops first, fighting for the center from a distance. Includes the Nimzo-Indian, King\'s Indian, Queen\'s Indian, and Catalan.',
    children: [
      { label: 'Catalan (1.d4 Nf6 2.c4 e6 3.g3)', codes: ecoRange('E00', 'E09') },
      { label: 'Queen\'s Indian Defense', codes: ecoRange('E10', 'E19') },
      { label: 'Nimzo-Indian Defense', codes: ecoRange('E20', 'E59') },
      { label: 'King\'s Indian Defense', codes: ecoRange('E60', 'E99') },
    ],
  },
];

function bytesToHuman(n: number): string {
  if (!n || n < 1024) return (n || 0) + ' B';
  if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
  if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + ' MB';
  return (n / 1024 / 1024 / 1024).toFixed(2) + ' GB';
}

function fmtCount(n: number): string {
  return new Intl.NumberFormat('en-US').format(n || 0);
}

// Curated player collections — all hosted on Bunny CDN at /players/<file>.pgn.
const playersModern = [
  { name: 'Magnus Carlsen', file: 'Carlsen' },
  { name: 'Hikaru Nakamura', file: 'Nakamura' },
  { name: 'Fabiano Caruana', file: 'Caruana' },
  { name: 'Ding Liren', file: 'Ding' },
  { name: 'Ian Nepomniachtchi', file: 'Nepomniachtchi' },
  { name: 'Alireza Firouzja', file: 'Firouzja' },
  { name: 'Wesley So', file: 'So' },
  { name: 'Viswanathan Anand', file: 'Anand' },
  { name: 'Levon Aronian', file: 'Aronian' },
  { name: 'Anish Giri', file: 'Giri' },
  { name: 'Gukesh Dommaraju', file: 'Gukesh' },
  { name: 'Praggnanandhaa R.', file: 'Praggnanandhaa' },
  { name: 'Vladimir Kramnik', file: 'Kramnik' },
  { name: 'Veselin Topalov', file: 'Topalov' },
  { name: 'Vassily Ivanchuk', file: 'Ivanchuk' },
  { name: 'Alexei Shirov', file: 'Shirov' },
  { name: 'Judit Polgar', file: 'Polgar' },
  { name: 'Maxime Vachier-Lagrave', file: 'VachierLagrave' },
