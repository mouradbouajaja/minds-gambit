.variation-toggle:hover { background: rgba(201,168,76,0.12); border-color: rgba(201,168,76,0.45); }



.variation-toggle[aria-expanded="true"] { background: rgba(201,168,76,0.15); border-color: rgba(201,168,76,0.55); color: #c9a84c; }



