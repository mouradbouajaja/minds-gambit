      items: [



        { name: 'Zukertort Main', move: '5.b3 then 6.Bb2' },



        { name: 'Colle-Koltanowski', move: '5.c3 instead of 5.b3' },



        { name: 'Phoenix Attack', move: 'Bxh7+ sacrifice ideas' },



        { name: 'Anti-Indian Colle', move: 'system vs ...Nf6/...g6' }



