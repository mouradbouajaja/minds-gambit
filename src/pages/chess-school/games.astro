<!-- chess.js for PGN parsing & move state -->
<script src="https://cdn.jsdelivr.net/npm/chess.js@0.13.4/chess.min.js"></script>

<script>
  // ----- Tabs + Search (same as before) -----
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      document.querySelector(`.tab-panel[data-panel="${tab}"]`)?.classList.add('active');
    });
  });

  function attachSearch(inputId: string, cardSelector: string, datasetKey: string) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    if (!input) return;
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      document.querySelectorAll(cardSelector).forEach((card) => {
        const haystack = ((card as HTMLElement).dataset[datasetKey] || '').toLowerCase();
        (card as HTMLElement).style.display = (!q || haystack.includes(q)) ? '' : 'none';
      });
    });
  }
  attachSearch('eco-search', '#eco-grid .eco-card', 'search');
  attachSearch('hist-search', '#hist-grid .eco-card', 'search');
  attachSearch('player-search', '.player-card', 'name');

  // ----- Click to open viewer -----
  document.querySelectorAll('.game-card[data-file]').forEach((card) => {
    card.addEventListener('click', () => openViewer(card as HTMLElement));
    card.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openViewer(card as HTMLElement); }
    });
  });

  // ===== Viewer state =====
  const overlay = document.getElementById('viewerOverlay')!;
  const titleEl = document.getElementById('viewerTitle')!;
  const subEl = document.getElementById('viewerSub')!;
  const gameListEl = document.getElementById('viewerGameList')!;
  const gameListEmptyEl = document.getElementById('viewerGameListEmpty')!;
  const boardSvg = document.getElementById('boardSvg') as unknown as SVGElement;
  const btnFirst = document.getElementById('btnFirst') as HTMLButtonElement;
  const btnPrev = document.getElementById('btnPrev') as HTMLButtonElement;
  const btnNext = document.getElementById('btnNext') as HTMLButtonElement;
  const btnLast = document.getElementById('btnLast') as HTMLButtonElement;
  const btnFlip = document.getElementById('btnFlip') as HTMLButtonElement;
  const boardPos = document.getElementById('boardPos')!;
  const gameHeadersDl = document.getElementById('gameHeadersDl')!;
  const moveListEl = document.getElementById('moveListEl')!;
  const closeBtn = document.getElementById('viewerClose')!;

  type ParsedGame = { headers: Record<string, string>; pgn: string };
  let games: ParsedGame[] = [];
  let currentGameIdx = -1;
  let currentMoves: { san: string; fen: string }[] = [];
  let currentMoveIdx = -1;
  let flipped = false;

  const STARTING_FEN = 'rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1';
  const PIECE = {
    K: '♔', Q: '♕', R: '♖', B: '♗', N: '♘', P: '♙',
    k: '♚', q: '♛', r: '♜', b: '♝', n: '♞', p: '♟',
  } as Record<string, string>;

  // Render an SVG chessboard from a FEN string.
  function renderBoard(fen: string) {
    const ranks = fen.split(' ')[0].split('/');
    const sq = 50;
    let svg = '';
    for (let r = 0; r < 8; r++) {
      let file = 0;
      const rankRow = ranks[r];
      for (const ch of rankRow) {
        if (/[1-8]/.test(ch)) { file += parseInt(ch); continue; }
        const dispR = flipped ? 7 - r : r;
        const dispF = flipped ? 7 - file : file;
        const x = dispF * sq;
        const y = dispR * sq;
        const isLight = (dispR + dispF) % 2 === 0;
        // Square color is drawn in batch below; here we draw piece on top.
        const piece = PIECE[ch] || '';
        const pieceColor = ch === ch.toUpperCase() ? '#1a1a1a' : '#0a0a0a';
        svg += `<text x="${x + sq/2}" y="${y + sq*0.72}" text-anchor="middle" font-family="Noto Sans Symbols 2, DejaVu Serif, Cambria, Georgia, Times New Roman, serif" font-size="${sq*0.82}" fill="${pieceColor}">${piece}</text>`;
        file++;
      }
    }
    // Draw squares first so they're underneath the pieces text.
    let squares = '';
    for (let r = 0; r < 8; r++) {
      for (let f = 0; f < 8; f++) {
        const dispR = flipped ? 7 - r : r;
        const dispF = flipped ? 7 - f : f;
        const x = dispF * sq;
        const y = dispR * sq;
        const isLight = (r + f) % 2 === 0;
        squares += `<rect x="${x}" y="${y}" width="${sq}" height="${sq}" fill="${isLight ? '#f5ead6' : '#c9a87a'}" />`;
      }
    }
    // Coordinate labels
    let coords = '';
    const fileLetters = flipped ? ['h','g','f','e','d','c','b','a'] : ['a','b','c','d','e','f','g','h'];
    const rankNumbers = flipped ? ['1','2','3','4','5','6','7','8'] : ['8','7','6','5','4','3','2','1'];
    for (let i = 0; i < 8; i++) {
      coords += `<text x="${i*sq + 4}" y="${8*sq - 4}" font-family="Georgia, serif" font-size="10" fill="rgba(0,0,0,0.4)">${fileLetters[i]}</text>`;
      coords += `<text x="${8*sq - 10}" y="${i*sq + 12}" font-family="Georgia, serif" font-size="10" fill="rgba(0,0,0,0.4)">${rankNumbers[i]}</text>`;
    }
    boardSvg.innerHTML = squares + coords + svg;
  }

  function openViewer(card: HTMLElement) {
    const file = card.dataset.file || '';
    const label = card.dataset.label || file;
    const bytes = parseInt(card.dataset.bytes || '0', 10);

    titleEl.textContent = label;
    subEl.textContent = bytes ? humanBytes(bytes) + ' on the network' : '';
    overlay.classList.add('active');
    document.body.style.overflow = 'hidden';
    renderBoard(STARTING_FEN);
    boardPos.textContent = 'Loading PGN...';
    gameListEmptyEl.textContent = 'Loading games...';
    gameListEmptyEl.style.display = '';
    games = [];
    currentGameIdx = -1;
    currentMoves = [];
    currentMoveIdx = -1;
    updateButtons();
    gameHeadersDl.innerHTML = '<dt>&mdash;</dt><dd>Loading game...</dd>';
    moveListEl.innerHTML = '';

    // Fetch first 200KB via Range request — enough for ~50 games' headers + moves.
    fetch('/api/pgn?file=' + encodeURIComponent(file), { headers: { 'Range': 'bytes=0-204800' } })
      .then((r) => r.text())
      .then((text) => {
        games = parsePgnBatch(text, 50);
        if (games.length === 0) {
          gameListEmptyEl.textContent = 'No games found in this file.';
          return;
        }
        renderGameList();
        selectGame(0);
      })
      .catch((err) => {
        gameListEmptyEl.textContent = 'Could not load PGN: ' + err.message;
      });
  }

  function humanBytes(n: number): string {
    if (n < 1024) return n + ' B';
    if (n < 1048576) return (n/1024).toFixed(1) + ' KB';
    if (n < 1073741824) return (n/1048576).toFixed(1) + ' MB';
    return (n/1073741824).toFixed(2) + ' GB';
  }

  // Parse a PGN string into individual games. Returns up to maxGames complete games.
  function parsePgnBatch(text: string, maxGames: number): ParsedGame[] {
    const result: ParsedGame[] = [];
    // Split on the start of a new game's [Event tag — preserve the [Event marker.
    const parts = text.split(/(?=^\[Event\b)/m);
    for (const part of parts) {
      const trimmed = part.trim();
      if (!trimmed || !trimmed.startsWith('[Event')) continue;
      const headers: Record<string, string> = {};
      const headerRegex = /^\[(\w+)\s+"((?:\\"|[^"])*)"\]\s*$/gm;
      let m: RegExpExecArray | null;
      while ((m = headerRegex.exec(trimmed)) !== null) {
        headers[m[1]] = m[2].replace(/\\"/g, '"');
      }
      // The move text is everything after the last header line.
      const lastHeaderEnd = trimmed.search(/\n\s*\n/);
      let moveText = lastHeaderEnd > -1 ? trimmed.slice(lastHeaderEnd).trim() : '';
      // Require a result token to count it as complete.
      if (!/(1-0|0-1|1\/2-1\/2|\*)\s*$/.test(moveText)) continue;
      result.push({ headers, pgn: trimmed });
      if (result.length >= maxGames) break;
    }
    return result;
  }

  function renderGameList() {
    gameListEmptyEl.style.display = 'none';
    gameListEl.innerHTML = '<h4>Games (' + games.length + ')</h4>' + games.map((g, i) => {
      const w = g.headers.White || 'Unknown';
      const b = g.headers.Black || 'Unknown';
      const res = g.headers.Result || '*';
      const event = g.headers.Event || '';
      const date = g.headers.Date || g.headers.UTCDate || '';
      return `<div class="viewer-gameitem" data-idx="${i}">
        <div class="viewer-gameitem-players">${escapeHtml(w)} &mdash; ${escapeHtml(b)}</div>
        <div class="viewer-gameitem-meta">
          <span class="viewer-gameitem-result">${res}</span>
          ${event ? `<span>${escapeHtml(event)}</span>` : ''}
          ${date ? `<span>${escapeHtml(date)}</span>` : ''}
        </div>
      </div>`;
    }).join('');
    gameListEl.querySelectorAll('.viewer-gameitem').forEach((el) => {
      el.addEventListener('click', () => selectGame(parseInt((el as HTMLElement).dataset.idx || '0', 10)));
    });
  }

  function escapeHtml(s: string): string {
    return s.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
  }

  function selectGame(idx: number) {
    if (idx < 0 || idx >= games.length) return;
    currentGameIdx = idx;
    gameListEl.querySelectorAll('.viewer-gameitem').forEach((el, i) => {
      el.classList.toggle('active', i === idx);
    });
    const g = games[idx];
    // Render headers
    const orderedHeaderKeys = ['White', 'Black', 'Result', 'Event', 'Site', 'Date', 'Round', 'ECO', 'Opening', 'WhiteElo', 'BlackElo'];
    let html = '';
    for (const k of orderedHeaderKeys) {
      if (g.headers[k]) html += `<dt>${k}</dt><dd>${escapeHtml(g.headers[k])}</dd>`;
    }
    gameHeadersDl.innerHTML = html || '<dt>&mdash;</dt><dd>(no headers)</dd>';

    // Parse via chess.js
    const ChessCtor = (window as any).Chess;
    if (!ChessCtor) {
      boardPos.textContent = 'chess.js failed to load';
      return;
    }
    const chess = new ChessCtor();
    let ok = false;
    try { ok = chess.load_pgn(g.pgn, { sloppy: true }); } catch (e) { ok = false; }
    if (!ok) {
      // chess.js can be picky; try a more permissive parse by stripping comments.
      const stripped = g.pgn.replace(/\{[^}]*\}/g, '').replace(/\([^)]*\)/g, '');
      try { ok = chess.load_pgn(stripped, { sloppy: true }); } catch (e) { ok = false; }
    }
    if (!ok) {
      boardPos.textContent = 'Could not parse this game';
      return;
    }
    // Step through the game to collect FEN at each ply.
    const history = chess.history({ verbose: true });
    const replay = new ChessCtor();
    currentMoves = [{ san: '', fen: replay.fen() }];
    for (const mv of history) {
      replay.move(mv);
      currentMoves.push({ san: mv.san, fen: replay.fen() });
    }
    renderMoveList();
    goToMove(currentMoves.length - 1); // Jump to end of game
  }

  function renderMoveList() {
    let html = '';
    for (let i = 1; i < currentMoves.length; i++) {
      if (i % 2 === 1) {
        html += `<span class="move-num">${Math.ceil(i/2)}.</span>`;
      }
      html += `<span class="move-san" data-move="${i}">${escapeHtml(currentMoves[i].san)}</span> `;
    }
    moveListEl.innerHTML = html;
    moveListEl.querySelectorAll('.move-san').forEach((el) => {
      el.addEventListener('click', () => goToMove(parseInt((el as HTMLElement).dataset.move || '0', 10)));
    });
  }

  function goToMove(idx: number) {
    if (currentMoves.length === 0) return;
    currentMoveIdx = Math.max(0, Math.min(idx, currentMoves.length - 1));
    renderBoard(currentMoves[currentMoveIdx].fen);
    boardPos.textContent = currentMoveIdx === 0
      ? 'Start position'
      : `Move ${Math.ceil(currentMoveIdx/2)}${currentMoveIdx % 2 === 1 ? '.' : '...'} ${currentMoves[currentMoveIdx].san}`;
    // highlight current move
    moveListEl.querySelectorAll('.move-san').forEach((el) => {
      el.classList.toggle('current', parseInt((el as HTMLElement).dataset.move || '0', 10) === currentMoveIdx);
    });
    updateButtons();
  }

  function updateButtons() {
    const has = currentMoves.length > 0;
    btnFirst.disabled = !has || currentMoveIdx <= 0;
    btnPrev.disabled = !has || currentMoveIdx <= 0;
    btnNext.disabled = !has || currentMoveIdx >= currentMoves.length - 1;
    btnLast.disabled = !has || currentMoveIdx >= currentMoves.length - 1;
    btnFlip.disabled = !has;
  }

  btnFirst.addEventListener('click', () => goToMove(0));
  btnPrev.addEventListener('click', () => goToMove(currentMoveIdx - 1));
  btnNext.addEventListener('click', () => goToMove(currentMoveIdx + 1));
  btnLast.addEventListener('click', () => goToMove(currentMoves.length - 1));
  btnFlip.addEventListener('click', () => { flipped = !flipped; if (currentMoves.length > 0) renderBoard(currentMoves[currentMoveIdx].fen); });

  closeBtn.addEventListener('click', closeViewer);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) closeViewer(); });

  function closeViewer() {
    overlay.classList.remove('active');
    document.body.style.overflow = '';
  }

  document.addEventListener('keydown', (e) => {
    if (!overlay.classList.contains('active')) return;
    if (e.key === 'Escape') closeViewer();
    else if (e.key === 'ArrowLeft') { e.preventDefault(); if (!btnPrev.disabled) goToMove(currentMoveIdx - 1); }
    else if (e.key === 'ArrowRight') { e.preventDefault(); if (!btnNext.disabled) goToMove(currentMoveIdx + 1); }
    else if (e.key === 'Home') { e.preventDefault(); goToMove(0); }
    else if (e.key === 'End') { e.preventDefault(); goToMove(currentMoves.length - 1); }
  });

  // Initial empty board so users see what they're getting before opening.
  renderBoard(STARTING_FEN);
</script>

</BaseLayout>
