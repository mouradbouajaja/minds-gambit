      }
      .nav-links .has-dropdown.open > .dropdown-menu { display: flex; }
    }

  </style>

<style is:global>
.founding-coach-section { padding: 3rem 1.5rem 1.5rem; }
.fc-inner { max-width: 1280px; margin: 0 auto; }
.fc-card { position: relative; background: linear-gradient(135deg, rgba(201,168,76,0.13) 0%, rgba(30,34,52,0.78) 60%, rgba(15,17,28,0.92) 100%); border: 1px solid rgba(201,168,76,0.55); border-radius: 18px; padding: 2.2rem 2.4rem 2rem; box-shadow: 0 18px 50px rgba(201,168,76,0.20), 0 10px 28px rgba(0,0,0,0.45); overflow: hidden; }
