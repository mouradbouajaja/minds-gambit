<script is:inline>
(function(){
  'use strict';
  var src=document.getElementById('book-source'); if(!src) return;
  var secs=Array.prototype.slice.call(src.children).filter(function(n){return n.tagName==='SECTION';});
  var book=document.getElementById('rd-book');
  var sheet=document.getElementById('rd-sheet');
  var runEl=sheet.querySelector('.rd-run');
  var bodyEl=sheet.querySelector('.rd-body');
  var folEl=sheet.querySelector('.rd-folio');
  var loadEl=document.getElementById('rd-load');
  var progEl=document.getElementById('rd-prog');
  var pages=[],cur=0,POS='mgReadPos';
  var FORTH=[['6','The Pattern Seekers'],['7','Medicine on 64 Squares'],['8','One More Game'],['9','The Ghost in the Machine'],['10','The Mind&rsquo;s Gambit Empirical Study']];

  var meas=sheet.cloneNode(true);
  meas.removeAttribute('id');
  meas.className='rd-sheet rd-meas';
  book.appendChild(meas);
  var measBody=meas.querySelector('.rd-body');

  function sizes(){
    var W=Math.min(640,window.innerWidth-16);
    var H=Math.min(window.innerHeight-210,Math.round(W*1.5));
    if(H<430)H=430;
    book.style.width=W+'px';book.style.height=H+'px';
  }

  function coverHtml(){
    return '<img class="rd-coverimg" src="/images/book-cover-2026.png" alt="The Mind&rsquo;s Gambit &mdash; book cover">';
  }
  function soonHtml(sec){
    var n=sec.getAttribute('data-num'),t=sec.getAttribute('data-title'),s=sec.getAttribute('data-sub')||'';
    return '<div class="soon"><div class="ch-kick">Chapter '+n+'</div><h2 class="ch-t">'+t+'</h2><div class="ch-sub">'+s+'</div><div class="ch-orn">&#11835;</div><div class="soon-badge">Coming soon</div><p class="soon-p">This chapter is being written now, alongside Episode '+n+' of the documentary series. The Mind&rsquo;s Gambit is written in public &mdash; new chapters appear on these pages the moment they are ready.</p><div class="soon-pawn">&#9823;</div></div>';
  }
  function openHtml(sec){
    var k=sec.getAttribute('data-kind'),t=sec.getAttribute('data-title'),s=sec.getAttribute('data-sub');
    var h='<div class="ch-open">';
    if(k==='chapter')h+='<div class="ch-kick">Chapter '+sec.getAttribute('data-num')+'</div><h2 class="ch-t">'+t+'</h2>'+(s?'<div class="ch-sub">'+s+'</div>':'');
    else h+='<h2 class="fm-h">'+t.toUpperCase()+'</h2>'+(s?'<div class="ch-sub">'+s+'</div>':'');
    return h+'<div class="ch-orn">&#11835;</div></div>';
  }
  function firstNum(id){
    for(var i=0;i<pages.length;i++)if(pages[i].sec.getAttribute('data-id')===id)return pages[i].num;
    return null;
  }
  function firstIdx(id){
    for(var i=0;i<pages.length;i++)if(pages[i].sec.getAttribute('data-id')===id)return i;
    return 0;
  }
  function contentsHtml(){
    var h='<div class="tc"><h2 class="fm-h">CONTENTS</h2><div class="ch-orn">&#11835;</div>';
    secs.forEach(function(sec){
      var k=sec.getAttribute('data-kind');
      if(k!=='front'&&k!=='chapter'&&k!=='soon')return;
      var id=sec.getAttribute('data-id'),t=sec.getAttribute('data-title');
      var n=(k==='front')?'':sec.getAttribute('data-num');
      var pg=firstNum(id);
      h+='<a class="tc-row" data-goto="'+id+'" href="javascript:void(0)">'+(n?'<span class="tc-n">'+n+'</span>':'<span class="tc-n"></span>')+'<span class="tc-t">'+t+'</span><span class="tc-dots"></span><span class="tc-pg">'+(pg||'&mdash;')+'</span></a>';
    });
    FORTH.forEach(function(f){
      h+='<div class="tc-row tc-dim"><span class="tc-n">'+f[0]+'</span><span class="tc-t">'+f[1]+'</span><span class="tc-dots"></span><span class="tc-pg">soon</span></div>';
    });
    h+='<div class="tc-note">About the Author &middot; Endnotes &middot; Bibliography &middot; Index &mdash; at publication.<br/>The book is written in public: chapters appear here as they are finished.</div></div>';
    return h;
  }

  function splitFit(node,q){
    if(node.children.length>0||!node.textContent){return false;}
    var words=node.textContent.split(' ');
    if(words.length<8)return false;
    var lo=1,hi=words.length-1,fit=0,orig=node.textContent;
    while(lo<=hi){
      var mid=(lo+hi)>>1;
      node.textContent=words.slice(0,mid).join(' ');
      if(measBody.scrollHeight<=measBody.clientHeight+1){fit=mid;lo=mid+1;}else{hi=mid-1;}
    }
    if(fit<1){node.textContent=orig;return false;}
    node.textContent=words.slice(0,fit).join(' ');
    var rest=document.createElement(node.tagName.toLowerCase());
    rest.className=((node.className||'').replace(/\bdc\b/,'').trim()+' cont').trim();
    rest.textContent=words.slice(fit).join(' ');
    q.unshift(rest);
    return true;
  }

  function flowSection(sec){
    var q=[],i;
    var open=document.createElement('div');open.innerHTML=openHtml(sec);
    q.push(open.firstChild);
    var kids=sec.children;
    for(i=0;i<kids.length;i++)q.push(kids[i].cloneNode(true));
    measBody.innerHTML='';
    function flush(){
      if(measBody.children.length===0)return;
      pages.push({sec:sec,html:measBody.innerHTML});
      measBody.innerHTML='';
    }
    var guard=0;
    while(q.length&&guard++<5000){
      var node=q.shift();
      measBody.appendChild(node);
      if(measBody.scrollHeight>measBody.clientHeight+1){
        if(measBody.children.length===1){
          if(!splitFit(node,q)){flush();}
          else{flush();}
        }else{
          measBody.removeChild(node);
          q.unshift(node);
          flush();
        }
      }
    }
    flush();
  }

  function paginate(){
    pages=[];sizes();
    secs.forEach(function(sec){
      var k=sec.getAttribute('data-kind');
      if(k==='cover')pages.push({sec:sec,plate:'cover',html:coverHtml()});
      else if(k==='titlepage')pages.push({sec:sec,plate:'title',html:sec.innerHTML});
      else if(k==='contents')pages.push({sec:sec,plate:'contents',html:''});
      else if(k==='soon')pages.push({sec:sec,plate:'soon',html:soonHtml(sec)});
      else flowSection(sec);
    });
    var n=0,started=false;
    pages.forEach(function(p){
      if(!p.plate||p.plate==='soon')started=true;
      if(started){n++;p.num=n;}else p.num=null;
    });
    var cp=null;
    for(var i=0;i<pages.length;i++)if(pages[i].plate==='contents')cp=pages[i];
    if(cp)cp.html=contentsHtml();
  }

  function render(i){
    if(i<0)i=0;if(i>pages.length-1)i=pages.length-1;
    cur=i;var p=pages[i];
    sheet.className='rd-sheet'+(p.plate?' pl-'+p.plate:'');
    runEl.textContent=p.plate?'':'THE MIND’S GAMBIT';
    bodyEl.innerHTML=p.html;
    folEl.textContent=(p.num&&!p.plate)?'— '+p.num+' —':'';
    progEl.textContent='Page '+(i+1)+' of '+pages.length;
    document.getElementById('rd-prev').disabled=(i===0);
    document.getElementById('rd-next').disabled=(i===pages.length-1);
    try{
      var id=p.sec.getAttribute('data-id');
      localStorage.setItem(POS,JSON.stringify({id:id,k:i-firstIdx(id)}));
    }catch(e){}
  }
  function nav(d){
    sheet.classList.add('rd-turn');
    setTimeout(function(){render(cur+d);sheet.classList.remove('rd-turn');},110);
  }
  function goto(id){render(firstIdx(id));}

  document.getElementById('rd-prev').addEventListener('click',function(){nav(-1);});
  document.getElementById('rd-next').addEventListener('click',function(){nav(1);});
  document.getElementById('rd-prev2').addEventListener('click',function(){nav(-1);});
  document.getElementById('rd-next2').addEventListener('click',function(){nav(1);});
  document.getElementById('rd-toc').addEventListener('click',function(){goto('contents');});
  document.getElementById('rd-full').addEventListener('click',function(){
    var st=document.getElementById('rd-stage');
    try{if(document.fullscreenElement)document.exitFullscreen();else st.requestFullscreen();}catch(e){}
  });
  bodyEl.addEventListener('click',function(e){
    var a=e.target.closest('a[data-goto]');
    if(a){goto(a.getAttribute('data-goto'));return;}
    var r=sheet.getBoundingClientRect(),x=e.clientX-r.left;
    if(x<r.width*0.3)nav(-1);else if(x>r.width*0.7)nav(1);
  });
  document.addEventListener('keydown',function(e){
    if(e.key==='ArrowLeft'||e.key==='PageUp')nav(-1);
    if(e.key==='ArrowRight'||e.key==='PageDown'||e.key===' ')if(e.target===document.body){e.preventDefault();nav(1);}
    else if(e.key==='ArrowRight'||e.key==='PageDown')nav(1);
  });
  var tx=null;
  sheet.addEventListener('touchstart',function(e){tx=e.changedTouches[0].clientX;},{passive:true});
  sheet.addEventListener('touchend',function(e){
    if(tx===null)return;
    var dx=e.changedTouches[0].clientX-tx;tx=null;
    if(dx>45)nav(-1);else if(dx<-45)nav(1);
  },{passive:true});

  var rt=null;
  window.addEventListener('resize',function(){
    clearTimeout(rt);
    rt=setTimeout(function(){
      var p=pages[cur],id=p?p.sec.getAttribute('data-id'):null,k=id?cur-firstIdx(id):0;
      paginate();
      if(id)render(Math.min(firstIdx(id)+k,pages.length-1));else render(0);
    },350);
  });

  function start(){
    paginate();
    var i=0;
    try{
      var s=JSON.parse(localStorage.getItem(POS)||'null');
      if(s&&s.id)i=Math.min(firstIdx(s.id)+(s.k||0),pages.length-1);
    }catch(e){}
    loadEl.style.display='none';
    render(i);
  }
  var done=false;function once(){if(done)return;done=true;start();}
  if(document.fonts&&document.fonts.ready)document.fonts.ready.then(function(){setTimeout(once,60);});
  setTimeout(once,1800);
})();
</script>

