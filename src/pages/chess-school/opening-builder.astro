<!-- ============================================================
     PROGRESS BADGES  reads localStorage and injects a small
     "Last: X/Y  Nd ago" label inside each opening card.
============================================================ -->
<script is:inline>
(function() {
  'use strict';

  function loadStats() {
    try {
      var raw = localStorage.getItem('mg_drill_stats');
      return raw ? JSON.parse(raw) : {};
    } catch (e) {
      return {};
    }
  }

  function formatRelative(ts) {
    if (!ts) return '';
    var diffMs = Date.now() - ts;
    var dayMs = 24 * 60 * 60 * 1000;
    var days = Math.floor(diffMs / dayMs);
    if (days < 0) return 'just now';
    if (days === 0) return 'today';
    if (days === 1) return 'yesterday';
    if (days < 7)  return days + 'd ago';
    if (days < 30) return Math.floor(days / 7) + 'w ago';
    if (days < 365) return Math.floor(days / 30) + 'mo ago';
    return Math.floor(days / 365) + 'y ago';
  }

  function render() {
    var stats = loadStats();
    var cards = document.querySelectorAll('.opening-card');
    for (var i = 0; i < cards.length; i++) {
      var card = cards[i];
      var id = card.getAttribute('data-id');
      if (!id) continue;
      var s = stats[id];
      if (!s || typeof s.lastDrilled !== 'number') continue;

      var dayMs = 24 * 60 * 60 * 1000;
      var ageDays = (Date.now() - s.lastDrilled) / dayMs;
      var dueForReview = ageDays > 7;

      var badge = document.createElement('span');
      badge.className = 'drill-badge' + (dueForReview ? ' due-for-review' : '');
      var scorePart = (typeof s.lastScoreCorrect === 'number' && typeof s.lastScoreTotal === 'number')
        ? ('Last: ' + s.lastScoreCorrect + '/' + s.lastScoreTotal)
        : 'Drilled';
      var when = formatRelative(s.lastDrilled);
      badge.textContent = scorePart + (when ? ' · ' + when : '') + (dueForReview ? ' · Due for review' : '');

      // Insert badge just before the CTA row.
      var cta = card.querySelector('.opening-cta-row') || card.querySelector('.opening-cta');
      if (cta && cta.parentNode === card) {
        card.insertBefore(badge, cta);
      } else {
        card.appendChild(badge);
      }
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', render);
  } else {
    render();
  }
})();
</script>

<!-- ============================================================
     MIND'S GAMBIT FAQ BOT
============================================================ -->
<button id="mg-faq-bubble" type="button" aria-label="Need help? Open Mind's Gambit Help" title="Click me for help">
  <span class="mg-faq-bubble-icon">&#9819;</span>
  <span class="mg-faq-bubble-label">Need help?</span>
  <span class="mg-faq-bubble-dot"></span>
</button>

<div id="mg-faq-panel" hidden>
  <header class="mg-faq-header">
    <div>
      <div class="mg-faq-title">Mind&rsquo;s Gambit Help</div>
      <div class="mg-faq-subtitle">Ask anything &middot; instant answers</div>
    </div>
    <button id="mg-faq-close" type="button" aria-label="Close">&times;</button>
  </header>
  <div class="mg-faq-messages" id="mg-faq-messages"></div>
  <form class="mg-faq-form" id="mg-faq-form" autocomplete="off">
    <input type="text" id="mg-faq-input" placeholder="Type your question&hellip;" maxlength="200" autocomplete="off" />
    <button type="submit" aria-label="Send">&#10142;</button>
  </form>
  <div class="mg-faq-suggested" id="mg-faq-suggested"></div>
</div>

<script is:inline>
(function() {
  'use strict';
  var FAQ_DATA = [
    { keywords: ['opening', 'repertoire', 'drill', 'opening builder'],
      q: 'How does the Opening Repertoire Builder work?',
      a: 'Click &lsquo;Drill mode&rsquo; on any opening card. You play the mainline against the engine, get instant feedback, and your score saves locally so you can track progress. Phase 3 (your own PGN lines) is next.' },
    { keywords: ['free', 'cost', 'price'],
      q: 'Is Mind\'s Gambit free?',
      a: 'All training, analysis, and content is <strong>completely free</strong>. No ads, no subscriptions.' },
    { keywords: ['coach', 'lesson', 'grandmaster'],
      q: 'Can I book a lesson with a coach?',
      a: 'Yes. Click <a href="/chess-school/grandmasters">Grandmasters</a> in the nav.' },
    { keywords: ['contact', 'email'],
      q: 'How do I contact Mourad?',
      a: 'Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a>.' }
  ];
  var bubble = document.getElementById('mg-faq-bubble');
  var panel = document.getElementById('mg-faq-panel');
  var closeBtn = document.getElementById('mg-faq-close');
  var form = document.getElementById('mg-faq-form');
  var input = document.getElementById('mg-faq-input');
  var messagesEl = document.getElementById('mg-faq-messages');
  var suggestedEl = document.getElementById('mg-faq-suggested');
  if (!bubble || !panel) return;
  function openPanel() { panel.removeAttribute('hidden'); input.focus(); if (!messagesEl.children.length) greet(); }
  function closePanel() { panel.setAttribute('hidden', ''); }
  bubble.addEventListener('click', function() { if (panel.hasAttribute('hidden')) openPanel(); else closePanel(); });
  closeBtn.addEventListener('click', closePanel);
  function addMessage(text, sender) {
    var div = document.createElement('div');
    div.className = 'mg-faq-msg mg-faq-msg-' + sender;
    div.innerHTML = text;
    messagesEl.appendChild(div);
    messagesEl.scrollTop = messagesEl.scrollHeight;
  }
  function score(query, keywords) {
    var q = query.toLowerCase();
    var s = 0;
    for (var i = 0; i < keywords.length; i++) {
      var k = keywords[i].toLowerCase();
      if (q.indexOf(k) !== -1) s += k.length * 2;
      var words = k.split(/\s+/);
      for (var w = 0; w < words.length; w++) {
        if (words[w].length >= 3 && q.indexOf(words[w]) !== -1) s += 1;
      }
    }
    return s;
  }
  function answer(query) {
    var best = null;
    var bestScore = 0;
    for (var i = 0; i < FAQ_DATA.length; i++) {
      var s = score(query, FAQ_DATA[i].keywords);
      if (s > bestScore) { bestScore = s; best = FAQ_DATA[i]; }
    }
    if (best && bestScore >= 3) return best.a;
    return null;
  }
  function greet() {
    addMessage('Hi &mdash; welcome to <strong>Mind&rsquo;s Gambit Help</strong>. Type a question or pick a suggestion below.', 'bot');
    showSuggestions(['How does the Opening Repertoire Builder work?', 'Is Mind\'s Gambit free?', 'Can I book a lesson?']);
  }
  function showSuggestions(questions) {
    suggestedEl.innerHTML = '';
    for (var i = 0; i < questions.length; i++) {
      var btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'mg-faq-suggest';
      btn.textContent = questions[i];
      (function(q) { btn.addEventListener('click', function() { handleQuery(q); }); })(questions[i]);
      suggestedEl.appendChild(btn);
    }
  }
  function handleQuery(query) {
    suggestedEl.innerHTML = '';
    addMessage(query, 'user');
    var a = answer(query);
    if (a) setTimeout(function() { addMessage(a, 'bot'); }, 200);
    else setTimeout(function() { addMessage('I don&rsquo;t have a stock answer for that yet. Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a>.', 'bot'); }, 200);
  }
  form.addEventListener('submit', function(e) { e.preventDefault(); var q = input.value.trim(); if (!q) return; input.value = ''; handleQuery(q); });
})();
</script>

