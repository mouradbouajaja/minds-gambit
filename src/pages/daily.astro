---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import {
  getDailyArchive,
  getDailyBookExcerpt,
  getDailyOpening,
  getDailyPlayer,
  getDailyWhatIs,
  getDailyQuote,
  getDailyThisWeek,
  getDailyGamesOfWeek,
} from '../utils/daily-rotation';

const today = new Date();
const etISO = today.toLocaleDateString('en-CA', { timeZone: 'America/New_York' });
const [etY, etM, etD] = etISO.split('-').map(Number);
const todayMidnight = new Date(etY, etM - 1, etD);
const dateLine = todayMidnight.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
const shortDate = todayMidnight.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const LAUNCH = new Date(2026, 4, 30);
const MS_PER_DAY = 86400000;
let anniversary = new Date(todayMidnight.getFullYear(), 4, 30);
if (anniversary > todayMidnight) anniversary = new Date(todayMidnight.getFullYear() - 1, 4, 30);
const volumeNumber = todayMidnight < LAUNCH ? 1 : (anniversary.getFullYear() - LAUNCH.getFullYear()) + 1;
const editionNumber = todayMidnight < LAUNCH ? 1 : Math.floor((todayMidnight - anniversary) / MS_PER_DAY) + 1;

const todaysQuote = getDailyQuote(today);
const todaysPlayer = getDailyPlayer(today);
const todaysArchive = getDailyArchive(today);
const todaysWhatIs = getDailyWhatIs(today);
const todaysOpening = getDailyOpening(today);
const todaysBookExcerpt = getDailyBookExcerpt(today);
const todaysThisWeek = getDailyThisWeek(today);
const todaysGames = getDailyGamesOfWeek(today);

const all = (await getCollection('daily', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const latestDate = all.length ? all[0].data.date.valueOf() : null;
const edition = latestDate !== null
  ? all.filter((s) => s.data.date.valueOf() === latestDate)
  : [];

const SECTION_LABELS = {
  world: 'World Chess',
  tournaments: 'Tournaments',
  players: 'Players',
  openings: 'Openings',
  local: 'Local',
  opinion: 'Opinion',
  puzzle: 'Puzzle',
};

function tileFor(section) {
  const map = {
    world: { color: 'fide', glyph: '♔' },
    tournaments: { color: 'blue', glyph: '♚' },
    players: { color: 'red', glyph: '♞' },
    openings: { color: 'opening', glyph: '♟' },
    local: { color: 'industry', glyph: '♜' },
    opinion: { color: 'industry', glyph: '♛' },
    puzzle: { color: 'opening', glyph: '♟' },
  };
  return map[section] || map.tournaments;
}
function tileVariantFor(story) {
  const fb = tileFor(story.data.section);
  return { color: story.data.tileVariant || fb.color, glyph: story.data.tileGlyph || fb.glyph };
}
function formatStoryDate(d) {
  return d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
function shortDateLabel(d) {
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}
function tileKickerFor(story) {
  return story.data.tileKicker || story.data.kicker || SECTION_LABELS[story.data.section];
}
function tileTitleFor(story) {
  if (story.data.tileTitle) return story.data.tileTitle;
  if (story.data.kicker && story.data.kicker.length <= 28) return story.data.kicker;
  const headline = story.data.headline || '';
  const words = headline.split(/\s+/).filter(Boolean);
  const start = ['the', 'a', 'an'].includes((words[0] || '').toLowerCase()) ? 1 : 0;
  return words.slice(start, start + 3).join(' ');
}
function tileMetaFor(story) {
  return story.data.tileMeta || shortDateLabel(story.data.date);
}

const lead = edition.find((s) => s.data.lead) || edition.find((s) => s.data.section !== 'local') || edition[0] || null;
const secondary = edition.filter((s) => s.data.section !== 'local' && s.id !== (lead && lead.id)).slice(0, 4);
const local = all.filter((s) => s.data.section === 'local').slice(0, 4);
const hasStories = edition.length > 0;

const openingTile = tileFor('openings');
const leadTile = lead ? tileVariantFor(lead) : tileFor('world');

const standingsOpen = (lead && lead.data.standings) || [];
const standingsWomen = (lead && lead.data.standingsWomen) || [];
const standingsRound = (lead && lead.data.standingsRound) || '';
const resultsOpen = (lead && lead.data.resultsOpen) || '';
const resultsWomen = (lead && lead.data.resultsWomen) || '';

const url = Astro.url;
const refMode = url.searchParams.get('ref') === '1';
---
<BaseLayout title="The Daily Gambit — Chess News, Results & Analysis" description="The Daily Gambit: your morning briefing from the chess world — tournament results, player news, opening theory, puzzles, local Pittsburgh & Pennsylvania chess, and analysis. Gathered fresh every day.">
  <div class="tdg-paper">
    <div class:list={["tdg-sheet", refMode && "tdg-reference"]}>
      {refMode && (
        <div class="tdg-ref-legend">
          <strong>REFERENCE MODE — Editor view.</strong> Slot tags (BOX 1, STORY 2…) and word-count badges visible. Remove <code>?ref=1</code> from the URL to see the published view.
        </div>
      )}

      <div class="tdg-strip">
        <span>Vol. {volumeNumber} &mdash; No. {editionNumber}</span>
        <span>The Mind&rsquo;s Gambit</span>
        <span>Price: Free</span>
      </div>

      <header class="tdg-masthead">
        <div class="tdg-mast-side tdg-mast-left">
          <span>{dateLine}</span>
          <span class="tdg-mast-edition">Morning Edition</span>
        </div>
        <div class="tdg-mast-center">
          <h1 class="tdg-nameplate">The Daily Gambit</h1>
          <p class="tdg-motto">&ldquo;All the chess that&rsquo;s fit to print&rdquo;</p>
        </div>
        <div class="tdg-mast-side tdg-mast-right">
          <span>Chess &middot; Mind &middot; Culture</span>
          <span class="tdg-mast-edition">A Mind&rsquo;s Gambit Publication</span>
        </div>
      </header>

      <nav class="tdg-sectionbar">
        <a href="#">Tournaments</a>
        <a href="#">Players</a>
        <a href="#">Openings</a>
        <a href="#tdg-local">Local</a>
        <a href="#">Puzzles</a>
        <a href="#">Opinion</a>
        <a href="#">World Chess</a>
        <a href="/daily/archive" class="tdg-archive-link">Archive</a>
      </nav>

      <div class="tdg-main-grid">

        <!-- LEFT COLUMN — story card river -->
        <div class="tdg-col-main">

          <!-- FEATURED LEAD CARD -->
          {lead ? (
            <article class="tdg-lead-card">
              <div class={`tdg-lead-img tdg-tile ${leadTile.color}`}>
                <span class="tdg-lead-glyph">{leadTile.glyph}</span>
                <p class="tdg-lead-tile-kicker">{tileKickerFor(lead)}</p>
                <h3 class="tdg-lead-tile-title">{tileTitleFor(lead)}</h3>
                <p class="tdg-lead-tile-meta">{tileMetaFor(lead)}</p>
              </div>
              <p class="tdg-card-kicker"><span class="tdg-slot-tag">LEAD</span>{lead.data.kicker || SECTION_LABELS[lead.data.section]}</p>
              <h2 class="tdg-lead-head">{lead.data.headline} <span class="tdg-wc-badge">~13 HEAD</span></h2>
              <p class="tdg-card-meta">{formatStoryDate(lead.data.date)} &middot; By The Daily Gambit Desk{lead.data.sourceName ? ` · Source: ${lead.data.sourceName}` : ''}</p>
              <p class="tdg-card-summary">{lead.data.summary} <span class="tdg-wc-badge">~55 SUMMARY</span></p>
              {lead.data.sourceUrl && (
                <a class="tdg-card-more" href={lead.data.sourceUrl} target="_blank" rel="noopener">More&hellip; &rarr;</a>
              )}
            </article>
          ) : (
            <article class="tdg-lead-card">
              <div class="tdg-lead-img tdg-tile fide">
                <span class="tdg-lead-glyph">&#9812;</span>
                <p class="tdg-lead-tile-kicker">World Championship</p>
                <h3 class="tdg-lead-tile-title">A New Era Begins on the 64 Squares</h3>
                <p class="tdg-lead-tile-meta">{shortDate}</p>
              </div>
              <p class="tdg-card-kicker">World Championship</p>
              <h2 class="tdg-lead-head">A New Era Begins on the 64 Squares</h2>
              <p class="tdg-card-meta">{shortDate} &middot; By The Daily Gambit Desk</p>
              <p class="tdg-card-summary">When The Daily Gambit goes live each morning, the day&rsquo;s biggest chess headline appears here, summarized in clean prose with a link to the original coverage.</p>
            </article>
          )}

          <!-- STORY CARDS — ChessBase content river (locked color order via tileVariant) -->
          {secondary.length > 0 ? secondary.map((s, i) => {
            const tile = tileVariantFor(s);
            const slotNum = i + 2;
            return (
              <article class="tdg-story-card">
                <div class={`tdg-thumb tdg-tile ${tile.color}`}>
                  <span class="tdg-tile-glyph">{tile.glyph}</span>
                  <p class="tdg-tile-kicker">{tileKickerFor(s)}</p>
                  <h4 class="tdg-tile-title">{tileTitleFor(s)}</h4>
                  <p class="tdg-tile-meta">{tileMetaFor(s)}</p>
                </div>
                <div class="tdg-story-body">
                  <p class="tdg-card-kicker"><span class="tdg-slot-tag">STORY {slotNum}</span>{s.data.kicker || SECTION_LABELS[s.data.section]}</p>
                  <h3 class="tdg-story-head">{s.data.headline} <span class="tdg-wc-badge">~45</span></h3>
                  <p class="tdg-card-meta">{formatStoryDate(s.data.date)} &middot; From the Daily Gambit Desk</p>
                  <p class="tdg-card-summary">{s.data.summary}</p>
                  {s.data.sourceUrl && (
                    <a class="tdg-card-more" href={s.data.sourceUrl} target="_blank" rel="noopener">More&hellip; &rarr;</a>
                  )}
                </div>
              </article>
            );
          }) : (
            <article class="tdg-story-card">
              <div class="tdg-thumb tdg-tile blue">
                <span class="tdg-tile-glyph">&#9818;</span>
                <p class="tdg-tile-kicker">Coming Soon</p>
                <h4 class="tdg-tile-title">More Stories Ahead</h4>
                <p class="tdg-tile-meta">Daily Gambit Desk</p>
              </div>
              <div class="tdg-story-body">
                <p class="tdg-card-kicker">Tournaments</p>
                <h3 class="tdg-story-head">More Stories Coming Soon</h3>
                <p class="tdg-card-meta">{shortDate} &middot; From the Daily Gambit Desk</p>
                <p class="tdg-card-summary">As editions are published, the day&rsquo;s tournament results, player news, and opening theory will fill this column.</p>
              </div>
            </article>
          )}

          <!-- OPENING SPOTLIGHT card (rotates daily) -->
          <article class="tdg-story-card">
            <div class={`tdg-thumb tdg-tile ${openingTile.color}`}>
              <span class="tdg-tile-glyph">{openingTile.glyph}</span>
              <p class="tdg-tile-kicker">Opening Spotlight</p>
              <h4 class="tdg-tile-title">{todaysOpening.opening}</h4>
              <p class="tdg-tile-meta">{todaysOpening.moves} &middot; Today&rsquo;s Pick</p>
            </div>
            <div class="tdg-story-body">
              <p class="tdg-card-kicker"><span class="tdg-slot-tag">FEATURE</span>Opening Spotlight (rotates daily)</p>
              <h3 class="tdg-story-head">The {todaysOpening.opening}</h3>
              <p class="tdg-card-meta">Today&rsquo;s pick &middot; {todaysOpening.moves}</p>
              {todaysOpening.paragraphs && todaysOpening.paragraphs.length > 0 && (
                <p class="tdg-card-summary">{todaysOpening.paragraphs[0]}</p>
              )}
              <a class="tdg-card-more" href="/chess-school/opening-builder">Explore openings &rarr;</a>
            </div>
          </article>
          <!-- PUZZLE OF THE DAY — ChessBase-style board card -->
          <section class="tdg-cb-card">
            <p class="tdg-cb-kicker"><span class="tdg-slot-tag">FEATURE</span>Puzzle of the Day</p>
            <h3 class="tdg-cb-head" id="tdg-puzzle-caption">Loading today&rsquo;s puzzle&hellip;</h3>
            <p class="tdg-cb-meta">From the Mind&rsquo;s Gambit Tactics Trainer</p>
            <link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />
            <div class="tdg-cb-board-wrap">
              <div class="tdg-cb-board-frame">
                <div id="tdg-daily-board" class="tdg-daily-board"></div>
              </div>
              <div class="tdg-cb-info">
                <p class="tdg-cb-instruction">A fresh tactic to sharpen your eye before your coffee gets cold. No solution shown &mdash; find the mate yourself or come back tomorrow.</p>
                <p class="tdg-cb-status" id="tdg-daily-status"></p>
                <a class="tdg-cb-more" href="/chess-school/puzzles">Browse past daily puzzles &rarr;</a>
              </div>
            </div>
          </section>

          <!-- FROM THE BOOK widget (flex:1 so its bottom aligns with Box 7 in the rail) -->
          <aside class="tdg-book-excerpt">
            <p class="tdg-book-kicker">From the Book &middot; The Mind&rsquo;s Gambit</p>
            <h3 class="tdg-book-title">{todaysBookExcerpt.title}</h3>
            <blockquote class="tdg-book-quote">
              {todaysBookExcerpt.paragraphs && todaysBookExcerpt.paragraphs.map((p) => <p>{p}</p>)}
            </blockquote>
            <p class="tdg-book-attr">&mdash; Mourad Bouajaja, <em>The Mind&rsquo;s Gambit</em> ({todaysBookExcerpt.chapter})</p>
            <a class="tdg-book-cta" href="/#book">Read more from the book &rarr;</a>
          </aside>

        </div>

        <!-- RIGHT SIDEBAR — all 8 boxes always render in locked order -->
        <aside class="tdg-col-side">

          <!-- MG PROMO (Fritz-style) -->
          <div class="tdg-promo-box">
            <div class="tdg-promo-img">
              <img src="/daily/book-cover.png" alt="The Mind's Gambit book cover" onerror="this.style.display='none'; this.parentElement.style.background='linear-gradient(135deg,#b8902a,#8a6d1d)';" />
            </div>
            <h4>The Mind&rsquo;s Gambit</h4>
            <p>The book by Mourad Bouajaja &mdash; Chess, Madness, and the Battle for the Mind.</p>
            <span class="tdg-promo-cta">On its way</span>
          </div>

          <!-- BOX 1 — STANDINGS (Open + Women). Always renders; falls back to placeholder. -->
          <div class="tdg-side-box">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 1</span>Standings{standingsRound ? ` · ${standingsRound}` : ''}</h4>
            {standingsOpen.length > 0 ? (
              <>
                <p class="tdg-standings-sub">Open</p>
                <ol class="tdg-standings">
                  {standingsOpen.map((row, i) => (
                    <li><span class="tdg-rank">{i + 1}.</span><span class="tdg-player">{row.player}</span><span class="tdg-score">{row.score}</span></li>
                  ))}
                </ol>
              </>
            ) : (
              <p class="tdg-side-placeholder">Round standings appear here once the edition is published.</p>
            )}
            {standingsWomen.length > 0 && (
              <>
                <p class="tdg-standings-sub">Women</p>
                <ol class="tdg-standings">
                  {standingsWomen.map((row, i) => (
                    <li><span class="tdg-rank">{i + 1}.</span><span class="tdg-player">{row.player}</span><span class="tdg-score">{row.score}</span></li>
                  ))}
                </ol>
              </>
            )}
          </div>

          <!-- BOX 2 — RESULTS AT A GLANCE (Open + Women). Always renders. -->
          <div class="tdg-side-box">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 2</span>Results at a Glance</h4>
            {(resultsOpen || resultsWomen) ? (
              <>
                {resultsOpen && (
                  <>
                    <p class="tdg-standings-sub">Open{standingsRound ? ` · ${standingsRound}` : ''}</p>
                    <p class="tdg-results" set:html={resultsOpen.replace(/\n/g, '<br>')}></p>
                  </>
                )}
                {resultsWomen && (
                  <>
                    <p class="tdg-standings-sub">Women{standingsRound ? ` · ${standingsRound}` : ''}</p>
                    <p class="tdg-results" set:html={resultsWomen.replace(/\n/g, '<br>')}></p>
                  </>
                )}
              </>
            ) : (
              <p class="tdg-side-placeholder">Round-by-round results appear here once the edition is published.</p>
            )}
          </div>

          <!-- BOX 3 — PLAYER PROFILE -->
          <div class="tdg-side-box">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 3</span>Player Profile</h4>
            <p class="tdg-name">{todaysPlayer.name}</p>
            <p class="tdg-name-meta">{todaysPlayer.meta}</p>
            <p>{todaysPlayer.bio}</p>
            <p class="tdg-side-cta"><a href="/daily/archive">More from the players desk &rarr;</a></p>
          </div>

          <!-- BOX 4 — FROM THE ARCHIVES -->
          <div class="tdg-side-box tdg-featured">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 4</span>From the Archives</h4>
            {todaysArchive.imageUrl && (
              <div class="tdg-arch-img">
                <img src={todaysArchive.imageUrl} alt={todaysArchive.imageAlt || todaysArchive.name} loading="lazy" referrerpolicy="no-referrer" />
              </div>
            )}
            {todaysArchive.imageCaption && (
              <p class="tdg-arch-caption">{todaysArchive.imageCaption}</p>
            )}
            <p class="tdg-name">{todaysArchive.name}</p>
            <p class="tdg-name-meta">{todaysArchive.meta}</p>
            <p>{todaysArchive.bio}</p>
            <p class="tdg-side-cta"><a href="/daily/archive">More chess history &rarr;</a></p>
          </div>

          <!-- BOX 5 — WHAT IS -->
          <div class="tdg-side-box tdg-featured">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 5</span>{todaysWhatIs.title}</h4>
            <p>{todaysWhatIs.paragraph}</p>
            <p class="tdg-side-cta"><a href={todaysWhatIs.ctaUrl}>{todaysWhatIs.ctaText}</a></p>
          </div>

          <!-- BOX 6 — QUOTE -->
          <div class="tdg-side-box tdg-warm tdg-quote-box">
            <p class="tdg-quote">&ldquo;{todaysQuote.text}&rdquo;</p>
            <p class="tdg-quote-attr">&mdash; {todaysQuote.author}</p>
          </div>

          <!-- BOX 7 — THIS WEEK IN HISTORY -->
          <div class="tdg-side-box tdg-warm">
            <h4 class="tdg-side-title"><span class="tdg-slot-tag">BOX 7</span>This Week in Chess History</h4>
            <ul class="tdg-timeline">
              {todaysThisWeek.events.map((e) => (
                <li><span class="tdg-tldate">{e.year}</span><span class="tdg-tltext">{e.text}</span></li>
              ))}
            </ul>
          </div>

        </aside>

      </div>
      <!-- GAMES OF THE WEEK (wide section) -->
      <section class="tdg-wide" id="tdg-games">
        <div class="tdg-wide-head">
          <span class="tdg-pin">&#9822;</span>
          <h2 class="tdg-wide-title">Games of the Week</h2>
          <span class="tdg-wide-tag">Annotated</span>
        </div>
        <p class="tdg-wide-intro">Two games worth replaying &mdash; one from the men&rsquo;s game, one from the women&rsquo;s &mdash; chosen for their beauty and their place in chess history.</p>
        <div class="tdg-two-col">
          <div class="tdg-game-cell">
            <p class="tdg-col-kicker">{todaysGames.men.kicker}</p>
            <h3 class="tdg-col-head">{todaysGames.men.players}</h3>
            <p class="tdg-game-meta">{todaysGames.men.meta}</p>
            <p class="tdg-col-body">{todaysGames.men.body}</p>
            {todaysGames.men.pgn && (
              <pre class="tdg-moves-pre">{todaysGames.men.pgn}</pre>
            )}
          </div>
          <div class="tdg-game-cell">
            <p class="tdg-col-kicker">{todaysGames.women.kicker}</p>
            <h3 class="tdg-col-head">{todaysGames.women.players}</h3>
            <p class="tdg-game-meta">{todaysGames.women.meta}</p>
            <p class="tdg-col-body">{todaysGames.women.body}</p>
            {todaysGames.women.pgn && (
              <pre class="tdg-moves-pre">{todaysGames.women.pgn}</pre>
            )}
          </div>
        </div>
      </section>

      <!-- ORIGINS (wide section) -->
      <section class="tdg-wide" id="tdg-origins">
        <div class="tdg-wide-head">
          <span class="tdg-pin">&#9822;</span>
          <h2 class="tdg-wide-title">The Long Road to the 64 Squares</h2>
          <span class="tdg-wide-tag">History</span>
        </div>
        <p class="tdg-wide-intro">Long before Morphy and Fischer, the game was born in India and carried west by Persian courts and Arab geographers. A history told from its source, not from Europe.</p>
        <div class="tdg-two-col">
          <div>
            <p class="tdg-col-kicker">India &middot; Chaturanga</p>
            <h3 class="tdg-col-head">A Game Named for an Army</h3>
            <p class="tdg-col-body">The oldest known ancestor of chess is chaturanga, played in northern India by the sixth and seventh centuries during the Gupta era. Its name is Sanskrit for &ldquo;having four limbs&rdquo; &mdash; the four divisions of a classical Indian army: infantry, cavalry, elephantry, and chariotry. Those four arms survive on today&rsquo;s board as the pawn, the knight, the bishop, and the rook. Most historians regard chaturanga as the common root of chess, Chinese xiangqi, Japanese shogi, and Thai makruk.</p>
          </div>
          <div>
            <p class="tdg-col-kicker">Persia &amp; Arabia &middot; Shatranj</p>
            <h3 class="tdg-col-head">The Geographer Who Wrote It Down</h3>
            <p class="tdg-col-body">From India the game travelled to Sassanid Persia, where it became chatrang and entered the education of the nobility; after the Arab conquest the name softened into shatranj. Among those who recorded its story was al-Mas&rsquo;udi (c. 896&ndash;956), the Baghdad-born historian called &ldquo;the Herodotus of the Arabs.&rdquo; It was through this Arabic and Persian world that chess crossed into Spain &mdash; not a European one.</p>
          </div>
        </div>
      </section>

      <!-- LOCAL — Pittsburgh & PA (wide, 4-col) -->
      <section class="tdg-wide" id="tdg-local">
        <div class="tdg-wide-head">
          <span class="tdg-pin">&#9823;</span>
          <h2 class="tdg-wide-title">Pittsburgh &amp; Pennsylvania</h2>
          <span class="tdg-wide-tag">Local Chess</span>
        </div>
        <p class="tdg-wide-intro">Coverage close to home &mdash; club nights, scholastic results, and tournaments across the Steel City and the Commonwealth.</p>
        <div class="tdg-four-col">
          {local.length > 0 ? local.map((s) => (
            <div>
              <p class="tdg-col-kicker">{s.data.kicker || 'Local'}</p>
              <h3 class="tdg-col-head">{s.data.headline}</h3>
              <p class="tdg-col-body">{s.data.summary}</p>
              {s.data.sourceUrl && (
                <p class="tdg-card-more-wrap"><a class="tdg-card-more" href={s.data.sourceUrl} target="_blank" rel="noopener">Read more &rarr;</a></p>
              )}
            </div>
          )) : (
            <>
              <div>
                <p class="tdg-col-kicker">Pittsburgh Chess League</p>
                <h3 class="tdg-col-head">Local Coverage Coming Soon</h3>
                <p class="tdg-col-body">Standings, scholastic results, and club news from Pittsburgh and across Pennsylvania will appear here.</p>
              </div>
              <div>
