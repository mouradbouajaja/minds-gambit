    /* Chess School dropdown */
    .nav-links .has-dropdown { position: relative; }
    .nav-links .has-dropdown > .dropdown-toggle { display: inline-flex; align-items: center; gap: 0.35rem; }
    .nav-links .has-dropdown > .dropdown-toggle .caret { font-size: 0.7em; transition: transform 0.2s; }
