---
import BaseLayout from '../../../layouts/BaseLayout.astro';

export const prerender = true;

const teacher = {
  name: "WGM Maryana Huda",
  shortTitle: "WGM",
  fideTitle: "Woman Grandmaster",
  trainerTitle: "FIDE Trainer (2022)",
  tagline: "Quality professional coaching for all levels, including for players with serious tournament goals.",
  photo: "https://image.lichess1.org/display?fmt=webp&h=350&op=thumbnail&path=morshynska1:coach:morshynska1:47WCJA8z.jpg&w=350&sig=7153456a989676933f39b96c09cc68502ebf226c",
  location: "Morshyn, Lviv region — Ukraine",
  fideRating: 2179,
  nationalRating: 2283,
  hourlyRate: "€20",
  packageRate: "€75 / 5 lessons",
  availability: "Accepting students",
  languages: ["English", "Spanish", "Ukrainian", "Russian", "Catalan"],
  email: "gudachess@gmail.com",
  lichessCoach: "https://lichess.org/coach/Morshynska1",
  lichessProfile: "https://lichess.org/@/Morshynska1",
  chessComProfile: "https://chess.com/member/morshynska",
  twitchProfile: "https://twitch.tv/maryanahuda"
};

const specialties = [
  "Openings — repertoire design, theory, your questions answered",
  "Middlegame strategy and positional understanding",
  "Endgame technique",
  "Tactics and calculation",
  "Advantage conversion and chess technique",
  "Game analysis with detailed human commentary",
  "Tournament preparation and opponent study",
  "Sports psychology and mental conditioning",
  "Prophylaxis and planning",
  "Work with chess classics and literature",
  "Spotting and neutralizing recurring mistakes",
  "Developing your own game style"
];

const freeStudies = [
  { title: "Lecture on the Center for beginners", url: "https://lichess.org/study/oPTsIN7c", chapters: 2 },
  { title: "Lecture on Piece Development for beginners", url: "https://lichess.org/study/b0ZqKFLd", chapters: 4 },
  { title: "Practice Exercises", url: "https://lichess.org/study/g7rXay67", chapters: 4 }
];
---

<BaseLayout title={`${teacher.name} — Chess Coach — Mind's Gambit Chess School`} description="Book lessons with WGM Maryana Huda — Woman Grandmaster, FIDE Trainer, and chess educator from Ukraine. Quality professional coaching for all levels, online.">
  <!-- Floating chess particle background -->
  <div class="particles-container" id="coach-particles"></div>
  <!-- Scroll progress ribbon -->
  <div class="scroll-progress" id="scrollProgress"></div>

  <nav>
    <div class="nav-inner">
      <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
      <ul class="nav-links">
        <li><a href="/">Home</a></li>
        <li><a href="/chess-school/grandmasters">All Grandmasters</a></li>
        <li><a href={`mailto:${teacher.email}?subject=Chess%20Lessons%20with%20WGM%20Maryana%20Huda`} class="nav-btn cta-btn">Book a Lesson</a></li>
      </ul>
    </div>
  </nav>

  <article class="coach-page">
    <a href="/chess-school/grandmasters" class="back-link" data-reveal>&larr; All Grandmasters</a>

    <!-- HERO -->
    <header class="coach-hero" data-reveal>
      <div class="hero-photo-wrap">
        <div class="photo-aura"></div>
        <div class="photo-ring"></div>
        <img src={teacher.photo} alt={teacher.name} class="hero-photo" loading="eager" referrerpolicy="no-referrer" />
        <span class="availability-badge"><span class="pulse-dot"></span>{teacher.availability}</span>
      </div>

      <div class="hero-content">
        <span class="eyebrow">Mind's Gambit Chess School &middot; Coach Profile</span>
        <h1 class="gradient-text">{teacher.name}</h1>
        <p class="tagline">{teacher.tagline}</p>

        <div class="title-row">
          <span class="title-chip primary">{teacher.shortTitle}</span>
          <span class="title-chip">{teacher.fideTitle}</span>
          <span class="title-chip">{teacher.trainerTitle}</span>
          <span class="title-chip">Master of Sports · Ukraine</span>
        </div>

        <div class="hero-cta">
          <a href={`mailto:${teacher.email}?subject=Chess%20Lessons%20with%20WGM%20Maryana%20Huda`} class="btn-primary cta-btn">
            <span class="btn-text">Book by Email</span>
            <span class="btn-shimmer"></span>
          </a>
          <a href={teacher.lichessCoach} target="_blank" rel="noopener" class="btn-secondary cta-btn">Book via Lichess &rarr;</a>
        </div>
      </div>
    </header>

    <!-- AT-A-GLANCE CARD -->
    <section class="at-a-glance" data-reveal>
      <div class="stat glass-card">
        <div class="stat-label">FIDE Rating</div>
        <div class="stat-value count-up" data-target="2179">0</div>
        <div class="stat-sub">Ukrainian: {teacher.nationalRating}</div>
      </div>
      <div class="stat glass-card">
        <div class="stat-label">Hourly Rate</div>
        <div class="stat-value">{teacher.hourlyRate}</div>
        <div class="stat-sub">{teacher.packageRate}</div>
      </div>
      <div class="stat glass-card">
        <div class="stat-label">Location</div>
        <div class="stat-value-sm">Ukraine 🇺🇦</div>
        <div class="stat-sub">Online lessons · worldwide</div>
      </div>
      <div class="stat glass-card">
        <div class="stat-label">Languages</div>
        <div class="stat-value count-up" data-target="5">0</div>
        <div class="stat-sub">{teacher.languages.join(" · ")}</div>
      </div>
    </section>

    <!-- BIO -->
    <section class="coach-section" data-reveal>
      <h2>About Maryana</h2>
      <p>Maryana Huda is a Woman Grandmaster (WGM) and certified FIDE Trainer from Morshyn in Ukraine's Lviv region. A holder of the Ukrainian Master of Sports title, she earned bronze medals at the 2015 Ukrainian Women's Championships in the U20 and rapid categories, and has been a winner and medalist in numerous national and international tournaments. She continues to compete actively in international events while maintaining deep ongoing study of chess theory, training methodology, and competitive practice.</p>
      <p>Her coaching experience spans nearly twenty years and began in the traditional system of specialized Children's and Youth Sports Schools (DYuSSh) in Ukraine, where long-term in-person development of tournament players formed the foundation of her teaching approach. Known for detailed and deeply explanatory game analysis, her coaching combines classical chess-school methods with modern understanding of sports psychology and competitive performance.</p>
      <p>She holds a Master's degree with honors in Physical Culture and Sports from Lviv State University of Physical Culture, where her research focused on psychological aspects of competitive chess, including concentration maintenance and advantage conversion under tournament pressure.</p>
    </section>

    <!-- PRICING -->
    <section class="pricing-section" data-reveal>
      <h2>Lessons &amp; Pricing</h2>
      <div class="pricing-grid">
        <div class="pricing-card tilt-card">
          <div class="pricing-eyebrow">Single Session</div>
          <div class="pricing-amount">€20<span class="pricing-unit">/ hour</span></div>
          <p class="pricing-description">A focused one-on-one session. Bring a recent game, a question, or a position you want to work through.</p>
          <a href={`mailto:${teacher.email}?subject=Single%20Lesson%20Inquiry%20%E2%80%94%20WGM%20Maryana%20Huda`} class="pricing-cta cta-btn">Book a Single Lesson</a>
        </div>

        <div class="pricing-card pricing-card-featured tilt-card">
          <div class="pricing-badge">Best Value</div>
          <div class="featured-glow"></div>
          <div class="pricing-eyebrow">Package</div>
          <div class="pricing-amount">€75<span class="pricing-unit">/ 5 lessons</span></div>
          <p class="pricing-description">Five hours of structured coaching at a reduced rate. The right choice for students serious about long-term improvement. Discounts available for regular students.</p>
          <a href={`mailto:${teacher.email}?subject=Five-Lesson%20Package%20Inquiry%20%E2%80%94%20WGM%20Maryana%20Huda`} class="pricing-cta pricing-cta-primary cta-btn">Book the 5-Lesson Package</a>
        </div>
      </div>
      <p class="pricing-note">Lessons conducted via Lichess, chess.com, Skype, or written analysis &mdash; whichever fits your workflow. Discounts offered to regular students.</p>
    </section>

    <!-- SPECIALTIES -->
    <section class="coach-section" data-reveal>
      <h2>Coaching Specialties</h2>
      <p class="section-intro">Detailed, "human" analysis. Individual approach to every student. The full range of competitive chess preparation:</p>
      <ul class="specialty-grid">
        {specialties.map((item, i) => (
          <li class="specialty-item" style={`--delay: ${i * 60}ms`}><span class="specialty-mark">♞</span>{item}</li>
        ))}
      </ul>
    </section>

    <!-- TEACHING APPROACH -->
    <section class="coach-section" data-reveal>
      <h2>Teaching Approach</h2>
      <blockquote class="pull-quote">
        "I try to do the work for students as it's usually done for players who prepare to be professional ones &mdash; step by step. We can discuss your games and practice some important positions."
      </blockquote>
      <p>Lessons follow an individual curriculum built around your level, your goals, and your gaps. Common rhythm: analyze your own games, study targeted positions or themes, work on openings or endgames you want to sharpen, and discuss the psychological dimensions of tournament play.</p>
      <p>For tournament players: opening prep, opponent study, and the mental conditioning that separates strong club performance from elite results. For improvers: pattern recognition, calculation discipline, and the chess-school methods that build a real foundation.</p>
    </section>

    <!-- WHO -->
    <section class="coach-section" data-reveal>
      <h2>Who She Works Best With</h2>
      <blockquote class="pull-quote">
        "Motivated and serious learners interested in long-term improvement and deeper understanding of chess &mdash; especially tournament players and ambitious improvers."
      </blockquote>
      <p>Languages of instruction adapt to the student. Sessions available in English, Spanish, Ukrainian, Russian, or Catalan &mdash; whichever you're most comfortable with.</p>
    </section>

    <!-- FREE STUDIES -->
    <section class="coach-section" data-reveal>
      <h2>Sample Her Teaching &mdash; Free</h2>
      <p class="section-intro">Before booking, see her teaching style directly. Three free interactive Lichess studies authored by Maryana:</p>
      <div class="studies-grid">
        {freeStudies.map(study => (
          <a href={study.url} target="_blank" rel="noopener" class="study-card tilt-card">
            <div class="study-glow"></div>
            <span class="study-icon">♟</span>
            <h3 class="study-title">{study.title}</h3>
            <span class="study-meta">{study.chapters} chapters · Free on Lichess</span>
            <span class="study-cta">Open Study &rarr;</span>
          </a>
        ))}
      </div>
    </section>

    <!-- SCIENTIFIC -->
    <section class="coach-section" data-reveal>
      <h2>Scientific Work</h2>
      <p>Maryana's academic research examines the intersection of sports psychology and chess performance &mdash; how psychological factors, temperament, and stress management influence competitive outcomes. A selection of her published work:</p>
      <ul class="publications">
        <li><a href="https://journals.ldufk.lviv.ua/index.php/pahs/article/view/92" target="_blank" rel="noopener">Physical Activity, Health and Sport Journal · LDUFK</a></li>
        <li><a href="https://repository.ldufk.edu.ua/items/cb21e1d6-2112-469b-a3e3-99d1f3250158" target="_blank" rel="noopener">LDUFK Repository · Research paper (1)</a></li>
        <li><a href="https://repository.ldufk.edu.ua/items/f3338c64-10e3-4ec9-b765-85dd621ef320" target="_blank" rel="noopener">LDUFK Repository · Research paper (2)</a></li>
        <li><a href="https://ktmfks.pnu.edu.ua/wp-content/uploads/sites/99/2025/06/tezy_2025-2.pdf" target="_blank" rel="noopener">PNU Conference Proceedings (PDF)</a></li>
      </ul>
    </section>

    <!-- PROFILES -->
    <section class="coach-section" data-reveal>
      <h2>Find Maryana Online</h2>
      <div class="profile-links">
        <a href={teacher.lichessCoach} target="_blank" rel="noopener" class="profile-link tilt-card">
          <span class="profile-platform">Lichess Coach Page</span>
          <span class="profile-handle">@Morshynska1</span>
        </a>
        <a href={teacher.chessComProfile} target="_blank" rel="noopener" class="profile-link tilt-card">
          <span class="profile-platform">Chess.com</span>
          <span class="profile-handle">@morshynska</span>
        </a>
        <a href={teacher.twitchProfile} target="_blank" rel="noopener" class="profile-link tilt-card">
          <span class="profile-platform">Twitch · occasional streams</span>
          <span class="profile-handle">@maryanahuda</span>
        </a>
      </div>
    </section>

    <!-- BIG CTA -->
    <section class="big-cta" data-reveal>
      <div class="big-cta-glow"></div>
      <div class="big-cta-inner">
        <h2>Ready to work with Maryana?</h2>
        <p>Reach out for an introductory session. Tell her your current level, your goals, and what you'd most like to improve. She'll design a plan from there.</p>
        <div class="big-cta-actions">
          <a href={`mailto:${teacher.email}?subject=Chess%20Lessons%20with%20WGM%20Maryana%20Huda`} class="btn-primary btn-large cta-btn">
            <span class="btn-text">Email Maryana Directly</span>
            <span class="btn-shimmer"></span>
          </a>
          <a href={teacher.lichessCoach} target="_blank" rel="noopener" class="btn-secondary btn-large cta-btn">Book on Lichess &rarr;</a>
        </div>
        <p class="cta-fineprint">Or reach the Mind's Gambit team at <a href="mailto:Mourad@mindsgambit.com">Mourad@mindsgambit.com</a> for an introduction.</p>
      </div>
    </section>

    <footer class="coach-footer">
      <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind's Gambit Chess School is a production of &copy; MYB Studio LLC. Maryana Huda is featured here as an independent coach &mdash; all coaching arrangements are made directly with her.</p>
    </footer>
  </article>

  <script>
    // ===== FLOATING CHESS PARTICLES =====
    const particlesContainer = document.getElementById('coach-particles');
    const chessPieces = ['♔','♕','♖','♗','♘','♙','♚','♛','♜','♝','♞','♟'];
    if (particlesContainer) {
      for (let i = 0; i < 22; i++) {
        const p = document.createElement('span');
        p.className = 'particle';
        p.textContent = chessPieces[Math.floor(Math.random() * chessPieces.length)];
        p.style.left = Math.random() * 100 + '%';
        p.style.top = Math.random() * 100 + '%';
        p.style.animationDuration = (20 + Math.random() * 28) + 's';
        p.style.animationDelay = (-Math.random() * 25) + 's';
        p.style.fontSize = (1.3 + Math.random() * 2.4) + 'rem';
        p.style.opacity = (0.08 + Math.random() * 0.12).toFixed(2);
        particlesContainer.appendChild(p);
      }
    }

    // ===== SCROLL PROGRESS =====
    const bar = document.getElementById('scrollProgress');
    function updateBar() {
      if (!bar) return;
      const max = document.documentElement.scrollHeight - window.innerHeight;
      bar.style.width = ((window.scrollY / max) * 100) + '%';
    }
    window.addEventListener('scroll', updateBar, { passive: true });

    // ===== SCROLL REVEAL =====
    const revealObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('revealed');
          revealObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -60px 0px' });
    document.querySelectorAll('[data-reveal]').forEach(el => revealObserver.observe(el));

    // ===== COUNT-UP STATS =====
    const countObserver = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          const el = entry.target;
          const target = parseInt(el.dataset.target, 10);
          const duration = 1400;
          const start = performance.now();
          function step(now) {
            const progress = Math.min((now - start) / duration, 1);
            const eased = 1 - Math.pow(1 - progress, 3);
            el.textContent = Math.floor(target * eased).toLocaleString();
            if (progress < 1) requestAnimationFrame(step);
            else el.textContent = target.toLocaleString();
          }
          requestAnimationFrame(step);
          countObserver.unobserve(el);
        }
      });
    }, { threshold: 0.5 });
    document.querySelectorAll('.count-up').forEach(el => countObserver.observe(el));

    // ===== 3D TILT ON CARDS =====
    document.querySelectorAll('.tilt-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;
        card.style.transform = `perspective(900px) rotateY(${x * 6}deg) rotateX(${-y * 6}deg) translateY(-4px)`;
      });
      card.addEventListener('mouseleave', () => {
        card.style.transform = 'perspective(900px) rotateY(0) rotateX(0) translateY(0)';
      });
    });

    // ===== MAGNETIC CTAS =====
    document.querySelectorAll('.cta-btn').forEach(btn => {
      btn.addEventListener('mousemove', (e) => {
        const rect = btn.getBoundingClientRect();
        const x = e.clientX - rect.left - rect.width / 2;
        const y = e.clientY - rect.top - rect.height / 2;
        btn.style.transform = `translate(${x * 0.12}px, ${y * 0.18}px)`;
      });
      btn.addEventListener('mouseleave', () => {
        btn.style.transform = '';
      });
    });

    // ===== PARALLAX HERO PHOTO =====
    const heroPhoto = document.querySelector('.hero-photo-wrap');
    if (heroPhoto) {
      window.addEventListener('scroll', () => {
        if (window.scrollY < 800) {
          heroPhoto.style.transform = `translateY(${window.scrollY * 0.06}px)`;
        }
      }, { passive: true });
    }

    // ===== REDUCED MOTION =====
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      document.querySelectorAll('.particle').forEach(p => p.remove());
      document.querySelectorAll('[data-reveal]').forEach(el => el.classList.add('revealed'));
    }
  </script>
</BaseLayout>

<style is:global>
nav { background: rgba(15,17,28,0.92); border-bottom: 1px solid rgba(201,168,76,0.18); position: sticky; top: 0; z-index: 100; backdrop-filter: blur(14px); -webkit-backdrop-filter: blur(14px); }
.nav-inner { max-width: 1200px; margin: 0 auto; padding: 0.75rem 2rem; display: flex; align-items: center; justify-content: space-between; }
.nav-links { display: flex; gap: 2rem; list-style: none; margin: 0; padding: 0; align-items: center; }
.nav-links a { color: #e8e0d0; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.1em; text-transform: uppercase; font-family: 'Playfair Display', Georgia, serif; transition: color 0.3s; }
.nav-links a:hover { color: #c9a84c; }
.nav-btn { background: #c9a84c !important; color: #0f111c !important; padding: 0.5rem 1.25rem; border-radius: 6px; font-weight: 700; transition: transform 0.2s, box-shadow 0.2s; }
.nav-btn:hover { transform: translateY(-1px); box-shadow: 0 6px 20px rgba(201,168,76,0.35); }

/* ====== PARTICLES ====== */
.particles-container { position: fixed; inset: 0; pointer-events: none; overflow: hidden; z-index: 0; }
.particle { position: absolute; color: #c9a84c; will-change: transform; animation: float linear infinite; }
@keyframes float {
  0% { transform: translate(0, 0) rotate(0deg); }
  50% { transform: translate(35px, -50px) rotate(180deg); }
  100% { transform: translate(0, -100vh) rotate(360deg); }
}

/* ====== SCROLL PROGRESS ====== */
.scroll-progress { position: fixed; top: 0; left: 0; height: 3px; width: 0%; background: linear-gradient(90deg, #c9a84c, #f4d989, #c9a84c); z-index: 200; transition: width 0.1s ease-out; box-shadow: 0 0 18px rgba(201,168,76,0.6); }

/* ====== PAGE ====== */
.coach-page { max-width: 1100px; margin: 0 auto; padding: 2.5rem 1.5rem 4rem; font-family: 'EB Garamond', Georgia, serif; color: #e0e0e0; position: relative; z-index: 1; }
.back-link { color: #c9a84c; text-decoration: none; font-size: 0.9rem; letter-spacing: 0.05em; display: inline-block; margin-bottom: 2rem; font-family: 'Playfair Display', Georgia, serif; transition: opacity 0.25s; }
.back-link:hover { opacity: 0.75; transform: translateX(-3px); }

/* ====== REVEAL ====== */
[data-reveal] { opacity: 0; transform: translateY(28px); transition: opacity 0.85s cubic-bezier(.2,.7,.2,1), transform 0.85s cubic-bezier(.2,.7,.2,1); }
[data-reveal].revealed { opacity: 1; transform: translateY(0); }

/* ====== HERO ====== */
.coach-hero { display: grid; grid-template-columns: 340px 1fr; gap: 3.5rem; align-items: center; margin-bottom: 4rem; padding-bottom: 3.5rem; border-bottom: 1px solid rgba(201,168,76,0.2); }

.hero-photo-wrap { width: 340px; position: relative; will-change: transform; }
.photo-aura {
  position: absolute; inset: -30px; border-radius: 24px;
  background: radial-gradient(circle, rgba(201,168,76,0.35) 0%, transparent 65%);
  filter: blur(28px); animation: pulseAura 5s ease-in-out infinite;
  z-index: 0;
}
@keyframes pulseAura {
  0%, 100% { opacity: 0.55; transform: scale(1); }
  50% { opacity: 0.85; transform: scale(1.07); }
}
.photo-ring {
  position: absolute; inset: -6px; border-radius: 20px;
  background: conic-gradient(from 0deg, #c9a84c, #f4d989, #c9a84c, #b88a30, #c9a84c);
  animation: rotateRing 12s linear infinite;
  z-index: 1;
}
@keyframes rotateRing { to { transform: rotate(360deg); } }
.hero-photo {
  position: relative; width: 340px; height: 340px; object-fit: cover; border-radius: 16px;
  border: 4px solid #0f111c; box-shadow: 0 20px 60px rgba(0,0,0,0.55);
  z-index: 2; display: block;
}
.availability-badge {
  position: absolute; bottom: 18px; left: 18px;
  background: rgba(20,32,22,0.92); color: #4ade80;
  padding: 0.5rem 0.95rem; border-radius: 999px;
  font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em;
  text-transform: uppercase; backdrop-filter: blur(8px);
  border: 1px solid rgba(74,222,128,0.4); z-index: 3;
  display: flex; align-items: center; gap: 0.5rem;
  font-family: 'Playfair Display', Georgia, serif;
}
.pulse-dot {
  width: 8px; height: 8px; border-radius: 50%; background: #4ade80;
  box-shadow: 0 0 0 0 rgba(74,222,128,0.7); animation: pulseDot 2s infinite;
}
@keyframes pulseDot {
  0% { box-shadow: 0 0 0 0 rgba(74,222,128,0.7); }
  70% { box-shadow: 0 0 0 12px rgba(74,222,128,0); }
  100% { box-shadow: 0 0 0 0 rgba(74,222,128,0); }
}

.hero-content { display: flex; flex-direction: column; gap: 1rem; }
.eyebrow { color: #c9a84c; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.22em; }
.coach-hero h1 { font-family: 'Playfair Display', Georgia, serif; font-size: 3.2rem; line-height: 1.05; margin: 0; }
.gradient-text {
  background: linear-gradient(120deg, #f4d989 0%, #c9a84c 40%, #e8e0d0 70%, #c9a84c 100%);
  background-size: 200% 100%;
  -webkit-background-clip: text; background-clip: text;
  -webkit-text-fill-color: transparent; color: transparent;
  animation: shimmer 6s ease-in-out infinite;
}
@keyframes shimmer { 0%, 100% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } }
.tagline { font-size: 1.15rem; color: rgba(232,224,208,0.8); line-height: 1.55; font-style: italic; margin: 0; }

.title-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
.title-chip {
  background: rgba(201,168,76,0.13); color: #c9a84c;
  padding: 0.45rem 1rem; border-radius: 999px;
