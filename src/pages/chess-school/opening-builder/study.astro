        { master: 'Vasyl Ivanchuk',  note: 'Modern QID dynamism; shows the imbalanced middlegame possibilities.' },



        { master: 'Daniil Dubov',    note: "Modern d4 specialist who plays both sides; his games illustrate the QID's flexibility. (Recommended by Mourad.)" }



      ]



    }



  };







  // ------------------------------------------------------------



  // VARIATIONS sidebar data — alternative move-orders / sub-lines



  // shown beside the main study guide. Keys match openingId.



  // ------------------------------------------------------------



  var VARIATIONS = {



    'italian': {



      note: '3...Bc5 leads to the mainlines featured in the study guide. The variations below are alternative third moves Black may try.',



      items: [



