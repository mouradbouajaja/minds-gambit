---
import BaseLayout from '../../layouts/BaseLayout.astro';

const BUNNY = 'https://mindsgambitgames.b-cdn.net';

// Curated player list — direct downloads. Files hosted from pgnmentor.com snapshot.
// Filename = LastName.pgn (case-sensitive on the CDN).
const playersModern = [
  { name: 'Magnus Carlsen', file: 'Carlsen' },
  { name: 'Hikaru Nakamura', file: 'Nakamura' },
  { name: 'Fabiano Caruana', file: 'Caruana' },
  { name: 'Ding Liren', file: 'Ding' },
  { name: 'Ian Nepomniachtchi', file: 'Nepomniachtchi' },
  { name: 'Alireza Firouzja', file: 'Firouzja' },
  { name: 'Wesley So', file: 'So' },
  { name: 'Viswanathan Anand', file: 'Anand' },
  { name: 'Levon Aronian', file: 'Aronian' },
  { name: 'Anish Giri', file: 'Giri' },
  { name: 'Gukesh Dommaraju', file: 'Gukesh' },
  { name: 'Praggnanandhaa R.', file: 'Praggnanandhaa' },
  { name: 'Vladimir Kramnik', file: 'Kramnik' },
  { name: 'Veselin Topalov', file: 'Topalov' },
  { name: 'Vassily Ivanchuk', file: 'Ivanchuk' },
  { name: 'Alexei Shirov', file: 'Shirov' },
  { name: 'Judit Polgar', file: 'Polgar' },
  { name: 'Maxime Vachier-Lagrave', file: 'VachierLagrave' },
];

const playersClassical = [
  { name: 'Garry Kasparov', file: 'Kasparov' },
  { name: 'Anatoly Karpov', file: 'Karpov' },
  { name: 'Bobby Fischer', file: 'Fischer' },
  { name: 'Boris Spassky', file: 'Spassky' },
  { name: 'Tigran Petrosian', file: 'Petrosian' },
  { name: 'Mikhail Botvinnik', file: 'Botvinnik' },
  { name: 'Mikhail Tal', file: 'Tal' },
  { name: 'Vasily Smyslov', file: 'Smyslov' },
  { name: 'Max Euwe', file: 'Euwe' },
  { name: 'Jose Raul Capablanca', file: 'Capablanca' },
  { name: 'Alexander Alekhine', file: 'Alekhine' },
  { name: 'Emanuel Lasker', file: 'Lasker' },
  { name: 'Wilhelm Steinitz', file: 'Steinitz' },
  { name: 'Paul Morphy', file: 'Morphy' },
  { name: 'Adolf Anderssen', file: 'Anderssen' },
  { name: 'Howard Staunton', file: 'Staunton' },
  { name: 'Akiba Rubinstein', file: 'Rubinstein' },
  { name: 'Aron Nimzowitsch', file: 'Nimzowitsch' },
];
---

<BaseLayout title="Games Database | Mind's Gambit" description="Browse and download 14.8 million chess games — TWIC (2012-present), Lumbra Gigabase (1485-2026), and player collections. Free, free to download, hosted on the Mind's Gambit network.">

<style>
:root {
  --bg: #0f111c;
  --bg-2: #181b2a;
  --bg-3: #1f2335;
  --gold: #c9a84c;
  --gold-dim: #9a7d3e;
  --text: #e8e0d0;
  --text-2: rgba(232, 224, 208, 0.7);
  --text-3: rgba(232, 224, 208, 0.45);
  --border: rgba(201, 168, 76, 0.2);
}

.games-page {
  background: var(--bg);
  color: var(--text);
  min-height: 100vh;
  padding: 4rem 1.5rem 6rem;
  font-family: 'Inter', system-ui, sans-serif;
}

.games-inner {
  max-width: 1200px;
  margin: 0 auto;
}

.games-hero {
  text-align: center;
  margin-bottom: 3rem;
}

.games-eyebrow {
  display: inline-block;
  color: var(--gold);
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 0.8rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  margin-bottom: 0.6rem;
}

.games-title {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 3rem;
  margin: 0 0 0.7rem;
  color: var(--text);
}

.games-sub {
  color: var(--text-2);
  font-size: 1.05rem;
  max-width: 720px;
  margin: 0 auto;
  line-height: 1.6;
}

.games-stats {
  display: flex;
  justify-content: center;
  gap: 2.5rem;
  flex-wrap: wrap;
  margin: 2rem 0 0;
  padding-top: 1.5rem;
  border-top: 1px solid var(--border);
}

.games-stat {
  text-align: center;
}

.games-stat-num {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.8rem;
  color: var(--gold);
  display: block;
}

.games-stat-label {
  font-size: 0.78rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-3);
  margin-top: 0.2rem;
  display: block;
}

/* Tabs */
.tab-bar {
  display: flex;
  gap: 0.5rem;
  flex-wrap: wrap;
  justify-content: center;
  margin-bottom: 2rem;
  padding-bottom: 1.5rem;
  border-bottom: 1px solid var(--border);
}

.tab-btn {
  background: var(--bg-2);
  border: 1px solid var(--border);
  color: var(--text-2);
  padding: 0.7rem 1.4rem;
  border-radius: 999px;
  font-size: 0.9rem;
  font-family: inherit;
  cursor: pointer;
  transition: all 0.2s;
  letter-spacing: 0.04em;
}

.tab-btn:hover {
  border-color: var(--gold-dim);
  color: var(--text);
}

.tab-btn.active {
  background: var(--gold);
  border-color: var(--gold);
  color: var(--bg);
  font-weight: 600;
}

/* Tab panel */
.tab-panel {
  display: none;
}

.tab-panel.active {
  display: block;
}

.panel-intro {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem 1.8rem;
  margin-bottom: 1.5rem;
  font-size: 0.95rem;
  color: var(--text-2);
  line-height: 1.6;
}

.panel-intro strong { color: var(--text); }

/* Search */
.search-row {
  display: flex;
  gap: 0.8rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.search-input {
  flex: 1;
  min-width: 220px;
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 0.8rem 1rem;
  color: var(--text);
  font-family: inherit;
  font-size: 0.95rem;
}

.search-input:focus {
  outline: none;
  border-color: var(--gold);
}

.search-info {
  align-self: center;
  font-size: 0.85rem;
  color: var(--text-3);
}

/* Grid of cards */
.games-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 0.9rem;
}

.game-card {
  background: var(--bg-2);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1rem 1.1rem;
  transition: all 0.2s;
  display: flex;
  flex-direction: column;
  gap: 0.6rem;
}

.game-card:hover {
  border-color: var(--gold-dim);
  background: var(--bg-3);
  transform: translateY(-2px);
}

.game-card-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 0.8rem;
}

.game-card-code {
  font-family: 'Playfair Display', Georgia, serif;
  font-size: 1.15rem;
  color: var(--gold);
  font-weight: 600;
}

.game-card-size {
  font-size: 0.75rem;
  color: var(--text-3);
  font-variant-numeric: tabular-nums;
}

.game-card-name {
  font-size: 0.95rem;
  color: var(--text);
  line-height: 1.35;
}

.game-card-stats {
  font-size: 0.78rem;
  color: var(--text-3);
  font-variant-numeric: tabular-nums;
  letter-spacing: 0.03em;
}

.game-card-btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.4rem;
  margin-top: 0.4rem;
  padding: 0.5rem 0.9rem;
  background: transparent;
  border: 1px solid var(--gold-dim);
  color: var(--gold);
  text-decoration: none;
  border-radius: 8px;
  font-size: 0.85rem;
  font-family: inherit;
  letter-spacing: 0.03em;
  transition: all 0.2s;
}

.game-card-btn:hover {
  background: var(--gold);
  color: var(--bg);
  border-color: var(--gold);
}

/* Loading + empty */
.loading,
.empty {
  text-align: center;
  padding: 3rem 1rem;
  color: var(--text-3);
  font-style: italic;
}

.loading::after {
  content: "";
  display: inline-block;
  width: 16px;
  height: 16px;
  margin-left: 0.6rem;
  border: 2px solid var(--gold-dim);
  border-top-color: transparent;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  vertical-align: middle;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

/* Placeholder panels */
.placeholder-card {
  background: var(--bg-2);
  border: 1px dashed var(--border);
  border-radius: 12px;
  padding: 3rem 2rem;
  text-align: center;
  color: var(--text-2);
  max-width: 720px;
  margin: 2rem auto;
}

.placeholder-card h3 {
  font-family: 'Playfair Display', Georgia, serif;
  color: var(--gold);
  font-size: 1.4rem;
  margin: 0 0 0.7rem;
}

.placeholder-card p { line-height: 1.6; margin: 0 0 0.5rem; }

.placeholder-card .meta {
  font-size: 0.85rem;
  color: var(--text-3);
  margin-top: 1rem;
}

.footnote {
  margin: 3rem auto 0;
  max-width: 900px;
  font-size: 0.85rem;
  color: var(--text-3);
  text-align: center;
  line-height: 1.6;
}

@media (max-width: 768px) {
  .games-title { font-size: 2.1rem; }
  .games-stats { gap: 1.5rem; }
}
</style>

<div class="games-page">
  <div class="games-inner">
    <header class="games-hero">
      <span class="games-eyebrow">Chess School &middot; Database</span>
      <h1 class="games-title">Games Database</h1>
      <p class="games-sub">14.8 million chess games organized for study and exploration. TWIC (2012 to present), Lumbra Gigabase (1485 to 2026), and curated collections by player and event. Free to browse, free to download.</p>
      <div class="games-stats">
        <div class="games-stat">
          <span class="games-stat-num">14.8M</span>
          <span class="games-stat-label">Games</span>
        </div>
        <div class="games-stat">
          <span class="games-stat-num">1,228</span>
          <span class="games-stat-label">PGN files</span>
        </div>
        <div class="games-stat">
          <span class="games-stat-num">500+</span>
          <span class="games-stat-label">ECO codes</span>
        </div>
        <div class="games-stat">
          <span class="games-stat-num">540 yrs</span>
          <span class="games-stat-label">1485&ndash;2026</span>
        </div>
      </div>
    </header>

    <nav class="tab-bar" role="tablist">
      <button class="tab-btn active" data-tab="eco" role="tab">By ECO Code</button>
      <button class="tab-btn" data-tab="historical" role="tab">By Historical Era</button>
      <button class="tab-btn" data-tab="players" role="tab">By Player</button>
      <button class="tab-btn" data-tab="events" role="tab">By Event</button>
      <button class="tab-btn" data-tab="openings" role="tab">By Opening Name</button>
    </nav>

    <!-- ECO TAB -->
    <section class="tab-panel active" data-panel="eco">
      <div class="panel-intro">
        <strong>The Week in Chess (TWIC)</strong> &mdash; modern tournament games from 2012 onward, organized by <strong>ECO code</strong> (the standard 5-letter classification: A00 through E99). Pick a code to download every game in that opening family.
      </div>
      <div class="search-row">
        <input type="text" class="search-input" id="eco-search" placeholder="Search ECO code or opening name (e.g. B90, Najdorf, Reti)..." aria-label="Search ECO" />
        <span class="search-info" id="eco-info">Loading manifest...</span>
      </div>
      <div class="games-grid" id="eco-grid">
        <div class="loading">Fetching the ECO manifest from Bunny CDN</div>
      </div>
    </section>

    <!-- HISTORICAL TAB -->
    <section class="tab-panel" data-panel="historical">
      <div class="panel-intro">
        <strong>Lumbra Gigabase</strong> &mdash; over the board (OTB) games from <strong>1485 through 2026</strong>, also organized by ECO code. Includes everything from Lucena and Damiano through the 19th-century masters to the modern era. About 11 million games.
      </div>
      <div class="search-row">
        <input type="text" class="search-input" id="hist-search" placeholder="Search ECO code or opening name..." aria-label="Search historical ECO" />
        <span class="search-info" id="hist-info">Loading manifest...</span>
      </div>
      <div class="games-grid" id="hist-grid">
        <div class="loading">Fetching the historical manifest from Bunny CDN</div>
      </div>
    </section>

    <!-- PLAYERS TAB -->
    <section class="tab-panel" data-panel="players">
      <div class="panel-intro">
        <strong>Player collections</strong> &mdash; the complete known game record for selected modern and classical masters. Each file is a single PGN containing every published game by that player, ready to load into ChessBase, SCID, or any PGN viewer.
      </div>
      <div class="search-row">
        <input type="text" class="search-input" id="player-search" placeholder="Search by name (e.g. Carlsen, Fischer, Polgar)..." aria-label="Search player" />
        <span class="search-info" id="player-info">{playersModern.length + playersClassical.length} players</span>
      </div>

      <h3 style="font-family:'Playfair Display',Georgia,serif; color:var(--gold); margin:1.5rem 0 1rem; font-size:1.2rem; letter-spacing:0.05em;">Modern Era</h3>
      <div class="games-grid" id="player-modern-grid">
        {playersModern.map((p) => (
          <div class="game-card player-card" data-name={p.name.toLowerCase()}>
            <div class="game-card-head">
              <span class="game-card-code">{p.name.split(' ').map((s) => s[0]).join('')}</span>
            </div>
            <div class="game-card-name">{p.name}</div>
            <div class="game-card-stats">Full career PGN</div>
            <a class="game-card-btn" href={`${BUNNY}/players/${p.file}.pgn`} download={`${p.file}.pgn`}>
              Download PGN
            </a>
          </div>
        ))}
      </div>

      <h3 style="font-family:'Playfair Display',Georgia,serif; color:var(--gold); margin:2.5rem 0 1rem; font-size:1.2rem; letter-spacing:0.05em;">Classical Era</h3>
      <div class="games-grid" id="player-classical-grid">
        {playersClassical.map((p) => (
          <div class="game-card player-card" data-name={p.name.toLowerCase()}>
            <div class="game-card-head">
              <span class="game-card-code">{p.name.split(' ').map((s) => s[0]).join('')}</span>
            </div>
            <div class="game-card-name">{p.name}</div>
            <div class="game-card-stats">Full career PGN</div>
            <a class="game-card-btn" href={`${BUNNY}/players/${p.file}.pgn`} download={`${p.file}.pgn`}>
              Download PGN
            </a>
          </div>
        ))}
      </div>
    </section>

    <!-- EVENTS TAB -->
    <section class="tab-panel" data-panel="events">
      <div class="placeholder-card">
        <h3>By Event &mdash; coming soon</h3>
        <p>982 individual tournament PGNs are uploaded to the network &mdash; everything from the Candidates, World Championship matches, Norway Chess, Tata Steel, Sinquefield, Wijk aan Zee, and U.S. Championships through to club and youth events.</p>
        <p>The event index isn't browsable yet. It'll appear here in the next iteration of this page.</p>
        <p class="meta">If you need a specific event PGN today, send the name and I'll point you at it directly.</p>
      </div>
    </section>

    <!-- OPENINGS TAB -->
    <section class="tab-panel" data-panel="openings">
      <div class="placeholder-card">
        <h3>By Opening Name &mdash; coming soon</h3>
        <p>233 named-variation PGNs (Sicilian Najdorf, Berlin Defense, King's Indian Mar del Plata, Catalan Open, etc.) are uploaded. For now, use the <strong>By ECO Code</strong> tab &mdash; every named opening maps to one or more ECO codes.</p>
        <p class="meta">A named-opening browser will appear here once the index is generated.</p>
      </div>
    </section>

    <p class="footnote">
      Sources &mdash; <a href="https://theweekinchess.com" target="_blank" rel="noopener" style="color:var(--gold);">The Week in Chess</a>, <a href="https://lumbrasgigabase.com" target="_blank" rel="noopener" style="color:var(--gold);">Lumbra's Gigabase</a>, <a href="https://www.pgnmentor.com" target="_blank" rel="noopener" style="color:var(--gold);">pgnmentor.com</a>. Files mirrored on the Mind's Gambit network and served free for study purposes. The original sources retain credit; please support them.
    </p>
  </div>
</div>

<script>
  const BUNNY = 'https://mindsgambitgames.b-cdn.net';

  function bytesToHuman(n) {
    if (!n || n < 1024) return (n || 0) + ' B';
    if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
    if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + ' MB';
    return (n / 1024 / 1024 / 1024).toFixed(2) + ' GB';
  }

  function fmtCount(n) {
    return new Intl.NumberFormat('en-US').format(n || 0);
  }

  // Tab switching
  document.querySelectorAll('.tab-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tab = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.tab-btn').forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      document.querySelectorAll('.tab-panel').forEach((p) => p.classList.remove('active'));
      document.querySelector(`.tab-panel[data-panel="${tab}"]`)?.classList.add('active');
    });
  });

  // Renders a manifest into a grid. Manifest = { ecos: { CODE: { name, gameCount|games, fileSize|sizeKB } } }
  function renderEcoGrid(gridId, infoId, manifest, basePath, gameCountKey, sizeKey, sizeIsKB) {
    const grid = document.getElementById(gridId);
    const info = document.getElementById(infoId);
    if (!grid || !manifest || !manifest.ecos) return;
    const codes = Object.keys(manifest.ecos).sort();
    info.textContent = codes.length + ' ECO codes · ' + fmtCount(manifest.totalGames) + ' games';
    grid.innerHTML = '';
    codes.forEach((code) => {
      const entry = manifest.ecos[code];
      const games = entry[gameCountKey] || 0;
      let sizeBytes = entry[sizeKey] || 0;
      if (sizeIsKB) sizeBytes = sizeBytes * 1024;
      const card = document.createElement('div');
      card.className = 'game-card eco-card';
      card.dataset.search = (code + ' ' + (entry.name || '')).toLowerCase();
      card.innerHTML =
        '<div class="game-card-head">' +
          '<span class="game-card-code">' + code + '</span>' +
          '<span class="game-card-size">' + bytesToHuman(sizeBytes) + '</span>' +
        '</div>' +
        '<div class="game-card-name">' + (entry.name || '') + '</div>' +
        '<div class="game-card-stats">' + fmtCount(games) + ' games</div>' +
        '<a class="game-card-btn" href="' + BUNNY + basePath + code + '.pgn" download="' + code + '.pgn">Download PGN</a>';
      grid.appendChild(card);
    });
  }

  // Fetch + render ECO (TWIC)
  fetch(BUNNY + '/eco/eco-index.json')
    .then((r) => r.json())
    .then((m) => renderEcoGrid('eco-grid', 'eco-info', m, '/eco/', 'gameCount', 'fileSize', false))
    .catch((e) => {
      const g = document.getElementById('eco-grid');
      if (g) g.innerHTML = '<div class="empty">Could not load the ECO manifest. Please try again.</div>';
    });

  // Fetch + render Historical (Lumbra)
  fetch(BUNNY + '/historical/eco-index.json')
    .then((r) => r.json())
    .then((m) => renderEcoGrid('hist-grid', 'hist-info', m, '/historical/', 'games', 'sizeKB', true))
    .catch((e) => {
      const g = document.getElementById('hist-grid');
      if (g) g.innerHTML = '<div class="empty">Could not load the historical manifest. Please try again.</div>';
    });

  // Search filtering — generic
  function attachSearch(inputId, cardSelector, searchAttr) {
    const input = document.getElementById(inputId) as HTMLInputElement | null;
    if (!input) return;
    input.addEventListener('input', () => {
      const q = input.value.trim().toLowerCase();
      document.querySelectorAll(cardSelector).forEach((card) => {
        const haystack = (card as HTMLElement).getAttribute(searchAttr) || (card as HTMLElement).dataset[searchAttr.replace('data-', '')] || '';
        (card as HTMLElement).style.display = (!q || haystack.includes(q)) ? '' : 'none';
      });
    });
  }

  attachSearch('eco-search', '.eco-card', 'data-search');
  attachSearch('hist-search', '#hist-grid .eco-card', 'data-search');

  // Player search
  const playerInput = document.getElementById('player-search') as HTMLInputElement | null;
  if (playerInput) {
    playerInput.addEventListener('input', () => {
      const q = playerInput.value.trim().toLowerCase();
      document.querySelectorAll('.player-card').forEach((card) => {
        const name = (card as HTMLElement).dataset.name || '';
        (card as HTMLElement).style.display = (!q || name.includes(q)) ? '' : 'none';
      });
    });
  }
</script>

</BaseLayout>
