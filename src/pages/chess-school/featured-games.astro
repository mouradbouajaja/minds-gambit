---
import BaseLayout from '../../layouts/BaseLayout.astro';

export const prerender = true;

// ============================================================
//  FEATURED GAMES — Curated annotated classics
//  Each game has rock-solid moves verified against authoritative sources.
//  Add more games to GAMES[] array. Each PGN must be valid chess.js input.
// ============================================================
const GAMES = [
  {
    id: 'morphy-opera',
    title: 'The Opera Game',
    white: 'Paul Morphy',
    black: 'Duke of Brunswick & Count Isouard',
    year: 1858,
    event: 'Paris Opera House',
    opening: "Philidor's Defense",
    era: 'Romantic era',
    significance: "The most famous teaching game in chess history. Morphy, age 21, played the Duke and Count while watching a performance of Norma. In just 17 moves he demonstrates the eternal principles of opening play: rapid development, central control, and decisive use of the king's exposed position. Every chess teacher in the world has shown this game.",
    pgn: '1. e4 e5 2. Nf3 d6 3. d4 Bg4 4. dxe5 Bxf3 5. Qxf3 dxe5 6. Bc4 Nf6 7. Qb3 Qe7 8. Nc3 c6 9. Bg5 b5 10. Nxb5 cxb5 11. Bxb5+ Nbd7 12. O-O-O Rd8 13. Rxd7 Rxd7 14. Rd1 Qe6 15. Bxd7+ Nxd7 16. Qb8+ Nxb8 17. Rd8# 1-0'
  },
  {
    id: 'anderssen-immortal',
    title: 'The Immortal Game',
    white: 'Adolf Anderssen',
    black: 'Lionel Kieseritzky',
    year: 1851,
    event: 'London',
    opening: "King's Gambit Accepted",
    era: 'Romantic era',
    significance: 'A casual game played during the London tournament of 1851 that became the symbol of Romantic chess. Anderssen sacrifices both rooks, a bishop, and his queen, then delivers mate with the three minor pieces he has left. Played without clocks, for honor, against the era’s tactical master.',
    pgn: '1. e4 e5 2. f4 exf4 3. Bc4 Qh4+ 4. Kf1 b5 5. Bxb5 Nf6 6. Nf3 Qh6 7. d3 Nh5 8. Nh4 Qg5 9. Nf5 c6 10. g4 Nf6 11. Rg1 cxb5 12. h4 Qg6 13. h5 Qg5 14. Qf3 Ng8 15. Bxf4 Qf6 16. Nc3 Bc5 17. Nd5 Qxb2 18. Bd6 Bxg1 19. e5 Qxa1+ 20. Ke2 Na6 21. Nxg7+ Kd8 22. Qf6+ Nxf6 23. Be7# 1-0'
  },
  {
    id: 'anderssen-evergreen',
    title: 'The Evergreen Game',
    white: 'Adolf Anderssen',
    black: 'Jean Dufresne',
    year: 1852,
    event: 'Berlin',
    opening: 'Evans Gambit',
    era: 'Romantic era',
    significance: 'Named "Evergreen" by Wilhelm Steinitz — a game whose beauty would never fade. Anderssen sacrifices his queen with 19.Rad1!! to set up an irresistible mating net. The companion piece to the Immortal Game, and proof that the same player could conjure brilliance twice.',
    pgn: '1. e4 e5 2. Nf3 Nc6 3. Bc4 Bc5 4. b4 Bxb4 5. c3 Ba5 6. d4 exd4 7. O-O d3 8. Qb3 Qf6 9. e5 Qg6 10. Re1 Nge7 11. Ba3 b5 12. Qxb5 Rb8 13. Qa4 Bb6 14. Nbd2 Bb7 15. Ne4 Qf5 16. Bxd3 Qh5 17. Nf6+ gxf6 18. exf6 Rg8 19. Rad1 Qxf3 20. Rxe7+ Nxe7 21. Qxd7+ Kxd7 22. Bf5+ Ke8 23. Bd7+ Kf8 24. Bxe7# 1-0'
  },
  {
    id: 'byrne-fischer-century',
    title: 'The Game of the Century',
    white: 'Donald Byrne',
    black: 'Bobby Fischer',
    year: 1956,
    event: 'Rosenwald Trophy, New York',
    opening: 'Grünfeld Defense',
    era: 'Cold War era',
    significance: 'Bobby Fischer was thirteen years old. Donald Byrne was a U.S. champion and one of America\'s top players. On move 17, Fischer played 17...Be6!! — offering his queen for a position of such positional and tactical power that Hans Kmoch, in Chess Review, christened it the Game of the Century. Played at the Marshall Chess Club, New York, October 17, 1956. The game that announced the prodigy who would become World Champion in 1972.',
    pgn: '1. Nf3 Nf6 2. c4 g6 3. Nc3 Bg7 4. d4 O-O 5. Bf4 d5 6. Qb3 dxc4 7. Qxc4 c6 8. e4 Nbd7 9. Rd1 Nb6 10. Qc5 Bg4 11. Bg5 Na4 12. Qa3 Nxc3 13. bxc3 Nxe4 14. Bxe7 Qb6 15. Bc4 Nxc3 16. Bc5 Rfe8+ 17. Kf1 Be6 18. Bxb6 Bxc4+ 19. Kg1 Ne2+ 20. Kf1 Nxd4+ 21. Kg1 Ne2+ 22. Kf1 Nc3+ 23. Kg1 axb6 24. Qb4 Ra4 25. Qxb6 Nxd1 26. h3 Rxa2 27. Kh2 Nxf2 28. Re1 Rxe1 29. Qd8+ Bf8 30. Nxe1 Bd5 31. Nf3 Ne4 32. Qb8 b5 33. h4 h5 34. Ne5 Kg7 35. Kg1 Bc5+ 36. Kf1 Ng3+ 37. Ke1 Bb4+ 38. Kd1 Bb3+ 39. Kc1 Ne2+ 40. Kb1 Nc3+ 41. Kc1 Rc2# 0-1'
  },
  {
    id: 'kasparov-topalov-1999',
    title: "Kasparov's Immortal (Pearl of Wijk)",
    white: 'Garry Kasparov',
    black: 'Veselin Topalov',
    year: 1999,
    event: 'Hoogovens, Wijk aan Zee',
    opening: 'Pirc Defense',
    era: 'Modern era',
    significance: "Kasparov hunts Topalov's king from b8 all the way to a3 in a 44-move attacking masterpiece. The 24.Rxd4!! rook sacrifice and the king-march that follows are widely considered one of the greatest combinations ever played in tournament chess. Wijk aan Zee, Round 4, January 20, 1999. Kasparov later called it one of the finest games of his career.",
    pgn: '1. e4 d6 2. d4 Nf6 3. Nc3 g6 4. Be3 Bg7 5. Qd2 c6 6. f3 b5 7. Nge2 Nbd7 8. Bh6 Bxh6 9. Qxh6 Bb7 10. a3 e5 11. O-O-O Qe7 12. Kb1 a6 13. Nc1 O-O-O 14. Nb3 exd4 15. Rxd4 c5 16. Rd1 Nb6 17. g3 Kb8 18. Na5 Ba8 19. Bh3 d5 20. Qf4+ Ka7 21. Rhe1 d4 22. Nd5 Nbxd5 23. exd5 Qd6 24. Rxd4 cxd4 25. Re7+ Kb6 26. Qxd4+ Kxa5 27. b4+ Ka4 28. Qc3 Qxd5 29. Ra7 Bb7 30. Rxb7 Qc4 31. Qxf6 Kxa3 32. Qxa6+ Kxb4 33. c3+ Kxc3 34. Qa1+ Kd2 35. Qb2+ Kd1 36. Bf1 Rd2 37. Rd7 Rxd7 38. Bxc4 bxc4 39. Qxh8 Rd3 40. Qa8 c3 41. Qa4+ Ke1 42. f4 f5 43. Kc1 Rd2 44. Qa7 1-0'
  },
  {
    id: 'polgar-kasparov-2001',
    title: "Polgar Breaks the Glass Ceiling",
    white: 'Judit Polgar',
    black: 'Garry Kasparov',
    year: 2001,
    event: 'World Cup of Rapid Chess, Cannes',
    opening: 'Sicilian Najdorf, English Attack',
    era: 'Modern era',
    significance: "The first time Judit Polgar defeated Garry Kasparov in tournament play. Cannes, March 22, 2001. Polgar — the strongest female chess player in history, and one of the very few players ever to beat both Kasparov and Karpov — exploits a hasty 36.Bxe5? to expose Kasparov's queen and king. Annotated in ChessBase by GM Lubomir Ftacnik.",
    pgn: '1. e4 c5 2. Nf3 d6 3. d4 cxd4 4. Nxd4 Nf6 5. Nc3 a6 6. Be3 e6 7. f3 b5 8. g4 Nfd7 9. Qd2 Nb6 10. O-O-O N8d7 11. Qf2 Bb7 12. Bd3 Rc8 13. Nce2 Nc5 14. Kb1 Nba4 15. b3 Nxd3 16. cxd3 Nc5 17. Ng3 Be7 18. Qb2 b4 19. Nh5 Rg8 20. Ne2 g6 21. Nhf4 a5 22. d4 Nd7 23. d5 e5 24. Nd3 Ba6 25. Qd2 Bf6 26. Rc1 Bb5 27. g5 Bg7 28. Nb2 Ke7 29. f4 exf4 30. Bxf4 Qb6 31. Be3 Qa6 32. Nd4 Ne5 33. Rhd1 Bd7 34. Bf4 Rxc1+ 35. Rxc1 Rc8 36. Bxe5 Rxc1+ 37. Qxc1 Bxe5 38. Nc6+ Bxc6 39. dxc6 Qe2 40. c7 Bxb2 41. c8=Q Bxc1 42. Qb7+ Kf8 43. Kxc1 Qxh2 44. Qa8+ Kg7 45. Qxa5 Qf4+ 46. Kd1 Qxe4 47. Qd8 Qb1+ 48. Ke2 Qxa2+ 49. Kf1 Qa1+ 50. Kg2 Qe5 0-1'
  }
];
---

<BaseLayout title="Featured Games — Annotated Classics — Mind's Gambit Chess School" description="Hand-picked annotated games from chess history. Play through Morphy's Opera Game, Anderssen's Immortal, and the games that defined chess pedagogy.">

<link rel="stylesheet" href="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.css" />

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo"><img src="/images/logo.jpg" alt="Mind's Gambit" style="height:55px;width:55px;border-radius:50%;object-fit:cover;border:2px solid #c8a84e;margin-left:10px;vertical-align:middle;" /></a>
    <ul class="nav-links">
      <li><a href="/">Home</a></li>
      <li><a href="/#book">The Book</a></li>
      <li><a href="/watch">Documentary</a></li>
      <li><a href="/blog">Blog</a></li>
      <li><a href="/chess-school">Chess School</a></li>
      <li><a href="/#about">About</a></li>
      <li><a href="/#contact">Contact</a></li>
      <li><a href="https://buymeacoffee.com/mouradbouajaja" target="_blank" rel="noopener" class="nav-btn">&#9749; Buy Me a Coffee</a></li>
    </ul>
  </div>
</nav>

<section class="page">
  <a href="/chess-school" class="back-link">&larr; Back to Chess School</a>
  <span class="eyebrow">Mind&rsquo;s Gambit Chess School</span>
  <h1>Featured Games</h1>
  <p class="lead">Annotated classics from the games that taught the world to play. Click any game to play through move by move. Read the notes. Learn from masters who lived and died for these moves.</p>

  <!-- GAME LIST -->
  <div id="game-list" class="games-grid">
    {GAMES.map((g) => (
      <article class="game-card" data-game-id={g.id}>
        <header class="game-card-header">
          <span class="game-era">{g.era}</span>
          <h2 class="game-title">{g.title}</h2>
          <p class="game-players"><strong>{g.white}</strong> vs <strong>{g.black}</strong></p>
          <p class="game-meta">{g.event} &middot; {g.year} &middot; {g.opening}</p>
        </header>
        <p class="game-significance">{g.significance}</p>
        <button class="game-open-btn" type="button" data-open={g.id}>Play through this game &rarr;</button>
      </article>
    ))}
  </div>

  <p class="games-more">More annotated games coming. Have a favorite you&rsquo;d love to see here? Email <a href="mailto:mourad@mindsgambit.com">mourad@mindsgambit.com</a>.</p>

  <!-- VIEWER (hidden until a game is opened) -->
  <div id="game-viewer" class="game-viewer" hidden>
    <button class="viewer-close" id="viewer-close" type="button" aria-label="Close viewer">&times; Close</button>
    <header class="viewer-header">
      <span class="viewer-era" id="viewer-era">&mdash;</span>
      <h2 class="viewer-title" id="viewer-title">&mdash;</h2>
      <p class="viewer-players" id="viewer-players">&mdash;</p>
      <p class="viewer-meta" id="viewer-meta">&mdash;</p>
    </header>
    <div class="viewer-body">
      <div class="viewer-board-wrap">
        <div id="viewer-board"></div>
        <div class="viewer-controls">
          <button class="nav-arrow" id="btn-first" type="button" title="Starting position">&laquo;</button>
          <button class="nav-arrow" id="btn-prev" type="button" title="Previous move">&lsaquo;</button>
          <span class="move-counter" id="move-counter">0 / 0</span>
          <button class="nav-arrow" id="btn-next" type="button" title="Next move">&rsaquo;</button>
          <button class="nav-arrow" id="btn-last" type="button" title="Last move">&raquo;</button>
        </div>
        <p class="viewer-tip">Tip: use &larr; and &rarr; keys to step through moves.</p>
      </div>
      <aside class="viewer-side">
        <h3 class="viewer-section-label">Why this game matters</h3>
        <p class="viewer-significance" id="viewer-significance">&mdash;</p>
        <h3 class="viewer-section-label">Moves</h3>
        <div class="viewer-move-list" id="viewer-move-list"></div>
      </aside>
    </div>
  </div>

  <footer class="page-footer">
    <p class="footer-credit">&copy; 2026 Mourad Bouajaja. Mind&rsquo;s Gambit Chess School is a production of &copy; MYB Studio LLC.</p>
  </footer>
</section>

<script is:inline src="https://code.jquery.com/jquery-3.7.1.min.js" integrity="sha256-/JqT3SQfawRcv/BIHPThkBvs0OEvtFFmqPF/lYI/Cxo=" crossorigin="anonymous"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/chess.js@0.10.3/chess.min.js"></script>
<script is:inline src="https://unpkg.com/@chrisoakman/chessboardjs@1.0.0/dist/chessboard-1.0.0.min.js"></script>

<script is:inline define:vars={{ GAMES }}>
(function() {
  'use strict';

  var board = null;
  var game = null;
  var moves = [];        // SAN move strings
  var positions = [];    // FENs after each move; positions[0] = start
  var currentMove = 0;
  var currentGame = null;

  var viewerEl = document.getElementById('game-viewer');
  var listEl = document.getElementById('game-list');
  var closeBtn = document.getElementById('viewer-close');
  var eraEl = document.getElementById('viewer-era');
  var titleEl = document.getElementById('viewer-title');
  var playersEl = document.getElementById('viewer-players');
  var metaEl = document.getElementById('viewer-meta');
  var significanceEl = document.getElementById('viewer-significance');
  var moveListEl = document.getElementById('viewer-move-list');
  var moveCounterEl = document.getElementById('move-counter');

  function findGame(id) {
    for (var i = 0; i < GAMES.length; i++) if (GAMES[i].id === id) return GAMES[i];
    return null;
  }

  function whenReady(cb) {
    if (window.Chess && window.Chessboard && window.jQuery) cb();
    else setTimeout(function() { whenReady(cb); }, 50);
  }

  function openGame(gameId) {
    var g = findGame(gameId);
    if (!g) return;
    currentGame = g;

    eraEl.textContent = g.era;
    titleEl.textContent = g.title;
    playersEl.innerHTML = '<strong>' + g.white + '</strong> vs <strong>' + g.black + '</strong>';
    metaEl.textContent = g.event + ' · ' + g.year + ' · ' + g.opening;
    significanceEl.textContent = g.significance;

    viewerEl.removeAttribute('hidden');
    window.scrollTo({ top: viewerEl.offsetTop - 60, behavior: 'smooth' });

    whenReady(function() {
      // Parse PGN with chess.js
      game = new Chess();
      var ok = game.load_pgn(g.pgn);
      if (!ok) {
        moveListEl.innerHTML = '<div class="viewer-error">Could not load this game. Please email mourad@mindsgambit.com.</div>';
        return;
      }
      moves = game.history();         // SAN strings
      // Build position list: replay through the game to capture FENs
      var replay = new Chess();
      positions = [replay.fen()];
      for (var i = 0; i < moves.length; i++) {
        replay.move(moves[i]);
        positions.push(replay.fen());
      }
      currentMove = 0;
      renderMoveList();

      if (board) { try { board.destroy && board.destroy(); } catch (e) {} }
      board = Chessboard('viewer-board', {
        position: positions[0],
        showNotation: true,
        pieceTheme: 'https://chessboardjs.com/img/chesspieces/wikipedia/{piece}.png'
      });
      updateView();
    });
  }

  function closeViewer() {
    viewerEl.setAttribute('hidden', '');
    if (board) { try { board.destroy && board.destroy(); } catch (e) {} board = null; }
  }

  function renderMoveList() {
    moveListEl.innerHTML = '';
    for (var i = 0; i < moves.length; i++) {
      var ply = i + 1;
      var isWhite = (i % 2 === 0);
      if (isWhite) {
        var moveNum = document.createElement('span');
        moveNum.className = 'viewer-move-num';
        moveNum.textContent = Math.ceil(ply / 2) + '.';
        moveListEl.appendChild(moveNum);
      }
      var moveBtn = document.createElement('button');
      moveBtn.type = 'button';
      moveBtn.className = 'viewer-move-btn';
      moveBtn.setAttribute('data-ply', String(ply));
      moveBtn.textContent = moves[i];
      (function(p) {
        moveBtn.addEventListener('click', function() { goToMove(p); });
      })(ply);
      moveListEl.appendChild(moveBtn);
    }
  }

  function goToMove(ply) {
    currentMove = Math.max(0, Math.min(moves.length, ply));
    updateView();
  }

  function updateView() {
    if (!board || !positions[currentMove]) return;
    board.position(positions[currentMove]);
    moveCounterEl.textContent = currentMove + ' / ' + moves.length;
    // Highlight current move in list
    var btns = moveListEl.querySelectorAll('.viewer-move-btn');
    for (var i = 0; i < btns.length; i++) {
      var ply = parseInt(btns[i].getAttribute('data-ply'), 10);
      if (ply === currentMove) btns[i].classList.add('viewer-move-current');
      else btns[i].classList.remove('viewer-move-current');
    }
    // Scroll current move into view
    var current = moveListEl.querySelector('.viewer-move-current');
    if (current && current.scrollIntoView) {
      current.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }
  }

  // Wire up game cards
  Array.from(document.querySelectorAll('[data-open]')).forEach(function(btn) {
    btn.addEventListener('click', function() {
      openGame(btn.getAttribute('data-open'));
    });
  });

  // Wire up viewer controls
  closeBtn.addEventListener('click', closeViewer);
  document.getElementById('btn-first').addEventListener('click', function() { goToMove(0); });
  document.getElementById('btn-prev').addEventListener('click', function() { goToMove(currentMove - 1); });
  document.getElementById('btn-next').addEventListener('click', function() { goToMove(currentMove + 1); });
  document.getElementById('btn-last').addEventListener('click', function() { goToMove(moves.length); });

  // Keyboard arrows
  document.addEventListener('keydown', function(e) {
    if (viewerEl.hasAttribute('hidden')) return;
    if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA')) return;
    if (e.key === 'ArrowLeft') { e.preventDefault(); goToMove(currentMove - 1); }
    else if (e.key === 'ArrowRight') { e.preventDefault(); goToMove(currentMove + 1); }
    else if (e.key === 'Home') { e.preventDefault(); goToMove(0); }
    else if (e.key === 'End') { e.preventDefault(); goToMove(moves.length); }
    else if (e.key === 'Escape') { closeViewer(); }
  });

  window.addEventListener('resize', function() { if (board) board.resize(); });
})();
</script>

<style>
.eyebrow { display: block; font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.18em; margin-top: 1.5rem; }
.page { max-width: 1100px; margin: 0 auto; padding: 1.5rem 1.25rem 3rem; }
.back-link { display: inline-block; color: rgba(232,224,208,0.65); text-decoration: none; font-family: 'EB Garamond', Georgia, serif; font-size: 0.95rem; margin: 1rem 0 0; transition: color 0.18s; }
.back-link:hover { color: #c9a84c; }
.page h1 { font-family: 'Playfair Display', Georgia, serif; color: #c9a84c; font-size: 2.6rem; margin: 0.6rem 0 0.7rem; letter-spacing: 0.01em; }
