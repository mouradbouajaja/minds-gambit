---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const today = new Date();
const dateLine = today.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

// Quote of the Day: one chess quote per weekday (0 = Sunday ... 6 = Saturday).
const QUOTES = [
  { text: '"All that matters on the chessboard is good moves."', author: '— Bobby Fischer' },
  { text: '"There are two types of sacrifices: correct ones and mine."', author: '— Mikhail Tal' },
  { text: '"A good player is always lucky."', author: '— Jose Raul Capablanca' },
  { text: '"The blunders are all there on the board, waiting to be made."', author: '— Savielly Tartakower' },
  { text: '"Chess is the art which expresses the science of logic."', author: '— Mikhail Botvinnik' },
  { text: "\"You need to be focused on the most important things, and let go of the things that you can't control.\"", author: '— Magnus Carlsen' },
  { text: '"When you see a good move, look for a better one."', author: '— Emanuel Lasker' },
];
const todaysQuote = QUOTES[today.getDay()];

// Pull all published Daily Gambit stories, newest first.
const all = (await getCollection('daily', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const SECTION_LABELS = {
  world: 'World Chess',
  tournaments: 'Tournaments',
  players: 'Players',
  openings: 'Openings',
  local: 'Local',
  opinion: 'Opinion',
  puzzle: 'Puzzle',
};

// Lead story: an explicit lead flag wins, otherwise the newest non-local story.
const lead = all.find((s) => s.data.lead) || all.find((s) => s.data.section !== 'local') || all[0] || null;
// Secondary column: non-local stories that are not the lead (max 4).
const secondary = all.filter((s) => s.data.section !== 'local' && s.id !== (lead && lead.id)).slice(0, 8);
// Local section: Pittsburgh & Pennsylvania stories (max 4).
const local = all.filter((s) => s.data.section === 'local').slice(0, 4);

const hasStories = all.length > 0;
---

